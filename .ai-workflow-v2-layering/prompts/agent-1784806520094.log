plyListLoadStarted();\n\t\t\tvoid (async function () {\n\t\t\t\ttry {\n\t\t\t\t\tconst list = await fetchAssetSummaries();\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult(toAssetsLoadResult(list));\n\t\t\t\t} catch (error) {\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult({\n\t\t\t\t\t\tok: false,\n\t\t\t\t\t\tmessage: errorMessage(error, \"加载资源列表失败\"),\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t})();\n\n\t\t\treturn function () {\n\t\t\t\tcancelled = true;\n\t\t\t};\n\t\t},\n\t\t[refreshStamp, applyListLoadStarted, applyListLoadResult],\n\t);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":84,"fileSize":2187,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/shellBis/assets/assets.shell.bis.ts","readRange":{"startLine":1,"endLine":84},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-7bc12dd1-5f38-44c7-82bc-880ac6e8a348-15\nfc_bb6f02ca-7c73-969a-870d-21e20bb58dc1_3","startedAtMs":"1784806567840","completedAtMs":"1784806568164"},"model_call_id":"760ac919-ef79-4d53-99c3-afefda3b7a00-3-cnl7","session_id":"f1905b4c-095a-4284-8d32-eb80ff150078","timestamp_ms":1784806568151}
