d((a) => a.assetId === deleteTargetId);\n\n\tasync function onCreateSubmit(values: CreateAssetFormValues): Promise<void> {\n\t\tawait session.onCreateSubmit(values);\n\t\tsetKind(\"all\");\n\t\tsetCreateOpen(false);\n\t}\n\n\tfunction onRequestDelete(assetId: string): void {\n\t\tsetDeleteError(undefined);\n\t\tsetDeleteTargetId(assetId);\n\t}\n\n\tasync function onConfirmDelete(): Promise<void> {\n\t\tif (deleteTargetId == null) return;\n\t\ttry {\n\t\t\tawait session.onConfirmDelete(deleteTargetId);\n\t\t\tsetDeleteTargetId(null);\n\t\t\tsetDeleteError(undefined);\n\t\t\tsetKind(\"all\");\n\t\t} catch (error) {\n\t\t\tsetDeleteError(errorMessage(error, \"删除失败，请稍后重试\"));\n\t\t}\n\t}\n\n\tfunction closeDeleteModal(): void {\n\t\tsetDeleteTargetId(null);\n\t\tsetDeleteError(undefined);\n\t}\n\n\treturn {\n\t\tkind,\n\t\tsetKind,\n\t\tfiltered,\n\t\tselected,\n\t\tcreateOpen,\n\t\tsetCreateOpen,\n\t\tdeleteTarget,\n\t\tdeleteError,\n\t\tloadError: session.loadError,\n\t\tloading: session.loading,\n\t\tsetSelectedId: session.setSelectedId,\n\t\tonCreateSubmit,\n\t\tonDetailSaved: session.onDetailSaved,\n\t\tonRequestDelete,\n\t\tonConfirmDelete,\n\t\tcloseDeleteModal,\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":100,"fileSize":2869,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/assets/hooks/useAssetLibraryPage.ts","readRange":{"startLine":1,"endLine":100},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-7bc12dd1-5f38-44c7-82bc-880ac6e8a348-16\nfc_bb6f02ca-7c73-969a-870d-21e20bb58dc1_4","startedAtMs":"1784806568165","completedAtMs":"1784806568317"},"model_call_id":"760ac919-ef79-4d53-99c3-afefda3b7a00-3-cnl7","session_id":"f1905b4c-095a-4284-8d32-eb80ff150078","timestamp_ms":1784806568300}
