\tlet cancelled = false;\n\t\t\tapplyListLoadStarted();\n\t\t\tvoid (async function () {\n\t\t\t\ttry {\n\t\t\t\t\tconst list = await listStoryPackagesFromDisk();\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult(toPackagesLoadResult(list));\n\t\t\t\t} catch (error) {\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult({\n\t\t\t\t\t\tok: false,\n\t\t\t\t\t\tmessage: errorMessage(error, \"加载故事包列表失败\"),\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t})();\n\n\t\t\treturn function () {\n\t\t\t\tcancelled = true;\n\t\t\t};\n\t\t},\n\t\t[refreshStamp, applyListLoadStarted, applyListLoadResult],\n\t);\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-0a9414bd-61b4-4fd9-ab0d-398b47fead99-55\nfc_392ea527-8671-9493-91ee-1c0b41a10a57_2","startedAtMs":"1784806662736"},"model_call_id":"760ac919-ef79-4d53-99c3-afefda3b7a00-9-hq5o","session_id":"f1905b4c-095a-4284-8d32-eb80ff150078","timestamp_ms":1784806662737}
