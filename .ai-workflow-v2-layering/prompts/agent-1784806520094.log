on],\n\t);\n\n\tuseLayoutEffect(\n\t\tfunction () {\n\t\t\tlet cancelled = false;\n\t\t\tapplyListLoadStarted();\n\t\t\tvoid (async function () {\n\t\t\t\ttry {\n\t\t\t\t\tconst users = await fetchProfileUsers();\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult(toUsersLoadResult(users));\n\t\t\t\t} catch (error) {\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult({\n\t\t\t\t\t\tok: false,\n\t\t\t\t\t\tmessage: errorMessage(error, \"加载玩家列表失败\"),\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t})();\n\n\t\t\treturn function () {\n\t\t\t\tcancelled = true;\n\t\t\t};\n\t\t},\n\t\t[refreshStamp, applyListLoadStarted, applyListLoadResult],\n\t);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":85,"fileSize":2276,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/shellBis/users/users.shell.bis.ts","readRange":{"startLine":1,"endLine":85},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-ff78d281-0487-4e91-8421-99121719bbb2-36\nfc_1a5719d9-8581-9b9b-8881-125aa71af59d_2","startedAtMs":"1784806588905","completedAtMs":"1784806589050"},"model_call_id":"760ac919-ef79-4d53-99c3-afefda3b7a00-6-tvkr","session_id":"f1905b4c-095a-4284-8d32-eb80ff150078","timestamp_ms":1784806589034}
