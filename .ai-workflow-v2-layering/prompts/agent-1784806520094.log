  description=\"先检查，再确认。不会直接写入或覆盖当前工程。\"\n      onClose={handleClose}\n      maxWidth=\"md\"\n    >\n      <ImportStepNav step={step} />\n      <ImportActiveStep\n        step={step}\n        fileLabel={fileLabel}\n        report={report}\n        canImport={canImport}\n        onPickDemo={onPickDemo}\n        onCancel={handleClose}\n        onBackToPick={() => setStep(\"pick\")}\n        onContinuePrecheck={() => setStep(\"confirm\")}\n        onBackToPrecheck={() => setStep(\"precheck\")}\n        onConfirmImport={onConfirmImport}\n      />\n    </AppModal>\n  );\n};\n","isEmpty":false,"exceededLimit":false,"totalLines":83,"fileSize":2338,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/packages/import/ImportPackageModal.tsx","readRange":{"startLine":1,"endLine":83},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-df4c84ff-6099-4ee5-aa48-26ec3fbb2a0c-23\nfc_abb30ba8-7b8f-9982-b57b-e543311f925e_4","startedAtMs":"1784806573407","completedAtMs":"1784806573777"},"model_call_id":"760ac919-ef79-4d53-99c3-afefda3b7a00-4-c3sn","session_id":"f1905b4c-095a-4284-8d32-eb80ff150078","timestamp_ms":1784806573759}
