n\t\t\tsetPackages(list);\n\t\t} catch (error) {\n\t\t\tsetPackages([]);\n\t\t\tsetLoadError(\n\t\t\t\terror instanceof Error ? error.message : \"加载故事包列表失败\",\n\t\t\t);\n\t\t} finally {\n\t\t\tsetLoading(false);\n\t\t}\n\t}, []);\n\n\tuseEffect(function () {\n\t\tvoid refreshPackages();\n\t}, [refreshPackages]);\n\n\tconst filtered = useMemo(\n\t\tfunction () {\n\t\t\treturn packages.filter(function (pkg) {\n\t\t\t\treturn matchesSearch(pkg, search);\n\t\t\t});\n\t\t},\n\t\t[packages, search],\n\t);\n\n\tconst pageItems = useMemo(\n\t\tfunction () {\n\t\t\treturn sliceForPage(filtered, page, PACKAGE_LIST_PAGE_SIZE);\n\t\t},\n\t\t[filtered, page],\n\t);\n\n\tfunction onSearchChange(next: string): void {\n\t\tsetSearch(next);\n\t\tsetPage(1);\n\t}\n\n\tfunction onImported(packageId: string): void {\n\t\tvoid refreshPackages();\n\t\tsetImportOpen(false);\n\t\trouter.push(`/stories/${packageId}`);\n\t}\n\n\tasync function onCreateSubmit(\n\t\tvalues: CreatePackageFormValues,\n\t): Promise<void> {\n\t\tconst { packageId } = await commitCreatePackage(values);\n\t\tsetCreateOpen(false);\n\t\tawait refreshPackages();\n\t\trouter.push(`/stories/${packageId}`);\n\t}\n\n\treturn {\n\t\tpackages,\n\t\tfilteredCount: filtered.length,\n\t\tloading,\n\t\tloadError,\n\t\tpage,\n\t\tsetPage,\n\t\tsearch,\n\t\tonSearchChange,\n\t\timportOpen,\n\t\tsetImportOpen,\n\t\tcreateOpen,\n\t\tsetCreateOpen,\n\t\tpageItems,\n\t\tonImported,\n\t\tonCreateSubmit,\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":110,"fileSize":2947,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/packages/list/hooks/usePackageListPage.ts","readRange":{"startLine":1,"endLine":110},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-7bc12dd1-5f38-44c7-82bc-880ac6e8a348-17\nfc_bb6f02ca-7c73-969a-870d-21e20bb58dc1_5","startedAtMs":"1784806568501","completedAtMs":"1784806568657"},"model_call_id":"760ac919-ef79-4d53-99c3-afefd