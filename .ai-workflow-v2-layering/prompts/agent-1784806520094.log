ror, \"删除失败，请稍后重试\"));\n\t\t}\n\t}\n\n\tfunction closeDeleteModal(): void {\n\t\tsetDeleteTargetId(null);\n\t\tsetDeleteError(undefined);\n\t}\n\n\treturn {\n\t\tprofiles: session.profiles,\n\t\tselected: session.selected,\n\t\tcreateOpen,\n\t\tsetCreateOpen,\n\t\tdeleteTarget,\n\t\tdeleteError,\n\t\tloadError: session.loadError,\n\t\tloading: session.loading,\n\t\tsetSelectedId: session.setSelectedId,\n\t\tonCreateSubmit,\n\t\tonDetailSaved: session.onDetailSaved,\n\t\tonRequestDelete,\n\t\tonConfirmDelete,\n\t\tcloseDeleteModal,\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":76,"fileSize":2207,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/users/hooks/useUserLibraryPage.ts","readRange":{"startLine":1,"endLine":76},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-ff78d281-0487-4e91-8421-99121719bbb2-37\nfc_1a5719d9-8581-9b9b-8881-125aa71af59d_3","startedAtMs":"1784806589302","completedAtMs":"1784806589471"},"model_call_id":"760ac919-ef79-4d53-99c3-afefda3b7a00-6-tvkr","session_id":"f1905b4c-095a-4284-8d32-eb80ff150078","timestamp_ms":1784806589455}
