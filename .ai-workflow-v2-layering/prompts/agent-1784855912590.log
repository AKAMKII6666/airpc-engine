ror, \"删除失败，请稍后重试\"));\n\t\t}\n\t}\n\n\tfunction closeDeleteModal(): void {\n\t\tsetDeleteTargetId(null);\n\t\tsetDeleteError(undefined);\n\t}\n\n\treturn {\n\t\tprofiles: session.profiles,\n\t\tselected: session.selected,\n\t\tcreateOpen,\n\t\tsetCreateOpen,\n\t\tdeleteTarget,\n\t\tdeleteError,\n\t\tloadError: session.loadError,\n\t\tloading: session.loading,\n\t\tsetSelectedId: session.setSelectedId,\n\t\tonCreateSubmit,\n\t\tonDetailSaved: session.onDetailSaved,\n\t\tonRequestDelete,\n\t\tonConfirmDelete,\n\t\tcloseDeleteModal,\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":76,"fileSize":2207,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/users/hooks/useUserLibraryPage.ts","readRange":{"startLine":1,"endLine":76},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-06668876-2e79-4a54-acd4-232a9688e0aa-19\nfc_2d9862dd-902e-9b0c-8c2b-4a1845d1ae44_1","startedAtMs":"1784855942402","completedAtMs":"1784855943151"},"model_call_id":"b88131f0-ccbc-416f-8993-56c7d341e9d9-4-gifp","session_id":"9d5d92a4-9197-4359-b529-714f8dc9f615","timestamp_ms":1784855943079}
