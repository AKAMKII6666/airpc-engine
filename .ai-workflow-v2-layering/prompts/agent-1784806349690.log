on],\n\t);\n\n\tuseLayoutEffect(\n\t\tfunction () {\n\t\t\tlet cancelled = false;\n\t\t\tapplyListLoadStarted();\n\t\t\tvoid (async function () {\n\t\t\t\ttry {\n\t\t\t\t\tconst users = await fetchProfileUsers();\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult(toUsersLoadResult(users));\n\t\t\t\t} catch (error) {\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult({\n\t\t\t\t\t\tok: false,\n\t\t\t\t\t\tmessage: errorMessage(error, \"加载玩家列表失败\"),\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t})();\n\n\t\t\treturn function () {\n\t\t\t\tcancelled = true;\n\t\t\t};\n\t\t},\n\t\t[refreshStamp, applyListLoadStarted, applyListLoadResult],\n\t);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":85,"fileSize":2276,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/shellBis/users/users.shell.bis.ts","readRange":{"startLine":1,"endLine":85},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-df0ac465-905d-4027-ae5f-ac7d0c814d96-12\nfc_f273ff83-ea75-91c9-b748-eb69e9aef38f_2","startedAtMs":"1784806374242","completedAtMs":"1784806374457"},"model_call_id":"49197619-e07a-419a-b989-d21a0cf7eab8-3-kh0f","session_id":"ae50ee7b-0275-49ac-a69d-40e90d9c1aca","timestamp_ms":1784806374440}
