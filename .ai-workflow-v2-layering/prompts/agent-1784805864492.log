t} catch (error) {\n\t\t\tsetDeleteError(errorMessage(error, \"删除失败，请稍后重试\"));\n\t\t}\n\t}\n\n\tfunction closeDeleteModal(): void {\n\t\tsetDeleteTargetId(null);\n\t\tsetDeleteError(undefined);\n\t}\n\n\treturn {\n\t\tcharacters: session.characters,\n\t\tselected: session.selected,\n\t\tcreateOpen,\n\t\tsetCreateOpen,\n\t\tdeleteTarget,\n\t\tdeleteError,\n\t\tloadError: session.loadError,\n\t\tloading: session.loading,\n\t\tsetSelectedId: session.setSelectedId,\n\t\tonCreateSubmit,\n\t\tonDetailSaved: session.onDetailSaved,\n\t\tonRequestDelete,\n\t\tonConfirmDelete,\n\t\tcloseDeleteModal,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-f6419452-b8af-4547-a19c-7fd127da292c-55\nfc_0bdebc7d-d891-9044-94f3-2df28dd704c1_0","startedAtMs":"1784806005696"},"model_call_id":"f4832d8a-b377-4c51-bdff-f1a0393497ff-11-1wvj","session_id":"0dd76478-7020-4972-b158-de93a08114ae","timestamp_ms":1784806005702}
