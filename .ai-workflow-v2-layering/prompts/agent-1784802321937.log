gExp(\n          `^(?://\\\\s*|\\\\{\\\\/\\\\*\\\\s*)引用了${tagName}组件，用于.+`,\n        );\n        if (!expected.test(prev)) {\n          violations.push({\n            ruleId: RULE.JSX_COMPONENT_COMMENT,\n            file: rel,\n            line: line + 1,\n            column: character + 1,\n            severity: \"error\",\n            message: `自定义组件 <${tagName}> 引用上方缺少用途注释`,\n            suggestion: `在组件引用上方增加一行：// 引用了${tagName}组件，用于XXX`,\n          });\n        }\n      }\n    }\n    ts.forEachChild(node, visit);\n  };\n  visit(sf);\n\n  return violations;\n}\n\n/**\n * @param {import('typescript').Node} node\n */","isEmpty":false,"exceededLimit":false,"totalLines":1627,"fileSize":50682,"path":"/Users/bolbiao/workspace/airpc-engine/scripts/studio-quality/check-studio-structure.mjs","readRange":{"startLine":1073,"endLine":1152},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-1dce8075-d261-422b-9e8d-c38f34c5f487-69\nfc_b65efb08-ae0f-99aa-8db4-657f458adf39_0","startedAtMs":"1784802522452","completedAtMs":"1784802522661"},"model_call_id":"dda7230a-b121-48f9-8620-1f733a844daa-16-xegf","session_id":"35dc3cce-69fb-4024-87a4-56d2194d9b5d","timestamp_ms":1784802522658}
