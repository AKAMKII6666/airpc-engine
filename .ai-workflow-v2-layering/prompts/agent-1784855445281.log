\n\t\t\t</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认缩放</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{editor.defaultZoomPercent}%\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={<Switch checked={editor.showMinimap} disabled />}\n\t\t\t\t\tlabel=\"显示小地图\"\n\t\t\t\t/>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t<Switch checked={editor.showValidationFloat} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认显示校验浮窗\"\n\t\t\t\t/>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={<Switch checked={editor.autoSave} disabled />}\n\t\t\t\t\tlabel={`自动保存（间隔 ${editor.autoSaveIntervalSec} 秒）`}\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>新卡片默认类型</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{editor.defaultCardKindLabel}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n\nexport type DebuggerPrefsPanelProps = {\n\t/** 调试器偏好投影 */\n\tdebuggerPrefs: DebuggerPrefs;\n};\n\nexport const DebuggerPrefsPanel: FC<DebuggerPrefsPanelProps> = function ({\n\t// debuggerPrefs 是调试器默认偏好投影\n\tdebuggerPrefs,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>调试器</h2>\n\t\t\t<p className={styles.sectionSub}>仅影响默认值，不改变引擎语义。</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认用户档案</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.defaultUserName || \"未设置\"}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t<Switch checked={debuggerPrefs.defaultResetStory} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认重置故事状态\"\n\t\t\t\t/>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t<Switch checked={debuggerPrefs.showAdvancedLogs} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认展开高级日志\"\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>时间推进步长</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.clockStepSec} 秒\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>调试记录保留</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.recordRetainCount} 条\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n","afterFullFileContent":"/**\n\t* 外观 / 编辑器 / 调试器偏好面板。\n\t* 静态演示；不写盘、无泳道相关项；数据由 props 注入。\n\t*/\n\"use client\";\n\nimport type { FC } from \"react\";\nimport { FormControlLabel, Switch } from \"@mui/material\";\nimport type {\n\tAppearancePrefs,\n\tDebuggerPrefs,\n\tEditorPrefs,\n} from \"@studio-v2/typeFiles/settings/studioSettings\";\nimport styles from \"../SettingsShell.module.scss\";\n\nexport type AppearancePanelProps = {\n\t/** 外观偏好投影 */\n\tappearance: AppearancePrefs;\n};\n\nexport const AppearancePanel: FC<AppearancePanelProps> = function ({\n\t// appearance 是外观偏好投影\n\tappearance,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>外观</h2>\n\t\t\t<p className={styles.sectionSub}>\n\t\t\t\t默认暗色调色板。本步不做浅色主题落地。\n\t\t\t</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>主题</span>\n\t\t\t\t\t<span className={styles.prefValue}>暗色（默认）</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>画布点阵强度</span>\n\t\t\t\t\t<span className={styles.prefValue}>{appearance.gridStrength}%</span>\n\t\t\t\t</div>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于连线动画开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于连线动画只读开关\n\t\t\t\t\t\t<Switch checked={appearance.edgeAnimation} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"连线动画\"\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>高亮强度</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{appearance.highlightStrength}%\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n\nexport type EditorPrefsPanelProps = {\n\t/** 编辑器偏好投影 */\n\teditor: EditorPrefs;\n};\n\nexport const EditorPrefsPanel: FC<EditorPrefsPanelProps> = function ({\n\t// editor 是编辑器偏好投影\n\teditor,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>编辑器</h2>\n\t\t\t<p className={styles.sectionSub}>\n\t\t\t\t基础偏好。无泳道设置；不提供手工 ID 生成规则。\n\t\t\t</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认缩放</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{editor.defaultZoomPercent}%\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于小地图开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于小地图只读开关\n\t\t\t\t\t\t<Switch checked={editor.showMinimap} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"显示小地图\"\n\t\t\t\t/>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于校验浮窗开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于校验浮窗只读开关\n\t\t\t\t\t\t<Switch checked={editor.showValidationFloat} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认显示校验浮窗\"\n\t\t\t\t/>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于自动保存开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于自动保存只读开关\n\t\t\t\t\t\t<Switch checked={editor.autoSave} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel={`自动保存（间隔 ${editor.autoSaveIntervalSec} 秒）`}\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>新卡片默认类型</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{editor.defaultCardKindLabel}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n\nexport type DebuggerPrefsPanelProps = {\n\t/** 调试器偏好投影 */\n\tdebuggerPrefs: DebuggerPrefs;\n};\n\nexport const DebuggerPrefsPanel: FC<DebuggerPrefsPanelProps> = function ({\n\t// debuggerPrefs 是调试器默认偏好投影\n\tdebuggerPrefs,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>调试器</h2>\n\t\t\t<p className={styles.sectionSub}>仅影响默认值，不改变引擎语义。</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认用户档案</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.defaultUserName || \"未设置\"}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于默认重置故事开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于默认重置故事只读开关\n\t\t\t\t\t\t<Switch checked={debuggerPrefs.defaultResetStory} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认重置故事状态\"\n\t\t\t\t/>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于高级日志开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于高级日志只读开关\n\t\t\t\t\t\t<Switch checked={debuggerPrefs.showAdvancedLogs} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认展开高级日志\"\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>时间推进步长</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.clockStepSec} 秒\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>调试记录保留</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.recordRetainCount} 条\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/settings/com/SettingsPrefsPanels.tsx"}}},"hookAdditionalContexts":[],"toolCallId":"call-4258dfec-9865-43d3-92bd-d0010acec734-87\nfc_2bd7193f-f360-9c0e-8d11-1145b775ee0c_4","startedAtMs":"1784855734888","completedAtMs":"1784855735534"},"model_call_id":"d5f9e08f-e925-468e-aca1-0e1d7d8c7880-17-kumy","session_id":"d077d01e-46bc-4c07-be60-b644d8d5fda5","timestamp_ms":1784855735513}
{"type":"tool_call","subtype":"completed","call_id":"call-4258dfec-9865-43d3-92bd-d0010acec734-88\nfc_2bd7193f-f360-9c0e-8d11-1145b775ee0c_5","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/settings/com/SettingsEnginePanels.tsx","streamContent":"/**\n\t* 导入导出 / 高级 / Schema 与校验报告面板。\n\t* 数据由 props 注入；禁止直引 ajaxProxy mock。\n\t*/\n\"use client\";\n\nimport type { FC } from \"react\";\nimport { FormControlLabel, Switch, Typography } from \"@mui/material\";\nimport type {\n\tImportExportPrefs,\n\tSchemaEngineStatus,\n\tValidationIssue,\n} from \"@studio-v2/typeFiles/settings/studioSettings\";\nimport { schemaCompatLabel } from \"@studio-v2/typeFiles/settings/settingsLabels\";\nimport { formatRelativeEdit } from \"@studio-v2/typeFiles/story/labels/statusLabels\";\n// 引用了ValidationReportPanel组件，用于展示校验问题列表\nimport { ValidationReportPanel } from \"@studio-v2/src/pageComponents/settings/com/ValidationReportPanel\";\nimport styles from \"../SettingsShell.module.scss\";\n\nexport type ImportExportPrefsPanelProps = {\n\t/** 导入导出偏好投影 */\n\tprefs: ImportExportPrefs;\n};\n\nexport const ImportExportPrefsPanel: FC<ImportExportPrefsPanelProps> = function ({\n\t// prefs 是导入导出偏好投影\n\tprefs,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>导入导出</h2>\n\t\t\t<p className={styles.sectionSub}>打包偏好；危险覆盖操作本步不提供。</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认导出类型</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{prefs.defaultExportKindLabel}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于导出布局元数据开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于导出布局元数据只读开关\n\t\t\t\t\t\t<Switch checked={prefs.includeLayoutMeta} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"导出编辑器布局元数据\"\n\t\t\t\t/>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于包含资源开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于包含资源只读开关\n\t\t\t\t\t\t<Switch checked={prefs.includeAssets} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"包含资源文件\"\n\t\t\t\t/>\n\t\t\t\t{/* 引用了FormControlLabel组件，用于导入复制资源开关行 */}\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t// 引用了Switch组件，用于导入复制资源只读开关\n\t\t\t\t\t\t<Switch checked={prefs.copyAssetsOnImport} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"导入时复制资源到资源库\"\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认导出目录</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{prefs.defaultExportDir || \"系统默认\"}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n\nexport const AdvancedPrefsPanel: FC = function () {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>高级</h2>\n\t\t\t<p className={styles.sectionSub}>\n\t\t\t\t默认隐藏内部 ID 与 JSON。普通创作路径不应依赖此区。\n\t\t\t</p>\n\t\t\t{/* 引用了FormControlLabel组件，用于显示内部 ID 开关行 */}\n\t\t\t<FormControlLabel\n\t\t\t\tcontrol={\n\t\t\t\t\t// 引用了Switch组件，用于显示内部 ID 只读开关\n\t\t\t\t\t<Switch checked={false} disabled />\n\t\t\t\t}\n\t\t\t\tlabel=\"显示内部 ID\"\n\t\t\t/>\n\t\t\t{/* 引用了FormControlLabel组件，用于 JSON 高级视图开关行 */}\n\t\t\t<FormControlLabel\n\t\t\t\tcontrol={\n\t\t\t\t\t// 引用了Switch组件，用于 JSON 高级视图只读开关\n\t\t\t\t\t<Switch checked={false} disabled />\n\t\t\t\t}\n\t\t\t\tlabel=\"默认打开 JSON 高级视图\"\n\t\t\t/>\n\t\t\t<div className={styles.warnBox}>\n\t\t\t\t清理缓存 / 重建索引会打断未保存编辑；本步仅展示警示，不执行危险操作。\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n\nexport type SchemaEnginePanelProps = {\n\t/** Schema / 引擎兼容态 */\n\tstatus: SchemaEngineStatus;\n\t/** 校验报告条目 */\n\tissues: readonly ValidationIssue[];\n\t/** 是否展开校验报告 */\n\tshowReport: boolean;\n\t/** 切换报告开合 */\n\tonToggleReport: () => void;\n};\n\nexport const SchemaEnginePanel: FC<SchemaEnginePanelProps> = function ({\n\t// status 是 Schema / 引擎兼容投影\n\tstatus,\n\t// issues 是校验报告条目\n\tissues,\n\t// showReport 控制报告展开\n\tshowReport,\n\t// onToggleReport 切换报告开合\n\tonToggleReport,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>Schema 与引擎</h2>\n\t\t\t<p className={styles.sectionSub}>\n\t\t\t\t工程兼容状态与校验报告入口。不在此编辑故事包 JSON。\n\t\t\t</p>\n\t\t\t<div className={styles.compatCard}>\n\t\t\t\t<span className={styles.compatBadge}>\n\t\t\t\t\t{schemaCompatLabel(status.compat)}\n\t\t\t\t</span>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>Studio schema</span>\n\t\t\t\t\t<span className={styles.prefValue}>{status.studioSchemaVersion}</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>引擎 schema</span>\n\t\t\t\t\t<span className={styles.prefValue}>{status.engineSchemaVersion}</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>最近同步</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{status.lastSyncedAt\n\t\t\t\t\t\t\t? formatRelativeEdit(status.lastSyncedAt)\n\t\t\t\t\t\t\t: \"尚未同步\"}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t{/* 引用了Typography组件，用于 CallCard 类型标签说明 */}\n\t\t\t\t<Typography variant=\"caption\" className={styles.prefLabel}>\n\t\t\t\t\t可用 CallCard 类型\n\t\t\t\t</Typography>\n\t\t\t\t<div className={styles.tagList}>\n\t\t\t\t\t{status.availableCardKinds.map(function (k) {\n\t\t\t\t\t\treturn (\n\t\t\t\t\t\t\t<span key={k} className={styles.tag}>\n\t\t\t\t\t\t\t\t{k}\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t);\n\t\t\t\t\t})}\n\t\t\t\t</div>\n\t\t\t\t{/* 引用了Typography组件，用于 Effect 类型标签说明 */}\n\t\t\t\t<Typography variant=\"caption\" className={styles.prefLabel}>\n\t\t\t\t\t可用 Effect 类型\n\t\t\t\t</Typography>\n\t\t\t\t<div className={styles.tagList}>\n\t\t\t\t\t{status.availableEffects.map(function (k) {\n\t\t\t\t\t\treturn (\n\t\t\t\t\t\t\t<span key={k} className={styles.tag}>\n\t\t\t\t\t\t\t\t{k}\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t);\n\t\t\t\t\t})}\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<button\n\t\t\t\ttype=\"button\"\n\t\t\t\tc