anelProps> = function ({\n\t// editor 是编辑器偏好投影\n\teditor,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>编辑器</h2>\n\t\t\t<p className={styles.sectionSub}>\n\t\t\t\t基础偏好。无泳道设置；不提供手工 ID 生成规则。\n\t\t\t</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认缩放</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{editor.defaultZoomPercent}%\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={<Switch checked={editor.showMinimap} disabled />}\n\t\t\t\t\tlabel=\"显示小地图\"\n\t\t\t\t/>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t<Switch checked={editor.showValidationFloat} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认显示校验浮窗\"\n\t\t\t\t/>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={<Switch checked={editor.autoSave} disabled />}\n\t\t\t\t\tlabel={`自动保存（间隔 ${editor.autoSaveIntervalSec} 秒）`}\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>新卡片默认类型</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{editor.defaultCardKindLabel}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n\nexport type DebuggerPrefsPanelProps = {\n\t/** 调试器偏好投影 */\n\tdebuggerPrefs: DebuggerPrefs;\n};\n\nexport const DebuggerPrefsPanel: FC<DebuggerPrefsPanelProps> = function ({\n\t// debuggerPrefs 是调试器默认偏好投影\n\tdebuggerPrefs,\n}) {\n\treturn (\n\t\t<div>\n\t\t\t<h2 className={styles.sectionTitle}>调试器</h2>\n\t\t\t<p className={styles.sectionSub}>仅影响默认值，不改变引擎语义。</p>\n\t\t\t<div className={styles.prefGrid}>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>默认用户档案</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.defaultUserName || \"未设置\"}\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t<Switch checked={debuggerPrefs.defaultResetStory} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认重置故事状态\"\n\t\t\t\t/>\n\t\t\t\t<FormControlLabel\n\t\t\t\t\tcontrol={\n\t\t\t\t\t\t<Switch checked={debuggerPrefs.showAdvancedLogs} disabled />\n\t\t\t\t\t}\n\t\t\t\t\tlabel=\"默认展开高级日志\"\n\t\t\t\t/>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>时间推进步长</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.clockStepSec} 秒\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.prefRow}>\n\t\t\t\t\t<span className={styles.prefLabel}>调试记录保留</span>\n\t\t\t\t\t<span className={styles.prefValue}>\n\t\t\t\t\t\t{debuggerPrefs.recordRetainCount} 条\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n};\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/settings/com/SettingsPrefsPanels.tsx","linesAdded":137,"linesRemoved":113,"diffString":"--- a//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/settings/com/SettingsPrefsPanels.tsx\n+++ b//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/settings/com/SettingsPrefsPanels.tsx\n@@ -1,125 +1,149 @@\n /**\n- * 外观 / 编辑器 / 调试器偏好面板。\n- * 静态演示；不写盘、无泳道相关项。\n- */\n+\t* 外观 / 编辑器 / 调试器偏好面板。\n+\t* 静态演示；不写盘、无泳道相关项；数据由 props 注入。\n+\t*/\n \"use client\";\n \n import type { FC } from \"react\";\n import { FormControlLabel, Switch } from \"@mui/material\";\n-import {\n-  MOCK_APPEARANCE,\n-  MOCK_DEBUGGER_PREFS,\n-  MOCK_EDITOR_PREFS,\n-} from \"@studio-v2/src/utils/ajaxProxy/settings/mockSettingsData\";\n+import type {\n+\tAppearancePrefs,\n+\tDebuggerPrefs,\n+\tEditorPrefs,\n+} from \"@studio-v2/typeFiles/settings/studioSettings\";\n import styles from \"../SettingsShell.module.scss\";\n \n-export const AppearancePanel: FC = function () {\n-  return (\n-    <div>\n-      <h2 className={styles.sectionTitle}>外观</h2>\n-      <p className={styles.sectionSub}>\n-        默认暗色调色板。本步不做浅色主题落地。\n-      </p>\n-      <div className={