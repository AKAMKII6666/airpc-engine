nt组件，用于右侧分类内容 */}\n\t\t\t\t\t\t<SettingsContent\n\t\t\t\t\t\t\tcategory={category}\n\t\t\t\t\t\t\tsnapshot={snapshot}\n\t\t\t\t\t\t\tshowReport={showReport}\n\t\t\t\t\t\t\tonToggleReport={function () {\n\t\t\t\t\t\t\t\tsetShowReport(function (v) {\n\t\t\t\t\t\t\t\t\treturn !v;\n\t\t\t\t\t\t\t\t});\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t/>\n\t\t\t\t\t</div>\n\t\t\t\t</>\n\t\t\t) : null}\n\t\t</main>\n\t);\n};\n"}},"hookAdditionalContexts":[],"toolCallId":"call-df360360-145e-4f16-b8fe-c259c860a8be-67\nfc_a7d9c6bf-460c-94c2-8549-0cee586e5927_2","startedAtMs":"1784855620201"},"model_call_id":"d5f9e08f-e925-468e-aca1-0e1d7d8c7880-13-7quf","session_id":"d077d01e-46bc-4c07-be60-b644d8d5fda5","timestamp_ms":1784855620157}
