maEnginePanel\n\t\t\tstatus={snapshot.schema}\n\t\t\tissues={snapshot.validationIssues}\n\t\t\tshowReport={showReport}\n\t\t\tonToggleReport={onToggleReport}\n\t\t/>\n\t);\n};\n"}},"hookAdditionalContexts":[],"toolCallId":"call-df360360-145e-4f16-b8fe-c259c860a8be-69\nfc_a7d9c6bf-460c-94c2-8549-0cee586e5927_4","startedAtMs":"1784855629755"},"model_call_id":"d5f9e08f-e925-468e-aca1-0e1d7d8c7880-13-7quf","session_id":"d077d01e-46bc-4c07-be60-b644d8d5fda5","timestamp_ms":1784855629713}
