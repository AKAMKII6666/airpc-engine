peFiles/story/editor/validate/packageValidationDto\";\n\nfunction errorMessage(error: unknown, fallback: string): string {\n\tif (error instanceof Error && error.message.trim() !== \"\") {\n\t\treturn error.message;\n\t}\n\treturn fallback;\n}\n\n/** 从保存异常提取 ValidationReport；非校验失败返回 null */\nfunction validationReportFromSaveError(\n\terror: unknown,\n): ValidationReport | null {\n\tif (\n\t\terror instanceof StudioApiError &&\n\t\terror.code === \"PACKAGE_VALIDATION_FAILED\" &&\n\t\tisPackageValidationFailDetails(error.details)\n\t) {\n\t\treturn error.details.report;\n\t}\n\treturn null;\n}\n\nexport type RunPackageSessionSaveArgs = {\n\t/** 路由包键 */\n\tpackageId: string;\n\t/** 当前会话 bundle；调用方已判非空 */\n\tbundle: DiskStoryPackageBundle;\n\t/** 同步 flush；失败表示画布未挂载 */\n\tflushCanvasToStore: () => boolean;\n};\n\n/**\n\t* 先 flush→store，再以 flushedGraph 组 bundle 写盘。\n\t* 相位经 store apply*；调用方勿再重复 applySaveStarted。\n\t*/\nexport async function runPackageSessionSave(\n\targs: RunPackageSessionSaveArgs,\n): Promise<void> {\n\tconst { packageId, bundle, flushCanvasToStore } = args;\n\tconst store = useStoryEditorStore.getState();\n\tif (!flushCanvasToStore()) {\n\t\tstore.applySaveFailure({\n\t\t\tmessage: \"画布未就绪，无法保存\",\n\t\t\tvalidation: null,\n\t\t});\n\t\treturn;\n\t}\n\tconst graph = useStoryEditorStore.getState().flushedGraph;\n\tif (!graph) {\n\t\tstore.applySaveFailure({\n\t\t\tmessage: \"画布快照缺失，无法保存\",\n\t\t\tvalidation: null,\n\t\t});\n\t\treturn;\n\t}\n\tstore.applySaveStarted();\n\ttry {\n\t\tconst saved = await saveStoryPackageToDisk({\n\t\t\tpackageId,\n\t\t\tbaseBundle: bundle,\n\t\t\tnodes: graph.nodes as Node[],\n\t\t\tedges: graph.edges as Edge[],\n\t\t});\n\t\tuseStoryEditorStore.getState().applySaveSuccess({\n\t\t\tbundle: saved.bundle,\n\t\t\tvalidation: saved.validation,\n\t\t});\n\t} catch (error) {\n\t\tuseStoryEditorStore.getState().applySaveFailure({\n\t\t\tmessage: errorMessage(error, \"保存失败，请稍后重试\"),\n\t\t\tvalidation: validationReportFromSaveError(error),\n\t\t});\n\t}\n}\n","afterFullFileContent":"/**\n\t* 包会话整包保存步骤：flush 门闸 + PUT；结果型写 store。\n\t* 从 mutate hook 抽出以降有效行数；禁 UI 直调。\n\t*/\nimport type { Edge, Node } from \"@xyflow/react\";\nimport { saveStoryPackageToDisk } from \"@studio-v2/src/bis/pageBis/storyEditor/package/io/saveStoryPackage_bis\";\nimport { useStoryEditorStore } from \"@studio-v2/src/stores/storyEditor/storyEditorStore\";\nimport { StudioApiError } from \"@studio-v2/src/utils/ajaxHelper/studioApiClient\";\nimport type { DiskStoryPackageBundle } from \"@studio-v2/typeFiles/story/package/diskStoryPackage\";\nimport type { ValidationReport } from \"@studio-v2/typeFiles/story/validate/engineValidation\";\nimport { isPackageValidationFailDetails } from \"@studio-v2/typeFiles/story/editor/validate/packageValidationDto\";\nimport type {\n\tStoryEditorSaveFailurePayload,\n\tStoryEditorSaveSuccessPayload,\n} from \"@studio-v2/typeFiles/story/editor/store/storyEditorStoreState\";\n\nfunction errorMessage(error: unknown, fallback: string): string {\n\tif (error instanceof Error && error.message.trim() !== \"\") {\n\t\treturn error.message;\n\t}\n\treturn fallback;\n}\n\n/** 从保存异常提取 ValidationReport；非校验失败返回 null */\nfunction validationReportFromSaveError(\n\terror: unknown,\n): ValidationReport | null {\n\tif (\n\t\terror instanceof StudioApiError &&\n\t\terror.code === \"PACKAGE_VALIDATION_FAILED\" &&\n\t\tisPackageValidationFailDetails(error.details)\n\t) {\n\t\treturn error.details.report;\n\t}\n\treturn null;\n}\n\n/** 保存编排入参；调用方已订 store actions */\nexport type CommitStoryEditorPackageSaveInput = {\n\t/** 路由包键；PUT 目标 */\n\tpackageId: string;\n\t/** 当前会话 bundle；空则 no-op */\n\tbundle: DiskStoryPackageBundle | null;\n\t/** 同步 flush；失败则记 applySaveFailure */\n\tflushCanvasToStore: () => boolean;\n\tapplySaveStarted: () => void;\n\tapplySaveSuccess: (payload: StoryEditorSaveSuccessPayload) => void;\n\tapplySaveFailure: (payload: StoryEditorSaveFailurePayload) => void;\n};\n\n/**\n\t* 先 flush→读 flushedGraph→PUT；成功/失败写 store。\n\t* 不以 canvasApi 为组 bundle 真源。\n\t*/\nexport async function commitStoryEditorPackageSave(\n\tinput: CommitStoryEditorPackageSaveInput,\n): Promise<void> {\n\tconst {\n\t\tpackageId,\n\t\tbundle,\n\t\tflushCanvasToStore,\n\t\tapplySaveStarted,\n\t\tapplySaveSuccess,\n\t\tapplySaveFailure,\n\t} = input;\n\tif (!bundle) return;\n\tif (!flushCanvasToStore()) {\n\t\tapplySaveFailure({\n\t\t\tmessage: \"画布未就绪，无法保存\",\n\t\t\tvalidation: null,\n\t\t});\n\t\treturn;\n\t}\n\tconst graph = useStoryEditorStore.getState().flushedGraph;\n\tif (!graph) {\n\t\tapplySaveFailure({\n\t\t\tmessage: \"画布快照缺失，无法保存\",\n\t\t\tvalidation: null,\n\t\t});\n\t\treturn;\n\t}\n\tapplySaveStarted();\n\ttry {\n\t\tconst saved = await saveStoryPackageToDisk({\n\t\t\tpackageId,\n\t\t\tbaseBundle: bundle,\n\t\t\tnodes: graph.nodes as Node[],\n\t\t\tedges: graph.edges as Edge[],\n\t\t});\n\t\tapplySaveSuccess({\n\t\t\tbundle: saved.bundle,\n\t\t\tvalidation: saved.validation,\n\t\t});\n\t} catch (error) {\n\t\tapplySaveFailure({\n\t\t\tmessage: errorMessage(error, \"保存失败，请稍后重试\"),\n\t\t\tvalidation: validationReportFromSaveError(error),\n\t\t});\n\t}\n}\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/session/packageSessionSave.ts"}}},"hookAdditionalContexts":[],"toolCallId":"call-3958e0c6-9194-4857-a172-9cf6b51d3568-101\nfc_7c11aca6-e7fc-9dae-8536-ff35fcca9d97_0","startedAtMs":"1784805808749","completedAtMs":"1784805809962"},"model_call_id":"4564573b-c9fa-4c89-ab5a-e1395a1cda0c-1-ix3r","session_id":"81e57bb5-9d55-4072-a422-0be29eed300e","timestamp_ms":1784805809947}
