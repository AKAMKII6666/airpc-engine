(\n\tlist: PromptSceneLayerForm[],\n): PromptSceneLayerForm[] {\n\treturn list.map((scene, index) => ({\n\t\t...scene,\n\t\tpriority: index * 10,\n\t}));\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":64,"fileSize":1704,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/commonUiComponents/form/blocks/PromptSceneListEditor/promptSceneListHelpers.ts","readRange":{"startLine":1,"endLine":64},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-aa7dc468-028e-4b48-83ba-5a6bf40676d0-55\nfc_5bd12660-07dd-99aa-9650-5fe1fe03ffe4_1","startedAtMs":"1784804576693","completedAtMs":"1784804576969"},"model_call_id":"f4e70ff6-7bed-4d73-8003-e6fc3840c800-10-zau5","session_id":"81e57bb5-9d55-4072-a422-0be29eed300e","timestamp_ms":1784804576960}
