ik>\n\t\t\t);\n\t\t}\n\n\t\treturn (\n\t\t\t// 引用了Formik组件，用于 CallCard 属性表单状态\n\t\t\t<Formik\n\t\t\t\tinitialValues={toNodePropertyFormValues(selection.data)}\n\t\t\t\tenableReinitialize\n\t\t\t\tvalidate={validateNodePropertyForm}\n\t\t\t\tonSubmit={function (values, helpers) {\n\t\t\t\t\treturn submitCallCardPropertyForm({\n\t\t\t\t\t\tdata: selection.data,\n\t\t\t\t\t\tnodeId: selection.nodeId,\n\t\t\t\t\t\tvalues,\n\t\t\t\t\t\thelpers,\n\t\t\t\t\t\tonApplyNodeData,\n\t\t\t\t\t});\n\t\t\t\t}}\n\t\t\t>\n\t\t\t\t{function (formik) {\n\t\t\t\t\treturn (\n\t\t\t\t\t\t// 引用了NodePropertyForm组件，用于 CallCard 属性字段\n\t\t\t\t\t\t<NodePropertyForm\n\t\t\t\t\t\t\tnodeData={selection.data}\n\t\t\t\t\t\t\tformik={formik}\n\t\t\t\t\t\t\tcharacterAnchors={characterAnchors}\n\t\t\t\t\t\t\teffectPanelSources={effectPanelSources}\n\t\t\t\t\t\t\tonAssignOwner={function (agentId, displayName) {\n\t\t\t\t\t\t\t\tonAssignOwner(\n\t\t\t\t\t\t\t\t\tselection.nodeId,\n\t\t\t\t\t\t\t\t\tagentId,\n\t\t\t\t\t\t\t\t\tdisplayName,\n\t\t\t\t\t\t\t\t);\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t/>\n\t\t\t\t\t);\n\t\t\t\t}}\n\t\t\t</Formik>\n\t\t);\n\t};\n","isEmpty":false,"exceededLimit":false,"totalLines":140,"fileSize":4564,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/com/panel/FloatingPanelFormBody.tsx","readRange":{"startLine":1,"endLine":140},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-d5f3ed81-d7b6-4fd8-8e22-61846a727f2d-45\nfc_cc0ce3ac-1454-9e86-aadc-3e9676eb6aa6_0","startedAtMs":"1784804533200","completedAtMs":"1784804533376"},"model_call_id":"f4e70ff6-7bed-4d73-8003-e6fc3840c800-8-orvp","session_id":"81e57bb5-9d55-4072-a422-0be29eed300e","timestamp_ms":1784804533366}
