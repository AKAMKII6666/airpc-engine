 PromptSceneLayerForm[],\n): PromptSceneLayerForm[] {\n\treturn list.map(function (scene, index) {\n\t\treturn {\n\t\t\t...scene,\n\t\t\tpriority: index * 10,\n\t\t};\n\t});\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-34a1498e-bc64-40d8-9b52-ac26be1a2f33-58\nfc_14733da9-2306-94ce-95ca-27af85c53040_0","startedAtMs":"1784804596095"},"model_call_id":"f4e70ff6-7bed-4d73-8003-e6fc3840c800-11-myzi","session_id":"81e57bb5-9d55-4072-a422-0be29eed300e","timestamp_ms":1784804596084}
