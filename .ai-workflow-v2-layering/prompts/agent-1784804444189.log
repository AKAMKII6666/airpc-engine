odeSchema */\n\tinteractionMode: EditorInteractionMode | \"\";\n\tcontext: {\n\t\tobjective: string;\n\t\tprivateBrief: string;\n\t\tspeakableBrief: string;\n\t\tbackground: string;\n\t\tpremise: string;\n\t\temotion: string;\n\t\tplaybackClipId: string;\n\t\tforbidden: string[];\n\t\t/** 场景提示词层；写回 context.promptScenes */\n\t\tpromptScenes: PromptSceneLayerForm[];\n\t};\n\tobjectives: {\n\t\trequiredBeats: string[];\n\t};\n\t/** 出口列表；提交后同步画布 Handle */\n\texits: ExitListFormRow[];\n\ttoolPolicy: {\n\t\tmode: EditorToolPolicyProjection[\"mode\"] | \"\";\n\t\tallowedToolIds: string[];\n\t};\n\t/**\n\t\t* 调度字段；IntegerInput 空串表示未填。\n\t\t* 仅 cardKind=schedule 时写回节点；其它种类忽略。\n\t\t*/\n\tschedule: {\n\t\tmode: \"daily\" | \"weekly\" | \"\";\n\t\thour: number | \"\";\n\t\tminute: number | \"\";\n\t\tcooldownMs: number | \"\";\n\t\tpriority: number | \"\";","isEmpty":false,"exceededLimit":false,"totalLines":277,"fileSize":8682,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/form/node/nodePropertyForm.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-54f5aede-87da-4e5e-972d-027711533759-23\nfc_c80015f3-779f-99d0-bea8-ae11540154d7_5","startedAtMs":"1784804485421","completedAtMs":"1784804485570"},"model_call_id":"f4e70ff6-7bed-4d73-8003-e6fc3840c800-4-araw","session_id":"81e57bb5-9d55-4072-a422-0be29eed300e","timestamp_ms":1784804485575}
