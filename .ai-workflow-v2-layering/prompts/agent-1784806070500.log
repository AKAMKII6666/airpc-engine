\n\t\t\t\tsetItems([]);\n\t\t\t\tsetTotal(0);\n\t\t\t\tsetError(\n\t\t\t\t\terr instanceof Error && err.message.trim() !== \"\"\n\t\t\t\t\t\t? err.message\n\t\t\t\t\t\t: \"加载记忆失败\",\n\t\t\t\t);\n\t\t\t} finally {\n\t\t\t\tsetLoading(false);\n\t\t\t}\n\t\t},\n\t\t[agentId],\n\t);\n\n\tuseEffect(() => {\n\t\tvoid load(1, userId);\n\t}, [agentId, userId, load]);\n\n\tfunction onPageChange(nextPage: number): void {\n\t\tsetPage(nextPage);\n\t\tvoid load(nextPage, userId);\n\t}\n\n\treturn {\n\t\tpage,\n\t\titems,\n\t\ttotal,\n\t\tloading,\n\t\terror,\n\t\tonPageChange,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-e92c4f22-fe73-4ff5-8a4a-cd4f31f33190-38\nfc_4931ac4d-f51e-906e-bb8f-9586ae752656_0","startedAtMs":"1784806157564"},"model_call_id":"ea3e9fad-a07d-412c-9480-d71e2e535b32-8-gi7w","session_id":"66581072-65ff-45d4-a604-354a3ac566e1","timestamp_ms":1784806157549}
