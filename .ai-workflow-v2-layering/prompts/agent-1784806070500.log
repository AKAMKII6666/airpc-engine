m() !== \"\"\n\t\t\t\t\t\t? err.message\n\t\t\t\t\t\t: \"加载调试用户失败\",\n\t\t\t\t);\n\t\t\t} finally {\n\t\t\t\tif (!cancelled) setUsersLoading(false);\n\t\t\t}\n\t\t}\n\t\tvoid loadUsers();\n\t\treturn function () {\n\t\t\tcancelled = true;\n\t\t};\n\t}, []);\n\n\tfunction onUserChange(event: SelectChangeEvent<string>): void {\n\t\tsetUserId(event.target.value);\n\t}\n\n\treturn {\n\t\tusersLoading,\n\t\tusersError,\n\t\tusers,\n\t\tuserId,\n\t\tonUserChange,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-e92c4f22-fe73-4ff5-8a4a-cd4f31f33190-39\nfc_4931ac4d-f51e-906e-bb8f-9586ae752656_1","startedAtMs":"1784806162158"},"model_call_id":"ea3e9fad-a07d-412c-9480-d71e2e535b32-8-gi7w","session_id":"66581072-65ff-45d4-a604-354a3ac566e1","timestamp_ms":1784806162147}
