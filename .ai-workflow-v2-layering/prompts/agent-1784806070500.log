 instanceof Error && err.message.trim() !== \"\"\n\t\t\t\t\t\t? err.message\n\t\t\t\t\t\t: \"加载记忆失败\",\n\t\t\t\t);\n\t\t\t} finally {\n\t\t\t\tsetLoading(false);\n\t\t\t}\n\t\t},\n\t\t[agentId],\n\t);\n\n\tuseEffect(() => {\n\t\tvoid load(1, userId);\n\t}, [agentId, userId, load]);\n\n\tfunction onPageChange(nextPage: number): void {\n\t\tsetPage(nextPage);\n\t\tvoid load(nextPage, userId);\n\t}\n\n\treturn {\n\t\tpage,\n\t\titems,\n\t\ttotal,\n\t\tloading,\n\t\terror,\n\t\tonPageChange,\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":85,"fileSize":1975,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/characters/com/memory/hooks/useCharacterMemoryList.ts","readRange":{"startLine":1,"endLine":85},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-749d1c23-2279-428f-bce0-7ddc0e4ca810-12\nfc_23a16e90-b959-97cd-914e-9b1e8341e7cd_1","startedAtMs":"1784806092332","completedAtMs":"1784806092534"},"model_call_id":"ea3e9fad-a07d-412c-9480-d71e2e535b32-3-tvy0","session_id":"66581072-65ff-45d4-a604-354a3ac566e1","timestamp_ms":1784806092529}
