ent,\n): Promise<ScheduledIntent> {\n\tif (intent.kind !== \"recurring\") {\n\t\tthrow new Error(\"仅每日外呼可暂停\");\n\t}\n\tconst nextStatus = intent.status === \"paused\" ? \"active\" : \"paused\";\n\treturn upsertAgentScheduleIntent({\n\t\tuserId,\n\t\tagentId,\n\t\tintent: { ...intent, status: nextStatus },\n\t});\n}\n"}}},"hookAdditionalContexts":[],"toolCallId":"call-e92c4f22-fe73-4ff5-8a4a-cd4f31f33190-42\nfc_4931ac4d-f51e-906e-bb8f-9586ae752656_4","startedAtMs":"1784806167811","completedAtMs":"1784806167983"},"model_call_id":"ea3e9fad-a07d-412c-9480-d71e2e535b32-8-gi7w","session_id":"66581072-65ff-45d4-a604-354a3ac566e1","timestamp_ms":1784806167970}
