arted();\n\ttry {\n\t\tconst result = await listenDebuggerMailboxSlot({\n\t\t\tuserId,\n\t\t\tvoicemailId: slot.id,\n\t\t\tcardId: slot.cardId || undefined,\n\t\t\tpackageId: slot.packageId || DEBUGGER_DEFAULT_PACKAGE_ID,\n\t\t\tagentId: slot.agentId,\n\t\t});\n\t\tapply.applyResult({\n\t\t\tmailbox: result.mailbox,\n\t\t\tlastListenSummary: `听完出口：${result.exitTitle || result.selectedExitId || \"(无)\"} · 未读=${result.mailbox.hasUnread ? \"是\" : \"否\"}`,\n\t\t});\n\t} catch (error) {\n\t\tapply.applyFailed(errorMessage(error, \"模拟听完失败\"));\n\t}\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-ba02ab33-03f3-4b57-ac24-e17c952a0697-63\nfc_32a8e0d0-3601-9c4e-aea2-fcf5bdccf850_0","startedAtMs":"1784855332620"},"model_call_id":"d28447b4-77e3-438d-a341-52a7d1fc3a05-15-rw6p","session_id":"945260ce-2ae4-4b00-a3dd-28691eb52a31","timestamp_ms":1784855332579}
