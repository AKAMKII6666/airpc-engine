\t\t\treturn sliceForPage(filtered, page, PACKAGE_LIST_PAGE_SIZE);\n\t\t},\n\t\t[filtered, page],\n\t);\n\n\tfunction onSearchChange(next: string): void {\n\t\tsetSearch(next);\n\t\tsetPage(1);\n\t}\n\n\tfunction onImported(packageId: string): void {\n\t\tsession.onImported(packageId);\n\t\tsetImportOpen(false);\n\t\trouter.push(`/stories/${packageId}`);\n\t}\n\n\tasync function onCreateSubmit(\n\t\tvalues: CreatePackageFormValues,\n\t): Promise<void> {\n\t\tconst { packageId } = await session.onCreateSubmit(values);\n\t\tsetCreateOpen(false);\n\t\trouter.push(`/stories/${packageId}`);\n\t}\n\n\treturn {\n\t\tpackages: session.packages,\n\t\tfilteredCount: filtered.length,\n\t\tloading: session.loading,\n\t\tloadError: session.loadError,\n\t\tpage,\n\t\tsetPage,\n\t\tsearch,","isEmpty":false,"exceededLimit":false,"totalLines":91,"fileSize":2546,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/packages/list/hooks/usePackageListPage.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-2d6f6861-a8c6-47f9-8294-6f587ef0a15e-17\nfc_9395df3c-f7f0-9160-9e23-8979a725ec13_1","startedAtMs":"1784855173017","completedAtMs":"1784855173206"},"model_call_id":"d28447b4-77e3-438d-a341-52a7d1fc3a05-4-bsgw","session_id":"945260ce-2ae4-4b00-a3dd-28691eb52a31","timestamp_ms":1784855173162}
