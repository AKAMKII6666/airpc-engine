etPreferSelectedId: (packageId: string | undefined) => void;\n\t/** feature 请求 shell 有界重拉 */\n\tbumpPackagesRefreshStamp: () => void;\n\t/** 离页或强制清空会话 */\n\tresetPackagesSession: () => void;\n};\n\nfunction createPackagesSessionSlice(): Pick<\n\tPackagesStoreState,\n\t| \"packages\"\n\t| \"selectedId\"\n\t| \"loading\"\n\t| \"loadError\"\n\t| \"preferSelectedId\"\n> {\n\treturn {\n\t\tpackages: [],\n\t\tselectedId: \"\",\n\t\tloading: false,\n\t\tloadError: undefined,\n\t\tpreferSelectedId: undefined,\n\t};\n}\n\nexport const usePackagesStore = create<PackagesStoreState>((set) => ({\n\t...createPackagesSessionSlice(),\n\trefreshStamp: 0,\n\n\tapplyListLoadStarted() {\n\t\tset({\n\t\t\tloading: true,\n\t\t\tloadError: undefined,\n\t\t});\n\t},\n\n\tapplyListLoadResult(result) {\n\t\tif (!result.ok) {\n\t\t\tset({\n\t\t\t\tloading: false,\n\t\t\t\tloadError: result.message,\n\t\t\t\tpackages: [],\n\t\t\t\tselectedId: \"\",\n\t\t\t});\n\t\t\treturn;\n\t\t}\n\t\tset(function (prev) {\n\t\t\tconst list = [...result.packages];\n\t\t\tconst selectedId = pickPackagesSelectedId(\n\t\t\t\tlist,\n\t\t\t\tprev.preferSelectedId,\n\t\t\t\tprev.selectedId,\n\t\t\t);\n\t\t\treturn {\n\t\t\t\tloading: false,\n\t\t\t\tloadError: undefined,\n\t\t\t\tpackages: list,\n\t\t\t\tselectedId,\n\t\t\t\tpreferSelectedId: undefined,\n\t\t\t};\n\t\t});\n\t},\n\n\tsetSelectedId(packageId) {\n\t\tset({ selectedId: packageId });\n\t},\n\n\tsetPreferSelectedId(packageId) {\n\t\tset({ preferSelectedId: packageId });\n\t},\n\n\tbumpPackagesRefreshStamp() {\n\t\tset(function (prev) {\n\t\t\treturn { refreshStamp: prev.refreshStamp + 1 };\n\t\t});\n\t},\n\n\tresetPackagesSession() {\n\t\tset(function (prev) {\n\t\t\treturn {\n\t\t\t\t...createPackagesSessionSlice(),\n\t\t\t\trefreshStamp: prev.refreshStamp,\n\t\t\t};\n\t\t});\n\t},\n}));\n","isEmpty":false,"exceededLimit":false,"totalLines":139,"fileSize":3620,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/stores/packages/packagesStore.