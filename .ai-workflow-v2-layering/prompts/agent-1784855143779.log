* 判别失败 */\n\tok: false;\n\t/** 人话错误 */\n\tmessage: string;\n};\n\n/** 信箱加载结果联合 */\nexport type DebuggerMailboxLoadResult =\n\t| DebuggerMailboxLoadOkPayload\n\t| DebuggerMailboxLoadFailPayload;\n"}},"hookAdditionalContexts":[],"toolCallId":"call-bdf25695-2e4d-4fe9-870a-1dac4587f54c-45\nfc_09871d8b-c55e-92cb-a67b-30c48fc99fbe_0","startedAtMs":"1784855229984"},"model_call_id":"d28447b4-77e3-438d-a341-52a7d1fc3a05-10-ycl2","session_id":"945260ce-2ae4-4b00-a3dd-28691eb52a31","timestamp_ms":1784855229950}
