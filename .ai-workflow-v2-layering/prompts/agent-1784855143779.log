ing,\n\t\tbusy,\n\t\terror: mailboxError ?? null,\n\t\tlastListenSummary: lastListenSummary ?? null,\n\t\tsetUserId,\n\t\trefresh,\n\t\tonSeed,\n\t\tonListen,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-ba02ab33-03f3-4b57-ac24-e17c952a0697-64\nfc_32a8e0d0-3601-9c4e-aea2-fcf5bdccf850_1","startedAtMs":"1784855336567"},"model_call_id":"d28447b4-77e3-438d-a341-52a7d1fc3a05-15-rw6p","session_id":"945260ce-2ae4-4b00-a3dd-28691eb52a31","timestamp_ms":1784855336523}
