eLayoutEffect(\n\t\tfunction () {\n\t\t\tlet cancelled = false;\n\t\t\tapplyListLoadStarted();\n\t\t\tvoid (async function () {\n\t\t\t\ttry {\n\t\t\t\t\tconst users = await fetchProfileUsers();\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult(toUsersLoadResult(users));\n\t\t\t\t} catch (error) {\n\t\t\t\t\tif (cancelled) return;\n\t\t\t\t\tapplyListLoadResult({\n\t\t\t\t\t\tok: false,\n\t\t\t\t\t\tmessage: errorMessage(error, \"加载玩家列表失败\"),\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t})();\n\n\t\t\treturn function () {\n\t\t\t\tcancelled = true;\n\t\t\t};\n\t\t},\n\t\t[refreshStamp, applyListLoadStarted, applyListLoadResult],\n\t);\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-52adce2d-2b0a-4b37-b87f-e087f9d66e67-47\nfc_316fa9d6-9831-9587-8fe7-8d91544b004b_2","startedAtMs":"1784806284805"},"model_call_id":"a25a74f1-b71b-4206-ac8b-ed45eaa7e341-7-f3s1","session_id":"9889126d-666f-4037-9a22-48d049bc9da4","timestamp_ms":1784806284790}
