"));\n\t\t}\n\t}\n\n\tfunction closeDeleteModal(): void {\n\t\tsetDeleteTargetId(null);\n\t\tsetDeleteError(undefined);\n\t}\n\n\treturn {\n\t\tprofiles: session.profiles,\n\t\tselected: session.selected,\n\t\tcreateOpen,\n\t\tsetCreateOpen,\n\t\tdeleteTarget,\n\t\tdeleteError,\n\t\tloadError: session.loadError,\n\t\tloading: session.loading,\n\t\tsetSelectedId: session.setSelectedId,\n\t\tonCreateSubmit,\n\t\tonDetailSaved: session.onDetailSaved,\n\t\tonRequestDelete,\n\t\tonConfirmDelete,\n\t\tcloseDeleteModal,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-52072bef-d9df-4bd1-865e-d69187c21bfc-49\nfc_ca053991-3481-99ff-b6a2-93f350d99343_0","startedAtMs":"1784806298275"},"model_call_id":"a25a74f1-b71b-4206-ac8b-ed45eaa7e341-8-mawn","session_id":"9889126d-666f-4037-9a22-48d049bc9da4","timestamp_ms":1784806298348}
