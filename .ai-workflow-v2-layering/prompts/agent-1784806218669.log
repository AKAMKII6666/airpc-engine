nst loading = useUsersStore(function (s) {\n\t\treturn s.loading;\n\t});\n\tconst loadError = useUsersStore(function (s) {\n\t\treturn s.loadError;\n\t});\n\tconst setSelectedId = useUsersStore(function (s) {\n\t\treturn s.setSelectedId;\n\t});\n\tconst applyUserUpsertResult = useUsersStore(function (s) {\n\t\treturn s.applyUserUpsertResult;\n\t});\n\tconst setPreferSelectedId = useUsersStore(function (s) {\n\t\treturn s.setPreferSelectedId;\n\t});\n\tconst bumpUsersRefreshStamp = useUsersStore(function (s) {\n\t\treturn s.bumpUsersRefreshStamp;\n\t});\n\n\tconst selected = useMemo(\n\t\tfunction () {\n\t\t\treturn (\n\t\t\t\tprofiles.find((u) => u.userId === selectedId) ?? profiles[0]\n\t\t\t);\n\t\t},\n\t\t[profiles, selectedId],\n\t);\n\n\tconst onDetailSaved = useCallback(\n\t\tfunction (next: UserProfileSummary) {\n\t\t\tapplyUserUpsertResult(next);\n\t\t},\n\t\t[applyUserUpsertResult],\n\t);\n\n\tconst onCreateSubmit = useCallback(\n\t\tasync function (values: CreateUserFormValues): Promise<void> {\n\t\t\tconst { userId } = await commitCreateUser(values);\n\t\t\tsetPreferSelectedId(userId);\n\t\t\tbumpUsersRefreshStamp();\n\t\t},\n\t\t[setPreferSelectedId, bumpUsersRefreshStamp],\n\t);\n\n\tconst onConfirmDelete = useCallback(\n\t\tasync function (userId: string): Promise<void> {\n\t\t\tawait commitDeleteUser(userId);\n\t\t\tbumpUsersRefreshStamp();\n\t\t},\n\t\t[bumpUsersRefreshStamp],\n\t);\n\n\treturn {\n\t\tprofiles,\n\t\tselected,\n\t\tloading,\n\t\tloadError,\n\t\tsetSelectedId,\n\t\tonDetailSaved,\n\t\tonCreateSubmit,\n\t\tonConfirmDelete,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-52adce2d-2b0a-4b37-b87f-e087f9d66e67-48\nfc_316fa9d6-9831-9587-8fe7-8d91544b004b_3","startedAtMs":"1784806285901"},"model_call_id":"a25a74f1-b71b-4206-ac8b-ed45eaa7e341-7-f3s1","session_id":"9889126d-666f-4037-9a22-48d049bc9da4","timestamp_ms":1784806285905}
