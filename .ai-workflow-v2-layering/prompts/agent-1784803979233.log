\n\t\t\t\treturn;\n\t\t\t}\n\t\t\tset({\n\t\t\t\tpackageId: result.packageId.trim(),\n\t\t\t\tloading: false,\n\t\t\t\tloadError: undefined,\n\t\t\t\tdiskPackages: [...result.diskPackages],\n\t\t\t\tbundle: result.bundle,\n\t\t\t\tgraphSeed: result.graphSeed,\n\t\t\t\tcardIndex: { ...result.cardIndex },\n\t\t\t\tentryCardIdByPackage: { ...result.entryCardIdByPackage },\n\t\t\t\tflushedGraph: null,\n\t\t\t\tcanvasPendingFlush: false,\n\t\t\t\tconfDirty: false,\n\t\t\t\tgraphDirty: false,\n\t\t\t\tsavePhase: \"idle\",\n\t\t\t\tsaveError: undefined,\n\t\t\t\tsaveValidation: null,\n\t\t\t});\n\t\t},\n\n\t\tbumpStoryEditorRefreshStamp() {\n\t\t\tset(function (prev) {\n\t\t\t\treturn { refreshStamp: prev.refreshStamp + 1 };\n\t\t\t});\n\t\t},\n\n\t\tresetStoryEditorSession() {\n\t\t\tset(function (prev) {\n\t\t\t\treturn {\n\t\t\t\t\t...createStoryEditorSessionSlice(),\n\t\t\t\t\trefreshStamp: prev.refreshStamp,\n\t\t\t\t};\n\t\t\t});\n\t\t},\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":91,"fileSize":2314,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/stores/storyEditor/writes/storyEditorStoreLoadWrites.ts","readRange":{"startLine":1,"endLine":91},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-9d6956ae-a588-402b-8a35-ba6d1c379d4a-15\nfc_87755644-3fea-9305-ba6c-4266e2645144_3","startedAtMs":"1784804051736","completedAtMs":"1784804051961"},"model_call_id":"c1257f6e-83db-456b-a7a9-7f8cce32a4eb-3-vugv","session_id":"cfef524f-82ae-40d6-8016-cf95181ea6e8","timestamp_ms":1784804051988}
