isabled: voicemailLocked,\n\t\t\thelperText: voicemailLocked\n\t\t\t\t? \"语音留言强制「仅播放」，不可改。\"\n\t\t\t\t: undefined,\n\t\t},\n\t];\n}\n\n/** 静态默认项（非 voicemail）；运行时请用 buildNodeBasicItems(cardKind) */\nexport const NODE_BASIC_ITEMS: AutoFormItem[] = buildNodeBasicItems(\"story\");\n"}},"hookAdditionalContexts":[],"toolCallId":"call-5a2c61af-7db2-48e9-904a-f578da1bc8a0-64\nfc_969edd8f-4024-91fc-ab0c-463c4de339f0_2","startedAtMs":"1784791054412"},"model_call_id":"1781aa25-787e-44ca-ac43-adf7e813a471-18-dzq0","session_id":"cfbde88a-3285-44a4-857a-c1322a225060","timestamp_ms":1784791054473}
