readNotifier(): OnVoicemailUnreadChanged & {\n\tcalls: boolean[];\n} {\n\tconst calls: boolean[] = [];\n\tconst notify = function onVoicemailUnreadChanged(hasUnread: boolean): void {\n\t\tcalls.push(hasUnread);\n\t};\n\treturn Object.assign(notify, { calls });\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-d2547a29-8d4b-4ce9-be9b-619b304f8573-44\nfc_14c684cd-7a73-97d9-ab2a-2e4ee223c121_0","startedAtMs":"1784790905528"},"model_call_id":"1781aa25-787e-44ca-ac43-adf7e813a471-12-hg4h","session_id":"cfbde88a-3285-44a4-857a-c1322a225060","timestamp_ms":1784790905428}
