(z.string()).optional(),\n});\n\nexport const CallCardExitSchema = z.object({\n  exitId: z.string(),\n  exitKind: ExitKindSchema.optional(),\n  title: z.string().optional(),\n  priority: z.number().default(0),\n  condition: ExitConditionSchema,\n  effects: z.array(EffectSchema).default([]),\n});\n\nexport const CallCardContextSchema = z\n  .object({\n    privateBrief: z.string().optional(),\n    speakableBrief: z.string().optional(),\n    background: z.string().optional(),\n    premise: z.string().optional(),","isEmpty":false,"exceededLimit":false,"totalLines":216,"fileSize":7052,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/schema/callCard.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f3908c56-6019-4899-8a1a-72e665b17651-30\nfc_78a86884-d661-995a-9565-911346e52976_4","startedAtMs":"1784790792180","completedAtMs":"1784790792341"},"model_call_id":"1781aa25-787e-44ca-ac43-adf7e813a471-7-9hcz","session_id":"cfbde88a-3285-44a4-857a-c1322a225060","timestamp_ms":1784790792273}
