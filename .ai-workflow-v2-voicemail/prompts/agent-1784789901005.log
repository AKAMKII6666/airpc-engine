{"type":"tool_call","subtype":"completed","call_id":"call-c931b104-67a8-466d-951a-4d9f7db6c4c1-94\nfc_49c12a08-3ae6-9316-b031-b1a3e7d0ca47_2","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/voicemail/scheduleEffect.ts","streamContent":"import type { PlayerProfile } from \"../../schema/profile.js\";\nimport type { Effect } from \"../../schema/outcome.js\";\nimport type { ScheduledCardLookup } from \"../../schedule/scheduleCardReferenceResolver.js\";"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/voicemail/scheduleEffect.ts","linesAdded":3,"linesRemoved":3,"diffString":"--- a//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/voicemail/scheduleEffect.ts\n+++ b//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/voicemail/scheduleEffect.ts\n@@ -3,9 +3,9 @@\n  * 模块说明：目标 voicemail 只写 once intent（到点入 GenStack），禁止挂 Board / 外呼。\n  * 需求：语音留言改造 §3.3；执行索引 V2-VM-5\n  */\n-import type { PlayerProfile } from \"../schema/profile.js\";\n-import type { Effect } from \"../schema/outcome.js\";\n-import type { ScheduledCardLookup } from \"../schedule/scheduleCardReferenceResolver.js\";\n+import type { PlayerProfile } from \"../../schema/profile.js\";\n+import type { Effect } from \"../../schema/outcome.js\";\n+import type { ScheduledCardLookup } from \"../../schedule/scheduleCardReferenceResolver.js\";\n import {\n \tisLookupVoicemailCard,\n \tVOICEMAIL_MAILBOX_DELIVERY,","beforeFullFileContent":"/**\n * 模块名称：schedule_call_card → voicemail 分流\n * 模块说明：目标 voicemail 只写 once intent（到点入 GenStack），禁止挂 Board / 外呼。\n * 需求：语音留言改造 §3.3；执行索引 V2-VM-5\n */\nimport type { PlayerProfile } from \"../schema/profile.js\";\nimport type { Effect } from \"../schema/outcome.js\";\nimport type { ScheduledCardLookup } from \"../schedule/scheduleCardReferenceResolver.js\";\nimport {\n\tisLookupVoicemailCard,\n\tVOICEMAIL_MAILBOX_DELIVERY,\n} from \"./genStack.js\";\n\n/** 仅取 schedule 分流所需字段，避免与 effectExecutor 循环依赖 */\nexport type VoicemailScheduleCtx = {\n\tprofile: PlayerProfile;\n\tnowIso: string;\n\tlookupCard?: ScheduledCardLookup | null;\n};\n\n/**\n * @returns true 已登记留言延迟 intent；false 走普通 schedule（Board + outbound）\n */\nexport function tryScheduleVoicemailCallCard(\n\teffect: Effect,\n\tctx: VoicemailScheduleCtx,\n): boolean {\n\tconst agentId = String(effect.agentId ?? \"\");\n\tconst cardId = String(effect.cardId ?? \"\");\n\tconst packageId = String(effect.packageId ?? \"\");\n\tif (!agentId || !cardId || !packageId) {\n\t\treturn false;\n\t}\n\n\tif (!isLookupVoicemailCard(ctx.lookupCard, packageId, cardId)) {\n\t\treturn false;\n\t}\n\n\tconst delayMinutes =\n\t\ttypeof effect.delayMinutes === \"number\" ? effect.delayMinutes : 5;\n\tconst minMs =\n\t\ttypeof effect.minMs === \"number\" ? effect.minMs : delayMinutes * 60_000;\n\n\tconst { profile, nowIso } = ctx;\n\tif (!profile.schedule) {\n\t\tprofile.schedule = { clockMs: 0, intents: [] };\n\t}\n\tconst clockMs = profile.schedule.clockMs ?? 0;\n\n\tprofile.schedule.intents.push({\n\t\tkind: \"once\",\n\t\tintentId: effect.id,\n\t\tagentId,\n\t\tcardId,\n\t\tpackageId,\n\t\ttopicHint:\n\t\t\ttypeof effect.topicHint === \"string\" ? effect.topicHint : undefined,\n\t\tfireAtMs: clockMs + minMs,\n\t\tstatus: \"pending\",\n\t\t/** 无 linkedInstanceId：留言不挂 Board pending */\n\t\tdelivery: VOICEMAIL_MAILBOX_DELIVERY,\n\t\tcreatedAt: nowIso,\n\t});\n\treturn true;\n}\n","afterFullFileContent":"/**\n * 模块名称：schedule_call_card → voicemail 分流\n * 模块说明：目标 voicemail 只写 once intent（到点入 GenStack），禁止挂 Board / 外呼。\n * 需求：语音留言改造 §3.3；执行索引 V2-VM-5\n */\nimport type { PlayerProfile } from \"../../schema/profile.js\";\nimport type { Effect } from \"../../schema/outcome.js\";\nimport type { ScheduledCardLookup } from \"../../schedule/scheduleCardReferenceResolver.js\";\nimport {\n\tisLookupVoicemailCard,\n\tVOICEMAIL_MAILBOX_DELIVERY,\n} from \"./genStack.js\";\n\n/** 仅取 schedule 分流所需字段，避免与 effectExecutor 循环依赖 */\nexport type VoicemailScheduleCtx = {\n\tprofile: PlayerProfile;\n\tnowIso: string;\n\tlookupCard?: ScheduledCardLookup | null;\n};\n\n/**\n * @returns true 已登记留言延迟 intent；false 走普通 schedule（Board + outbound）\n */\nexport function tryScheduleVoicemailCallCard(\n\teffect: Effect,\n\tctx: VoicemailScheduleCtx,\n): boolean {\n\tconst agentId = String(effect.agentId ?? \"\");\n\tconst cardId = String(effect.cardId ?? \"\");\n\tconst packageId = String(effect.packageId ?? \"\");\n\tif (!agentId || !cardId || !packageId) {\n\t\treturn false;\n\t}\n\n\tif (!isLookupVoicemailCard(ctx.lookupCard, packageId, cardId)) {\n\t\treturn false;\n\t}\n\n\tconst delayMinutes =\n\t\ttypeof effect.delayMinutes === \"number\" ? effect.delayMinutes : 5;\n\tconst minMs =\n\t\ttypeof effect.minMs === \"number\" ? effect.minMs : delayMinutes * 60_000;\n\n\tconst { profile, nowIso } = ctx;\n\tif (!profile.schedule) {\n\t\tprofile.schedule = { clockMs: 0, intents: [] };\n\t}\n\tconst clockMs = profile.schedule.clockMs ?? 0;\n\n\tprofile.schedule.intents.push({\n\t\tkind: \"once\",\n\t\tintentId: effect.id,\n\t\tagentId,\n\t\tcardId,\n\t\tpackageId,\n\t\ttopicHint:\n\t\t\ttypeof effect.topicHint === \"string\" ? effect.topicHint : undefined,\n\t\tfireAtMs: clockMs + minMs,\n\t\tstatus: \"pending\",\n\t\t/** 无 linkedInstanceId：留言不挂 Board pending */\n\t\tdelivery: VOICEMAIL_MAILBOX_DELIVERY,\n\t\tcreatedAt: nowIso,\n\t});\n\treturn true;\n}\n","message":"The file /Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/voicemail/scheduleEffect.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"call-c931b104-67a8-466d-951a-4d9f7db6c4c1-94\nfc_49c12a08-3ae6-9316-b031-b1a3e7d0ca47_2","startedAtMs":"1784790410242","completedAtMs":"1784790410558"},"model_call_id":"67ff93d2-5343-4368-a533-07730f753f6e-26-ykg2","session_id":"ba23dced-71a4-4eed-9681-1cc1df8b9408","timestamp_ms":1784790410485}
