ng?.instanceId ?? randomUUID();\n\tif (!existing) {\n\t\tboard.pending.push({\n\t\t\tinstanceId,\n\t\t\tcardId,\n\t\t\tpackageId,\n\t\t\tagentId,\n\t\t\tstatus: \"pending\",\n\t\t\tentryMode: \"either\",\n\t\t\tactivationHint: \"outbound_auto\",\n\t\t\tscheduledIntentId: effect.id,\n\t\t\tcreatedAt: nowIso,\n\t\t\tupdatedAt: nowIso,\n\t\t});\n\t} else {\n\t\texisting.entryMode = existing.entryMode ?? \"either\";\n\t\texisting.activationHint = existing.activationHint ?? \"outbound_auto\";\n\t\texisting.scheduledIntentId = effect.id;\n\t\texisting.updatedAt = nowIso;\n\t}\n\tprofile.schedule.intents.push({\n\t\tkind: \"once\",\n\t\tintentId: effect.id,\n\t\tagentId,\n\t\tcardId,\n\t\tpackageId,\n\t\ttopicHint:\n\t\t\ttypeof effect.topicHint === \"string\" ? effect.topicHint : undefined,\n\t\tfireAtMs: clockMs + minMs,\n\t\tstatus: \"pending\",\n\t\tlinkedInstanceId: instanceId,\n\t\tcreatedAt: nowIso,\n\t});\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":87,"fileSize":2447,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/scheduleCallCardEffect.ts","readRange":{"startLine":1,"endLine":87},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-507b7e59-9e5d-4701-b5d3-1f8dc67278d4-104\nfc_241c0c38-ba68-9a5a-9007-eee965d86a01_1","startedAtMs":"1784790437797","completedAtMs":"1784790437999"},"model_call_id":"67ff93d2-5343-4368-a533-07730f753f6e-29-9qto","session_id":"ba23dced-71a4-4eed-9681-1cc1df8b9408","timestamp_ms":1784790437915}
