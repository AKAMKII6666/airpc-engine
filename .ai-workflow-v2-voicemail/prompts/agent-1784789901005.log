stanceId ?? instance.instanceId,\n\t\t\tstatus: \"fired\",\n\t\t},\n\t\tfired: {\n\t\t\tintentId: once.intentId,\n\t\t\tagentId: once.agentId,\n\t\t\tcardId: once.cardId,\n\t\t\tpackageId: once.packageId,\n\t\t\tinstanceId: instance.instanceId,\n\t\t},\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-01cb1a0d-2902-4e62-a914-af01d29e0318-71\nfc_84bc0110-07e6-9104-a479-90c54a00a16e_0","startedAtMs":"1784790323930"},"model_call_id":"67ff93d2-5343-4368-a533-07730f753f6e-18-kwfz","session_id":"ba23dced-71a4-4eed-9681-1cc1df8b9408","timestamp_ms":1784790323852}
