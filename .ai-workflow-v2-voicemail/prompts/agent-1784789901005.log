d: string;\n\tpackageId: string;\n\tinstanceId: string;\n}\n\nexport interface AdvanceToNextResult {\n\tfromClockMs: number;\n\ttoClockMs: number;\n\tadvancedMs: number;\n\tfired: FiredScheduleItem[];\n\treason: \"once\" | \"recurring\" | \"none\";\n}\n\n/**\n * 将 recurring 卡引用解析为可挂 pending 的 cardId+packageId。\n * scheduleCardId → (__schedule__, id)；否则使用显式 cardId+packageId。\n */\nexport function resolveRecurringCardTarget(\n\trec: Pick<\n\t\tScheduledRecurringIntent,\n\t\t\"scheduleCardId\" | \"cardId\" | \"packageId\"\n\t>,\n): { cardId: string; packageId: string } | null {\n\tif (typeof rec.scheduleCardId === \"string\" && rec.scheduleCardId) {\n\t\treturn {\n\t\t\tcardId: rec.scheduleCardId,\n\t\t\tpackageId: SCHEDULE_PACKAGE_ID,\n\t\t};\n\t}\n\tif (\n\t\ttypeof rec.cardId === \"string\" &&\n\t\trec.cardId &&\n\t\ttypeof rec.packageId === \"string\" &&\n\t\trec.packageId\n\t) {\n\t\treturn { cardId: rec.cardId, packageId: rec.packageId };\n\t}\n\treturn null;\n}\n\nfunction asRecurringIntent(raw: unknown): ScheduledRecurringIntent | null {\n\tif (!raw || typeof raw !== \"object\") {\n\t\treturn null;\n\t}\n\tconst row = raw as Record<string, unknown>;\n\tif (row.kind !== \"recurring\") {\n\t\treturn null;\n\t}\n\tconst intentId =\n\t\ttypeof row.intentId === \"string\"\n\t\t\t? row.intentId\n\t\t\t: typeof row.id === \"string\"\n\t\t\t\t? row.id","isEmpty":false,"exceededLimit":false,"totalLines":598,"fileSize":16822,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/scheduleTick.ts","readRange":{"startLine":1,"endLine":100},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-0226f129-1832-47c5-81f7-841d41f6861c-112\nfc_7bc68fe9-10f6-936b-825d-3190afd8e052_0","startedAtMs":"1784790524428","completedAtMs":"1784790524735"},"model_call_id":"67ff93d2-5343-4368-a533-07730f753f6e-35-3iy6","session_id":"ba23dced-71a4-4eed-9681-1cc1df8b9408","timestamp_ms":1784790524656}
