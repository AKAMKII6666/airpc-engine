ageId\");\n}\n\nfunction assertKindAllowed(\n  packageId: string,\n  kind: CardKind,\n  viaScheduleCardId: boolean,\n): ScheduledCardResolveFail | null {\n  if (viaScheduleCardId || packageId === SCHEDULE_PACKAGE_ID) {\n    if (kind !== \"schedule\") {\n      return fail(\n        \"CARD_KIND\",\n        `scheduleCardId must resolve to cardKind=schedule, got ${kind}`,\n      );\n    }\n    return null;\n  }\n  if (kind === \"story\") {","isEmpty":false,"exceededLimit":false,"totalLines":142,"fileSize":3565,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/schedule/scheduleCardReferenceResolver.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-74c64c94-f005-4130-b167-fadf0e44d038-18\nfc_9c7fc124-71cd-93ef-a605-3a7b620350c7_1","startedAtMs":"1784789950288","completedAtMs":"1784789950433"},"model_call_id":"67ff93d2-5343-4368-a533-07730f753f6e-4-v0ae","session_id":"ba23dced-71a4-4eed-9681-1cc1df8b9408","timestamp_ms":1784789950370}
