owIso,\n\t});\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-ad3c4684-c5ec-4a51-84e3-f220d57f4cb0-64\nfc_333d1284-a530-971a-baf9-ce3a83d93101_0","startedAtMs":"1784790277046"},"model_call_id":"67ff93d2-5343-4368-a533-07730f753f6e-16-ursr","session_id":"ba23dced-71a4-4eed-9681-1cc1df8b9408","timestamp_ms":1784790276983}
