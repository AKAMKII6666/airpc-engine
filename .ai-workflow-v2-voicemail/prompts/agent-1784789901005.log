domUUID();\n\tif (!existing) {\n\t\tboard.pending.push({\n\t\t\tinstanceId,\n\t\t\tcardId,\n\t\t\tpackageId,\n\t\t\tagentId,\n\t\t\tstatus: \"pending\",\n\t\t\tentryMode: \"either\",\n\t\t\tactivationHint: \"outbound_auto\",\n\t\t\tscheduledIntentId: effect.id,\n\t\t\tcreatedAt: nowIso,\n\t\t\tupdatedAt: nowIso,\n\t\t});\n\t} else {\n\t\texisting.entryMode = existing.entryMode ?? \"either\";\n\t\texisting.activationHint = existing.activationHint ?? \"outbound_auto\";\n\t\texisting.scheduledIntentId = effect.id;\n\t\texisting.updatedAt = nowIso;\n\t}\n\tprofile.schedule.intents.push({\n\t\tkind: \"once\",\n\t\tintentId: effect.id,\n\t\tagentId,\n\t\tcardId,\n\t\tpackageId,\n\t\ttopicHint:\n\t\t\ttypeof effect.topicHint === \"string\" ? effect.topicHint : undefined,\n\t\tfireAtMs: clockMs + minMs,\n\t\tstatus: \"pending\",\n\t\tlinkedInstanceId: instanceId,\n\t\tcreatedAt: nowIso,\n\t});\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-ad3c4684-c5ec-4a51-84e3-f220d57f4cb0-65\nfc_333d1284-a530-971a-baf9-ce3a83d93101_1","startedAtMs":"1784790277573"},"model_call_id":"67ff93d2-5343-4368-a533-07730f753f6e-16-ursr","session_id":"ba23dced-71a4-4eed-9681-1cc1df8b9408","timestamp_ms":1784790277509}
