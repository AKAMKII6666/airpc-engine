texts":[],"toolCallId":"call-035944b1-0f60-47b2-9263-d4c70a2b1ece-83\nfc_7b904d68-4e49-9384-9896-454eaf17fd80_5","startedAtMs":"1784791808300"},"model_call_id":"0a01194b-5abc-4302-bf01-d4f15eb13225-15-t4vc","session_id":"2b29ceb0-bbfd-4ff0-833a-eff8328e834a","timestamp_ms":1784791808310}
