tring }\n  | { op: \"all_required_beats_completed\" };\n\n/** 与 validatePackage 白名单对齐；未知名在 Zod parse 即失败 */\nexport const KNOWN_EFFECT_NAMES = [\n  \"set_character_unlocked\",\n  \"attach_call_card\",\n  \"set_redial_slot\",\n  \"unmount_call_card\",\n  \"keep_card_pending\",\n  \"schedule_call_card\",\n  \"schedule_recurring_call\",\n  \"create_research_commitment\",\n  \"update_user_profile\",\n  \"patch_memory\",\n  \"set_world_fact\",\n  \"update_npc_knowledge\",\n  \"end_story\",","isEmpty":false,"exceededLimit":false,"totalLines":103,"fileSize":2648,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/schema/outcome.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-3478801c-a6cc-488d-9a66-5079949fc82f-27\nfc_6633508b-e234-9cb9-9afa-d2273dfa3f97_5","startedAtMs":"1784791606367","completedAtMs":"1784791606606"},"model_call_id":"0a01194b-5abc-4302-bf01-d4f15eb13225-5-c087","session_id":"2b29ceb0-bbfd-4ff0-833a-eff8328e834a","timestamp_ms":1784791606605}
