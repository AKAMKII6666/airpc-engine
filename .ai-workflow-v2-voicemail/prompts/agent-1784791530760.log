lbox_open\");\n\t\texpect(resolved.card.interactionMode).toBe(\"playback_only\");\n\n\t\tconst session = await host.beginCall(\"demo-user\", resolved, {\n\t\t\tchannel: \"manual\",\n\t\t});\n\t\tif (isEngineError(session)) throw session;\n\t\texpect(session.interactionPhase).toBe(\"playback\");\n\t\texpect(session.frozenCard.cardId).toBe(\"lanxing_voicemail\");\n\n\t\tconst afterPlay = host.completePlayback(session.sessionId);\n\t\texpect(isEngineError(afterPlay)).toBe(false);\n\t\tif (isEngineError(afterPlay)) return;\n\t\texpect(afterPlay.phoneFlags.playback_completed).toBe(true);\n\n\t\tconst end = await host.endCall(session.sessionId, {\n\t\t\tflags: {\n\t\t\t\tanswered_completed: true,\n\t\t\t\tplayback_completed: true,\n\t\t\t\tvoicemail_listened: true,\n\t\t\t},\n\t\t\tcompletedBeats: [],\n\t\t\tmissedRequiredBeats: [],\n\t\t});\n\t\tif (isEngineError(end)) throw end;\n\t\texpect(end.selectedExitId).toBe(\"exit_end\");\n\n\t\tconst profile = await host.ensureProfile(\"demo-user\");\n\t\texpect(profile.telephony?.redialSlot?.agentId).toBe(\"lanxing\");\n\t\texpect(profile.telephony?.redialSlot?.cardId).toBe(\n\t\t\t\"lanxing_callback_intro\",\n\t\t);\n\t});\n});\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/voicemail-mailbox-listen.test.ts","linesAdded":77,"linesRemoved":0,"diffString":"--- /dev/null\n+++ b//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/voicemail-mailbox-listen.test.ts\n@@ -1 +1,78 @@\n+/**\n+ * V2-VM-11：mailbox_open / playback_only 听完路径\n+ * beginCall → completePlayback → endCall(Outcome) → ExitSelector → exits（set_redial_slot）\n+ */\n+import { cp, mkdtemp, rm } from \"node:fs/promises\";\n+import os from \"node:os\";\n+import path from \"node:path\";\n+import { fileURLToPath } from \"node:url\";\n+import { afterEach, describe, expect, it } from \"vitest\";\n+import { isEngineError } from \"../../src/index.js\";\n+import { createTestHost } from \"../helpers/inMemory