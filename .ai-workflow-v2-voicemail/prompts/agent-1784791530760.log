mise\": \"挂机后想起没自报；片刻后再拨同一号码。\",\n    \"emotion\": \"认真、带一点懊恼的笑\",\n    \"forbidden\": [\n      \"替用户做决定是否接下小皮\"\n    ],\n    \"promptScenes\": [\n      {\n        \"layerId\": \"callback_open\",\n        \"priority\": 0,\n        \"match\": {\n          \"callDirection\": \"outbound\",\n          \"localHourRange\": { \"from\": 0, \"to\": 24 }\n        },\n        \"patch\": {\n          \"openingSpeakable\": \"喂？还是刚才那个电话吗？\",\n          \"openingPrivate\": \"急忙确认没又打错；再自报姓名。\",\n          \"emotion\": \"急切转温和\",\n          \"toneHint\": \"认真留号\",\n          \"appendSpeakable\": \"\",\n          \"appendPrivate\": \"\"\n        }\n      }\n    ]\n  },\n  \"objectives\": {\n    \"requiredBeats\": [\n      \"自报姓名\",\n      \"留下号码\",\n      \"提起小皮露营\"\n    ]\n  },\n  \"toolPolicy\": {\n    \"mode\": \"inherit_free\"\n  },\n  \"exits\": [\n    {\n      \"exitId\": \"exit_known\",\n      \"exitKind\": \"terminal\",\n      \"title\": \"记住名号\",\n      \"priority\": 10,\n      \"condition\": {\n        \"op\": \"and\",\n        \"items\": [\n          {\n            \"op\": \"outcome_flag\",\n            \"flag\": \"answered_completed\",\n            \"equals\": true\n          },\n          {\n            \"op\": \"all_required_beats_completed\"\n          }\n        ]\n      },\n      \"effects\": [\n        {\n          \"id\": \"fx_end_known\",\n          \"effect\": \"end_story\",\n          \"reason\": \"初识成立\"\n        }\n      ]\n    },\n    {\n      \"exitId\": \"exit_voicemail\",\n      \"exitKind\": \"callback\",\n      \"title\": \"没说清→留言\",\n      \"priority\": 0,\n      \"condition\": {\n        \"op\": \"or\",\n        \"items\": [\n          {\n            \"op\": \"outcome_flag\",\n            \"flag\": \"hangup_early\",\n            \"equals\": true\n          },\n          {\n            \"op\": \"beat_missing\",\n            \"beatId\": \"自报姓名\"\n          },\n          {\n            \"op\": \"beat_missing\",\n            \"beatId\": \"留下号码\"\n         