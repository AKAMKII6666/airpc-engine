 createRecordingUnreadNotifier(): OnVoicemailUnreadChanged & {\n\tcalls: boolean[];\n} {\n\tconst calls: boolean[] = [];\n\tconst notify = function onVoicemailUnreadChanged(hasUnread: boolean): void {\n\t\tcalls.push(hasUnread);\n\t};\n\treturn Object.assign(notify, { calls });\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":70,"fileSize":2266,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/runtime/voicemailPorts.ts","readRange":{"startLine":1,"endLine":70},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-83ec1295-9b0c-4008-a6b8-3239b5c1bbdb-29\nfc_f02191df-824d-9c16-8743-07298799b1fb_1","startedAtMs":"1784792722085","completedAtMs":"1784792722288"},"model_call_id":"38ac4e31-68ba-4988-a00f-708e88213e1d-7-5phr","session_id":"001d8657-5fdc-4284-95ab-d8d3e6836461","timestamp_ms":1784792722300}
