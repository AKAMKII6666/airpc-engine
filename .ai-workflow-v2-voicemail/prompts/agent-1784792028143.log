{"type":"tool_call","subtype":"completed","call_id":"call-c944bdd3-40fd-49d5-aaf3-038255557087-96\nfc_20cee34e-fc5a-958a-8073-7912bfb5f7c3_1","tool_call":{"grepToolCall":{"args":{"pattern":"create_voicemail|CreateVoicemail|summarizeEffect","path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests","caseInsensitive":false,"multiline":false,"toolCallId":"call-c944bdd3-40fd-49d5-aaf3-038255557087-96\nfc_20cee34e-fc5a-958a-8073-7912bfb5f7c3_1","offset":0},"result":{"success":{"pattern":"create_voicemail|CreateVoicemail|summarizeEffect","path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests","outputMode":"content","workspaceResults":{"/Users/bolbiao/workspace/airpc-engine":{"content":{"matches":[{"file":"apps/studioV2/tests/storyEditor/nodePropertyAndRole.test.ts","matches":[{"lineNumber":247,"content":"\tit(\"exposes EFFECT_NAME_OPTIONS without create_voicemail\", () => {","contentTruncated":false,"isContextLine":false},{"lineNumber":253,"content":"\t\t\tEFFECT_NAME_OPTIONS.some((o) => o.value === \"create_voicemail\"),","contentTruncated":false,"isContextLine":false}]},{"file":"apps/studioV2/tests/storyEditor/summarizeEffect.test.ts","matches":[{"lineNumber":2,"content":"\t* summarizeEffect 自动派生摘要回归（S7-6）。","contentTruncated":false,"isContextLine":false},{"lineNumber":5,"content":"import { summarizeEffect } from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/effects/summarizeEffect\";","contentTruncated":false,"isContextLine":false},{"lineNumber":21,"content":"describe(\"summarizeEffect\", () => {","contentTruncated":false,"isContextLine":false},{"lineNumber":23,"content":"\t\tconst text = summarizeEffect(","contentTruncated":false,"isContextLine":false},{"lineNumber":32,"content":"\t\tconst text = summarizeEffect(","contentTruncated":false,"isContextLine":false},{"lineNumber":41,"content":"\t\tconst text = summarizeEffect(","contentTruncated":false,"isContextLine":false},{"lineNumber":57,"content":"\t\t\tsummarizeEffect(\"keep_card_pending\"