t 的过渡态）时回落默认值。\n\t*/\nexport function readEffectParams<E extends KnownEffectName>(\n\teffect: E,\n\tparams: EditorEffectParams | undefined,\n): EffectParamsFor<E> {\n\tif (params && params.effect === effect) {\n\t\treturn params as EffectParamsFor<E>;\n\t}\n\treturn EFFECT_PARAMS_DEFAULTS[effect]() as EffectParamsFor<E>;\n}\n\n/**\n\t* 解析整数输入框到 [min,max] 闭区间；供 hour/minute/delayMinutes 等标量字段复用。\n\t* 空串或非纯数字返回 undefined（等同「未配置」）；越界按边界夹紧，避免写入非法值。\n\t*/\nexport function parseBoundedInt(\n\traw: string,\n\tmin: number,\n\tmax: number,\n): number | undefined {\n\tif (raw === \"\" || !/^\\d+$/.test(raw)) {\n\t\treturn undefined;\n\t}\n\treturn Math.min(max, Math.max(min, Number(raw)));\n}\n","message":"The file /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/form/exitList/effects/effectParams.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"call-3032b707-cb6d-4021-803f-cc8e17e3ee72-82\nfc_a50cca77-993f-9fec-b99a-14ba4d5c4bd8_5","startedAtMs":"1784792235492","completedAtMs":"1784792236005"},"model_call_id":"f12dbec0-e618-4303-97ed-4c0da6d9d7a9-15-q0p2","session_id":"7b604dd9-4abf-4259-a8ae-6f931abdf158","timestamp_ms":1784792236003}
