{"type":"tool_call","subtype":"started","call_id":"call-425d4194-5eb3-4fcb-9903-abf4039708ca-71\nfc_3251c347-993e-9b02-a8d6-687edebf510c_3","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/engine-plan-7.4-7.5.test.ts","streamContent":"            id: \"m-crit\",\n            effect: \"play_system_prompt\",\n            clipId: \"clip_crit\",\n            critical: true,\n          },"}},"hookAdditionalContexts":[],"toolCallId":"call-425d4194-5eb3-4fcb-9903-abf4039708ca-71\nfc_3251c347-993e-9b02-a8d6-687edebf510c_3","startedAtMs":"1784792205674"},"model_call_id":"f12dbec0-e618-4303-97ed-4c0da6d9d7a9-13-8ww1","session_id":"7b604dd9-4abf-4259-a8ae-6f931abdf158","timestamp_ms":1784792205672}
