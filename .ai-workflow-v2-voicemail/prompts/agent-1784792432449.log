{"type":"tool_call","subtype":"completed","call_id":"call-6044c7d6-91f3-46fe-982c-aae8692de871-22\nfc_13cb6219-1d13-960f-ae00-889d40c41bb3_2","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/voicemail-mailbox-listen.test.ts"},"result":{"success":{"content":"/**\n * V2-VM-11：mailbox_open / playback_only 听完路径\n * beginCall → completePlayback → endCall(Outcome) → ExitSelector → exits（set_redial_slot）\n */\nimport { cp, mkdtemp, rm } from \"node:fs/promises\";\nimport os from \"node:os\";\nimport path from \"node:path\";\nimport { fileURLToPath } from \"node:url\";\nimport { afterEach, describe, expect, it } from \"vitest\";\nimport { isEngineError } from \"../../src/index.js\";\nimport { createTestHost } from \"../helpers/inMemoryMemoryPort.js\";\n\nconst repoRoot = path.resolve(\n\tpath.dirname(fileURLToPath(import.meta.url)),\n\t\"../../../..\",\n);\nconst dataSrc = path.join(repoRoot, \"data\");\n\ndescribe(\"voicemail mailbox_open listen path (V2-VM-11)\", () => {\n\tlet tmpRoot: string | undefined;\n\n\tafterEach(async () => {\n\t\tif (tmpRoot) {\n\t\t\tawait rm(tmpRoot, { recursive: true, force: true });\n\t\t\ttmpRoot = undefined;\n\t\t}\n\t});\n\n\tit(\"mailbox_open → playback → Outcome → exit set_redial_slot\", async () => {\n\t\ttmpRoot = await mkdtemp(path.join(os.tmpdir(), \"airpc-vm-listen-\"));\n\t\tconst dataRoot = path.join(tmpRoot, \"data\");\n\t\tawait cp(dataSrc, dataRoot, { recursive: true });\n\n\t\tconst host = createTestHost({ persist: false, dataRoot });\n\t\tawait host.loadWorkspace(dataRoot, { resetRuntime: true });\n\t\tawait host.ensureProfile(\"demo-user\");\n\n\t\tconst resolved = await host.resolveAsync(\"demo-user\", {\n\t\t\tkind: \"simulate_start\",\n\t\t\tpackageId: \"wrong_number_act1\",\n\t\t\tcardId: \"lanxing_voicemail\",\n\t\t});\n\t\tif (isEngineError(resolved)) throw resolved;\n\t\texpect(resolved.card.cardKind).toBe(\"voicemail\");\n\t\texpect(resolved.card.entryMode).toBe(\"mailbox_open\");\n\t\texpect(resolved.card.interactionMode).toBe(\"playback_only\");\n\n\t\tconst session = await host.beginCall(\"demo-user\", resolved, {\n\t\t\tchannel: \"manual\",\n\t\t});\n\t\tif (isEngineError(session)) throw session;\n\t\texpect(session.interactionPhase).toBe(\"playback\");\n\t\texpect(session.frozenCard.cardId).toBe(\"lanxing_voicemail\");\n\n\t\tconst afterPlay = host.completePlayback(session.sessionId);\n\t\texpect(isEngineError(afterPlay)).toBe(false);\n\t\tif (isEngineError(afterPlay)) return;\n\t\texpect(afterPlay.phoneFlags.playback_completed).toBe(true);\n\n\t\tconst end = await host.endCall(session.sessionId, {\n\t\t\tflags: {\n\t\t\t\tanswered_completed: true,\n\t\t\t\tplayback_completed: true,\n\t\t\t\tvoicemail_listened: true,\n\t\t\t},\n\t\t\tcompletedBeats: [],\n\t\t\tmissedRequiredBeats: [],\n\t\t});\n\t\tif (isEngineError(end)) throw end;\n\t\texpect(end.selectedExitId).toBe(\"exit_end\");\n\n\t\tconst profile = await host.ensureProfile(\"demo-user\");\n\t\texpect(profile.telephony?.redialSlot?.agentId).toBe(\"lanxing\");\n\t\texpect(profile.telephony?.redialSlot?.cardId).toBe(\n\t\t\t\"lanxing_callback_intro\",\n\t\t);\n\t});\n});\n","isEmpty":false,"exceededLimit":false,"totalLines":79,"fileSize":2659,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/voicemail-mailbox-listen.test.ts","readRange":{"startLine":1,"endLine":79},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-6044c7d6-91f3-46fe-982c-aae8692de871-22\nfc_13cb6219-1d13-960f-ae00-889d40c41bb3_2","startedAtMs":"1784792476716","completedAtMs":"1784792476861"},"model_call_id":"2b71313b-a89a-48db-b7fc-d60c320a4473-4-uof3","session_id":"d50e5eff-861e-4156-870f-dc415b750581","timestamp_ms":1784792476866}
