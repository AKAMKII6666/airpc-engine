        path.join(\n          \"scripts\",\n          \"engine-quality\",\n          \"tests\",\n          \"check-engine-structure.test.mjs\",\n        ),\n      ],\n    ],\n  ];\n\n  for (const [label, cmd, args] of steps) {\n    if (!runStep(label, cmd, args)) {\n      console.error(\"\\nquality:engine FAILED\");\n      process.exit(process.exitCode || 1);\n    }\n  }\n  console.log(\"\\nquality:engine ok\");\n}","isEmpty":false,"exceededLimit":false,"totalLines":83,"fileSize":2023,"path":"/Users/bolbiao/workspace/airpc-engine/scripts/engine-quality/quality-engine.mjs","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-3079f75d-45c2-44c3-9ed8-263521deb511-80\nfc_0e167b04-32d9-9ea9-8cbc-352e9385db6e_0","startedAtMs":"1784788661520","completedAtMs":"1784788661705"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-26-gm2q","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788661654}
