.ruleId === \"VOICEMAIL_CREATE_EFFECT\"),\n    ).toBe(true);\n  });\n});\n"}},"hookAdditionalContexts":[],"toolCallId":"call-98bfee21-8ff7-4d8c-86f4-9b8d25375643-40\nfc_408f52f1-e1a2-90be-8578-07538d015713_1","startedAtMs":"1784788322242"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-9-36us","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788322956}
