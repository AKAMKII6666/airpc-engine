ing_01.wav\",\n      status: \"unread\",","isEmpty":false,"exceededLimit":false,"totalLines":112,"fileSize":3417,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/schema/voicemail-schema.test.ts","readRange":{"startLine":1,"endLine":50},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-04da744d-db05-405f-8891-236300df66ae-32\nfc_cdfddbce-0f5e-931b-b1d4-beeb4b1fba30_1","startedAtMs":"1784788232241","completedAtMs":"1784788233184"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-7-gbgv","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788233126}
