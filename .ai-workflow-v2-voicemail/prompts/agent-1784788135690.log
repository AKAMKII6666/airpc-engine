\t\t\t);\n\t\t\tconst { CallCardDefinitionSchema } = await import(\"../../src/index.js\");\n\t\t\tconst port = createFsContentPort();\n\t\t\tconst bundle = await port.loadPackageForValidate({\n\t\t\t\tworkspaceKey: prepared.dataRoot,\n\t\t\t\tpackageId: VM_VALIDATE_PKG,\n\t\t\t});\n\t\t\tconst entry = bundle.cards.find(\n\t\t\t\t(c) => c.cardId === \"doubao_intro_outbound\",\n\t\t\t);\n\t\t\tconsole.log(\n\t\t\t\t\"DBG entry card null?\",\n\t\t\t\tentry?.card == null,\n\t\t\t\t\"raw kind\",\n\t\t\t\t(entry?.cardRaw as { cardKind?: string } | null)?.cardKind,\n\t\t\t\t\"reparse\",\n\t\t\t\tCallCardDefinitionSchema.safeParse(entry?.cardRaw).success,\n\t\t\t);\n\t\t\tif (entry?.cardRaw) {\n\t\t\t\tconst r = CallCardDefinitionSchema.safeParse(entry.cardRaw);\n\t\t\t\tif (!r.success) console.log(\"DBG issues\", r.error.issues.slice(0, 10));\n\t\t\t}\n\t\t}\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_INTERACTION_MODE\"),\n\t\t).toBe(true);\n\t\texpect(hasBlockingErrors(report)).toBe(true);\n\t});\n\n\tit(\"VOICEMAIL_ENTRY_MODE\", async () => {\n\t\tconst prepared = await prepareVmValidateWorkspace();\n\t\ttmpRoot = prepared.tmpRoot;\n\t\tawait mutateGoldenCard(prepared.dataRoot, (card) => {\n\t\t\tcard.cardKind = \"voicemail\";\n\t\t\tcard.interactionMode = \"playback_only\";\n\t\t\tcard.entryMode = \"outbound_auto\";\n\t\t\tcard.toolPolicy = { mode: \"deny_all\" };\n\t\t\tconst ctx = (card.context ?? {}) as Record<string, unknown>;\n\t\t\tctx.playbackClipId = \"clip_dummy\";\n\t\t\tcard.context = ctx;\n\t\t});\n\t\tconst report = await prepared.host.validatePackage(VM_VALIDATE_PKG);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_ENTRY_MODE\"),\n\t\t).toBe(true);\n\t});\n\n\tit(\"VOICEMAIL_TOOL_POLICY\", async () => {\n\t\tconst prepared = await prepareVmValidateWorkspace();\n\t\ttmpRoot = prepared.tmpRoot;\n\t\tawait mutateGoldenCard(prepared.dataRoot, (card) => {\n\t\t\tcard.cardKind = \"voicemail\";\n\t\t\tcard.interactionMode = \"playback_only\";\n\t\t\tcard.entryMode = \"mailbox_open\";\n\t\t\tcard.toolPolicy = { mode: \"inherit_free\" };\n\t\t});\n\t\tconst report = await prepared.host.validatePackage(VM_VALIDATE_PKG);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_TOOL_POLICY\"),\n\t\t).toBe(true);\n\t});\n});\n","message":"The file /Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/validation/voicemail-validate.modes.test.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"call-516c1f5a-04d7-4099-aee4-43c95e639455-75\nfc_f338327b-75b9-9b22-bf34-15120e791f8a_0","startedAtMs":"1784788643427","completedAtMs":"1784788644169"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-24-7mau","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788644146}
