ateEngineHost({\n\t\t\tpersist: false,\n\t\t\tcontent: createFsContentPort(),\n\t\t});\n\t\tawait host.loadWorkspace(dataRoot);\n\t\treturn { dataRoot, host };\n\t}\n\n\tasync function mutateCard(\n\t\tdataRoot: string,\n\t\tmutator: (card: Record<string, unknown>) => void,\n\t): Promise<void> {\n\t\tconst cardPath = path.join(dataRoot, CARD_REL);\n\t\tconst card = JSON.parse(await readFile(cardPath, \"utf8\")) as Record<\n\t\t\tstring,\n\t\t\tunknown\n\t\t>;\n\t\tmutator(card);\n\t\tawait writeFile(cardPath, JSON.stringify(card, null, 2));\n\t}\n\n\tit(\"合法 voicemail 组合无 VOICEMAIL_* / PLAYBACK_NO_ASSET\", async () => {\n\t\tconst { dataRoot, host } = await prepare();\n\t\tawait mutateCard(dataRoot, (card) => {\n\t\t\tcard.cardKind = \"voicemail\";\n\t\t\tcard.interactionMode = \"playback_only\";\n\t\t\tcard.entryMode = \"mailbox_open\";\n\t\t\tcard.toolPolicy = { mode: \"deny_all\" };\n\t\t\t// 无 playbackClipId：物化前合法\n\t\t\tconst ctx = (card.context ?? {}) as Record<string, unknown>;\n\t\t\tdelete ctx.playbackClipId;\n\t\t\tcard.context = ctx;\n\t\t});\n\t\tconst report = await host.validatePackage(PKG);\n\t\tconst vmErrors = report.errors.filter((e) =>\n\t\t\te.ruleId.startsWith(\"VOICEMAIL_\"),\n\t\t);\n\t\texpect(vmErrors).toEqual([]);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"PLAYBACK_NO_ASSET\"),\n\t\t).toBe(false);\n\t});\n\n\tit(\"VOICEMAIL_INTERACTION_MODE：非 playback_only\", async () => {\n\t\tconst { dataRoot, host } = await prepare();\n\t\tawait mutateCard(dataRoot, (card) => {\n\t\t\tcard.cardKind = \"voicemail\";\n\t\t\tcard.interactionMode = \"realtime_dialogue\";\n\t\t\tcard.entryMode = \"mailbox_open\";\n\t\t\tcard.toolPolicy = { mode: \"deny_all\" };\n\t\t});\n\t\tconst report = await host.validatePackage(PKG);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_INTERACTION_MODE\"),\n\t\t).toBe(true);\n\t\texpect(hasBlockingErrors(report)).toBe(true);\n\t});\n\n\tit(\"VOICEMAIL_ENTRY_MODE：非 mailbox_open\", async () => {\n\t\tconst { dataRoot, host } = await prepare();\n\t\tawait mutateCard(dataRoot, (card) => {\n\t\t\tcard.cardKind = \"voicemail\";\n\t\t\tcard.interactionMode = \"playback_only\";\n\t\t\tcard.entryMode = \"outbound_auto\";\n\t\t\tcard.toolPolicy = { mode: \"deny_all\" };\n\t\t\tconst ctx = (card.context ?? {}) as Record<string, unknown>;\n\t\t\tctx.playbackClipId = \"clip_dummy\";\n\t\t\tcard.context = ctx;\n\t\t});\n\t\tconst report = await host.validatePackage(PKG);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_ENTRY_MODE\"),\n\t\t).toBe(true);\n\t});\n\n\tit(\"VOICEMAIL_TOOL_POLICY：非 deny_all\", async () => {\n\t\tconst { dataRoot, host } = await prepare();\n\t\tawait mutateCard(dataRoot, (card) => {\n\t\t\tcard.cardKind = \"voicemail\";\n\t\t\tcard.interactionMode = \"playback_only\";\n\t\t\tcard.entryMode = \"mailbox_open\";\n\t\t\tcard.toolPolicy = { mode: \"inherit_free\" };\n\t\t});\n\t\tconst report = await host.validatePackage(PKG);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_TOOL_POLICY\"),\n\t\t).toBe(true);\n\t});\n\n\tit(\"VOICEMAIL_ENTRY_KIND：非 voicemail 使用 mailbox_open\", async () => {\n\t\tconst { dataRoot, host } = await prepare();\n\t\tawait mutateCard(dataRoot, (card) => {\n\t\t\tcard.cardKind = \"story\";\n\t\t\tcard.entryMode = \"mailbox_open\";\n\t\t\tcard.interactionMode = \"realtime_dialogue\";\n\t\t});\n\t\tconst report = await host.validatePackage(PKG);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_ENTRY_KIND\"),\n\t\t).toBe(true);\n\t});\n\n\tit(\"VOICEMAIL_CREATE_EFFECT：拒绝 create_voicemail\", async () => {\n\t\tconst { dataRoot, host } = await prepare();\n\t\tawait mutateCard(dataRoot, (card) => {\n\t\t\tconst exits = card.exits as Array<{\n\t\t\t\texitId: string;\n\t\t\t\teffects: Array<Record<string, unknown>>;\n\t\t\t}>;\n\t\t\tconst first = exits[0];\n\t\t\tif (!first) return;\n\t\t\tfirst.effects.push({\n\t\t\t\tid: \"fx_legacy_voicemail\",\n\t\t\t\teffect: \"create_voicemail\",\n\t\t\t\tagentId: \"doubao\",\n\t\t\t\ttopicHint: \"legacy\",\n\t\t\t});\n\t\t});\n\t\tconst report = await host.validatePackage(PKG);\n\t\texpect(\n\t\t\treport.errors.some((e) => e.ruleId === \"VOICEMAIL_CREATE_EFFECT\"),\n\t\t).toBe(true);\n\t\texpect(hasBlockingErrors(report)).toBe(true);\n\t});\n});\n"}}},"hookAdditionalContexts":[],"toolCallId":"call-e1413081-45e2-49de-b2db-90b125a01b65-54\nfc_2ddad5f9-41c6-9cae-a1fd-7da5e0a43e64_3","startedAtMs":"1784788474018","completedAtMs":"1784788474195"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-14-njus","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788474150}
{"type":"tool_call","subtype":"started","call_id":"call-e1413081-45e2-49de-b2db-90b125a01b65-55\nfc_2ddad5f9-41c6-9cae-a1fd-7da5e0a43e64_4","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/validation/package/voicemail.ts","streamContent":"/**\n * 废弃 create_voicemail：包内出现即 error，指引改为 attach/schedule 指向 voicemail 卡。\n * Schema 仍可解析该 effect 名，以便给出明确 ruleId 而非 SCHEMA_UNSUPPORTED。\n */\nexport function validateDeprecatedCreateVoicemail(\n\teffect: { id: string; effect: string },\n\tissuePath: string,\n\terrors: ValidationIssue[],\n): void {\n\tif (effect.effect !== \"create_voicemail\") return;\n\tpush(errors, {\n\t\truleId: \"VOICEMAIL_CREATE_EFFECT\",\n\t\tlevel: \"error\",\n\t\tpath: issuePath,\n\t\tmessage:\n\t\t\t\"create_voicemail 已废弃：请改用 attach_call_card / schedule_call_card 指向 cardKind=voicemail 卡\",\n\t});\n}\n\n/**\n * 普通 playback 卡缺片报错；voicemail 靠物化，允许无 playbackClipId。\n * 从 cards 循环抽出以降复杂度。\n */\nexport function validatePlaybackClipRequired(\n\tcard: CallCardDefinition,\n\tcardPath: string,\n\terrors: ValidationIssue[],\n): void {\n\tif (card.cardKind === \"voicemail\") return;\n\tconst isPlayback =\n\t\tcard.interactionMode === \"playback_only\" ||\n\t\tcard.entryMode === \"playback\";\n\tif (!isPlayback) return;\n\tconst ctx = card.context as { playbackClipId?: string } | undefined;\n\tif (ctx?.playbackClipId) return;\n\tpush(errors, {\n\t\truleId: \"PLAYBACK_NO_ASSET\",\n\t\tlevel: \"error\",\n\t\tpath: `${cardPath}#context`,\n\t\tmessage: \"playback card missing playbackClipId\",\n\t});\n}"}},"hookAdditionalContexts":[],"toolCallId":"call-e1413081-45e2-49de-b2db-90b125a01b65-55\nfc_2ddad5f9-41c6-9cae-a1fd-7da5e0a43e64_4","startedAtMs":"1784788475097"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-14-njus","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788475036}
