 {\n+\tif (!policy) return true;\n+\treturn policy.mode === \"deny_all\";\n+}\n+\n+/**\n+ * voicemail 强制 playback_only + mailbox_open + deny_all；\n+ * 非 voicemail 不得使用 mailbox_open（仅配对）。\n+ */\n+export function validateVoicemailCardModes(\n+\tcard: CallCardDefinition,\n+\tcardPath: string,\n+\terrors: ValidationIssue[],\n+): void {\n+\tif (card.cardKind === \"voicemail\") {\n+\t\tvalidateVoicemailForcedCombo(card, cardPath, errors);\n+\t\treturn;\n+\t}\n+\tif (card.entryMode === \"mailbox_open\") {\n+\t\tpush(errors, {\n+\t\t\truleId: \"VOICEMAIL_ENTRY_KIND\",\n+\t\t\tlevel: \"error\",\n+\t\t\tpath: `${cardPath}#entryMode`,\n+\t\t\tmessage:\n+\t\t\t\t\"entryMode=mailbox_open 仅允许 cardKind=voicemail；请改卡种或入口\",\n+\t\t});\n+\t}\n+}\n+\n+function validateVoicemailForcedCombo(\n+\tcard: CallCardDefinition,\n+\tcardPath: string,\n+\terrors: ValidationIssue[],\n+): void {\n+\tif (card.interactionMode !== \"playback_only\") {\n+\t\tpush(errors, {\n+\t\t\truleId: \"VOICEMAIL_INTERACTION_MODE\",\n+\t\t\tlevel: \"error\",\n+\t\t\tpath: `${cardPath}#interactionMode`,\n+\t\t\tmessage:\n+\t\t\t\t\"cardKind=voicemail 必须 interactionMode=playback_only（Studio 锁定）\",\n+\t\t});\n+\t}\n+\tif (card.entryMode !== \"mailbox_open\") {\n+\t\tpush(errors, {\n+\t\t\truleId: \"VOICEMAIL_ENTRY_MODE\",\n+\t\t\tlevel: \"error\",\n+\t\t\tpath: `${cardPath}#entryMode`,\n+\t\t\tmessage:\n+\t\t\t\t\"cardKind=voicemail 必须 entryMode=mailbox_open（信箱打开）\",\n+\t\t});\n+\t}\n+\tif (!isDenyAllEquivalent(card.toolPolicy)) {\n+\t\tpush(errors, {\n+\t\t\truleId: \"VOICEMAIL_TOOL_POLICY\",\n+\t\t\tlevel: \"error\",\n+\t\t\tpath: `${cardPath}#toolPolicy`,\n+\t\t\tmessage:\n+\t\t\t\t\"cardKind=voicemail 必须 toolPolicy 等价 deny_all（与 playback_only 一致）\",\n+\t\t});\n+\t}\n+}\n+\n+/**\n+ * 废弃 create_voicemail：包内出现即 error，指引改为 attach/schedule 指向 voicemail 卡。\n+ * Schema 仍可解析该 effect 名，以便给出明确 ruleId 而非 SCHEMA_UNSUPPORTED。\n+ */\n+export function validateDeprecatedCreateVoicemail(\n+\teffect: { id: string; effect: string },\n+\tissuePath: string,\n+\terrors: ValidationIssue[],\n+): void {\n+\tif (effect.effect !== \"create_voicemail\") return;\n+\tpush(errors, {\n+\t\truleId: \"VOICEMAIL_CREATE_EFFECT\",\n+\t\tlevel: \"error\",\n+\t\tpath: issuePath,\n+\t\tmessage:\n+\t\t\t\"create_voicemail 已废弃：请改用 attach_call_card / schedule_call_card 指向 cardKind=voicemail 卡\",\n+\t});\n+}","afterFullFileContent":"/**\n * 模块名称：validatePackage 语音留言（voicemail）规则\n * 模块说明：强制 cardKind=voicemail 的 mode 组合；废弃 create_voicemail Effect。\n * 需求：语音留言改造 §3.1–§3.3；执行索引 V2-VM-3。\n */\nimport type { CallCardDefinition } from \"../../schema/callCard.js\";\nimport type { ValidationIssue } from \"../types.js\";\n\nfunction push(list: ValidationIssue[], issue: ValidationIssue): void {\n\tlist.push(issue);\n}\n\n/** toolPolicy 等价 deny_all：缺省或显式 deny_all（禁止 allowlist / inherit_free） */\nfunction isDenyAllEquivalent(\n\tpolicy: CallCardDefinition[\"toolPolicy\"],\n): boolean {\n\tif (!policy) return true;\n\treturn policy.mode === \"deny_all\";\n}\n\n/**\n * voicemail 强制 playback_only + mailbox_open + deny_all；\n * 非 voicemail 不得使用 mailbox_open（仅配对）。\n */\nexport function validateVoicemailCardModes(\n\tcard: CallCardDefinition,\n\tcardPath: string,\n\terrors: ValidationIssue[],\n): void {\n\tif (card.cardKind === \"voicemail\") {\n\t\tvalidateVoicemailForcedCombo(card, cardPath, errors);\n\t\treturn;\n\t}\n\tif (card.entryMode === \"mailbox_open\") {\n\t\tpush(errors, {\n\t\t\truleId: \"VOICEMAIL_ENTRY_KIND\",\n\t\t\tlevel: \"error\",\n\t\t\tpath: `${cardPath}#entryMode`,\n\t\t\tmessage:\n\t\t\t\t\"entryMode=mailbox_open 仅允许 cardKind=voicemail；请改卡种或入口\",\n\t\t});\n\t}\n}\n\nfunction validateVoicemailForcedCombo(\n\tcard: CallCardDefinition,\n\tcardPath: string,\n\terrors: ValidationIssue[],\n): void {\n\tif (card.interactionMode !== \"playback_only\") {\n\t\tpush(errors, {\n\t\t\truleId: \"VOICEMAIL_INTERACTION_MODE\",\n\t\t\tlevel: \"error\",\n\t\t\tpath: `${cardPath}#interactionMode`,\n\t\t\tmessage:\n\t\t\t\t\"cardKind=voicemail 必须 interactionMode=playback_only（Studio 锁定）\",\n\t\t});\n\t}\n\tif (card.entryMode !== \"mailbox_open\") {\n\t\tpush(errors, {\n\t\t\truleId: \"VOICEMAIL_ENTRY_MODE\",\n\t\t\tlevel: \"error\",\n\t\t\tpath: `${cardPath}#entryMode`,\n\t\t\tmessage:\n\t\t\t\t\"cardKind=voicemail 必须 entryMode=mailbox_open（信箱打开）\",\n\t\t});\n\t}\n\tif (!isDenyAllEquivalent(card.toolPolicy)) {\n\t\tpush(errors, {\n\t\t\truleId: \"VOICEMAIL_TOOL_POLICY\",\n\t\t\tlevel: \"error\",\n\t\t\tpath: `${cardPath}#toolPolicy`,\n\t\t\tmessage:\n\t\t\t\t\"cardKind=voicemail 必须 toolPolicy 等价 deny_all（与 playback_only 一致）\",\n\t\t});\n\t}\n}\n\n/**\n * 废弃 create_voicemail：包内出现即 error，指引改为 attach/schedule 指向 voicemail 卡。\n * Schema 仍可解析该 effect 名，以便给出明确 ruleId 而非 SCHEMA_UNSUPPORTED。\n */\nexport function validateDeprecatedCreateVoicemail(\n\teffect: { id: string; effect: string },\n\tissuePath: string,\n\terrors: ValidationIssue[],\n): void {\n\tif (effect.effect !== \"create_voicemail\") return;\n\tpush(errors, {\n\t\truleId: \"VOICEMAIL_CREATE_EFFECT\",\n\t\tlevel: \"error\",\n\t\tpath: issuePath,\n\t\tmessage:\n\t\t\t\"create_voicemail 已废弃：请改用 attach_call_card / schedule_call_card 指向 cardKind=voicemail 卡\",\n\t});\n}\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/validation/package/voicemail.ts"}}},"hookAdditionalContexts":[],"toolCallId":"call-0095b4df-a2a1-4722-9347-47277b66cf82-34\nfc_8f8d8937-70a9-98c0-b21d-f6b326a680e2_0","startedAtMs":"1784788246879","completedAtMs":"1784788247324"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-8-dq06","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788247273}
{"type":"tool_call","subtype":"started","call_id":"call-0095b4df-a2a1-4722-9347-47277b66cf82-35\nfc_8f8d8937-70a9-98c0-b21d-f6b326a680e2_1","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/validation/package/cards.ts","streamContent":"import { validateToolPolicy } from \"./toolPolicy.js\";\nimport {\n\tvalidateDeprecatedCreateVoicemail,\n\tvalidateVoicemailCardModes,\n} from \"./voicemail.js\";\n\nconst KNOWN_EFFECTS = new Set<string>(KNOWN_EFFECT_NAMES);"}},"hookAdditionalContexts":[],"toolCallId":"call-0095b4df-a2a1-4722-9347-47277b66cf82-35\nfc_8f8d8937-70a9-98c0-b21d-f6b326a680e2_1","startedAtMs":"1784788250965"},"model_call_id":"b389604d-3268-439e-80f5-928ecb5767ac-8-dq06","session_id":"3bb78126-6129-463f-92ce-cf543f7b8658","timestamp_ms":1784788250932}
