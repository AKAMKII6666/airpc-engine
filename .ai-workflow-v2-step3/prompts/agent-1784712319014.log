n\t\t\t\t</div>\n\t\t\t\t{/* 引用了WorkbenchSideCol组件，用于右侧工程状态与调试 mock */}\n\t\t\t\t<WorkbenchSideCol />\n\t\t\t</div>\n\t\t</main>\n\t);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":51,"fileSize":1866,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/home/WorkbenchShell.tsx","readRange":{"startLine":1,"endLine":51},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_1e74e2c2-d4ec-4db5-bb8b-35d7ed2981b","startedAtMs":"1784712395518","completedAtMs":"1784712395782"},"model_call_id":"6f555e41-da79-4bdb-bf1b-d59e02fe117a-8-ewzq","session_id":"d97da1b1-636d-4283-93dc-a19e3cbaa29a","timestamp_ms":1784712395648}
