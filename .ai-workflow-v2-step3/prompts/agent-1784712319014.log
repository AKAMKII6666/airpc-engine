2\">正在从磁盘加载故事包…</Typography>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t);\n\t}\n\n\tif (loadError || !graphSeed || !bundle) {\n\t\treturn (\n\t\t\t<div className={styles.root}>\n\t\t\t\t{/* 引用了Alert组件，用于加载失败提示 */}\n\t\t\t\t<Alert severity=\"error\" className={styles.loadError}>\n\t\t\t\t\t{loadError ?? \"无法加载故事包\"}\n\t\t\t\t</Alert>\n\t\t\t</div>\n\t\t);\n\t}\n\n\treturn (\n\t\t<div className={styles.root}>\n\t\t\t{/* 引用了StoryEditorTopBar组件，用于顶栏包名与保存 */}\n\t\t\t<StoryEditorTopBar\n\t\t\t\tpackageTitle={shell.packageTitle}\n\t\t\t\tchapterTitle={bundle.conf.title ?? \"章节\"}\n\t\t\t\tsaveState={saveState}\n\t\t\t\tsaveError={saveError}\n\t\t\t\tonSave={function () {\n\t\t\t\t\tvoid onSave();\n\t\t\t\t}}\n\t\t\t/>\n\t\t\t<div className={styles.body}>\n\t\t\t\t{/* 引用了StoryEditorCanvasLayer组件，用于画布与浮窗叠层 */}\n\t\t\t\t<StoryEditorCanvasLayer\n\t\t\t\t\tpackageId={packageId}\n\t\t\t\t\tgraphSeed={graphSeed}\n\t\t\t\t\tbundle={bundle}\n\t\t\t\t\tselection={shell.selection}\n\t\t\t\t\tassetFloat={shell.assetFloat}\n\t\t\t\t\tpackageFloat={shell.packageFloat}\n\t\t\t\t\tassets={assetForms.assets}\n\t\t\t\t\tcharacterAnchors={shell.characterAnchors}\n\t\t\t\t\teffectPanelSources={shell.effectPanelSources}\n\t\t\t\t\tchapterDiskCtx={shell.chapterDiskCtx}","isEmpty":false,"exceededLimit":false,"totalLines":121,"fileSize":4659,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/StoryEditorShell.tsx","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_bf389df8-32ee-43f2-8c9e-482f9c905d1","startedAtMs":"1784712382039","completedAtMs":"1784712382237"},"model_call_id":"6f555e41-da79-4bdb-bf1b-d59e02fe117a-7-qjfu","session_id":"d97da1b1-636d-4283-93dc-a19e3cbaa29a","timestamp_ms":1784712382218}
