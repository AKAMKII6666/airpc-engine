hy组件，用于章节与状态副标题 */}\n\t\t\t\t\t<Typography variant=\"caption\" className={styles.chapter}>\n\t\t\t\t\t\t{chapterTitle} · {saveStateLabel(saveState)}\n\t\t\t\t\t\t{saveError ? ` · ${saveError}` : \"\"} · 校验正常\n\t\t\t\t\t</Typography>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div className={styles.actions}>\n\t\t\t\t{/* 引用了Button组件，用于整包保存 */}\n\t\t\t\t<Button\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tvariant=\"contained\"\n\t\t\t\t\tcolor=\"primary\"\n\t\t\t\t\tdisabled={saveDisabled || saveState === \"saving\"}\n\t\t\t\t\tonClick={onSave}\n\t\t\t\t>\n\t\t\t\t\t保存\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于搜索占位 */}\n\t\t\t\t<Button size=\"small\" variant=\"text\" disabled>\n\t\t\t\t\t搜索\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于视图占位 */}\n\t\t\t\t<Button size=\"small\" variant=\"text\" disabled>\n\t\t\t\t\t视图\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于跳转导出页 */}\n\t\t\t\t<Button\n\t\t\t\t\tcomponent={Link}\n\t\t\t\t\thref=\"/packages/export\"\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tvariant=\"outlined\"\n\t\t\t\t>\n\t\t\t\t\t导出\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于跳转调试器 */}\n\t\t\t\t<Button component={Link} href=\"/debugger\" size=\"small\" variant=\"contained\">\n\t\t\t\t\t运行调试\n\t\t\t\t</Button>\n\t\t\t</div>\n\t\t</header>\n\t);\n};\n","message":"The file /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/StoryEditorTopBar.tsx has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"tool_5fa9c872-8108-4ff1-a37d-7fb1cd615b2","startedAtMs":"1784712174480","completedAtMs":"1784712174857"},"model_call_id":"21e69b80-135a-4cb4-88fc-fe6f84256357-22-8odb","session_id":"09de13b4-00ac-4b19-bfbf-a7c4bebb862d","timestamp_ms":1784712174720}
