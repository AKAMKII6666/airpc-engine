{"type":"tool_call","subtype":"completed","call_id":"tool_2731e191-2b2f-4427-ac67-f22bf36a079","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/io/loadStoryPackage_bis.ts","streamContent":"import { bundleToEditorGraph } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\nimport { fetchCharacterDefs } from \"@studio-v2/src/utils/ajaxProxy/library/api/charactersApi\";\nimport { fetchDiskStoryPackage } from \"@studio-v2/src/utils/ajaxProxy/packages/api/storiesApi\";\nimport type { CharacterDisplayLookup } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\nimport type { EditorGraphSeed } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/io/loadStoryPackage_bis.ts","linesAdded":3,"linesRemoved":3,"diffString":"--- a//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/io/loadStoryPackage_bis.ts\n+++ b//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/io/loadStoryPackage_bis.ts\n@@ -1,11 +1,11 @@\n /**\n \t* 编辑器打开：读盘整包 + 角色 displayName + 画布 seed。\n \t*/\n-import { bundleToEditorGraph } from \"@studio-v2/src/bis/pageBis/storyEditor/package/diskBundleGraph\";\n+import { bundleToEditorGraph } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\n import { fetchCharacterDefs } from \"@studio-v2/src/utils/ajaxProxy/library/api/charactersApi\";\n import { fetchDiskStoryPackage } from \"@studio-v2/src/utils/ajaxProxy/packages/api/storiesApi\";\n-import type { CharacterDisplayLookup } from \"@studio-v2/src/bis/pageBis/storyEditor/package/diskBundleGraph\";\n-import type { EditorGraphSeed } from \"@studio-v2/src/bis/pageBis/storyEditor/package/diskBundleGraph\";\n+import type { CharacterDisplayLookup } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\n+import type { EditorGraphSeed } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\n import type { DiskStoryPackageBundle } from \"@studio-v2/typeFiles/story/package/diskStoryPackage\";\n \n /** 编辑器打开故事包后的会话载荷；bundle 为磁盘真源，graphSeed 为画布初始投影 */","beforeFullFileContent":"/**\n\t* 编辑器打开：读盘整包 + 角色 displayName + 画布 seed。\n\t*/\nimport { bundleToEditorGraph } from \"@studio-v2/src/bis/pageBis/storyEditor/package/diskBundleGraph\";\nimport { fetchCharacterDefs } from \"@studio-v2/src/utils/ajaxProxy/library/api/charactersApi\";\nimport { fetchDiskStoryPackage } from \"@studio-v2/src/utils/ajaxProxy/packages/api/storiesApi\";\nimport type { CharacterDisplayLookup } from \"@studio-v2/src/bis/pageBis/storyEditor/package/diskBundleGraph\";\nimport type { EditorGraphSeed } from \"@studio-v2/src/bis/pageBis/storyEditor/package/diskBundleGraph\";\nimport type { DiskStoryPackageBundle } from \"@studio-v2/typeFiles/story/package/diskStoryPackage\";\n\n/** 编辑器打开故事包后的会话载荷；bundle 为磁盘真源，graphSeed 为画布初始投影 */\nexport type LoadedStoryPackageSession = {\n\t/** 当前打开的磁盘整包；保存时作为 baseBundle */\n\tbundle: DiskStoryPackageBundle;\n\t/** 由 bundle 投影的 React Flow 初始图；会话内可编辑 */\n\tgraphSeed: EditorGraphSeed;\n};\n\nasync function buildCharacterNameLookup(\n\tparticipants: readonly string[],\n): Promise<CharacterDisplayLookup> {\n\tconst lookup: Record<string, { displayName: string }> = {};\n\ttry {\n\t\tconst defs = await fetchCharacterDefs();\n\t\tfor (const def of defs) {\n\t\t\tconst name = def.displayName?.trim() || def.agentId;\n\t\t\tlookup[def.agentId] = { displayName: name };\n\t\t}\n\t} catch {\n\t\tfor (const agentId of participants) {\n\t\t\tlookup[agentId] = { displayName: agentId };\n\t\t}\n\t\treturn lookup;\n\t}\n\tfor (const agentId of participants) {\n\t\tif (!lookup[agentId]) {\n\t\t\tlookup[agentId] = { displayName: agentId };\n\t\t}\n\t}\n\treturn lookup;\n}\n\n/** GET /api/stories/:id 并投影画布初始图 */\nexport async function loadStoryPackageForEditor(\n\tpackageId: string,\n): Promise<LoadedStoryPackageSession> {\n\tconst bundle = await fetchDiskStoryPackage(packageId);\n\tconst names = await buildCharacterNameLookup(bundle.conf.participants);\n\tconst graphSeed = bundleToEditorGraph(bundle, names);\n\treturn { bundle, graphSeed };\n}\n","afterFullFileContent":"/**\n\t* 编辑器打开：读盘整包 + 角色 displayName + 画布 seed。\n\t*/\nimport { bundleToEditorGraph } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\nimport { fetchCharacterDefs } from \"@studio-v2/src/utils/ajaxProxy/library/api/charactersApi\";\nimport { fetchDiskStoryPackage } from \"@studio-v2/src/utils/ajaxProxy/packages/api/storiesApi\";\nimport type { CharacterDisplayLookup } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\nimport type { EditorGraphSeed } from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph\";\nimport type { DiskStoryPackageBundle } from \"@studio-v2/typeFiles/story/package/diskStoryPackage\";\n\n/** 编辑器打开故事包后的会话载荷；bundle 为磁盘真源，graphSeed 为画布初始投影 */\nexport type LoadedStoryPackageSession = {\n\t/** 当前打开的磁盘整包；保存时作为 baseBundle */\n\tbundle: DiskStoryPackageBundle;\n\t/** 由 bundle 投影的 React Flow 初始图；会话内可编辑 */\n\tgraphSeed: EditorGraphSeed;\n};\n\nasync function buildCharacterNameLookup(\n\tparticipants: readonly string[],\n): Promise<CharacterDisplayLookup> {\n\tconst lookup: Record<string, { displayName: string }> = {};\n\ttry {\n\t\tconst defs = await fetchCharacterDefs();\n\t\tfor (const def of defs) {\n\t\t\tconst name = def.displayName?.trim() || def.agentId;\n\t\t\tlookup[def.agentId] = { displayName: name };\n\t\t}\n\t} catch {\n\t\tfor (const agentId of participants) {\n\t\t\tlookup[agentId] = { displayName: agentId };\n\t\t}\n\t\treturn lookup;\n\t}\n\tfor (const agentId of participants) {\n\t\tif (!lookup[agentId]) {\n\t\t\tlookup[agentId] = { displayName: agentId };\n\t\t}\n\t}\n\treturn lookup;\n}\n\n/** GET /api/stories/:id 并投影画布初始图 */\nexport async function loadStoryPackageForEditor(\n\tpackageId: string,\n): Promise<LoadedStoryPackageSession> {\n\tconst bundle = await fetchDiskStoryPackage(packageId);\n\tconst names = await buildCharacterNameLookup(bundle.conf.participants);\n\tconst graphSeed = bundleToEditorGraph(bundle, names);\n\treturn { bundle, graphSeed };\n}\n","message":"The file /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/io/loadStoryPackage_bis.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"tool_2731e191-2b2f-4427-ac67-f22bf36a079","startedAtMs":"1784712168772","completedAtMs":"1784712169321"},"model_call_id":"21e69b80-135a-4cb4-88fc-fe6f84256357-21-thj1","session_id":"09de13b4-00ac-4b19-bfbf-a7c4bebb862d","timestamp_ms":1784712169182}
