2\">正在从磁盘加载故事包…</Typography>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t);\n\t}\n\n\tif (loadError || !graphSeed || !bundle) {\n\t\treturn (\n\t\t\t<div className={styles.root}>\n\t\t\t\t{/* 引用了Alert组件，用于加载失败提示 */}\n\t\t\t\t<Alert severity=\"error\" className={styles.loadError}>\n\t\t\t\t\t{loadError ?? \"无法加载故事包\"}\n\t\t\t\t</Alert>\n\t\t\t</div>\n\t\t);\n\t}\n\n\treturn (\n\t\t<div className={styles.root}>\n\t\t\t{/* 引用了StoryEditorTopBar组件，用于顶栏包名与保存 */}\n\t\t\t<StoryEditorTopBar\n\t\t\t\tpackageTitle={shell.packageTitle}\n\t\t\t\tchapterTitle={bundle.conf.title ?? \"章节\"}\n\t\t\t\tsaveState={saveState}\n\t\t\t\tsaveError={saveError}\n\t\t\t\tonSave={function () {\n\t\t\t\t\tvoid onSave();\n\t\t\t\t}}\n\t\t\t/>\n\t\t\t<div className={styles.body}>\n\t\t\t\t{/* 引用了StoryEditorCanvasLayer组件，用于画布与浮窗叠层 */}\n\t\t\t\t<StoryEditorCanvasLayer\n\t\t\t\t\tpackageId={packageId}\n\t\t\t\t\tgraphSeed={graphSeed}\n\t\t\t\t\tbundle={bundle}\n\t\t\t\t\tselection={shell.selection}\n\t\t\t\t\tassetFloat={shell.assetFloat}\n\t\t\t\t\tpackageFloat={shell.packageFloat}\n\t\t\t\t\tassets={assetForms.assets}\n\t\t\t\t\tcharacterAnchors={shell.characterAnchors}\n\t\t\t\t\teffectPanelSources={shell.effectPanelSources}\n\t\t\t\t\tchapterDiskCtx={shell.chapterDiskCtx}","isEmpty":false,"exceededLimit":false,"totalLines":121,"fileSize":4659,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/StoryEditorShell.tsx","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_1a13383c-7bf9-45f1-9f77-8e58c6f6134","startedAtMs":"1784710604730","completedAtMs":"1784710604959"},"model_call_id":"d22e785a-7447-4382-9fc1-1b8b1b098c30-7-p4mm","session_id":"ee6bc1ff-4c7b-4cdd-8d6e-d4c1f8175047","timestamp_ms":1784710604884}
