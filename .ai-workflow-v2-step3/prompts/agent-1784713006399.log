em.id} className={styles.statusItem}>\n              <span className={styles.statusLabel}>\n                <span className={workbenchBadgeClass(item.level)}>\n                  {validationLabel(item.level)}\n                </span>{\" \"}\n                {item.label}\n              </span>\n              <span className={styles.statusDetail}>{item.detail}</span>\n            </li>\n          ))}\n        </ul>\n        <Button\n          component={Link}\n          href=\"/settings\"\n          size=\"small\"\n          sx={{ mt: 1, px: 0 }}\n        >\n          打开校验报告 / 工程状态\n        </Button>\n      </section>\n\n      <section className={styles.panel} aria-labelledby=\"recent-debug-title\">\n        <h3 id=\"recent-debug-title\" className={styles.panelTitle}>\n          最近调试\n        </h3>\n        {MOCK_RECENT_DEBUGS.map((d) => (\n          <div key={d.sessionId} className={styles.debugItem}>\n            <div className={styles.debugTitle}>{d.packageTitle}</div>","isEmpty":false,"exceededLimit":false,"totalLines":101,"fileSize":3274,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/home/WorkbenchSideCol.tsx","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_b12d90e8-7b1a-4147-a253-2a2b9eaec1e","startedAtMs":"1784713040997","completedAtMs":"1784713041226"},"model_call_id":"d89841fd-457a-49fa-8413-4e377e0e924f-4-y6vm","session_id":"8e98fde1-c0c8-4bb2-b54f-b1d682a97d99","timestamp_ms":1784713041098}
