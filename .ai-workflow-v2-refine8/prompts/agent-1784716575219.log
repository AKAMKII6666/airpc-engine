{"type":"tool_call","subtype":"completed","call_id":"call-fb7cab27-bb2d-459c-ac28-7f5db57c3044-25\nfc_025aceac-9dc4-9dc4-b1cc-fd9eaf06d8c1_4","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/schema/callCard.ts","limit":80},"result":{"success":{"content":"/**\n * 模块名称：CallCard Zod（S7：核心枚举收紧；V2：ScheduleCard）\n *\n * 存放约定：\n * - StoryCard → storis-packages/<pkg>/cards/\n * - FreeCard → characters/free-cards/\n * - ScheduleCard → characters/schedule-cards/（角色侧日常调度卡；非剧情循环节点）\n */\nimport { z } from \"zod\";\nimport { EffectSchema, ExitConditionSchema } from \"./outcome.js\";\nimport { PromptSceneLayerSchema } from \"./promptScene.js\";\n\nexport const EntryModeSchema = z.enum([\n  \"inbound_user_dial\",\n  \"outbound_auto\",\n  \"either\",\n  /** 等价别名（Composer / 历史包） */\n  \"inbound\",\n  \"outbound\",\n  \"agent_outbound\",\n  /** 历史：playback 曾写在 entryMode */\n  \"playback\",\n]);\n\nexport const InteractionModeSchema = z.enum([\n  \"realtime_dialogue\",\n  \"playback_only\",\n  \"hybrid\",\n]);\n\nexport const CardKindSchema = z.enum([\"story\", \"free\", \"system\", \"schedule\"]);\n\nexport const ExitKindSchema = z.enum([\n  \"handoff\",\n  \"callback\",\n  \"recovery\",\n  \"failure\",\n  \"terminal\",\n  /** 运行时动态出口；内容 JSON 勿手写 */\n  \"dynamic\",\n]);\n\nexport const ToolPolicySchema = z.object({\n  mode: z.enum([\"inherit_free\", \"allowlist\", \"deny_all\"]),\n  allowedToolIds: z.array(z.string()).optional(),\n});\n\nexport const CallCardExitSchema = z.object({\n  exitId: z.string(),\n  exitKind: ExitKindSchema.optional(),\n  title: z.string().optional(),\n  priority: z.number().default(0),\n  condition: ExitConditionSchema,\n  effects: z.array(EffectSchema).default([]),\n});\n\nexport const CallCardContextSchema = z\n  .object({\n    privateBrief: z.string().optional(),\n    speakableBrief: z.string().optional(),\n    background: z.string().optional(),\n    premise: z.string().optional(),\n    emotion: z.string().optional(),\n    objective: z.string().optional(),\n    forbidden: z.array(z.string()).optional(),\n    promptScenes: z.array(PromptSceneLayerSchema).optional(),\n    playbackClipId: z.string().optional(),\n  })\n  .passthrough();\n\n/**\n * ScheduleCard = FreeCard 超集：同为 CallCard，额外带调度元信息。\n * v1 允许缺省部分字段；物化 recurring 时仍须能解析到本卡。\n */\nexport const ScheduleMetaSchema = z\n  .object({\n    mode: z.enum([\"daily\", \"weekly\"]).optional(),\n    hour: z.number().int().min(0).max(23).optional(),\n    minute: z.number().int().min(0).max(59).optional(),\n    weekdays: z.array(z.number().int().min(0).max(6)).optional(),","isEmpty":false,"exceededLimit":false,"totalLines":151,"fileSize":4827,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/schema/callCard.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-fb7cab27-bb2d-459c-ac28-7f5db57c3044-25\nfc_025aceac-9dc4-9dc4-b1cc-fd9eaf06d8c1_4","startedAtMs":"1784716629242","completedAtMs":"1784716629413"},"model_call_id":"e8f0e443-2f8a-4251-871d-51f79a3ac428-5-sv2a","session_id":"eacc12ed-f499-44ba-b456-b70f5f1f7aa9","timestamp_ms":1784716629378}
