频类 |","contentTruncated":false,"isContextLine":false},{"lineNumber":53,"content":"| `ASSET_PACKAGE_INLINE` | warning | 包内出现完整 assets[] 内联（应迁全局库） |","contentTruncated":false,"isContextLine":false},{"lineNumber":66,"content":"- [x] `ASSET_URI_MISSING` 硬拦（meta 存在但 `uri` 文件缺失）；见 `VALIDATE_PACKAGE_ERROR_COVERAGE.covered`","contentTruncated":false,"isContextLine":false},{"lineNumber":67,"content":"- [x] warning 主路径进 coverage：`CARD_FILE_ORPHAN`／`EXIT_*`／`TOOL_INTRODUCE_GUARD`／`ASSET_KIND_MISMATCH`／`NARRATIVE_NEEDS_NO_FREE`／`ASSET_PACKAGE_INLINE`","contentTruncated":false,"isContextLine":false}]}],"totalLines":13,"totalMatchedLines":13,"clientTruncated":false,"ripgrepTruncated":false}}}}}},"hookAdditionalContexts":[],"toolCallId":"call-c164399f-b920-4d10-a8ee-a2b35e75e9ea-51\nfc_3005d63a-8cc4-97b7-8327-89344abf475c_4","startedAtMs":"1784770056139","completedAtMs":"1784770056349"},"model_call_id":"3bb1eaa0-dc1e-4666-b7a1-f546fede52a6-4-ssns","session_id":"13d95b2c-2da1-4bb3-a463-cffe162be1c5","timestamp_ms":1784770056302}
{"type":"tool_call","subtype":"completed","call_id":"call-c164399f-b920-4d10-a8ee-a2b35e75e9ea-47\nfc_3005d63a-8cc4-97b7-8327-89344abf475c_0","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/assets/assetsFs.server.ts","limit":80},"result":{"success":{"content":"/**\n\t* 全局资产库读写：data/assets/meta/<assetId>.json + files/。\n\t* 仅 Next API 门面调用；禁止 client 直引。真源口径见需求 14。\n\t*/\nimport {\n\taccess,\n\tmkdir,\n\treaddir,\n\treadFile,\n\tstat,\n\tunlink,\n\twriteFile,\n} from \"node:fs/promises\";\nimport path from \"node:path\";\nimport type { AssetMeta } from \"@airpc/rpg-engine\";\nimport { getStudioV2DataRoot } from \"../data/dataRoot.server\";\n\n/** assetId：小写开头，允许数字 / _ / -；与 createStudioId(\"asset\") 及既有 clip_* 对齐 */\nconst ASSET_ID_RE = /^[a-z][a-z0-9_-]{0,63}$/;\n\nexport function isValidAssetId(assetId: string): boolean {\n\treturn ASSET_ID_RE.test(assetId);\n}\n\nfunction assetsRoot(): string {\n\treturn path.join(getStudioV2DataRoot(), \"assets\");\n}\n\nfunction metaRoot(): string {\n\treturn path.join(assetsRoot(), \"meta\");\n}\n\nfunction metaPath(assetId: string): string {\n\treturn path.join(metaRoot(), `${assetId}.json`);\n}\n\nasync function pathExists(p: string): Promise<boolean> {\n\ttry {\n\t\tawait access(p);\n\t\treturn true;\n\t} catch {\n\t\treturn false;\n\t}\n}\n\n/**\n\t* 解析 uri 相对 data/assets/ 的绝对路径；拒绝越界。\n\t*/\nexport function resolveAssetFilePath(uri: string): string {\n\tconst uriRel = uri.replace(/^\\.?\\//, \"\");\n\tif (\n\t\turiRel.includes(\"..\") ||\n\t\tpath.isAbsolute(uriRel) ||\n\t\turiRel.startsWith(\"~\")\n\t) {\n\t\tthrow Object.assign(new Error(`asset uri escapes assets root: ${uri}`), {\n\t\t\tcode: \"VALIDATION_FAILED\",\n\t\t});\n\t}\n\treturn path.join(assetsRoot(), uriRel);\n}\n\n/**\n\t* 列出 meta/*.json 对应的 assetId（跳过破损文件名）。\n\t*/\nexport async function listAssetIds(): Promise<string[]> {\n\tconst root = metaRoot();\n\tif (!(await pathExists(root))) {\n\t\treturn [];\n\t}\n\tconst names = await readdir(root);\n\tconst out: string[] = [];\n\tfor (const name of names) {\n\t\tif (!name.endsWith(\".json\")) continue;\n\t\tconst assetId = name.slice(0, -\".json\".length);\n\t\tif (!isValidAssetId(assetId)) continue;\n\t\tout.push(assetId);\n\t}\n\treturn out.sort(function (a, b) {\n\t\treturn a.localeCompare(b);","isEmpty":false,"exceededLimit":false,"totalLines":209,"fileSize":5296,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/assets/assetsFs.server.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-c164399f-b920-4d10-a8ee-a2b35e75e9ea-47\nfc_3005d63a-8cc4-97b7-8327-89344abf475c_0","startedAtMs":"1784770056128","completedAtMs":"1784770056351"},"model_call_id":"3bb1eaa0-dc1e-4666-b7a1-f546fede52a6-4-ssns","session_id":"13d95b2c-2da1-4bb3-a463-cffe162be1c5","timestamp_ms":1784770056304}
{"type":"tool_call","subtype":"completed","call_id":"call-c164399f-b920-4d10-a8ee-a2b35e75e9ea-48\nfc_3005d63a-8cc4-97b7-8327-89344abf475c_1","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/typeFiles/story/editor/callCard/editorEffectParams.ts","limit":120},"result":{"success":{"content":"/**\n\t* 出口 Effect 参数投影：按 effect 判别的会话 mock 联合。\n\t* 字段名与「必填」意图对齐引擎 effectExecutor.ts 读取（只读镜像，禁 import 引擎值）。\n\t* 仅内存 UI 投影；不写 storis-packages / Host；缺省字段等同「未配置」，前端仅角标提示。\n\t*/\nimport type { KnownEffectName } from \"@airpc/rpg-engine\";\nimport type { EditorEntryMode } from \"@studio-v2/typeFiles/story/editor/callCard/editorCallCardProjection\";\nimport type { CallCardLabelOption } from \"@studio-v2/typeFiles/story/callCardLabels\";\n\n/** set_character_unlocked：解锁/可拨某角色，写用户 Profile 解锁位 */\nexport type SetCharacterUnlockedParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"set_character_unlocked\";\n\t/** 目标角色 agentId；取画布锚点，必填（缺省仅角标提示） */\n\tagentId?: string;\n\t/** 是否解锁；缺省语义等同引擎默认 true */\n\tunlocked?: boolean;\n};\n\n/** attach_call_card：向角色待办板挂一张待处理卡（连线子型，边见 §2.3） */\nexport type AttachCallCardParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"attach_call_card\";\n\t/** 归属角色 agentId；默认取 target 卡归属，可覆盖 */\n\tagentId?: string;\n\t/** 被挂载的卡 cardId；取画布 CallCard 节点，必填 */\n\tcardId?: string;\n\t/** 归属故事包 id；缺省沿用当前会话包 */\n\tpackageId?: string;\n\t/** 入口模式；写入 pending 卡的 entryMode，缺省表示不指定 */\n\tactivation?: EditorEntryMode;\n};\n\n/** set_redial_slot：设定「重拨」默认接通的角色（及可选卡） */\nexport type SetRedialSlotParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"set_redial_slot\";\n\t/** 重拨目标角色 agentId；取画布锚点，必填 */\n\tagentId?: string;\n\t/** 重拨默认卡 cardId；可空表示只记角色不指定卡 */\n\tcardId?: string;\n};\n\n/** unmount_call_card：从角色待办板移除一张待处理卡（连线子型，边见 §2.3） */\nexport type UnmountCallCardParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"unmount_call_card\";\n\t/** 目标角色 agentId；缺省语义=当前会话角色 */\n\tagentId?: string;\n\t/** 被卸载的卡 cardId；缺省语义=当前会话卡 */\n\tcardId?: string;\n};\n\n/** keep_card_pending：保持当前卡待处理；语义固定，无参数 */\nexport type KeepCardPendingParams = {\n\t/** 判别键；固定该 effect 名，无其它字段 */\n\teffect: \"keep_card_pending\";\n};\n\n/** schedule_call_card：登记一次性定时外呼意图，到点触发 */\nexport type ScheduleCallCardParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"schedule_call_card\";\n\t/** 目标角色 agentId；取画布锚点，必填 */\n\tagentId?: string;\n\t/** 目标故事包 id；取包配置源，必填 */\n\tpackageId?: string;\n\t/** 目标卡 cardId；取画布 CallCard 节点，必填 */\n\tcardId?: string;\n\t/** 延迟触发；单位分钟，缺省语义等同引擎默认 5 */\n\tdelayMinutes?: number;\n\t/** 外呼话题提示；缺省表示不带提示 */\n\ttopicHint?: string;\n};\n\n/** schedule_recurring_call 调度周期；weekly 时需配 weekdays */\nexport type ScheduleRecurringMode = \"daily\" | \"weekly\";\n\n/** schedule_recurring_call：登记每日/每周循环外呼意图 */\nexport type ScheduleRecurringCallParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"schedule_recurring_call\";\n\t/** 目标角色 agentId；缺省语义=当前会话角色 */\n\tagentId?: string;\n\t/** 预置调度卡引用；与 cardId+packageId 二选一 */\n\tscheduleCardId?: string;\n\t/** 目标卡 cardId；与 scheduleCardId 二选一，需搭配 packageId */\n\tcardId?: string;\n\t/** 目标故事包 id；搭配 cardId 使用 */\n\tpackageId?: string;\n\t/** 调度周期；缺省语义等同引擎默认 daily */\n\tscheduleMode?: ScheduleRecurringMode;\n\t/** 触发小时；单位 0–23 本地时，缺省语义等同引擎默认 9 */\n\thour?: number;\n\t/** 触发分钟；单位 0–59，缺省语义等同引擎默认 0 */\n\tminute?: number;\n\t/** 周几多选；weekly 时取值 0–6（0=周日），daily 忽略 */\n\tweekdays?: number[];\n\t/** 外呼话题提示；缺省表示不带提示 */\n\ttopicHint?: string;\n};\n\n/** create_research_commitment：记录待研究问题，后续回访 */\nexport type CreateResearchCommitmentParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"create_research_commitment\";\n\t/** 待研究问题正文；必填 */\n\tquestion?: string;\n\t/** 回访时机；缺省语义等同引擎默认 next_call */\n\tnotifyMode?: string;\n};\n\n/** update_user_profile：写用户昵称/全名到用户档案 */\nexport type UpdateUserProfileParams = {\n\t/** 判别键；固定该 effect 名 */\n\teffect: \"update_user_profile\";\n\t/** 用户昵称；必填 */\n\tnickname?: string;\n\t/** 用户全名；缺省表示不改全名 */\n\tfullName?: string;","isEmpty":false,"exceededLimit":false,"totalLines":276,"fileSize":10394,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/typeFiles/story/editor/callCard/editorEffectParams.ts","readRange":{"startLine":1,"endLine":120},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-c164399f-b920-4d10-a8ee-a2b35e75e9ea-48\nfc_3005d63a-8cc4-97b7-8327-89344abf475c_1","startedAtMs":"1784770056131","completedAtMs":"1784770056357"},"model_call_id":"3bb1eaa0-dc1e-4666-b7a1-f546fede52a6-4-ssns","session_id":"13d95b2c-2da1-4bb3-a463-cffe162be1c5","timestamp_ms":1784770056308}
{"type":"tool_call","subtype":"completed","call_id":"call-c164399f-b920-4d10-a8ee-a2b35e75e9ea-50\nfc_3005d63a-8cc4-97b7-8327-89344abf475c_3","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/docs/AI和人类/需求/08-内容校验规则.md","limit":100},"result":{"success":{"content":"# 08. 内容校验规则\n\n相关：[01](./01-CallCard数据模型.md) · [13](./13-工具与能力注册.md) · [14](./14-资源与媒体资产.md) · [19](../技术设计文档/19-引擎宿主与会话模型.md) · [03](./03-编辑器界面需求.md)\n\n`validatePackage(packageId)` / `validateWorkspace()` 产出 `ValidationReport`：`{ errors[], warnings[] }`，每项含 `ruleId`、路径、文案。\n\n**级别：** `error` 阻断导出与调试开跑（可配置）；`warning` 可导出，底栏提示。\n\n## 1. 包 / 磁盘\n\n| ruleId | 级别 | 说明 |\n|--------|------|------|\n| `CONF_CARD_FILE_MISSING` | error | conf `cards[]` 有 cardId，无 `cards/<id>.s-card.json` |\n| `CARD_FILE_ORPHAN` | warning | 磁盘有 `.s-card.json` 未登记进 conf |\n| `ENTRY_CARD_UNKNOWN` | error | `entryCardId` 不在索引内 |\n| `REFERENCED_AGENT_UNKNOWN` | error | 包内派生引用的 agentId（owner / effects / attach 等）不在角色库 |\n| `PARTICIPANT_UNKNOWN` | warning | 遗留 `participants` 含不存在的 agentId（字段将忽略）；空数组或不写不报错 |\n| `FREE_PACKAGE_SENTINEL` | error | 试图把 `__free__` 当真实故事包目录创建或 load |\n| `SCHEMA_UNSUPPORTED` | error | schemaVersion 不兼容（见 [17](../技术设计文档/17-版本迁移与兼容策略.md)） |\n| `LAYOUT_IGNORED` | — | layout 旁车不参与运行校验（可存在） |\n\n**路径 B（角色全局化）：** `participants` 可选、非白名单。`validatePackage` 对 `collectReferencedAgentIds` 派生集合做角色库存在性与 free/social 校验；`ownerAgentId` 不在遗留 `participants` 但在角色库 → **不得** error。\n\n## 2. CallCard / 出口\n\n| ruleId | 级别 | 说明 |\n|--------|------|------|\n| `PROMPT_SCENE_PATCH_HARD` | error | `promptScenes.patch` 含 objective/forbidden |\n| `EXIT_EMPTY_STORY` | warning | story 卡无 exits（创作建议至少成功+failure） |\n| `EXIT_NO_FAILURE` | warning | story 卡缺 failure 类出口 |\n| `EXIT_NO_RECOVERY` | warning | story 卡缺 recovery 建议出口 |\n| `EFFECT_UNKNOWN` | error | 未知 effect 名 |\n| `EFFECT_ID_DUP` | error | 包内 effect.id 重复 |\n| `PLAYBACK_NO_ASSET` | error | playback_only 无 playbackClipId |\n\n## 3. 工具\n\n| ruleId | 级别 | 说明 |\n|--------|------|------|\n| `TOOL_UNKNOWN` | error | allowedToolIds 含未注册 id |\n| `TOOL_KIND_MISMATCH` | error | 工具不允许该 cardKind |\n| `TOOL_PLAYBACK` | error | playback_only 仍声明工具 |\n| `TOOL_DIRECT_EFFECT` | error | 试图标成通话中直接 effect |\n| `TOOL_INTRODUCE_GUARD` | warning | 引荐类工具目标无 `canIntroduce` |\n\n## 4. 资产 / 角色\n\n| ruleId | 级别 | 说明 |\n|--------|------|------|\n| `ASSET_UNKNOWN` | error | 引用不存在的 assetId |\n| `ASSET_URI_MISSING` | error | uri 指向缺失文件 |\n| `ASSET_KIND_MISMATCH` | warning | playback 引用了非音频类 |\n| `ASSET_PACKAGE_INLINE` | warning | 包内出现完整 assets[] 内联（应迁全局库） |\n| `SOCIAL_TARGET_UNKNOWN` | error | social.target 不在角色库 |\n| `NARRATIVE_DIALABLE` | error | `isNarrativeOnly` 但 `dialable: true` |\n| `NARRATIVE_NEEDS_NO_FREE` | warning | narrative-only 仍配置了 freeCardId |\n| `FREE_CARD_MISSING` | error | 非 narrative-only 可通话角色缺 freeCardId 或文件 |\n| `FREE_CARD_KIND` | error | free 卡 `cardKind !== \"free\"` |\n| `CHARACTER_NOT_DIALABLE` | — | 运行时错误码，非包校验 |\n\n## 5. 验收\n\n- [x] error 阻断导出；点击问题可定位卡/文件（导出 API `hasBlockingErrors`；定位 UX 可增强）\n- [x] golden 包 validate 无 error\n- [x] `__free__` 哨兵不可当包路径通过校验\n- [x] `ASSET_URI_MISSING` 硬拦（meta 存在但 `uri` 文件缺失）；见 `VALIDATE_PACKAGE_ERROR_COVERAGE.covered`\n- [x] warning 主路径进 coverage：`CARD_FILE_ORPHAN`／`EXIT_*`／`TOOL_INTRODUCE_GUARD`／`ASSET_KIND_MISMATCH`／`NARRATIVE_NEEDS_NO_FREE`／`ASSET_PACKAGE_INLINE`\n","isEmpty":false,"exceededLimit":false,"totalLines":68,"fileSize":3933,"path":"/Users/bolbiao/workspace/airpc-engine/docs/AI和人类/需求/08-内容校验规则.md","readRange":{"startLine":1,"endLine":68},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-c164399f-b920-4d10-a8ee-a2b35e75e9ea-50\nfc_3005d63a-8cc4-97b7-8327-89344abf475c_3","startedAtMs":"1784770056136","completedAtMs":"1784770056360"},"model_call_id":"3bb1eaa0-dc1e-4666-b7a1-f546fede52a6-4-ssns","session_id":"13d95b2c-2da1-4bb3-a463-cffe162be1c5","timestamp_ms":1784770056314}
