{"type":"tool_call","subtype":"completed","call_id":"call-c5dc74b5-0262-489e-b47d-38a1f3a071fc-53\nfc_a20bae0e-a34c-9aef-8c24-6cab128f0271_1","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/typeFiles/story/editor/callCard/editorEffectParams.ts","offset":240,"limit":50},"result":{"success":{"content":"\t| PlaySystemPromptParams;\n\n/** 按 effect 名取对应参数变体类型；供面板与读取器强类型收窄 */\nexport type EffectParamsFor<E extends KnownEffectName> = Extract<\n\tEditorEffectParams,\n\t{ effect: E }\n>;\n\n/**\n\t* Effect 面板 id 下拉的候选数据源（会话投影）。\n\t* 数据来自画布/包/资源，由上层查询注入；本轮未接入时给空数组走 helperText 提示。\n\t*/\nexport type EffectPanelSources = {\n\t/** 角色候选；value=agentId · label=显示名，来自画布锚点 */\n\tcharacters: readonly CallCardLabelOption[];\n\t/** 卡候选；value=cardId · label=title，来自画布 CallCard 节点 */\n\tcards: readonly CallCardLabelOption[];\n\t/** 包候选；value=packageId · label=包名，来自包配置源 */\n\tpackages: readonly CallCardLabelOption[];\n\t/** 片段候选；value=资源 id · label=资源名，来自资源浮窗 */\n\tclips: readonly CallCardLabelOption[];\n\t/**\n\t\t* 卡 cardId → 归属角色 agentId 映射；来自画布 CallCard 节点的 ownerAgentId。\n\t\t* 供 attach/unmount 目标卡选定后默认回填角色（§2.3）；无归属的卡不入表。\n\t\t*/\n\tcardOwnerAgentId: Readonly<Record<string, string>>;\n};\n\n/** 空数据源常量；下拉无候选时复用，避免每处新建空数组 */\nexport const EMPTY_EFFECT_PANEL_SOURCES: EffectPanelSources = {\n\tcharacters: [],\n\tcards: [],\n\tpackages: [],\n\tclips: [],\n\tcardOwnerAgentId: {},\n};\n","isEmpty":false,"exceededLimit":false,"totalLines":276,"fileSize":10394,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/typeFiles/story/editor/callCard/editorEffectParams.ts","readRange":{"startLine":240,"endLine":276},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-c5dc74b5-0262-489e-b47d-38a1f3a071fc-53\nfc_a20bae0e-a34c-9aef-8c24-6cab128f0271_1","startedAtMs":"1784770065483","completedAtMs":"1784770065674"},"model_call_id":"3bb1eaa0-dc1e-4666-b7a1-f546fede52a6-5-rjxw","session_id":"13d95b2c-2