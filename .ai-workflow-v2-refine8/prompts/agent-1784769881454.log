l schedule node\"),\n      ),\n    ).toBe(true);\n    expect(\n      kindErrors.some((e) => e.path.includes(\"ok_schedule_cards_ref\")),\n    ).toBe(false);\n  });\n\n  it(\"V1-E3：物化 → agent_outbound → beginCall frozenCard 为 ScheduleCard\", async () => {"}},"hookAdditionalContexts":[],"toolCallId":"call-91d0f19e-9a53-40c9-9e7c-a297f01e00c3-76\nfc_e3fc0464-b2b1-9d1a-897b-5c5a346189ad_0","startedAtMs":"1784770123193"},"model_call_id":"3bb1eaa0-dc1e-4666-b7a1-f546fede52a6-11-029b","session_id":"13d95b2c-2da1-4bb3-a463-cffe162be1c5","timestamp_ms":1784770123148}
