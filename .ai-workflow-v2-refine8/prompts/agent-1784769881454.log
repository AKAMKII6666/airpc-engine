ssetId)) {\n\t\treturn apiFail(\"VALIDATION_FAILED\", \"assetId 格式无效\");\n\t}\n\tif (await assetMetaExists(assetId)) {\n\t\treturn apiFail(\n\t\t\t\"VALIDATION_FAILED\",\n\t\t\t`asset already exists: ${assetId}`,\n\t\t);\n\t}\n\treturn null;\n}\n\n/** 路径 A：客户端已组好 AssetMeta */\nasync function postFromAssetMeta(asset: unknown): Promise<Response> {\n\tconst raw = asset as { assetId?: string };\n\tif (!raw.assetId || typeof raw.assetId !== \"string\") {\n\t\treturn apiFail(\"VALIDATION_FAILED\", \"assetId required\");\n\t}\n\tconst blocked = await rejectIfAssetIdUnavailable(raw.assetId);\n\tif (blocked) return blocked;\n\tconst parsed = AssetMetaSchema.safeParse(asset);\n\tif (!parsed.success) {\n\t\treturn apiFail(\"VALIDATION_FAILED\", formatZodError(parsed.error), 400, {\n\t\t\tissues: parsed.error.issues,","isEmpty":false,"exceededLimit":false,"totalLines":157,"fileSize":4543,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/app/api/assets/route.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-c5dc74b5-0262-489e-b47d-38a1f3a071fc-55\nfc_a20bae0e-a34c-9aef-8c24-6cab128f0271_3","startedAtMs":"1784770065591","completedAtMs":"1784770065764"},"model_call_id":"3bb1eaa0-dc1e-4666-b7a1-f546fede52a6-5-rjxw","session_id":"13d95b2c-2da1-4bb3-a463-cffe162be1c5","timestamp_ms":1784770065722}
