免再落白名单字段。\n\t* 内存/Zod 解析仍可有缺省 []；磁盘推荐省略键。\n\t*/\nexport function omitParticipantsForDiskWrite(\n\tconf: StoryPackageConf,\n): Omit<StoryPackageConf, \"participants\"> & {\n\tparticipants?: undefined;\n} {\n\tconst { participants: _legacy, ...rest } = conf;\n\tvoid _legacy;\n\treturn rest;\n}\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/conf/referencedAgentsDerive.ts","linesAdded":72,"linesRemoved":0,"diffString":"--- /dev/null\n+++ b//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/conf/referencedAgentsDerive.ts\n@@ -1 +1,73 @@\n+/**\n+\t* 路径 B：本包引用角色派生（lanes / 包配置 / 列表 characterCount）。\n+\t* 真源 = collectReferencedAgentIds；禁止手维 conf.participants 白名单。\n+\t*/\n+import {\n+\tcollectReferencedAgentIds,\n+\ttype CallCardDefinition,\n+\ttype StoryPackageConf,\n+} from \"@airpc/rpg-engine\";\n \n+/** conf+cards 切片；layout 不参与派生 */\n+export type ReferencedAgentsBundleSlice = {\n+\t/** 包 conf；仅作引擎 collect 入参壳，派生不读 participants */\n+\tconf: StoryPackageConf;\n+\t/** 本包已加载 CallCard；owner/effects 为引用真源 */\n+\tcards: readonly CallCardDefinition[];\n+};\n+\n+/** 有挂卡（owner）者排前，其余引用角色随后；稳定去重 */\n+function sortUsedOwnersFirst(\n+\tagentIds: readonly string[],\n+\tcards: readonly CallCardDefinition[],\n+): string[] {\n+\tconst used: string[] = [];\n+\tconst unused: string[] = [];\n+\tfor (const agentId of agentIds) {\n+\t\tconst hasOwnerCard = cards.some(function (c) {\n+\t\t\treturn c.ownerAgentId === agentId;\n+\t\t});\n+\t\tif (hasOwnerCard) used.push(agentId);\n+\t\telse unused.push(agentId);\n+\t}\n+\treturn [...used, ...unused];\n+}\n+\n+/**\n+\t* 本包内容引用的 agentId 列表（有卡者优先）。\n+\t* 与引擎 validate 口径一致；遗留 participants 不入集。\n+\t*/\n+export function listDerivedReferencedAgentIds(\n+\tbundle: ReferencedAgentsBundleSlice,\n+): string[] {\n+\tconst ids = [\n+\t\t...collectReferencedAgentIds({\n+\t\t\tconf: bundle.conf,\n+\t\t\tcards: [...bundle.cards],\n+\t\t}),\n+\t];\n+\treturn sortUsedOwnersFirst(ids, bundle.cards);\n+}\n+\n+/** Studio layout.lanes：按派生引用角色写序；引擎忽略 */\n+export function deriveLayoutLanes(\n+\tbundle: ReferencedAgentsBundleSlice,\n+): Array<{ agentId: string; order: number }> {\n+\treturn listDerivedReferencedAgentIds(bundle).map(function (agentId, order) {\n+\t\treturn { agentId, order };\n+\t});\n+}\n+\n+/**\n+\t* 保存写盘：去掉遗留 participants，避免再落白名单字段。\n+\t* 内存/Zod 解析仍可有缺省 []；磁盘推荐省略键。\n+\t*/\n+export function omitParticipantsForDiskWrite(\n+\tconf: StoryPackageConf,\n+): Omit<StoryPackageConf, \"participants\"> & {\n+\tparticipants?: undefined;\n+} {\n+\tconst { participants: _legacy, ...rest } = conf;\n+\tvoid _legacy;\n+\treturn rest;\n+}","afterFullFileContent":"/**\n\t* 路径 B：本包引用角色派生（lanes / 包配置 / 列表 characterCount）。\n\t* 真源 = collectReferencedAgentIds；禁止手维 conf.participants 白名单。\n\t*/\nimport {\n\tcollectReferencedAgentIds,\n\ttype CallCardDefinition,\n\ttype StoryPackageConf,\n} from \"@airpc/rpg-engine\";\n\n/** conf+cards 切片；layout 不参与派生 */\nexport type ReferencedAgentsBundleSlice = {\n\t/** 包 conf；仅作引擎 collect 入参壳，派生不读 participants */\n\tconf: StoryPackageConf;\n\t/** 本包已加载 CallCard；owner/effects 为引用真源 */\n\tcards: readonly CallCardDefinition[];\n};\n\n/** 有挂卡（owner）者排前，其余引用角色随后；稳定去重 */\nfunction sortUsedOwnersFirst(\n\tagentIds: readonly string[],\n\tcards: readonly CallCardDefinition[],\n): string[] {\n\tconst used: string[] = [];\n\tconst unused: string[] = [];\n\tfor (const agentId of agentIds) {\n\t\tconst hasOwnerCard = cards.some(function (c) {\n\t\t\treturn c.ownerAgentId === agentId;\n\t\t});\n\t\tif (hasOwnerCard) used.push(agentId);\n\t\telse unused.push(agentId);\n\t}\n\treturn [...used, ...unused];\n}\n\n/**\n\t* 本包内容引用的 agentId 列表（有卡者优先）。\n\t* 与引擎 validate 口径一致；遗留 participants 不入集。\n\t*/\nexport function listDerivedReferencedAgentIds(\n\tbundle: ReferencedAgentsBundleSlice,\n): string[] {\n\tconst ids = [\n\t\t...collectReferencedAgentIds({\n\t\t\tconf: bundle.conf,\n\t\t\tcards: [...bundle.cards],\n\t\t}),\n\t];\n\treturn sortUsedOwnersFirst(ids, bundle.cards);\n}\n\n/** Studio layout.lanes：按派生引用角色写序；引擎忽略 */\nexport function deriveLayoutLanes(\n\tbundle: ReferencedAgentsBundleSlice,\n): Array<{ agentId: string; order: number }> {\n\treturn listDerivedReferencedAgentIds(bundle).map(function (agentId, order) {\n\t\treturn { agentId, order };\n\t});\n}\n\n/**\n\t* 保存写盘：去掉遗留 participants，避免再落白名单字段。\n\t* 内存/Zod 解析仍可有缺省 []；磁盘推荐省略键。\n\t*/\nexport function omitParticipantsForDiskWrite(\n\tconf: StoryPackageConf,\n): Omit<StoryPackageConf, \"participants\"> & {\n\tparticipants?: undefined;\n} {\n\tconst { participants: _legacy, ...rest } = conf;\n\tvoid _legacy;\n\treturn rest;\n}\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/conf/referencedAgentsDerive.ts"}}},"hookAdditionalContexts":[],"toolCallId":"call-937ede34-8c4b-48a7-ba97-1db4b3648cc7-86\nfc_792ca8c9-bc02-9ff6-860f-5047b66c2f58_0","startedAtMs":"1784722015425","completedAtMs":"1784722015657"},"model_call_id":"124a1fb1-f79e-4399-b664-27f6b79df98a-23-cj81","session_id":"b3f16bdc-d809-4891-a7df-372622951939","timestamp_ms":1784722015703}
