n className={styles.rule}>{issue.ruleId}</span>\n\t\t\t\t\t\t\t<span className={styles.msg}>{issue.message}</span>\n\t\t\t\t\t\t\t<span className={styles.path} title={issue.path}>\n\t\t\t\t\t\t\t\t{issue.path}\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t);\n\t\t\t\t})}\n\t\t\t</ul>\n\t\t</div>\n\t);\n};\n\nexport const PackageValidatePanel: FC<PackageValidatePanelProps> = function ({\n\t// packages 是磁盘故事包列表\n\tpackages,\n\t// packageId 是当前选中包键\n\tpackageId,\n\t// listLoading 表示列表加载中\n\tlistLoading,\n\t// listError 是列表失败人话\n\tlistError,\n\t// validating 表示校验请求进行中\n\tvalidating,\n\t// validateError 是校验请求失败人话\n\tvalidateError,\n\t// report 是最近一次读盘 ValidationReport\n\treport,\n\t// onPackageChange 切换目标包并清空旧报告\n\tonPackageChange,\n\t// onValidate 触发只读 validate\n\tonValidate,\n}) {\n\tconst errorCount = report?.errors.length ?? 0;\n\tconst warningCount = report?.warnings.length ?? 0;\n\tconst clean =\n\t\treport !== null && errorCount === 0 && warningCount === 0;\n\n\treturn (\n\t\t<section className={styles.root} aria-label=\"读盘包校验\">\n\t\t\t<div className={styles.head}>\n\t\t\t\t<div className={styles.headText}>\n\t\t\t\t\t{/* 引用了Typography组件，用于面板标题 */}\n\t\t\t\t\t<Typography variant=\"subtitle1\" className={styles.title}>\n\t\t\t\t\t\t读盘包校验\n\t\t\t\t\t</Typography>\n\t\t\t\t\t<span className={styles.hint}>\n\t\t\t\t\t\t只读 data/storis-packages · 不写盘 · 不 Host beginCall\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.actions}>\n\t\t\t\t\t{/* 引用了FormControl组件，用于故事包 Select */}\n\t\t\t\t\t<FormControl size=\"small\" className={styles.select}>\n\t\t\t\t\t\t{/* 引用了InputLabel组件，用于 Select 标签 */}\n\t\t\t\t\t\t<InputLabel id=\"debugger-pkg-validate-label\">\n\t\t\t\t\t\t\t故事包\n\t\t\t\t\t\t</InputLabel>\n\t\t\t\t\t\t{/* 引用了Select组件，用于选择磁盘包 */}\n\t\t\t\t\t\t<Select\n\t\t\t\t\t\t\tlabelId=\"debugger-pkg-validate-label\"\n\t\t\t\t\t\t\tlabel=\"故事包\"\n\t\t\t\t\t\t\tvalue={packageId}\n\t\t\t\t\t\t\tdisabled={listLoading || packages.length === 0}\n\t\t\t\t\t\t\tonChange={function (e) {\n\t\t\t\t\t\t\t\tonPackageChange(String(e.target.value));\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t{packages.map(function (p) {\n\t\t\t\t\t\t\t\treturn (\n\t\t\t\t\t\t\t\t\t// 引用了MenuItem组件，用于单条包选项\n\t\t\t\t\t\t\t\t\t<MenuItem\n\t\t\t\t\t\t\t\t\t\tkey={p.packageId}\n\t\t\t\t\t\t\t\t\t\tvalue={p.packageId}\n\t\t\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t\t\t{p.title}（{p.packageId}）\n\t\t\t\t\t\t\t\t\t</MenuItem>\n\t\t\t\t\t\t\t\t);\n\t\t\t\t\t\t\t})}\n\t\t\t\t\t\t</Select>\n\t\t\t\t\t</FormControl>\n\t\t\t\t\t{/* 引用了Button组件，用于触发读盘 validate */}\n\t\t\t\t\t<Button\n\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\tvariant=\"contained\"\n\t\t\t\t\t\tdisabled={\n\t\t\t\t\t\t\tlistLoading || validating || !packageId\n\t\t\t\t\t\t}\n\t\t\t\t\t\tonClick={onValidate}\n\t\t\t\t\t>\n\t\t\t\t\t\t{validating ? \"校验中…\" : \"校验读盘包\"}\n\t\t\t\t\t</Button>\n\t\t\t\t\t{/* 引用了Button组件，用于跳转编辑器改 Content */}\n\t\t\t\t\t<Button\n\t\t\t\t\t\tcomponent={Link}\n\t\t\t\t\t\thref={`/stories/${encodeURIComponent(packageId)}`}\n\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\tvariant=\"outlined\"\n\t\t\t\t\t\tdisabled={!packageId}\n\t\t\t\t\t>\n\t\t\t\t\t\t打开编辑器\n\t\t\t\t\t</Button>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t{listError ? (\n\t\t\t\t// 引用了Alert组件，用于列表加载失败\n\t\t\t\t<Alert severity=\"error\">{listError}</Alert>\n\t\t\t) : null}\n\t\t\t{validateError ? (\n\t\t\t\t// 引用了Alert组件，用于校验请求失败\n\t\t\t\t<Alert severity=\"error\">{validateError}</Alert>\n\t\t\t) : null}\n\n\t\t\t{report ? (\n\t\t\t\t<div className={styles.report}>\n\t\t\t\t\t{/* 引用了Typography组件，用于校验摘要 */}\n\t\t\t\t\t<Typography variant=\"body2\" className={styles.summary}>\n\t\t\t\t\t\t{clean\n\t\t\t\t\t\t\t? `包 ${report.packageId} 通过校验（无 error / warning）`\n\t\t\t\t\t\t\t: `包 ${report.packageId} · ${errorCount} 个错误 · ${warningCount} 个警告`}\n\t\t\t\t\t</Typography>\n\t\t\t\t\t{/* 引用了IssueList组件，用于展示 errors */}\n\t\t\t\t\t<IssueList\n\t\t\t\t\t\ttitle=\"错误\"\n\t\t\t\t\t\tissues={report.errors}\n\t\t\t\t\t\ttone=\"error\"\n\t\t\t\t\t/>\n\t\t\t\t\t{/* 引用了IssueList组件，用于展示 warnings */}\n\t\t\t\t\t<IssueList\n\t\t\t\t\t\ttitle=\"警告\"\n\t\t\t\t\t\tissues={report.warnings}\n\t\t\t\t\t\ttone=\"warning\"\n\t\t\t\t\t/>\n\t\t\t\t</div>\n\t\t\t) : (\n\t\t\t\t<p className={styles.empty}>\n\t\t\t\t\t选择故事包后点击「校验读盘包」，展示引擎 validatePackage 结果。\n\t\t\t\t</p>\n\t\t\t)}\n\t\t</section>\n\t);\n};\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/debugger/com/PackageValidatePanel.tsx","linesAdded":201,"linesRemoved":0,"diffString":"--- /dev/null\n+++ b//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/debugger/com/PackageValidatePanel.tsx\n@@ -1 +1,202 @@\n+/**\n+\t* 调试器读盘校验面板：选包 → validatePackage 结果；不 Host。\n+\t*/\n+\"use client\";\n \n+import type { FC } from \"react\";\n+import Link from \"next/link\";\n+import {\n+\tAlert,\n+\tButton,\n+\tFormControl,\n+\tInputLabel,\n+\tMenuItem,\n+\tSelect,\n+\tTypography,\n+} from \"@mui/material\";\n+import type { ValidationIssue, ValidationReport } from \"@airpc/rpg-engine\";\n+import type { StoryPackageSummary } from \"@studio-v2/typeFiles/story/summary/storyPackageSummary\";\n+import styles from \"./PackageValidatePanel.module.scss\";\n+\n+export type PackageValidatePanelProps = {\n+\tpackages: StoryPackageSummary[];\n+\tpackageId: string;\n+\tlistLoading: boolean;\n+\tlistError: string | undefined;\n+\tvalidating: boolean;\n+\tvalidateError: string | undefined;\n+\treport: ValidationReport | null;\n+\tonPackageChange: (packageId: string) => void;\n+\tonValidate: () => void;\n+};\n+\n+type IssueListProps = {\n+\ttitle: string;\n+\tissues: readonly ValidationIssue[];\n+\ttone: \"error\" | \"warning\";\n+};\n+\n+const IssueList: FC<IssueListProps> = function ({\n+\t// title 是区块标题（错误/警告）\n+\ttitle,\n+\t// issues 是引擎校验条目\n+\tissues,\n+\t// tone 决定样式强调\n+\ttone,\n+}) {\n+\tif (issues.length === 0) return null;\n+\treturn (\n+\t\t<div className={tone === \"error\" ? styles.blockError : styles.block