{"type":"tool_call","subtype":"completed","call_id":"call-1e3cee50-099d-4c19-9cde-3942e070b2cf-16\nfc_9b633413-83a6-904a-ab5b-8919bf1be2cb_1","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/session/packageMetaJson.ts"},"result":{"success":{"content":"/**\n\t* 包配置 worldFacts / meta 受控 JSON 块：序列化、解析与 schema 校验。\n\t* 非法 JSON 不写会话；空数组 / 空对象表示清空磁盘可选键。\n\t*/\nimport {\n\tFactMetaSchema,\n\tStoryPackageMetaSchema,\n\ttype FactMeta,\n\ttype StoryPackageMeta,\n} from \"@airpc/rpg-engine\";\n\n/** JSON 块解析结果；ok=false 时 message 可直接作 helperText */\nexport type PackageMetaJsonParseResult<T> =\n\t| { ok: true; value: T | undefined }\n\t| { ok: false; message: string };\n\n/** 投影为多行编辑草稿；缺省字段用空数组 / 空对象占位便于作者起步 */\nexport function stringifyWorldFactsDraft(\n\tworldFacts: readonly FactMeta[] | undefined,\n): string {\n\treturn JSON.stringify(worldFacts ?? [], null, 2);\n}\n\n/** meta 缺省用 `{}`，避免失焦时把空壳 imports/exports 误写入 */\nexport function stringifyPackageMetaDraft(\n\tmeta: StoryPackageMeta | undefined,\n): string {\n\treturn JSON.stringify(meta ?? {}, null, 2);\n}\n\n/**\n\t* 解析 worldFacts JSON：须为数组；每项至少含 factId。\n\t* `[]` → undefined（磁盘省略键）。\n\t*/\nexport function parseWorldFactsJson(\n\traw: string,\n): PackageMetaJsonParseResult<FactMeta[]> {\n\tconst trimmed = raw.trim();\n\tif (trimmed === \"\") {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tlet parsed: unknown;\n\ttry {\n\t\tparsed = JSON.parse(trimmed);\n\t} catch {\n\t\treturn { ok: false, message: \"JSON 语法错误\" };\n\t}\n\tif (!Array.isArray(parsed)) {\n\t\treturn { ok: false, message: \"worldFacts 须为 JSON 数组\" };\n\t}\n\tif (parsed.length === 0) {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tconst items: FactMeta[] = [];\n\tfor (let i = 0; i < parsed.length; i += 1) {\n\t\tconst one = FactMetaSchema.safeParse(parsed[i]);\n\t\tif (!one.success) {\n\t\t\treturn {\n\t\t\t\tok: false,\n\t\t\t\tmessage: `worldFacts[${i}] 须含 factId 字符串`,\n\t\t\t};\n\t\t}\n\t\titems.push(one.data);\n\t}\n\treturn { ok: true, value: items };\n}\n\n/**\n\t* 解析 meta JSON：须为对象；空 `{}` → undefined。\n\t* 允许仅填 imports/exports.facts；多余键 passthrough 保留。\n\t*/\nexport function parsePackageMetaJson(\n\traw: string,\n): PackageMetaJsonParseResult<StoryPackageMeta> {\n\tconst trimmed = raw.trim();\n\tif (trimmed === \"\") {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tlet parsed: unknown;\n\ttry {\n\t\tparsed = JSON.parse(trimmed);\n\t} catch {\n\t\treturn { ok: false, message: \"JSON 语法错误\" };\n\t}\n\tif (parsed === null || typeof parsed !== \"object\" || Array.isArray(parsed)) {\n\t\treturn { ok: false, message: \"meta 须为 JSON 对象\" };\n\t}\n\tconst keys = Object.keys(parsed as object);\n\tif (keys.length === 0) {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tconst checked = StoryPackageMetaSchema.safeParse(parsed);\n\tif (!checked.success) {\n\t\treturn { ok: false, message: \"meta 结构不符合 imports/exports 约定\" };\n\t}\n\treturn { ok: true, value: checked.data };\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":98,"fileSize":2827,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/session/packageMetaJson.ts","readRange":{"startLine":1,"endLine":98},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-1e3cee50-099d-4c19-9cde-3942e070b2cf-16\nfc_9b633413-83a6-904a-ab5b-8919bf1be2cb_1","startedAtMs":"1784769456981","completedAtMs":"1784769457566"},"model_call_id":"cd0869cd-7f0d-4065-b99c-0becc962f0f5-4-syn2","session_id":"58b50694-8aa0-43b1-8262-e6b28ff478df","timestamp_ms":1784769457538}
