: `${cardPath}#context.promptScenes`,\n          message: patchErr.message,\n        });\n      }\n      const rawPolicy = (cardRaw as { toolPolicy?: Record<string, unknown> })\n        .toolPolicy;\n      if (\n        rawPolicy &&\n        (rawPolicy.applyEffectsDuringCall === true ||\n          rawPolicy.directEffects != null)\n      ) {\n        push(errors, {\n          ruleId: \"TOOL_DIRECT_EFFECT\",\n          level: \"error\",\n          path: `${cardPath}#toolPolicy`,\n          message:\n            \"in-call direct effects are forbidden; use RuntimeExitCandidate\",\n        });\n      }\n    }\n\n    const cardParsed = CallCardDefinitionSchema.safeParse(cardRaw);\n    if (!cardParsed.success) {\n      push(errors, {\n        ruleId: \"SCHEMA_UNSUPPORTED\",\n        level: \"error\",\n        path: cardPath,\n        message: `card ${cardRef.cardId} schema invalid`,\n      });\n      continue;\n    }\n    const card = cardParsed.data;\n    parsedCards.push(card);\n\n    if (card.cardKind === \"story\" && card.exits.length === 0) {\n      push(warnings, {\n        ruleId: \"EXIT_EMPTY_STORY\",\n        level: \"warning\",\n        path: `${cardPath}#exits`,\n        message: \"story card has no exits\",\n      });\n    } else if (card.cardKind === \"story\" && card.exits.length > 0) {\n      const kinds = new Set(\n        card.exits\n          .map((e) => e.exitKind)\n          .filter((k): k is NonNullable<typeof k> => Boolean(k)),","isEmpty":false,"exceededLimit":false,"totalLines":720,"fileSize":20246,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/validation/validatePackage.ts","readRange":{"startLine":140,"endLine":239},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-534eeea8-b653-4786-be7b-d584572f139f-58\nfc_e09257c2-f271-9b51-bc10-a2e88c76c121_0","startedAtMs":"1784771973090","completedAtMs":"1784771973363"},"model_call_id":"e5bbcebc-0eba-4630-8c3b-ab4089fe4c37-13-h5ip","se