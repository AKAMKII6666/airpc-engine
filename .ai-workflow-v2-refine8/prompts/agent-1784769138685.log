{"type":"tool_call","subtype":"started","call_id":"call-6cf9a7f4-4461-40b0-8956-c8f1b8f38c14-55\nfc_c0021a4c-6eee-98c9-bc41-5227afddc64f_1","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/session/packageSessionLoad.ts","streamContent":"/**\n\t* 会话内改 conf.assetRefs；去重保序；空数组表示清空引用。\n\t* 候选须来自 /api/assets；调用方负责只写入合法 assetId。\n\t*/\nexport function withAssetRefs(\n\tbundle: DiskStoryPackageBundle,\n\tassetRefs: readonly string[],\n): DiskStoryPackageBundle {\n\tconst seen = new Set<string>();\n\tconst next: string[] = [];\n\tfor (const raw of assetRefs) {\n\t\tconst id = raw.trim();\n\t\tif (id === \"\" || seen.has(id)) continue;\n\t\tseen.add(id);\n\t\tnext.push(id);\n\t}\n\treturn {\n\t\t...bundle,\n\t\tconf: {\n\t\t\t...bundle.conf,\n\t\t\tassetRefs: next.length > 0 ? next : undefined,\n\t\t},\n\t};\n}\n\n/**\n\t* 会话内改 conf.worldFacts；undefined 表示清空可选键。\n\t* 调用方须先经 parseWorldFactsJson；本函数不再二次校验。\n\t*/\nexport function withWorldFacts(\n\tbundle: DiskStoryPackageBundle,\n\tworldFacts: readonly FactMeta[] | undefined,\n): DiskStoryPackageBundle {\n\treturn {\n\t\t...bundle,\n\t\tconf: {\n\t\t\t...bundle.conf,\n\t\t\tworldFacts:\n\t\t\t\tworldFacts && worldFacts.length > 0\n\t\t\t\t\t? [...worldFacts]\n\t\t\t\t\t: undefined,\n\t\t},\n\t};\n}\n\n/**\n\t* 会话内改 conf.meta；undefined 表示清空可选键。\n\t* 调用方须先经 parsePackageMetaJson。\n\t*/\nexport function withPackageMeta(\n\tbundle: DiskStoryPackageBundle,\n\tmeta: StoryPackageMeta | undefined,\n): DiskStoryPackageBundle {\n\treturn {\n\t\t...bundle,\n\t\tconf: {\n\t\t\t...bundle.conf,\n\t\t\tmeta,\n\t\t},\n\t};\n}"}},"hookAdditionalContexts":[],"toolCallId":"call-6cf9a7f4-4461-40b0-8956-c8f1b8f38c14-55\nfc_c0021a4c-6eee-98c9-bc41-5227afddc64f_1","startedAtMs":"1784769229924"},"model_call_id":"9a82b57f-cd94-4b73-ad8d-e1d7fd46b7ce-14-qiw4","session_id":"c107c1ba-b725-44dc-b67c-eb2439bd913e","timestamp_ms":1784769229905}
