(\n\t\t\t\t\t<ul className={styles.list}>\n\t\t\t\t\t\t{assetOptions.map(function (opt) {\n\t\t\t\t\t\t\treturn (\n\t\t\t\t\t\t\t\t<li key={opt.value} className={styles.item}>\n\t\t\t\t\t\t\t\t\t{/* 引用了FormControlLabel组件，用于勾选包级资产引用 */}\n\t\t\t\t\t\t\t\t\t<FormControlLabel\n\t\t\t\t\t\t\t\t\t\tcontrol={\n\t\t\t\t\t\t\t\t\t\t\t// 引用了Checkbox组件，用于写入 conf.assetRefs\n\t\t\t\t\t\t\t\t\t\t\t<Checkbox\n\t\t\t\t\t\t\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\t\t\t\t\t\t\tchecked={selected.has(opt.value)}\n\t\t\t\t\t\t\t\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\t\t\t\t\t\t\t\ttoggle(opt.value, e.target.checked);\n\t\t\t\t\t\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\t\t\t\t\t\tinputProps={{\n\t\t\t\t\t\t\t\t\t\t\t\t\t\"aria-label\": `引用资产 ${opt.label}`,\n\t\t\t\t\t\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\t\t\t\t\t/>\n\t\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t\t\tlabel={opt.label}\n\t\t\t\t\t\t\t\t\t/>\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t);\n\t\t\t\t\t\t})}\n\t\t\t\t\t</ul>\n\t\t\t\t)}\n\t\t\t</div>\n\t\t);\n\t};\n","isEmpty":false,"exceededLimit":false,"totalLines":81,"fileSize":2496,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/library/PackageAssetRefsEditor.tsx","readRange":{"startLine":1,"endLine":81},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-59b6cf8c-6b79-489c-83b8-b14017f8a59b-18\nfc_c93e16b0-a845-9ba9-9dba-0c776e8a0c71_2","startedAtMs":"1784769161054","completedAtMs":"1784769161226"},"model_call_id":"9a82b57f-cd94-4b73-ad8d-e1d7fd46b7ce-4-e3c3","session_id":"c107c1ba-b725-44dc-b67c-eb2439bd913e","timestamp_ms":1784769161180}
