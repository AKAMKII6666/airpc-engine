] | undefined,\n): string {\n\treturn JSON.stringify(worldFacts ?? [], null, 2);\n}\n\n/** meta 缺省用含 imports/exports 空壳，对齐需求 01 字段名 */\nexport function stringifyPackageMetaDraft(\n\tmeta: StoryPackageMeta | undefined,\n): string {\n\tconst draft: StoryPackageMeta = meta ?? {\n\t\timports: { facts: [] },\n\t\texports: { facts: [] },\n\t};\n\treturn JSON.stringify(draft, null, 2);\n}\n\n/**\n\t* 解析 worldFacts JSON：须为数组；每项至少含 factId。\n\t* `[]` → undefined（磁盘省略键）。\n\t*/\nexport function parseWorldFactsJson(\n\traw: string,\n): PackageMetaJsonParseResult<FactMeta[]> {\n\tconst trimmed = raw.trim();\n\tif (trimmed === \"\") {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tlet parsed: unknown;\n\ttry {\n\t\tparsed = JSON.parse(trimmed);\n\t} catch {\n\t\treturn { ok: false, message: \"JSON 语法错误\" };\n\t}\n\tif (!Array.isArray(parsed)) {\n\t\treturn { ok: false, message: \"worldFacts 须为 JSON 数组\" };\n\t}\n\tif (parsed.length === 0) {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tconst items: FactMeta[] = [];\n\tfor (let i = 0; i < parsed.length; i += 1) {\n\t\tconst one = FactMetaSchema.safeParse(parsed[i]);\n\t\tif (!one.success) {\n\t\t\treturn {\n\t\t\t\tok: false,\n\t\t\t\tmessage: `worldFacts[${i}] 须含 factId 字符串`,\n\t\t\t};\n\t\t}\n\t\titems.push(one.data);\n\t}\n\treturn { ok: true, value: items };\n}\n\n/**\n\t* 解析 meta JSON：须为对象；空 `{}` → undefined。\n\t* 允许仅填 imports/exports.facts；多余键 passthrough 保留。\n\t*/\nexport function parsePackageMetaJson(\n\traw: string,\n): PackageMetaJsonParseResult<StoryPackageMeta> {\n\tconst trimmed = raw.trim();\n\tif (trimmed === \"\") {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tlet parsed: unknown;\n\ttry {\n\t\tparsed = JSON.parse(trimmed);\n\t} catch {\n\t\treturn { ok: false, message: \"JSON 语法错误\" };\n\t}\n\tif (parsed === null || typeof parsed !== \"object\" || Array.isArray(parsed)) {\n\t\treturn { ok: false, message: \"meta 须为 JSON 对象\" };\n\t}\n\tconst keys = Object.keys(parsed as object);\n\tif (keys.length === 0) {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tconst checked = StoryPackageMetaSchema.safeParse(parsed);\n\tif (!checked.success) {\n\t\treturn { ok: false, message: \"meta 结构不符合 imports/exports 约定\" };\n\t}\n\treturn { ok: true, value: checked.data };\n}\n","afterFullFileContent":"/**\n\t* 包配置 worldFacts / meta 受控 JSON 块：序列化、解析与 schema 校验。\n\t* 非法 JSON 不写会话；空数组 / 空对象表示清空磁盘可选键。\n\t*/\nimport {\n\tFactMetaSchema,\n\tStoryPackageMetaSchema,\n\ttype FactMeta,\n\ttype StoryPackageMeta,\n} from \"@airpc/rpg-engine\";\n\n/** JSON 块解析结果；ok=false 时 message 可直接作 helperText */\nexport type PackageMetaJsonParseResult<T> =\n\t| { ok: true; value: T | undefined }\n\t| { ok: false; message: string };\n\n/** 投影为多行编辑草稿；缺省字段用空数组 / 空对象占位便于作者起步 */\nexport function stringifyWorldFactsDraft(\n\tworldFacts: readonly FactMeta[] | undefined,\n): string {\n\treturn JSON.stringify(worldFacts ?? [], null, 2);\n}\n\n/** meta 缺省用 `{}`，避免失焦时把空壳 imports/exports 误写入 */\nexport function stringifyPackageMetaDraft(\n\tmeta: StoryPackageMeta | undefined,\n): string {\n\treturn JSON.stringify(meta ?? {}, null, 2);\n}\n\n/**\n\t* 解析 worldFacts JSON：须为数组；每项至少含 factId。\n\t* `[]` → undefined（磁盘省略键）。\n\t*/\nexport function parseWorldFactsJson(\n\traw: string,\n): PackageMetaJsonParseResult<FactMeta[]> {\n\tconst trimmed = raw.trim();\n\tif (trimmed === \"\") {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tlet parsed: unknown;\n\ttry {\n\t\tparsed = JSON.parse(trimmed);\n\t} catch {\n\t\treturn { ok: false, message: \"JSON 语法错误\" };\n\t}\n\tif (!Array.isArray(parsed)) {\n\t\treturn { ok: false, message: \"worldFacts 须为 JSON 数组\" };\n\t}\n\tif (parsed.length === 0) {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tconst items: FactMeta[] = [];\n\tfor (let i = 0; i < parsed.length; i += 1) {\n\t\tconst one = FactMetaSchema.safeParse(parsed[i]);\n\t\tif (!one.success) {\n\t\t\treturn {\n\t\t\t\tok: false,\n\t\t\t\tmessage: `worldFacts[${i}] 须含 factId 字符串`,\n\t\t\t};\n\t\t}\n\t\titems.push(one.data);\n\t}\n\treturn { ok: true, value: items };\n}\n\n/**\n\t* 解析 meta JSON：须为对象；空 `{}` → undefined。\n\t* 允许仅填 imports/exports.facts；多余键 passthrough 保留。\n\t*/\nexport function parsePackageMetaJson(\n\traw: string,\n): PackageMetaJsonParseResult<StoryPackageMeta> {\n\tconst trimmed = raw.trim();\n\tif (trimmed === \"\") {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tlet parsed: unknown;\n\ttry {\n\t\tparsed = JSON.parse(trimmed);\n\t} catch {\n\t\treturn { ok: false, message: \"JSON 语法错误\" };\n\t}\n\tif (parsed === null || typeof parsed !== \"object\" || Array.isArray(parsed)) {\n\t\treturn { ok: false, message: \"meta 须为 JSON 对象\" };\n\t}\n\tconst keys = Object.keys(parsed as object);\n\tif (keys.length === 0) {\n\t\treturn { ok: true, value: undefined };\n\t}\n\tconst checked = StoryPackageMetaSchema.safeParse(parsed);\n\tif (!checked.success) {\n\t\treturn { ok: false, message: \"meta 结构不符合 imports/exports 约定\" };\n\t}\n\treturn { ok: true, value: checked.data };\n}\n","message":"The file /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/conf/packageMetaJson.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"call-6bf2dae7-6710-4e28-b7c8-cad641f40da7-76\nfc_68d68710-03b8-9c8f-b558-80be5964263e_0","startedAtMs":"1784769310932","completedAtMs":"1784769311280"},"model_call_id":"9a82b57f-cd94-4b73-ad8d-e1d7fd46b7ce-20-86rc","session_id":"c107c1ba-b725-44dc-b67c-eb2439bd913e","timestamp_ms":1784769311247}
