d);\n\t\tif (!card) continue;\n\t\tawait writeJson(path.join(dir, \"cards\", `${cardId}.s-card.json`), card);\n\t}\n\n\tconst onDisk = await listCardIdsOnDisk(packageId);\n\tfor (const orphan of onDisk) {\n\t\tif (keep.has(orphan)) continue;\n\t\tawait unlink(path.join(dir, \"cards\", `${orphan}.s-card.json`));\n\t}\n\n\tawait writeJson(path.join(dir, \"canvas.layout.json\"), layout);\n\treturn { conf, cards: ordered, layout };\n}\n\n/** 包目录是否已有 story.conf.json（未校验 schema） */\nexport async function packageExists(packageId: string): Promise<boolean> {\n\tif (!isValidPackageId(packageId)) return false;\n\treturn pathExists(path.join(packageDir(packageId), \"story.conf.json\"));\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":289,"fileSize":7855,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/packages/fs/packagesFs.server.ts","readRange":{"startLine":210,"endLine":289},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-e2b81a77-c855-46b0-b605-b740db143cf6-37\nfc_f35e1083-b9cb-9dd7-b013-78e029b46825_1","startedAtMs":"1784769176732","completedAtMs":"1784769176947"},"model_call_id":"9a82b57f-cd94-4b73-ad8d-e1d7fd46b7ce-8-fbjd","session_id":"c107c1ba-b725-44dc-b67c-eb2439bd913e","timestamp_ms":1784769176911}
