\t\t\t\tIDLE_DOCK_TOOL_MODE.placementKind,\n\t\t\t);\n\t\t\treturn;\n\t\t}\n\t\tconst placed = createDockPlacementNode(kind, position);\n\t\tif (!placed) return;\n\t\tselectedIdRef.current = placed.id;\n\t\tsetNodes((prev) => appendPlacedNodeSelected(prev, placed));\n\t\tonSelectionChange(selectionFromPlacedNode(placed));\n\t\tsetToolMode(\n\t\t\tIDLE_DOCK_TOOL_MODE.mode,\n\t\t\tIDLE_DOCK_TOOL_MODE.placementKind,\n\t\t);\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":59,"fileSize":2067,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/canvas/createAddNodeAtCommand.ts","readRange":{"startLine":1,"endLine":59},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-1e5aa6a5-62b1-47eb-bee2-4a12fb2e027e-61\nfc_a918a2d4-72a4-94a1-b81a-413e87f80c9f_0","startedAtMs":"1784771324563","completedAtMs":"1784771324708"},"model_call_id":"60f67b1d-3ad1-4611-9cc4-6aa32a145540-13-240q","session_id":"79bbae55-4798-4921-9584-898a64ef9b19","timestamp_ms":1784771324632}
{"type":"tool_call","subtype":"completed","call_id":"call-1e5aa6a5-62b1-47eb-bee2-4a12fb2e027e-62\nfc_a918a2d4-72a4-94a1-b81a-413e87f80c9f_1","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/canvas/storyCanvasSelection.ts"},"result":{"success":{"content":"/**\n\t* 画布选中投影与 onReady 注册；从 useStoryCanvasGraph 拆出以控 hook 行数。\n\t*/\nimport { useCallback, useEffect, useRef, type MutableRefObject } from \"react\";\nimport type { Node, OnSelectionChangeParams } from \"@xyflow/react\";\nimport {\n\treadCallCardData,\n\treadChapterNodeData,\n\treadCharacterAnchorData,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/role/roleConnection\";\nimport type {\n\tCharacterAnchorNodeData,\n\tStoryEditorSelection,\n} from \"@studio-v2/typeFiles/story/editor/mock/storyEditorMock\";\nimport type { StoryCanvasStageApi } from \"@studio-v2/src/pageComponents/storyEditor/canvas/storyCanvasTypes\";\n\n/** 将 RF 节点投影为属性浮窗选中；CallCard 或章节，其它返回 null */\nexport function toStoryCanvasSelection(\n\tnode: Node | undefined,\n): StoryEditorSelection | null {\n\tif (!node) return null;\n\tconst card = readCallCardData(node);\n\tif (card) {\n\t\treturn { selectionKind: \"callCard\", nodeId: node.id, data: card };\n\t}\n\tconst chapter = readChapterNodeData(node);\n\tif (chapter) {\n\t\treturn { selectionKind: \"chapter\", nodeId: node.id, data: chapter };\n\t}\n\treturn null;\n}\n\nexport function useStoryCanvasSelection(args: {\n\tonSelectionChange: (selection: StoryEditorSelection | null) => void;\n\tonCharacterAnchorSelect: (anchor: CharacterAnchorNodeData | null) => void;\n\tinitialSelection: StoryEditorSelection | null;\n\t/** 与归属命令共享的选中节点 id；选中变化时同步写入 */\n\tselectedIdRef: MutableRefObject<string | null>;\n}) {\n\tconst {\n\t\tonSelectionChange,\n\t\tonCharacterAnchorSelect,\n\t\tinitialSelection,\n\t\tselectedIdRef,\n\t} = args;\n\tconst seededRef = useRef(false);\n\n\tuseEffect(() => {\n\t\tif (seededRef.current) return;\n\t\tseededRef.current = true;\n\t\tonSelectionChange(initialSelection);\n\t}, [initialSelection, onSelectionChange]);\n\n\treturn useCallback(\n\t\t(params: OnSelectionChangeParams) => {\n\t\t\t// 框选多卡仅用于整体挪位置，不做批量编辑，也不弹属性面板；\n\t\t\t// 只有恰好单选时才投影为属性浮窗选中，避免多选竞态读到不完整 values。\n\t\t\tconst node = params.nodes.length === 1 ? params.nodes[0] : undefined;\n\t\t\tselectedIdRef.current = node?.id ?? null;\n\t\t\tconst anchor = readCharacterAnchorData(node);\n\t\t\tif (anchor) {\n\t\t\t\tonSelectionChange(null);\n\t\t\t\tonCharacterAnchorSelect(anchor);\n\t\t\t\treturn;\n\t\t\t}\n\t\t\tonCharacterAnchorSelect(null);\n\t\t\tonSelectionChange(toStoryCanvasSelection(node));\n\t\t},\n\t\t[onCharacterAnchorSelect, onSelectionChange, selectedIdRef],\n\t);\n}\n\nexport function useRegisterStoryCanvasApi(\n\tapi: StoryCanvasStageApi,\n\tonReady: (next: StoryCanvasStageApi) => void,\n): void {\n\tuseEffect(() => {\n\t\tonReady(api);\n\t}, [api, onReady]);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":81,"fileSize":2667,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/canvas/storyCanvasSelection.ts","readRange":{"startLine":1,"endLine":81},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-1e5aa6a5-62b1-47eb-bee2-4a12fb2e027e-62\nfc_a918a2d4-72a4-94a1-b81a-413e87f80c9f_1","startedAtMs":"1784771324599","completedAtMs":"1784771324740"},"model_call_id":"60f67b1d-3ad1-4611-9cc4-6aa32a145540-13-240q","session_id":"79bbae55-4798-4921-9584-898a64ef9b19","timestamp_ms":1784771324663}
