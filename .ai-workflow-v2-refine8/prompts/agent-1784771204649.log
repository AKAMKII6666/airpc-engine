{"type":"tool_call","subtype":"completed","call_id":"call-edc475e4-5ab4-4d87-8ba4-5459e4897dd4-38\nfc_0bafd1bb-23f3-9475-86ad-dfdda942079d_0","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxHelper/studioApiClient.ts"},"result":{"success":{"content":"/**\n\t* Studio V2 客户端 API 响应解析（ajaxHelper）。\n\t* 统一 { ok:true, data } / { ok:false, code, message }；禁止页面裸拼错误分支。\n\t*/\n\nexport type StudioApiFail = {\n\tok: false;\n\tcode: string;\n\tmessage: string;\n\tdetails?: unknown;\n};\n\nexport type StudioApiOk<T> = {\n\tok: true;\n\tdata: T;\n};\n\nexport type StudioApiEnvelope<T> = StudioApiOk<T> | StudioApiFail;\n\n/**\n\t* 解析 fetch Response；非 JSON 或业务失败时抛 Error（message 为人话）。\n\t*/\nexport async function parseStudioApiJson<T>(\n\tres: Response,\n): Promise<T> {\n\tlet body: unknown;\n\ttry {\n\t\tbody = await res.json();\n\t} catch {\n\t\tthrow new Error(`请求失败（HTTP ${res.status}），响应非 JSON`);\n\t}\n\tif (\n\t\ttypeof body !== \"object\" ||\n\t\tbody === null ||\n\t\t!(\"ok\" in body)\n\t) {\n\t\tthrow new Error(`请求失败（HTTP ${res.status}），响应格式无效`);\n\t}\n\tconst envelope = body as StudioApiEnvelope<T>;\n\tif (envelope.ok === true) {\n\t\treturn envelope.data;\n\t}\n\tconst message =\n\t\ttypeof envelope.message === \"string\" && envelope.message.trim() !== \"\"\n\t\t\t? envelope.message\n\t\t\t: `请求失败（${envelope.code ?? res.status}）`;\n\tthrow new Error(message);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":49,"fileSize":1167,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxHelper/studioApiClient.ts","readRange":{"startLine":1,"endLine":49},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-edc475e4-5ab4-4d87-8ba4-5459e4897dd4-38\nfc_0bafd1bb-23f3-9475-86ad-dfdda942079d_0","startedAtMs":"1784771294010","completedAtMs":"1784771294150"},"model_call_id":"60f67b1d-3ad1-4611-9cc4-6aa32a145540-9-omxu","session_id":"79bbae55-4798-4921-