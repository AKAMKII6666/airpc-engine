ack}>\n\t\t\t\t\t← 工作台\n\t\t\t\t</Button>\n\t\t\t\t<div>\n\t\t\t\t\t{/* 引用了Typography组件，用于包标题 */}\n\t\t\t\t\t<Typography variant=\"subtitle2\" className={styles.pkg}>\n\t\t\t\t\t\t{packageTitle}\n\t\t\t\t\t</Typography>\n\t\t\t\t\t{/* 引用了Typography组件，用于章节与状态副标题 */}\n\t\t\t\t\t<Typography variant=\"caption\" className={styles.chapter}>\n\t\t\t\t\t\t{chapterTitle} · {saveStateLabel(saveState)}\n\t\t\t\t\t\t{saveError ? ` · ${saveError}` : \"\"} · {validateLabel}\n\t\t\t\t\t</Typography>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div className={styles.actions}>\n\t\t\t\t{/* 引用了Button组件，用于整包保存 */}\n\t\t\t\t<Button\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tvariant=\"contained\"\n\t\t\t\t\tcolor=\"primary\"\n\t\t\t\t\tdisabled={saveDisabled || saveState === \"saving\"}\n\t\t\t\t\tonClick={onSave}\n\t\t\t\t>\n\t\t\t\t\t保存\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于搜索占位 */}\n\t\t\t\t<Button size=\"small\" variant=\"text\" disabled>\n\t\t\t\t\t搜索\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于视图占位 */}\n\t\t\t\t<Button size=\"small\" variant=\"text\" disabled>\n\t\t\t\t\t视图\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于跳转导出页 */}\n\t\t\t\t<Button\n\t\t\t\t\tcomponent={Link}\n\t\t\t\t\thref=\"/packages/export\"\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tvariant=\"outlined\"\n\t\t\t\t>\n\t\t\t\t\t导出\n\t\t\t\t</Button>\n\t\t\t\t{/* 引用了Button组件，用于跳转调试器 */}\n\t\t\t\t<Button component={Link} href=\"/debugger\" size=\"small\" variant=\"contained\">\n\t\t\t\t\t运行调试\n\t\t\t\t</Button>\n\t\t\t</div>\n\t\t</header>\n\t);\n};\n"}},"hookAdditionalContexts":[],"toolCallId":"call-abd26a04-3f88-4280-aa46-03078c69d51f-92\nfc_08478d7f-1665-9edb-899e-2477c6511a7f_0","startedAtMs":"1784771610320"},"model_call_id":"60f67b1d-3ad1-4611-9cc4-6aa32a145540-23-zosi","session_id":"79bbae55-4798-4921-9584-898a64ef9b19","timestamp_ms":1784771610443}
