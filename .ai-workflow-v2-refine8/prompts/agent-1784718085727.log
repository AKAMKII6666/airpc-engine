ted\" || prev.op === \"beat_missing\") &&\n\t\t\t\tprev.beatId.trim() !== \"\"\n\t\t\t\t\t? prev.beatId\n\t\t\t\t\t: \"\";\n\t\t\treturn { op: \"beat_missing\", beatId };\n\t\t}\n\t\tdefault: {\n\t\t\tconst _exhaustive: never = op;\n\t\t\treturn _exhaustive;\n\t\t}\n\t}\n}\n\n/** 由 condition 派生人话预览；嵌套给出只读提示，不假装可编 */\nexport function summarizeExitCondition(condition: ExitCondition): string {\n\tswitch (condition.op) {\n\t\tcase \"always\":\n\t\t\treturn \"始终\";\n\t\tcase \"all_required_beats_completed\":\n\t\t\treturn \"全部必做节拍完成\";\n\t\tcase \"outcome_flag\": {\n\t\t\tconst flagLabel =\n\t\t\t\tOUTCOME_FLAG_OPTIONS.find((o) => o.value === condition.flag)\n\t\t\t\t\t?.label ?? condition.flag;\n\t\t\treturn condition.equals\n\t\t\t\t? `结果标记 · ${flagLabel}`\n\t\t\t\t: `结果标记非 · ${flagLabel}`;\n\t\t}\n\t\tcase \"beat_completed\":\n\t\t\treturn condition.beatId.trim() !== \"\"\n\t\t\t\t? `节拍已完成 · ${condition.beatId}`\n\t\t\t\t: \"节拍已完成（未选 beatId）\";\n\t\tcase \"beat_missing\":\n\t\t\treturn condition.beatId.trim() !== \"\"\n\t\t\t\t? `节拍缺失 · ${condition.beatId}`\n\t\t\t\t: \"节拍缺失（未选 beatId）\";\n\t\tcase \"and\":\n\t\t\treturn `复合条件 and（${condition.items.length} 项，只读）`;\n\t\tcase \"or\":\n\t\t\treturn `复合条件 or（${condition.items.length} 项，只读）`;\n\t\tcase \"not\":\n\t\t\treturn \"复合条件 not（只读）\";\n\t\tdefault:\n\t\t\treturn \"未知条件\";\n\t}\n}\n","message":"The file /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/form/exitList/exitConditionForm.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"call-4413d306-5855-4e89-9b7f-77ec1c70c55c-68\nfc_a4f92916-70eb-90bc-9cbd-23e795c2bce9_0","startedAtMs":"1784718422612","completedAtMs":"1784718423204"},"model_call_id":"f387c279-9edf-4198-96a5-71f8fd7b4d26-19-kmbz","session_id":"5d005d3a-9775-4240-a19d-f2f02555a63d","timestamp_ms":1784718423195}
