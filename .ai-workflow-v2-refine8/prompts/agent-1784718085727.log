{"type":"tool_call","subtype":"started","call_id":"call-0a93f7c0-99ae-4186-969c-087cdc579144-37\nfc_beafcd12-6716-945d-b34b-f7747f811e63_2","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/com/panel/ExitListEditor/com/ExitConditionEditor.tsx","streamContent":"/**\n\t* 出口条件 v1 编辑器：always / outcome_flag / beat_* / all_required。\n\t* 嵌套 and/or/not 只读提示；写回 exit.condition，summary 派生。\n\t*/\n\"use client\";\n\nimport type { FC } from \"react\";\nimport { MenuItem, TextField, Typography } from \"@mui/material\";\nimport type { ExitCondition } from \"@airpc/rpg-engine\";\nimport {\n\tbuildExitConditionForOp,\n\tEXIT_CONDITION_OP_OPTIONS,\n\tisExitConditionV1Leaf,\n\tOUTCOME_FLAG_OPTIONS,\n\tsummarizeExitCondition,\n\ttype ExitConditionV1Op,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/exitConditionForm\";\nimport styles from \"../index.module.scss\";\n\nexport type ExitConditionEditorProps = {\n\t/** 当前出口 condition；嵌套时面板只读 */\n\tcondition: ExitCondition;\n\t/** 本卡 objectives.requiredBeats；供 beatId 下拉 */\n\trequiredBeats: readonly string[];\n\t/** 写回 condition + 派生 summary */\n\tonChange: (next: {\n\t\tcondition: ExitCondition;\n\t\tconditionSummary: string;\n\t}) => void;\n};\n\nexport const ExitConditionEditor: FC<ExitConditionEditorProps> =\n\tfunction ExitConditionEditor({\n\t\t// condition 是引擎 ExitCondition 真源，用于面板绑定\n\t\tcondition,\n\t\t// requiredBeats 是本卡必做节拍，用于 beatId Select\n\t\trequiredBeats,\n\t\t// onChange 同步写回 condition 与派生 summary\n\t\tonChange,\n\t}) {\n\t\tconst editable = isExitConditionV1Leaf(condition);\n\n\t\tfunction commit(next: ExitCondition): void {\n\t\t\tonChange({\n\t\t\t\tcondition: next,\n\t\t\t\tconditionSummary: summarizeExitCondition(next),\n\t\t\t});\n\t\t}\n\n\t\tif (!editable) {\n\t\t\treturn (\n\t\t\t\t<div className={styles.conditionBlock}>\n\t\t\t\t\t{/* 引用了Typography组件，用于嵌套条件只读提示 */}\n\t\t\t\t\t<Typography variant=\"caption\" className={styles.conditionHint}>\n\t\t\t\t\t\t当前为复合条件（and/or/not），本轮不可可视化编辑；保存时保留原\n\t\t\t\t\t\tcondition，不被默认值覆盖。\n\t\t\t\t\t</Typography>\n\t\t\t\t\t{/* 引用了TextField组件，用于只读摘要预览 */}\n\t\t\t\t\t<TextField\n\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\tfullWidth\n\t\t\t\t\t\tmultiline\n\t\t\t\t\t\tminRows={2}\n\t\t\t\t\t\tlabel=\"条件预览（只读）\"\n\t\t\t\t\t\tvalue={summarizeExitCondition(condition)}\n\t\t\t\t\t\tInputProps={{ readOnly: true }}\n\t\t\t\t\t/>\n\t\t\t\t</div>\n\t\t\t);\n\t\t}\n\n\t\tconst beatOptions = Array.from(\n\t\t\tnew Set([\n\t\t\t\t...requiredBeats.filter((id) => id.trim() !== \"\"),\n\t\t\t\tcondition.op === \"beat_completed\" || condition.op === \"beat_missing\"\n\t\t\t\t\t? condition.beatId\n\t\t\t\t\t: \"\",\n\t\t\t]),\n\t\t).filter((id) => id.length > 0);\n\n\t\treturn (\n\t\t\t<div className={styles.conditionBlock}>\n\t\t\t\t{/* 引用了TextField组件，用于条件 op 选择 */}\n\t\t\t\t<TextField\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tfullWidth\n\t\t\t\t\tselect\n\t\t\t\t\tlabel=\"出口条件\"\n\t\t\t\t\tvalue={condition.op}\n\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\tcommit(\n\t\t\t\t\t\t\tbuildExitConditionForOp(\n\t\t\t\t\t\t\t\te.target.value as ExitConditionV1Op,\n\t\t\t\t\t\t\t\tcondition,\n\t\t\t\t\t\t\t),\n\t\t\t\t\t\t);\n\t\t\t\t\t}}\n\t\t\t\t>\n\t\t\t\t\t{EXIT_CONDITION_OP_OPTIONS.map((opt) => (\n\t\t\t\t\t\t// 引用了MenuItem组件，用于条件 op 选项\n\t\t\t\t\t\t<MenuItem key={opt.value} value={opt.value}>\n\t\t\t\t\t\t\t{opt.label}\n\t\t\t\t\t\t</MenuItem>\n\t\t\t\t\t))}\n\t\t\t\t</TextField>\n\n\t\t\t\t{condition.op === \"outcome_flag\" ? (\n\t\t\t\t\t<>\n\t\t\t\t\t\t{/* 引用了TextField组件，用于 outcome flag */}\n\t\t\t\t\t\t<TextField\n\t\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\t\tfullWidth\n\t\t\t\t\t\t\tselect\n\t\t\t\t\t\t\tlabel=\"结果标记\"\n\t\t\t\t\t\t\tvalue={condition.flag}\n\t\t\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\t\t\tcommit({\n\t\t\t\t\t\t\t\t\top: \"outcome_flag\",\n\t\t\t\t\t\t\t\t\tflag: e.target.value,\n\t\t\t\t\t\t\t\t\tequals: condition.equals,\n\t\t\t\t\t\t\t\t});\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t{OUTCOME_FLAG_OPTIONS.map((opt) => (\n\t\t\t\t\t\t\t\t// 引用了MenuItem组件，用于 OutcomeFlag 选项\n\t\t\t\t\t\t\t\t<MenuItem key={opt.value} value={opt.value}>\n\t\t\t\t\t\t\t\t\t{opt.label}\n\t\t\t\t\t\t\t\t</MenuItem>\n\t\t\t\t\t\t\t))}\n\t\t\t\t\t\t</TextField>\n\t\t\t\t\t\t{/* 引用了TextField组件，用于 equals 布尔 */}\n\t\t\t\t\t\t<TextField\n\t\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\t\tfullWidth\n\t\t\t\t\t\t\tselect\n\t\t\t\t\t\t\tlabel=\"等于\"\n\t\t\t\t\t\t\tvalue={condition.equals ? \"true\" : \"false\"}\n\t\t\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\t\t\tcommit({\n\t\t\t\t\t\t\t\t\top: \"outcome_flag\",\n\t\t\t\t\t\t\t\t\tflag: condition.flag,\n\t\t\t\t\t\t\t\t\tequals: e.target.value === \"true\",\n\t\t\t\t\t\t\t\t});\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t{/* 引用了MenuItem组件，用于 equals=true */}\n\t\t\t\t\t\t\t<MenuItem value=\"true\">是</MenuItem>\n\t\t\t\t\t\t\t{/* 引用了MenuItem组件，用于 equals=false */}\n\t\t\t\t\t\t\t<MenuItem value=\"false\">否</MenuItem>\n\t\t\t\t\t\t</TextField>\n\t\t\t\t\t</>\n\t\t\t\t) : null}\n\n\t\t\t\t{condition.op === \"beat_completed\" ||\n\t\t\t\tcondition.op === \"beat_missing\" ? (\n\t\t\t\t\t<>\n\t\t\t\t\t\t{/* 引用了TextField组件，用于 beatId 下拉 */}\n\t\t\t\t\t\t<TextField\n\t\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\t\tfullWidth\n\t\t\t\t\t\t\tselect\n\t\t\t\t\t\t\tlabel=\"节拍 beatId\"\n\t\t\t\t\t\t\tvalue={\n\t\t\t\t\t\t\t\tbeatOptions.includes(condition.beatId)\n\t\t\t\t\t\t\t\t\t? condition.beatId\n\t\t\t\t\t\t\t\t\t: \"\"\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\t\t\tcommit({\n\t\t\t\t\t\t\t\t\top: condition.op,\n\t\t\t\t\t\t\t\t\tbeatId: e.target.value,\n\t\t\t\t\t\t\t\t});\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\thelperText=\"选项来自本卡必做节拍；也可下方手填。\"\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t{/* 引用了MenuItem组件，用于清空 beatId */}\n\t\t\t\t\t\t\t<MenuItem value=\"\">（未选）</MenuItem>\n\t\t\t\t\t\t\t{beatOptions.map((beatId) => (\n\t\t\t\t\t\t\t\t// 引用了MenuItem组件，用于 requiredBeats 选项\n\t\t\t\t\t\t\t\t<MenuItem key={beatId} value={beatId}>\n\t\t\t\t\t\t\t\t\t{beatId}\n\t\t\t\t\t\t\t\t</MenuItem>\n\t\t\t\t\t\t\t))}\n\t\t\t\t\t\t</TextField>\n\t\t\t\t\t\t{/* 引用了TextField组件，用于 beatId 手填逃生 */}\n\t\t\t\t\t\t<TextField\n\t\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\t\tfullWidth\n\t\t\t\t\t\t\tlabel=\"beatId 手填\"\n\t\t\t\t\t\t\tvalue={condition.beatId}\n\t\t\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\t\t\tcommit({\n\t\t\t\t\t\t\t\t\top: condition.op,\n\t\t\t\t\t\t\t\t\tbeatId: e.target.value,\n\t\t\t\t\t\t\t\t});\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\thelperText=\"逃生口：写入未列入 requiredBeats 的 id。\"\n\t\t\t\t\t\t/>\n\t\t\t\t\t</>\n\t\t\t\t) : null}\n\n\t\t\t\t{/* 引用了TextField组件，用于派生条件预览 */}\n\t\t\t\t<TextField\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tfullWidth\n\t\t\t\t\tlabel=\"条件预览\"\n\t\t\t\t\tvalue={summarizeExitCondition(condition)}\n\t\t\t\t\tInputProps={{ readOnly: true }}\n\t\t\t\t\thelperText=\"由 condition 派生；不替代写盘。\"\n\t\t\t\t/>\n\t\t\t</div>\n\t\t);\n\t};\n"}},"hookAdditionalContexts":[],"toolCallId":"call-0a93f7c0-99ae-4186-969c-087cdc579144-37\nfc_beafcd12-6716-945d-b34b-f7747f811e63_2","startedAtMs":"1784718248255"},"model_call_id":"f387c279-9edf-4198-96a5-71f8fd7b4d26-9-aw7j","session_id":"5d005d3a-9775-4240-a19d-f2f02555a63d","timestamp_ms":1784718248265}
