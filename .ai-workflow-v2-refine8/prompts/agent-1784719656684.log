rmik.values.exits);\n\tconst requiredBeats = requiredBeatsFromForm(formik);\n\n\tfunction writeList(next: ExitListFormRow[]): void {\n\t\tvoid formik.setFieldValue(\"exits\", next);\n\t\tvoid formik.setFieldTouched(\"exits\", true);\n\t}\n\n\tfunction patchRow(\n\t\tindex: number,\n\t\tpatch: Partial<ExitListFormRow>,\n\t): void {\n\t\twriteList(\n\t\t\tlist.map((row, i) => (i === index ? { ...row, ...patch } : row)),\n\t\t);\n\t}\n\n\treturn (\n\t\t<div className={styles.root}>\n\t\t\t{/* 引用了Typography组件，用于出口列表说明 */}\n\t\t\t<Typography variant=\"caption\" className={styles.hint}>\n\t\t\t\t出口 Handle 按本列表动态生成；条件写 exit.condition（v1 叶子可编）。\n\t\t\t</Typography>\n\t\t\t<ul className={styles.list}>\n\t\t\t\t{list.map((row, index) => (\n\t\t\t\t\t// 引用了ExitListRow组件，用于单出口字段编辑\n\t\t\t\t\t<ExitListRow\n\t\t\t\t\t\tkey={row.exitId}\n\t\t\t\t\t\trow={row}\n\t\t\t\t\t\tindex={index}\n\t\t\t\t\t\trequiredBeats={requiredBeats}\n\t\t\t\t\t\tsources={sources}\n\t\t\t\t\t\tonPatch={patchRow}\n\t\t\t\t\t\tonRemove={(removeIndex) => {\n\t\t\t\t\t\t\twriteList(list.filter((_, i) => i !== removeIndex));\n\t\t\t\t\t\t}}\n\t\t\t\t\t/>\n\t\t\t\t))}\n\t\t\t</ul>\n\t\t\t{/* 引用了Button组件，用于新增出口 */}\n\t\t\t<Button\n\t\t\t\tsize=\"small\"\n\t\t\t\tvariant=\"outlined\"\n\t\t\t\tonClick={() => {\n\t\t\t\t\twriteList([...list, emptyExitRow(list)]);\n\t\t\t\t}}\n\t\t\t>\n\t\t\t\t添加出口\n\t\t\t</Button>\n\t\t</div>\n\t);\n};\n","isEmpty":false,"exceededLimit":false,"totalLines":99,"fileSize":3050,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/com/panel/ExitListEditor/ExitListEditor.tsx","readRange":{"startLine":1,"endLine":99},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-efc5fd96-08c7-45aa-ba08-eca42c1454c8-35\nfc_180ea35d-fb18-96a9-9111-dbcff02a61f0_1","startedAtMs":"1784719731686","completedAtMs":"1784719731831"},"model_call_id":"c409cd48-d9a4-4532-91cf-5021d9a3da75-9-xuqz","session_id":"5553ba5b-1321