ition: { op: \"always\" },\n\t\t\t\t\tconditionSummary: \"\",\n\t\t\t\t\teffects: [],\n\t\t\t\t},\n\t\t\t\tbase,\n\t\t\t),\n\t\t).toEqual({ op: \"always\" });\n\t\texpect(\n\t\t\tresolveExitCondition(\n\t\t\t\t{\n\t\t\t\t\texitId: \"exit_ok\",\n\t\t\t\t\tpriority: 0,\n\t\t\t\t\tconditionSummary: \"\",\n\t\t\t\t\teffects: [],\n\t\t\t\t},\n\t\t\t\tbase,\n\t\t\t),\n\t\t).toEqual(base.condition);\n\t\texpect(\n\t\t\tresolveExitCondition({\n\t\t\t\texitId: \"exit_new\",\n\t\t\t\tpriority: 0,\n\t\t\t\tconditionSummary: \"\",\n\t\t\t\teffects: [],\n\t\t\t}),\n\t\t).toEqual(defaultExitCondition());\n\t});\n\n\tit(\"writes edited leaf condition even when summary text differs\", () => {\n\t\tconst def = sampleCard([], {\n\t\t\top: \"outcome_flag\",\n\t\t\tflag: \"answered_completed\",\n\t\t\tequals: true,\n\t\t});\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\tproj.exits[0] = {\n\t\t\t...proj.exits[0]!,\n\t\t\tcondition: { op: \"beat_completed\", beatId: \"beat_from_required\" },\n\t\t\tconditionSummary: \"任意人话，不得替代 condition\",\n\t\t};\n\t\tconst back = callCardProjectionToDef(proj, def);\n\t\texpect(back.exits[0]?.condition).toEqual({\n\t\t\top: \"beat_completed\",\n\t\t\tbeatId: \"beat_from_required\",\n\t\t});\n\t});\n});\n"}},"hookAdditionalContexts":[],"toolCallId":"call-13f3e6ca-0033-4269-b097-2e4f7e000deb-51\nfc_38eec93f-3b1a-9bd7-b44e-3ace9045649c_3","startedAtMs":"1784719798280"},"model_call_id":"c409cd48-d9a4-4532-91cf-5021d9a3da75-13-8l9h","session_id":"5553ba5b-1321-4e89-b04c-2f1eadf21aad","timestamp_ms":1784719798268}
