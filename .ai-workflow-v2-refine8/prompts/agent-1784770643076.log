le: string;\n\tdescription?: string;\n\twithStartCard?: boolean;\n\tpackageId?: string;\n}): Promise<DiskStoryPackageBundle> {\n\tconst res = await fetch(\"/api/stories\", {\n\t\tmethod: \"POST\",\n\t\theaders: { \"Content-Type\": \"application/json\" },\n\t\tbody: JSON.stringify(body),\n\t});\n\treturn parseStudioApiJson<DiskStoryPackageBundle>(res);\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-21fde69b-0c29-44cf-99e8-edeb5c57c079-119\nfc_db1fd539-4b80-9c8f-a921-8e15ab02eeb7_0","startedAtMs":"1784770936147"},"model_call_id":"a4ddf5ab-bdf9-4190-9892-f4da1b574d4b-31-2a2o","session_id":"086c6681-fcf7-46d9-8405-ea9407b78f48","timestamp_ms":1784770936080}
