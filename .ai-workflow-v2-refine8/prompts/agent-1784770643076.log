rm(formik) {\n\t\t\t\t\tconst formError =\n\t\t\t\t\t\ttypeof formik.status === \"object\" &&\n\t\t\t\t\t\tformik.status !== null &&\n\t\t\t\t\t\t\"formError\" in formik.status &&\n\t\t\t\t\t\ttypeof (formik.status as { formError?: unknown }).formError ===\n\t\t\t\t\t\t\t\"string\"\n\t\t\t\t\t\t\t? (formik.status as { formError: string }).formError\n\t\t\t\t\t\t\t: undefined;\n\n\t\t\t\t\treturn (\n\t\t\t\t\t\t<form\n\t\t\t\t\t\t\tclassName={styles.form}\n\t\t\t\t\t\t\tonSubmit={formik.handleSubmit}\n\t\t\t\t\t\t\tnoValidate\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t{formError ? (\n\t\t\t\t\t\t\t\t// 引用了Alert组件，用于展示提交级错误\n\t\t\t\t\t\t\t\t<Alert severity=\"error\" role=\"alert\">\n\t\t\t\t\t\t\t\t\t{formError}\n\t\t\t\t\t\t\t\t</Alert>\n\t\t\t\t\t\t\t) : null}\n\t\t\t\t\t\t\t{/* 引用了AutoForm组件，用于编排新建故事包字段 */}\n\t\t\t\t\t\t\t<AutoForm\n\t\t\t\t\t\t\t\tformik={formik}\n\t\t\t\t\t\t\t\tmode=\"add\"\n\t\t\t\t\t\t\t\tenabled\n\t\t\t\t\t\t\t\titems={CREATE_PACKAGE_FORM_ITEMS}\n\t\t\t\t\t\t\t/>\n\t\t\t\t\t\t\t<div className={styles.footer}>\n\t\t\t\t\t\t\t\t{/* 引用了Button组件，用于取消返回列表 */}\n\t\t\t\t\t\t\t\t<Button component={Link} href=\"/packages\" variant=\"text\">\n\t\t\t\t\t\t\t\t\t取消\n\t\t\t\t\t\t\t\t</Button>\n\t\t\t\t\t\t\t\t{/* 引用了Button组件，用于提交并进入编辑器 */}\n\t\t\t\t\t\t\t\t<Button\n\t\t\t\t\t\t\t\t\ttype=\"submit\"\n\t\t\t\t\t\t\t\t\tvariant=\"contained\"\n\t\t\t\t\t\t\t\t\tdisabled={formik.isSubmitting}\n\t\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t\t创建并进入编辑器\n\t\t\t\t\t\t\t\t</Button>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</form>\n\t\t\t\t\t);\n\t\t\t\t}}\n\t\t\t</Formik>\n\t\t</main>\n\t);\n};\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/packages/create/CreatePackageView.tsx","linesAdded":3,"linesRemoved":3,"diffString":"--- a//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/packages/create/CreatePackageView.tsx\n+++ b//Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/packages/create/CreatePack