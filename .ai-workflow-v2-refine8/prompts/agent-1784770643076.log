{"type":"tool_call","subtype":"completed","call_id":"call-a1711d22-c382-463c-8603-8716d8b00714-124\nfc_4a5b7168-4c38-9bec-947a-9ad7a1fa8aea_0","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/commonUiComponents/modal/shared/modalTypes.ts"},"result":{"success":{"content":"/**\n\t* commonUi Modal 契约：统一 Dialog 壳与 Formik 表单弹层。\n\t* 只放展示/交互 props；业务提交编排留在 bis / 调用方。\n\t*/\n\nimport type { ReactNode } from \"react\";\nimport type { FormikErrors, FormikProps } from \"formik\";\nimport type { AutoFormItem } from \"../../form/autoFormTypes\";\nimport type { FormFieldMode } from \"../../form/formTypes\";\n\n/** AppModal / FormModal 共用的宽度档；对应 MUI Dialog maxWidth */\nexport type AppModalMaxWidth = \"xs\" | \"sm\" | \"md\" | \"lg\";\n\n/**\n\t* 无表单的通用 Dialog 壳。\n\t* 动作区由调用方传入，避免壳内耦合业务按钮语义。\n\t*/\nexport type AppModalProps = {\n\topen: boolean;\n\ttitle: string;\n\tonClose: () => void;\n\tchildren: ReactNode;\n\t/** 底部动作区；省略则不渲染 DialogActions */\n\tactions?: ReactNode;\n\t/** 标题下的说明文案（全中文） */\n\tdescription?: string;\n\tmaxWidth?: AppModalMaxWidth;\n\t/**\n\t\t* 忙碌态：拦截 Esc / 遮罩关闭，防止半提交态被关掉。\n\t\t* 单位：布尔开关；与 Formik isSubmitting 对齐。\n\t\t*/\n\tbusy?: boolean;\n};\n\n/**\n\t* 内嵌 Formik 的表单弹层。\n\t* 主路径：items → AutoForm；无 items 时用 children 逃生口。\n\t*/\nexport type FormModalProps<\n\tTValues extends Record<string, unknown> = Record<string, unknown>,\n> = {\n\topen: boolean;\n\ttitle: string;\n\tonClose: () => void;\n\t/** Formik 初值；弹层重开时由 enableReinitialize 同步 */\n\tinitialValues: TValues;\n\t/**\n\t\t* 提交回调；成功后由调用方决定是否关弹层 / 跳转。\n\t\t* 抛错或 reject 时文案进入弹层错误区，不自动关闭。\n\t\t*/\n\tonSubmit: (values: TValues) => void | Promise<void>;\n\tmode?: FormFieldMode;\n\t/** AutoForm 声明式 items；主编排路径 */\n\titems?: AutoFormItem[];\n\t/** 自定义表单体；已提供 items 时忽略 */\n\tchildren?: (formik: FormikProps<TValues>) => ReactNode;\n\tvalidate?: (\n\t\tvalues: TValues,\n\t) => void | FormikErrors<TValues> | Promise<FormikErrors<TValues>>;\n\t/** 主按钮文案；默认「确认」 */\n\tsubmitLabel?: string;\n\t/** 取消按钮文案；默认「取消」 */\n\tcancelLabel?: string;\n\tdescription?: string;\n\tmaxWidth?: AppModalMaxWidth;\n\t/** 调用方注入的表单级错误（优先于 Formik status） */\n\tformError?: string;\n};\n","isEmpty":false,"exceededLimit":false,"totalLines":69,"fileSize":2262,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/commonUiComponents/modal/shared/modalTypes.ts","readRange":{"startLine":1,"endLine":69},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-a1711d22-c382-463c-8603-8716d8b00714-124\nfc_4a5b7168-4c38-9bec-947a-9ad7a1fa8aea_0","startedAtMs":"1784770957518","completedAtMs":"1784770957694"},"model_call_id":"a4ddf5ab-bdf9-4190-9892-f4da1b574d4b-32-y2uc","session_id":"086c6681-fcf7-46d9-8405-ea9407b78f48","timestamp_ms":1784770957627}
