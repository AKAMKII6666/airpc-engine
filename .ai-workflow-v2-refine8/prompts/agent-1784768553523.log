(\n\t\t\t\t\t<ul className={styles.list}>\n\t\t\t\t\t\t{assetOptions.map(function (opt) {\n\t\t\t\t\t\t\treturn (\n\t\t\t\t\t\t\t\t<li key={opt.value} className={styles.item}>\n\t\t\t\t\t\t\t\t\t{/* 引用了FormControlLabel组件，用于勾选包级资产引用 */}\n\t\t\t\t\t\t\t\t\t<FormControlLabel\n\t\t\t\t\t\t\t\t\t\tcontrol={\n\t\t\t\t\t\t\t\t\t\t\t// 引用了Checkbox组件，用于写入 conf.assetRefs\n\t\t\t\t\t\t\t\t\t\t\t<Checkbox\n\t\t\t\t\t\t\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\t\t\t\t\t\t\tchecked={selected.has(opt.value)}\n\t\t\t\t\t\t\t\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\t\t\t\t\t\t\t\ttoggle(opt.value, e.target.checked);\n\t\t\t\t\t\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\t\t\t\t\t\tinputProps={{\n\t\t\t\t\t\t\t\t\t\t\t\t\t\"aria-label\": `引用资产 ${opt.label}`,\n\t\t\t\t\t\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\t\t\t\t\t/>\n\t\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t\t\tlabel={opt.label}\n\t\t\t\t\t\t\t\t\t/>\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t);\n\t\t\t\t\t\t})}\n\t\t\t\t\t</ul>\n\t\t\t\t)}\n\t\t\t</div>\n\t\t);\n\t};\n","isEmpty":false,"exceededLimit":false,"totalLines":81,"fileSize":2496,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/library/PackageAssetRefsEditor.tsx","readRange":{"startLine":1,"endLine":81},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-fc4ac04b-6a6a-4a13-90d8-aa8d067e1bda-42\nfc_1dba77f2-003e-9bcb-9f9c-30f8964271ba_2","startedAtMs":"1784768640928","completedAtMs":"1784768641101"},"model_call_id":"962c4d68-4691-490e-ac1c-46694bb6125b-9-olmh","session_id":"e15d86d9-5b06-4711-9901-566b8f282b49","timestamp_ms":1784768641107}
