: true, force: true });\\n      tmpRoot = undefined;\\n    }\\n  });\\n\\n  it(\\\"package-local schedule node cannot be recurring target\\\", async () => {\\n    tmpRoot = await mkdtemp(path.join(os.tmpdir(), \\\"airpc-sched-pkg-node-\\\"));\\n    const dataRoot = path.join(tmpRoot, \\\"data\\\");\\n    await cp(dataSrc, dataRoot, { recursive: true });\\n\\n    const confPath = path.join(\\n      dataRoot,\\n      \\\"storis-packages/golden_handoff/story.conf.json\\\",\\n    );\\n    const conf = JSON.parse(await readFile(confPath, \\\"utf8\\\")) as {\\n      cards: Array<{ cardId: string }>;\\n    };\\n    conf.cards.push({ cardId: \\\"plot_schedule_node\\\" });\\n    conf.cards.push({ cardId: \\\"free_host_for_recurring\\\" });\\n    await writeFile(confPath, JSON.stringify(conf, null, 2) + \\\"\\\\n\\\", \\\"utf8\\\");\\n\\n    const plotScheduleNode = {\\n      cardId: \\\"plot_schedule_node\\\",\\n      cardKind: \\\"schedule\\\",\\n      title: \\\"包内剧情调度节点\\\",\\n      ownerAgentId: \\\"doubao-sister\\\",\\n      entryMode: \\\"outbound_auto\\\",\\n      interactionMode: \\\"realtime_dialogue\\\",\\n      context: {\\n        privateBrief: \\\"t\\\",\\n        speakableBrief: \\\"t\\\",\\n        background: \\\"\\\",\\n        premise: \\\"\\\",\\n        emotion: \\\"\\\",\\n        objective: \\\"\\\",\\n        forbidden: [],\\n      },\\n      objectives: { requiredBeats: [] },\\n      toolPolicy: { mode: \\\"inherit_free\\\" },\\n      schedule: { mode: \\\"daily\\\", hour: 10 },\\n      exits: [],\\n    };\\n    await writeFile(\\n      path.join(\\n        dataRoot,\\n        \\\"storis-packages/golden_handoff/cards/plot_schedule_node.s-card.json\\\",\\n      ),\\n      JSON.stringify(plotScheduleNode, null, 2) + \\\"\\\\n\\\",\\n      \\\"utf8\\\",\\n    );\\n\\n    const freeHost = {\\n      cardId: \\\"free_host_for_recurring\\\",\\n      cardKind: \\\"free\\\",\\n      title: \\\"host\\\",\\n      ownerAgentId: \\\"doubao-sister\\\",\\n      entr