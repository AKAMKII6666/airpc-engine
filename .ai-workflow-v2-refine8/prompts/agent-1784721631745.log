splayName?.trim();\\n\\t\\tconst displayName =\\n\\t\\t\\trawName !== undefined && rawName !== \\\"\\\" ? rawName : agentId;\\n\\t\\tconst pendingCardCount = pendingCountForAgent(agentId, bundle.cards);\\n\\t\\tconst data: CharacterAnchorNodeData = {\\n\\t\\t\\tagentId,\\n\\t\\t\\tdisplayName,\\n\\t\\t\\tstatusLabel: characterAnchorStatusLabel(pendingCardCount),\\n\\t\\t\\tpendingCardCount,\\n\\t\\t};\\n\\t\\treturn {\\n\\t\\t\\tid: anchorNodeId(agentId),\\n\\t\\t\\ttype: \\\"characterAnchor\\\" as const,\\n\\t\\t\\tposition: { x: -40, y: 40 + index * 110 },\\n\\t\\t\\tdata,\\n\\t\\t\\tdraggable: false,\\n\\t\\t\\tselectable: true,\\n\\t\\t};\\n\\t});\\n}\\n\\n/** layout role 边 target 可能是裸 agentId；统一成 anchor_* 节点 id */\\nexport function resolveAnchorTarget(target: string): string {\\n\\tif (target.startsWith(\\\"anchor_\\\")) return target;\\n\\treturn anchorNodeId(target);\\n}\\n\\n/** 卡投影用展示名：优先角色库 lookup，缺省回落 agentId */\\nexport function ownerDisplayNameForCard(\\n\\tcard: CallCardDefinition,\\n\\tnames: CharacterDisplayLookup,\\n): string {\\n\\tconst agentId = card.ownerAgentId ?? \\\"\\\";\\n\\tif (agentId && names[agentId]?.displayName) {\\n\\t\\treturn names[agentId]!.displayName;\\n\\t}\\n\\treturn agentId;\\n}\\n\",\"message\":\"The file /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/graph/characterAnchorGraph.ts has been updated.\"}}},\"hookAdditionalContexts\":[],\"toolCallId\":\"call-36491a3d-2028-4e62-8434-c8cd807d5319-59\\nfc_6e7062cd-cee9-97fc-9868-fd4f23835bf7_0\",\"startedAtMs\":\"1784721614852\",\"completedAtMs\":\"1784721615294\"},\"model_call_id\":\"6f083b9c-715b-401c-bee6-8dedacfc25fa-18-bt8z\",\"session_id\":\"9981a650-ae57-4a10-b6bb-90832abae14e\",\"timestamp_ms\":1784721615418}\n{\"type\":\"tool_call\",\"subtype\":\"completed\",\"call_id\":\"call-36491a3d-2028-4e62-8434-c8cd807d5319-60\\nfc_6e7062cd-cee9-97fc-9868-fd4f23835bf7_1\",\"tool_call\":{\"shellToolCall\":{\"args\":{\"command\":\"npm run quali