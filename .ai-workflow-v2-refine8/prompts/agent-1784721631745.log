plication/json\" },\n\t\tbody: JSON.stringify({ character }),\n\t});\n\tconst data = await parseStudioApiJson<CharacterOneData>(res);\n\treturn data.character;\n}\n\n/** DELETE /api/characters/:agentId */\nexport async function deleteCharacterDef(agentId: string): Promise<void> {","isEmpty":false,"exceededLimit":false,"totalLines":66,"fileSize":2064,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxProxy/library/api/charactersApi.ts","readRange":{"startLine":1,"endLine":60},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-36dff93b-233e-4653-8fa7-f17f1ed0c76f-37\nfc_7eed3cd1-6e60-9cf9-affd-17b0737cae5a_3","startedAtMs":"1784721684166","completedAtMs":"1784721684354"},"model_call_id":"658f42f1-1bf6-445a-a1d9-ec67fb86384d-7-2x7w","session_id":"825c0ccb-6319-4e70-83d3-6360f165f6e5","timestamp_ms":1784721684401}
