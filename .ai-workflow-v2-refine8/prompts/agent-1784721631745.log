/apps/studioV2/src/pageComponents/storyEditor/canvas/nodes/CharacterAnchorFlowNode.tsx","readRange":{"startLine":1,"endLine":48},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-9f1bfdbc-d29c-41d5-8ccb-b344b0245801-20\nfc_3f5c333e-281d-9ad2-aa8c-385b7c057d59_3","startedAtMs":"1784721668046","completedAtMs":"1784721668142"},"model_call_id":"658f42f1-1bf6-445a-a1d9-ec67fb86384d-4-lnja","session_id":"825c0ccb-6319-4e70-83d3-6360f165f6e5","timestamp_ms":1784721668182}
