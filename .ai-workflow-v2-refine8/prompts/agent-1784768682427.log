\t}\n\treturn {\n\t\tassetId: input.assetId,\n\t\tkind: \"image\",\n\t\turi,\n\t\tdisplayName,\n\t\tmeta: bag,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-25eb4be4-2517-4123-a6c2-6950a73517a8-60\nfc_b809e1c9-13d8-9083-b881-e248a90e0a99_1","startedAtMs":"1784768788275"},"model_call_id":"17288759-001b-4838-a5a3-bc802f2e36cd-13-wvxi","session_id":"b7917dae-9ff2-4027-991c-a16f09dab1b5","timestamp_ms":1784768788239}
