.then(function onOk(assetId) {\n\t\t\t\topts.onUploaded(assetId);\n\t\t\t})\n\t\t\t.catch(function onFail(err: unknown) {\n\t\t\t\tsetUploadError(\n\t\t\t\t\terr instanceof Error ? err.message : \"头像上传失败，请重试\",\n\t\t\t\t);\n\t\t\t})\n\t\t\t.finally(function onDone() {\n\t\t\t\tsetUploading(false);\n\t\t\t});\n\t}\n\n\treturn {\n\t\tlocalPreviewUrl,\n\t\tuploading,\n\t\tuploadError,\n\t\thandleFilePick,\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-6ab9750e-2b78-4019-a2f2-8280f118d765-95\nfc_5d3b7ca8-66a8-9169-90ce-3065e509ccfd_0","startedAtMs":"1784768938356"},"model_call_id":"17288759-001b-4838-a5a3-bc802f2e36cd-27-un15","session_id":"b7917dae-9ff2-4027-991c-a16f09dab1b5","timestamp_ms":1784768938317}
