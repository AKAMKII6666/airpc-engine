{"type":"tool_call","subtype":"completed","call_id":"call-997180f0-8bb2-4288-9481-2354371d6020-30\nfc_0925605a-6215-9715-a53e-c75a9ff0d268_1","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxProxy/library/api/assetsApi.ts"},"result":{"success":{"content":"/**\n\t* 资源库 BFF：读写 data/assets（经 /api/assets）。\n\t* 列表/详情 UI 用 AssetSummary；写盘用 AssetMeta。\n\t*/\nimport type { AssetMeta } from \"@airpc/rpg-engine\";\nimport { parseStudioApiJson } from \"@studio-v2/src/utils/ajaxHelper/studioApiClient\";\nimport type { CreateAssetFormValues } from \"@studio-v2/src/bis/pageBis/assets/createAssetForm\";\nimport type { AssetSummary } from \"@studio-v2/typeFiles/library/assets/assetSummary\";\n\nexport type AssetsListData = {\n\tassets: AssetSummary[];\n};\n\nexport type AssetOneData = {\n\tasset: AssetSummary;\n\t/** 磁盘真源；详情保存合并用 */\n\tmeta: AssetMeta;\n};\n\n/** GET /api/assets：列出磁盘资产投影 */\nexport async function fetchAssetSummaries(): Promise<AssetSummary[]> {\n\tconst res = await fetch(\"/api/assets\");\n\tconst data = await parseStudioApiJson<AssetsListData>(res);\n\treturn data.assets;\n}\n\n/** GET /api/assets/:assetId：投影 + 原始 meta */\nexport async function fetchAssetRecord(\n\tassetId: string,\n): Promise<AssetOneData> {\n\tconst res = await fetch(`/api/assets/${encodeURIComponent(assetId)}`);\n\treturn parseStudioApiJson<AssetOneData>(res);\n}\n\n/**\n\t* POST /api/assets：表单新建（系统 assetId）。\n\t* 仅写 meta；二进制上传留给 S8-14。\n\t*/\nexport async function postAssetFromForm(\n\tassetId: string,\n\tform: CreateAssetFormValues,\n): Promise<AssetSummary> {\n\tconst res = await fetch(\"/api/assets\", {\n\t\tmethod: \"POST\",\n\t\theaders: { \"Content-Type\": \"application/json\" },\n\t\tbody: JSON.stringify({ assetId, form }),\n\t});\n\tconst data = await parseStudioApiJson<AssetOneData>(res);\n\treturn data.asset;\n}\n\n/** PUT /api/assets/:assetId：整份 AssetMeta 落盘 */\nexport async function putAssetMeta(\n\tassetId: string,\n\tasset: AssetMeta,\n): Promise<AssetSummary> {\n\tconst res = await fetch(`/api/assets/${encodeURIComponent(assetId)}`, {\n\t\tmethod: \"PUT\",\n\t\theaders: { \"Content-Type\": \"application/json\" },\n\t\tbody: JSON.stringify({ asset }),\n\t});\n\tconst data = await parseStudioApiJson<AssetOneData>(res);\n\treturn data.asset;\n}\n\n/** DELETE /api/assets/:assetId */\nexport async function deleteAsset(assetId: string): Promise<void> {\n\tconst res = await fetch(`/api/assets/${encodeURIComponent(assetId)}`, {\n\t\tmethod: \"DELETE\",\n\t});\n\tawait parseStudioApiJson<{ ok: true }>(res);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":73,"fileSize":2281,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxProxy/library/api/assetsApi.ts","readRange":{"startLine":1,"endLine":73},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-997180f0-8bb2-4288-9481-2354371d6020-30\nfc_0925605a-6215-9715-a53e-c75a9ff0d268_1","startedAtMs":"1784768714953","completedAtMs":"1784768715094"},"model_call_id":"17288759-001b-4838-a5a3-bc802f2e36cd-7-dy6n","session_id":"b7917dae-9ff2-4027-991c-a16f09dab1b5","timestamp_ms":1784768715058}
