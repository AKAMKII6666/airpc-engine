{"type":"tool_call","subtype":"completed","call_id":"call-f2b16d70-24be-4fa4-9531-202dfa2eec25-44\nfc_8a65ea2a-c989-98f2-8b64-4f5994f31bde_2","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxHelper/studioApiClient.ts"},"result":{"success":{"content":"/**\n\t* Studio V2 客户端 API 响应解析（ajaxHelper）。\n\t* 统一 { ok:true, data } / { ok:false, code, message }；禁止页面裸拼错误分支。\n\t*/\n\nexport type StudioApiFail = {\n\tok: false;\n\tcode: string;\n\tmessage: string;\n\tdetails?: unknown;\n};\n\nexport type StudioApiOk<T> = {\n\tok: true;\n\tdata: T;\n};\n\nexport type StudioApiEnvelope<T> = StudioApiOk<T> | StudioApiFail;\n\n/**\n\t* 解析 fetch Response；非 JSON 或业务失败时抛 Error（message 为人话）。\n\t*/\nexport async function parseStudioApiJson<T>(\n\tres: Response,\n): Promise<T> {\n\tlet body: unknown;\n\ttry {\n\t\tbody = await res.json();\n\t} catch {\n\t\tthrow new Error(`请求失败（HTTP ${res.status}），响应非 JSON`);\n\t}\n\tif (\n\t\ttypeof body !== \"object\" ||\n\t\tbody === null ||\n\t\t!(\"ok\" in body)\n\t) {\n\t\tthrow new Error(`请求失败（HTTP ${res.status}），响应格式无效`);\n\t}\n\tconst envelope = body as StudioApiEnvelope<T>;\n\tif (envelope.ok === true) {\n\t\treturn envelope.data;\n\t}\n\tconst message =\n\t\ttypeof envelope.message === \"string\" && envelope.message.trim() !== \"\"\n\t\t\t? envelope.message\n\t\t\t: `请求失败（${envelope.code ?? res.status}）`;\n\tthrow new Error(message);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":49,"fileSize":1167,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxHelper/studioApiClient.ts","readRange":{"startLine":1,"endLine":49},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f2b16d70-24be-4fa4-9531-202dfa2eec25-44\nfc_8a65ea2a-c989-98f2-8b64-4f5994f31bde_2","startedAtMs":"1784768741553","completedAtMs":"1784768741831"},"model_call_id":"17288759-001b-4838-a5a3-bc802f2e36cd-9-2dbb","session_id":"b7917dae-9ff2-4027-