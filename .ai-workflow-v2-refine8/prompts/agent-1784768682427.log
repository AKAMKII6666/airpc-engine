ror = readFormError(formik.status);\n\n\t\treturn (\n\t\t\t<form onSubmit={formik.handleSubmit} noValidate>\n\t\t\t\t{formError ? (\n\t\t\t\t\t// 引用了Alert组件，用于展示提交级错误\n\t\t\t\t\t<Alert severity=\"error\" role=\"alert\">\n\t\t\t\t\t\t{formError}\n\t\t\t\t\t</Alert>\n\t\t\t\t) : null}\n\n\t\t\t\t<div className={styles.section}>\n\t\t\t\t\t<h3 className={styles.sectionTitle}>基本信息</h3>\n\t\t\t\t\t{/* 引用了AutoForm组件，用于编排头像与基本信息字段 */}\n\t\t\t\t\t<AutoForm\n\t\t\t\t\t\tformik={formik}\n\t\t\t\t\t\tmode=\"edit\"\n\t\t\t\t\t\tenabled\n\t\t\t\t\t\titems={CHARACTER_BASIC_ITEMS}\n\t\t\t\t\t/>\n\t\t\t\t</div>\n\n\t\t\t\t<div className={styles.section}>\n\t\t\t\t\t<h3 className={styles.sectionTitle}>提示词</h3>\n\t\t\t\t\t{/* 引用了AutoForm组件，用于编排人设与场景提示词字段 */}\n\t\t\t\t\t<AutoForm\n\t\t\t\t\t\tformik={formik}\n\t\t\t\t\t\tmode=\"edit\"\n\t\t\t\t\t\tenabled\n\t\t\t\t\t\titems={CHARACTER_PROMPT_ITEMS}\n\t\t\t\t\t/>\n\t\t\t\t</div>\n\n\t\t\t\t{/* 引用了CharacterSchedulePanel组件，用于场景提示词下方定时外呼 */}\n\t\t\t\t<CharacterSchedulePanel agentId={character.agentId} />\n\n\t\t\t\t<div className={styles.section}>\n\t\t\t\t\t<h3 className={styles.sectionTitle}>引用情况</h3>\n\t\t\t\t\t{character.referenceLines.length === 0 ? (\n\t\t\t\t\t\t// 引用了Typography组件，用于无引用空态\n\t\t\t\t\t\t<Typography variant=\"body2\" color=\"text.secondary\">\n\t\t\t\t\t\t\t尚未被故事包引用\n\t\t\t\t\t\t</Typography>\n\t\t\t\t\t) : (\n\t\t\t\t\t\t<ul className={styles.refList}>\n\t\t\t\t\t\t\t{character.referenceLines.map((line) => (\n\t\t\t\t\t\t\t\t<li key={line}>{line}</li>\n\t\t\t\t\t\t\t))}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t)}\n\t\t\t\t</div>\n\n\t\t\t\t<div className={styles.advanced}>\n\t\t\t\t\t<h3 className={styles.sectionTitle}>高级信息</h3>\n\t\t\t\t\t<div className={styles.advancedId}>agentId · {character.agentId}</div>\n\t\t\t\t\t{/* 引用了Typography组件，用于只读展示头像资源 id */}\n\t\t\t\t\t<Typography variant=\"caption\" className={styles.detailMeta}>\n\t\t\t\t\t\t头像资源：\n\t\t\t\t\t\t{character.avatarAssetId ?? \"默认头像（无破图）\"}\n\t\t\t\t\t</Typography>\n\t\t\t\t</div>\n\n\t\t\t\t<div className={styles.section}>\n\t\t\t\t\t{/* 引用了Button组件，用于提交并落盘 */}\n\t\t\t\t\t<Button\n\t\t\t\t\t\ttype=\"submit\"\n\t\t\t\t\t\tvariant=\"contained\"\n\t\t\t\t\t\tdisabled={formik.isSubmitting}\n\t\t\t\t\t>\n\t\t\t\t\t\t保存到角色 JSON\n\t\t\t\t\t</Button>\n\t\t\t\t</div>\n\t\t\t</form>\n\t\t);\n\t};\n","isEmpty":false,"exceededLimit":false,"totalLines":122,"fileSize":3962,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/characters/com/CharacterDetailEditForm.tsx","readRange":{"startLine":1,"endLine":122},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-b96482f8-82b0-41ac-b5d7-882c17ebe072-17\nfc_b6371142-564a-91de-984a-16f5af801891_5","startedAtMs":"1784768703375","completedAtMs":"1784768703582"},"model_call_id":"17288759-001b-4838-a5a3-bc802f2e36cd-4-yc0w","session_id":"b7917dae-9ff2-4027-991c-a16f09dab1b5","timestamp_ms":1784768703622}
