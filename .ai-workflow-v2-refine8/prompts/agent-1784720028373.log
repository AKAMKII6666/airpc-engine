n\t\t\t\ttitle,\n\t\t\t\texitKind,\n\t\t\t\tpriority,\n\t\t\t\tconditionSummary,\n\t\t\t\teffects: normalizeEffectList(row.effects),\n\t\t\t};\n\t\t\tif (condition !== undefined) {\n\t\t\t\tnormalized.condition = condition;\n\t\t\t}\n\t\t\treturn normalized;\n\t\t})\n\t\t.filter((row) => row.exitId.length > 0);\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":178,"fileSize":5714,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/form/exitList/exitListForm.ts","readRange":{"startLine":115,"endLine":178},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f2a44ba1-842b-499b-abe0-e1d9ba5eb41d-16\nfc_073af608-afdb-9c02-abab-95a0e648d7b1_1","startedAtMs":"1784720151840","completedAtMs":"1784720152026"},"model_call_id":"b2981217-1094-4495-bedc-2d366b5462b5-4-ivrq","session_id":"ed19c1d9-bc9f-4ebc-94da-c517ab71378a","timestamp_ms":1784720152018}
