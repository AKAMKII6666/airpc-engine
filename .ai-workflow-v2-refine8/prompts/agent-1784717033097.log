", `${orphan}.s-card.json`));\n\t}\n\n\tawait writeJson(path.join(dir, \"canvas.layout.json\"), layout);\n\tconst ordered = conf.cards.map(function (ref) {\n\t\treturn byId.get(ref.cardId)!;\n\t});\n\treturn { conf, cards: ordered, layout };\n}\n\n/** 包目录是否已有 story.conf.json（未校验 schema） */\nexport async function packageExists(packageId: string): Promise<boolean> {\n\tif (!isValidPackageId(packageId)) return false;\n\treturn pathExists(path.join(packageDir(packageId), \"story.conf.json\"));\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":274,"fileSize":7346,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/packages/fs/packagesFs.server.ts","readRange":{"startLine":205,"endLine":274},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f4f83305-a7c7-471d-9ff6-65fed79b7718-25\nfc_16285d6c-f332-903d-af45-fb13cdb6a8ad_1","startedAtMs":"1784717102013","completedAtMs":"1784717102978"},"model_call_id":"bf1a8463-fd73-4b78-a300-3c7a82abb20b-6-3atu","session_id":"184cc83c-f7ba-4888-90ba-efbe15436a07","timestamp_ms":1784717102967}
