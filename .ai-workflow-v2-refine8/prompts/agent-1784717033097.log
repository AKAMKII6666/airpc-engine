dDefinition {\n\tconst baseExits = new Map(\n\t\t(base?.exits ?? []).map(function (ex) {\n\t\t\treturn [ex.exitId, ex];\n\t\t}),\n\t);\n\treturn {\n\t\tcardId: proj.cardId,\n\t\tcardKind: proj.cardKind,\n\t\ttitle: proj.title,\n\t\townerAgentId: proj.ownerAgentId,\n\t\tentryMode: proj.entryMode,\n\t\tinteractionMode: proj.interactionMode,\n\t\tcontext: proj.context,\n\t\tobjectives: proj.objectives,\n\t\ttoolPolicy: proj.toolPolicy,\n\t\tschedule: proj.schedule,\n\t\texits: proj.exits.map(function (ex) {\n\t\t\treturn exitProjectionToDef(ex, baseExits.get(ex.exitId));\n\t\t}),\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":154,"fileSize":4831,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/graph/callCardProjectionMapper.ts","readRange":{"startLine":80,"endLine":154},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f4f83305-a7c7-471d-9ff6-65fed79b7718-24\nfc_16285d6c-f332-903d-af45-fb13cdb6a8ad_0","startedAtMs":"1784717101394","completedAtMs":"1784717101604"},"model_call_id":"bf1a8463-fd73-4b78-a300-3c7a82abb20b-6-3atu","session_id":"184cc83c-f7ba-4888-90ba-efbe15436a07","timestamp_ms":1784717101591}
