hapterNodeData = useCallback(\n\t\t(nodeId: string, next: EditorChapterNodeData) => {\n\t\t\tcanvasApiRef.current?.applyChapterNodeData(nodeId, next);\n\t\t},\n\t\t[canvasApiRef],\n\t);\n\n\tconst onAssignOwner = useCallback(\n\t\t(nodeId: string, agentId: string, displayName: string) => {\n\t\t\tcanvasApiRef.current?.assignOwnerToCallCard(\n\t\t\t\tnodeId,\n\t\t\t\tagentId,\n\t\t\t\tdisplayName,\n\t\t\t);\n\t\t},\n\t\t[canvasApiRef],\n\t);\n\n\treturn {\n\t\tchapterEndDisabled,\n\t\tcharacterAnchors,\n\t\tcallCards,\n\t\tonCanvasReady,\n\t\tonGraphMetaChange,\n\t\tonApplyNodeData,\n\t\tonApplyChapterNodeData,\n\t\tonAssignOwner,\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":73,"fileSize":2183,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/hooks/shell/useStoryEditorCanvasBindings.ts","readRange":{"startLine":1,"endLine":73},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-c5e5b729-0a26-44fe-8e45-44b218ddbba5-51\nfc_758ff03e-e569-9eb3-8dcf-c10b04aa63bc_1","startedAtMs":"1784768228110","completedAtMs":"1784768228305"},"model_call_id":"d1a062e0-df04-41ef-8d6a-b97759db341f-11-6rob","session_id":"2f03fd97-78a6-4c45-8025-3dd48c837c63","timestamp_ms":1784768228277}
