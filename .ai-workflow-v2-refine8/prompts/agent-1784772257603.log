={styles.root} aria-label=\"读盘包校验\">\n\t\t\t<div className={styles.head}>\n\t\t\t\t<div className={styles.headText}>\n\t\t\t\t\t{/* 引用了Typography组件，用于面板标题 */}\n\t\t\t\t\t<Typography variant=\"subtitle1\" className={styles.title}>\n\t\t\t\t\t\t读盘包校验\n\t\t\t\t\t</Typography>\n\t\t\t\t\t<span className={styles.hint}>\n\t\t\t\t\t\t只读 data/storis-packages · 不写盘 · 不 Host beginCall\n\t\t\t\t\t</span>\n\t\t\t\t</div>\n\t\t\t\t<div className={styles.actions}>\n\t\t\t\t\t{/* 引用了FormControl组件，用于故事包 Select */}\n\t\t\t\t\t<FormControl size=\"small\" className={styles.select}>\n\t\t\t\t\t\t{/* 引用了InputLabel组件，用于 Select 标签 */}\n\t\t\t\t\t\t<InputLabel id=\"debugger-pkg-validate-label\">\n\t\t\t\t\t\t\t故事包\n\t\t\t\t\t\t</InputLabel>\n\t\t\t\t\t\t{/* 引用了Select组件，用于选择磁盘包 */}\n\t\t\t\t\t\t<Select\n\t\t\t\t\t\t\tlabelId=\"debugger-pkg-validate-label\"\n\t\t\t\t\t\t\tlabel=\"故事包\"\n\t\t\t\t\t\t\tvalue={packageId}\n\t\t\t\t\t\t\tdisabled={selectDisabled}\n\t\t\t\t\t\t\tonChange={function (e) {\n\t\t\t\t\t\t\t\tonPackageChange(String(e.target.value));\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t{packages.map(function (p) {\n\t\t\t\t\t\t\t\treturn (\n\t\t\t\t\t\t\t\t\t// 引用了MenuItem组件，用于单条包选项\n\t\t\t\t\t\t\t\t\t<MenuItem\n\t\t\t\t\t\t\t\t\t\tkey={p.packageId}\n\t\t\t\t\t\t\t\t\t\tvalue={p.packageId}\n\t\t\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t\t\t{p.title}（{p.packageId}）\n\t\t\t\t\t\t\t\t\t</MenuItem>\n\t\t\t\t\t\t\t\t);\n\t\t\t\t\t\t\t})}\n\t\t\t\t\t\t</Select>\n\t\t\t\t\t</FormControl>\n\t\t\t\t\t{/* 引用了Button组件，用于触发读盘 validate */}\n\t\t\t\t\t<Button\n\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\tvariant=\"contained\"\n\t\t\t\t\t\tdisabled={validateDisabled}\n\t\t\t\t\t\tonClick={onValidate}\n\t\t\t\t\t>\n\t\t\t\t\t\t{validating ? \"校验中…\" : \"校验读盘包\"}\n\t\t\t\t\t</Button>\n\t\t\t\t\t{/* 引用了Button组件，用于跳转编辑器改 Content */}\n\t\t\t\t\t<Button\n\t\t\t\t\t\tcomponent={Link}\n\t\t\t\t\t\thref={`/stories/${encodeURIComponent(packageId)}`}\n\t\t\t\t\t\tsize=\"small\"\n\t\t\t\t\t\tvariant=\"outlined\"\n\t\t\t\t\t\tdisabled={!packageId}\n\t\t\t\t\t>\n\t\t\t\t\t\t打开编辑器\n\t\t\t\t\t</Button>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t{listError ? (\n\t\t\t\t// 引用了Alert组件，用于列表加载失败\n\t\t\t\t<Alert severity=\"error\">{listError}</Alert>\n\t\t\t) : null}\n\t\t\t{validateError ? (\n\t\t\t\t// 引用了Alert组件，用于校验请求失败\n\t\t\t\t<Alert severity=\"error\">{validateError}</Alert>\n\t\t\t) : null}\n\n\t\t\t{/* 引用了PackageValidateReport组件，用于展示报告或空态 */}\n\t\t\t<PackageValidateReport report={report} />\n\t\t</section>\n\t);\n};\n","isEmpty":false,"exceededLimit":false,"totalLines":136,"fileSize":4065,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/debugger/com/packageValidate/PackageValidatePanel.tsx","readRange":{"startLine":1,"endLine":136},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-118f3b9f-d3d1-4a9b-9ef8-60da9b7f21b4-20\nfc_41731827-aafd-9eec-a136-631eb1c97f71_2","startedAtMs":"1784772295012","completedAtMs":"1784772295161"},"model_call_id":"7ae2761f-cc7b-4753-b67d-8fe8970e155e-5-s5ux","session_id":"759b6cee-2534-43a8-aca0-c1aa206c91c6","timestamp_ms":1784772295109}
