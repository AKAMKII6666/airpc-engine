treport,\n}) {\n\tif (!report) {\n\t\treturn (\n\t\t\t<p className={styles.empty}>\n\t\t\t\t选择故事包后点击「校验读盘包」，展示引擎 validatePackage 结果。\n\t\t\t</p>\n\t\t);\n\t}\n\tconst errorCount = report.errors.length;\n\tconst warningCount = report.warnings.length;\n\tconst clean = errorCount === 0 && warningCount === 0;\n\treturn (\n\t\t<div className={styles.report}>\n\t\t\t{/* 引用了Typography组件，用于校验摘要 */}\n\t\t\t<Typography variant=\"body2\" className={styles.summary}>\n\t\t\t\t{clean\n\t\t\t\t\t? `包 ${report.packageId} 通过校验（无 error / warning）`\n\t\t\t\t\t: `包 ${report.packageId} · ${errorCount} 个错误 · ${warningCount} 个警告`}\n\t\t\t</Typography>\n\t\t\t{/* 引用了IssueList组件，用于展示 errors */}\n\t\t\t<IssueList title=\"错误\" issues={report.errors} tone=\"error\" />\n\t\t\t{/* 引用了IssueList组件，用于展示 warnings */}\n\t\t\t<IssueList title=\"警告\" issues={report.warnings} tone=\"warning\" />\n\t\t</div>\n\t);\n};\n","isEmpty":false,"exceededLimit":false,"totalLines":85,"fileSize":2527,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/debugger/com/packageValidate/PackageValidateReport.tsx","readRange":{"startLine":1,"endLine":85},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-118f3b9f-d3d1-4a9b-9ef8-60da9b7f21b4-21\nfc_41731827-aafd-9eec-a136-631eb1c97f71_3","startedAtMs":"1784772295344","completedAtMs":"1784772295516"},"model_call_id":"7ae2761f-cc7b-4753-b67d-8fe8970e155e-5-s5ux","session_id":"759b6cee-2534-43a8-aca0-c1aa206c91c6","timestamp_ms":1784772295462}
