{"type":"tool_call","subtype":"completed","call_id":"call-29a19092-bea6-4a05-8e2f-6e8386e311de-25\nfc_256d46a8-950e-9e8f-9e18-1a4fe229a79d_2","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/packages/validate/validateStoryPackage.server.ts"},"result":{"success":{"content":"/**\n\t* 故事包磁盘 validate：加载角色 Map 后调引擎 validatePackage。\n\t* 仅 Next API / server FS 调用；禁止 client 直引。\n\t*/\nimport {\n\tCharacterDefSchema,\n\tvalidatePackage,\n\ttype CharacterDef,\n\ttype ValidationReport,\n} from \"@airpc/rpg-engine\";\nimport {\n\tlistCharacterAgentIds,\n\treadCharacterJson,\n} from \"../../characters/charactersFs.server\";\nimport { getStudioV2DataRoot } from \"../../data/dataRoot.server\";\n\n/** 扫描 data/characters 为 validatePackage 所需 Map；破损文件跳过 */\nexport async function loadCharacterDefsMap(): Promise<\n\tMap<string, CharacterDef>\n> {\n\tconst map = new Map<string, CharacterDef>();\n\tconst ids = await listCharacterAgentIds();\n\tfor (const agentId of ids) {\n\t\ttry {\n\t\t\tconst raw = await readCharacterJson(agentId);\n\t\t\tconst parsed = CharacterDefSchema.safeParse(raw);\n\t\t\tif (!parsed.success) continue;\n\t\t\tmap.set(parsed.data.agentId, parsed.data);\n\t\t} catch {\n\t\t\t// 单角色读失败不阻断整包校验；引用缺失由 validate 报 REFERENCED_*\n\t\t}\n\t}\n\treturn map;\n}\n\n/**\n\t* 对已落盘的 packageId 跑引擎校验（读 data/storis-packages）。\n\t* 保存闸门须在写盘后调用；失败时由写盘层回滚。\n\t*/\nexport async function validateStoryPackageOnDisk(\n\tpackageId: string,\n): Promise<ValidationReport> {\n\treturn validatePackage({\n\t\trootDir: getStudioV2DataRoot(),\n\t\tpackageId,\n\t\tcharacters: await loadCharacterDefsMap(),\n\t});\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":49,"fileSize":1419,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/packages/validate/validateStoryPackage.server.ts","readRange":{"startLine":1,"endLine":49},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"