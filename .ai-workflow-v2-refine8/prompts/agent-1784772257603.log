oryPackageSummary[]\\n> {\\n\\tconst disk = await fetchDiskStoryPackages();\\n\\treturn disk.map(diskSummaryToPackageSummary);\\n}\\n\",\"isEmpty\":false,\"exceededLimit\":false,\"totalLines\":15,\"fileSize\":614,\"path\":\"/Use [... omitted end of long line]","contentTruncated":false,"isContextLine":false},{"lineNumber":232,"content":"{\"type\":\"tool_call\",\"subtype\":\"completed\",\"call_id\":\"call-0cca7537-2af6-4d3d-88a1-5680fa30d8a4-37\\nfc_d4bcd9cb-7850-93c6-a645-5c55195c1180_1\",\"tool_call\":{\"readToolCall\":{\"args\":{\"path\":\"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/ajaxHelper/studioApiClient.ts\",\"limit\":80},\"result\":{\"success\":{\"content\":\"/**\\n\\t* Studio V2 客户端 API 响应解析（ajaxHelper）。\\n\\t* 统一 { ok:true, data } / { ok:false, code, message, details? }；禁止页面裸拼错误分支。\\n\\t*/\\n\\nexport type StudioApiFail = {\\n\\tok: false;\\n\\tcode: string;\\n\\tmessage: string;\\n\\tdetails?: unknown;\\n};\\n\\nexport type StudioApiOk<T> = {\\n\\tok: true;\\n\\tdata: T;\\n};\\n\\nexport type StudioApiEnvelope<T> = StudioApiOk<T> | StudioApiFail;\\n\\n/** 带 code/details 的 API 失败；保存 validate 等需读 details.report */\\nexport class StudioApiError extends Error {\\n\\treadonly code: string;\\n\\treadonly details: unknown | undefined;\\n\\n\\tconstructor(code: string, message: string, details?: unknown) {\\n\\t\\tsuper(message);\\n\\t\\tthis.name = \\\"StudioApiError\\\"; [... omitted end of long line]","contentTruncated":false,"isContextLine":false},{"lineNumber":233,"content":"{\"type\":\"tool_call\",\"subtype\":\"completed\",\"call_id\":\"call-0cca7537-2af6-4d3d-88a1-5680fa30d8a4-40\\nfc_d4bcd9cb-7850-93c6-a645-5c55195c1180_4\",\"tool_call\":{\"grepToolCall\":{\"args\":{\"pattern\":\"quality:studio\",\"path\":\"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/package.json\",\"caseInsensitive\":false,\"multiline\":false,\"toolCallId\":\"call-0cca7537-2af6-4d3d-88a1-5680fa30d8a4-40\\nfc_d4bcd9cb-7850-93c6-a645-5c55195c1180_4\",\"offset\":0}