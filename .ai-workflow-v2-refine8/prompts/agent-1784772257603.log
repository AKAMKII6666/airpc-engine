 string;\\n  /** 角色回复摘要 */\\n  replySummary: string;\\n};\\n\\n/** 出口命中叙事；勿只展示 exitId */\\nexport type DebugExitHitView = {\\n  /** 出口人类标题 */\\n  exitTitle: string;\\n  /** 命中原因人话 */\\n  reason: string;\\n  /** 是否兜底出口 */\\n  isFallback: boolean;\\n  /** 出口动作列表（人话） */\\n  actionLines: readonly string[];\\n};\\n\\n/** 单条 Effect 执行结果投影 */\\nexport type DebugEffectItem = {\\n  /** 稳定键，仅列表用 */\\n  id: string;\\n  /** 动作类型人话，如「挂卡」「延迟外呼」 */\\n  actionLabel: string;\\n  /** 目标对象人话 */\\n  targetLabel: string;\\n  /** 输入摘要 */\\n  inputSummary: string;\\n  /** 执行状态 */\\n  status: EffectRunStatus;\\n  /** 是否 critical；失败可中止后续 */\\n  critical: boolean;\\n  /** 成功/失败原因；空串表示尚无 */\\n  detail: string;\\n};\\n\\n/** 右侧角色挂卡/外呼状态 */\\nexport type DebugRoleBoardItem = {\\n  /** 角色显示名 */\\n  characterName: string;\\n  /** 是否可自由通话 */\\n  freeDialable: boolean;\\n  /** 当前挂卡标题；空串表示无 */\\n  pendingCardTitle: string;\\n  /** 挂卡来源人话；空串表示无 */\\n  pendingSource: string;\\n  /** 是否有待外呼 */\\n  hasOutbound: boolean;\\n  /**\\n   * 延迟外呼剩余毫秒；null 表示无计时。\\n   * 仅 UI 倒计时投影，非 Host 时钟真源。\\n   */\\n  delayRemainingMs: number | null;\\n};\\n\\n/** 底部时间线条目：WET 判定或 Effect 步骤 */\\nexport type DebugTimelineItem = {\\n  /** 稳定键 */\\n  id: string;\\n  /** 阶段标签，如 WET / Effect */\\n  phase: string;\\n  /** 叙事摘要 */\\n  summary: string;\\n  /** 状态短标签 */\\n  statusLabel: string;\\n};\\n\\n/** 高级抽屉内容：故意不进主视图 */\\nexport type DebugAdvancedSnapshot = {\\n  /** 格式化 JSON 字符串；仅抽屉展示 */\\n  rawJson: string;\\n  /** 日志摘要行 */\\n  logLines: readonly string[];\\n};\\n\",\"isEmpty\":false,\"exceededLimit\":false,\"totalLines\":135,\"fileSize\":3550,\"path\":\"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/typeFiles/debugger/debugSessionView.ts\",\"readRange\":{\"startLine\":1,\"endLine\":135},\"relatedCursorRulePaths\":[],\"relatedCursorRules\":[]}}},\"hookAdditionalContexts\":[],\"toolCallId\":\"call-c6f007cc-a952-448c-ae66-7e4af0c69915-50\\nfc_16caf14b-c784-9200-a284-b4e917b354aa_2\",\"startedAtMs\":\"1784772074213\",\"completedAtMs\":\"1784772074369\"},\"model_call_id\":\"6b82946c-3426-4b1a-b96b-c24e3ae27360-10-g733\",\"session_id\":\"a37c5f81-7a23-47f7-8628-a8c00d676a4f\",\"timestamp_ms\":1784772074330}\n325:{\"type\":\"tool_call\",\"subtype\":\"completed\",\"call_id\":\"call-c6f007cc-a952-448c-ae66-7e4af0c69915-52\\nfc_16caf14b-c784-9200-a284-b4e917b354aa_4\",\"tool_call\":{\"readToolCall\":{\"args\":{\"path\":\"/Users/bolbiao/workspace/airpc-engine/docs/AI/studio-v2/01-分层与目录落点.md\",\"limit\":80},\"result\":{\"success\":{\"content\":\"# Studio V2 · 分层与目录落点（代码事实）\\n\\n> 对照：`apps/studioV2/` · 需求真源见 [09-Studio-V2前端目录结构与落点规则](../../AI和人类/sudioV2.0版本/需求/ui/09-Studio-V2前端目录结构与落点规则.md)。  \\n> 固化：2026-07-22（V2-T3-8：第三步真源接通收口）。\\n\\n## 1. 只认的业务顶层\\n\\n```text\\napps/studioV2/\\n  app/           # Next 路由入口；page.tsx 不写完整业务\\n  src/\\n    pageComponents/<route>/   # 页面主组件与页私有 com/hooks\\n    bis/pageBis/              # 页面编排、表单契约、纯函数命令\\n    stores/                   # Zustand（若有）\\n    utils/                    # 工具；mock 多在 ajaxProxy/**/mock/\\n    commonUiComponents/       # ≥2 页复用的展示组件（目录单元，禁 barrel）\\n  typeFiles/                  # 类型、DTO、UI 投影、枚举选项\\n  tests/                      # Vitest；禁与 src 平放 *.test.ts\\n```\\n\\n禁止再引入旧式顶层：`features/`、`domain/`、`services/`、`commands/`、`store/`（旧 Studio 那套）。\\n\\n## 2. 职责怎么分（对照代码习惯）\\n\\n| 层 | 放什么 | 不放什么 |\\n|----|--------|----------|\\n| `pageComponents` | JSX、壳编排、画布节点 UI | 领域判断、保存事务、磁盘 Content 真源 |\\n| `bis/pageBis` | Formik items/validate/apply、投影纯函数、整包读写 | React 组件（少数例外已在 page） |\\n| `typeFiles` | 投影类型、Select options、标签表 | mock 数据数组本身 |\\n| `utils/.../mock` | **仅**资源库/调试器/设置等允许暂留的展示 mock | 角色/玩家/故事包 Content 真源 |\\n\\n## 3. 真源与剩余 mock（重要）\\n\\n| 域 | 落点 | 说明 |\\n|----|------|------|\\n| **角色库列表/详情** | `data/characters` ↔ `/api/characters` | **已接通**；角色业务 mock **已删** |\\n| **玩家配置列表/详情** | `data/users` ↔ `/api/users` | **已接通**；玩家列表 mock **已删** |\\n| **故事包列表** | `listStoryPackages_bis` → `GET /api/stories` 扫磁盘 | **已接通**；`MOCK_STORY_PACKAGES` **已删** |\\n| **编辑器打开/保存** | `loadStoryPackage_bis` / `saveStoryPackage_bis` + `graph/diskBundleGraph.ts` | **已接通**；`CanvasMockGraph` **已删** |\\n| 画布角色锚点 | 打开时由 `bundle.participants` + `/api/characters` displayName 生成 | 非独立 mock 数组 |\\n| 包配置浮窗 | `package/conf/packageConfProjection.ts` | 读当前 bundle conf，禁止内存种子 |\\n| 资源库列表 | `utils/ajaxProxy/library/mock/mockLibraryData.ts` | **仅**资源会话 mock（本步允许暂留） |\\n| 工作台侧栏 | `mockWorkbenchData.ts` | 工程状态/最近调试 **展示 mock**（非故事包列表真源） |\\n| 调试器 / 设置 | `mockDebuggerData` / `mockSettingsData` | 展示 mock（本步允许暂留） |\\n\\n**统一口径：** 角色 / 玩家 / 故事包 Content **已落盘**；上表「允许暂留」项不得被业务误当成 Content 真源。\\n\\n## 4. 质量门禁提醒（写代码时）\\n\\n- V2 统一入口：`npm run quality:studio`（lint / typecheck / comments / structure / tests）。  \\n- **触碰历史空格缩进文件**须整文件改 tab，否则 `STUDIO-STRUCT-017`。  \\n- 大文件告警线约 350：`diskBundleGraph.ts` 等拆分或控增长。  \\n- `apps/studioV2` **禁止**业务 `index.ts` barrel。\\n\\n## 5. 与旧 Studio / 引擎边界\\n\\n- Studio **client 不 import 引擎写口**；类型可从 `@airpc/rpg-engine` 门面读。  \\n- 引擎纯度：`packages/rpg-engine` 无 React / DOM / Next。  \\n- 旧 `apps/studio` 仅参考，不得降低 V2 门禁。\\n\",\"isEmpty\":false,\"exceededLimit\":false,\"totalLines\":60,\"fileSize\":3592,\"path\":\"/Users/bolbiao/workspace/airpc-engine/docs/AI/studio-v2/01-分层与目录落点.md\",\"readRange\":{\"startLine\":1,\"endLine\":60},\"relatedCursorRulePaths\":[],\"relatedCursorRules\":[]}}},\"hookAdditionalContexts\":[],\"toolCallId\":\"call-c6f007cc-a952-448c-ae66-7e4af0c69915-52\\nfc_16caf14b-c784-9200-a284-b4e917b354aa_4\",\"startedAtMs\":\"1784772074403\",\"completedAtMs\":\"1784772074563\"},\"model_call_id\":\"6b82946c-3426-4b1a-b96b-c24e3ae27360-10-g733\",\"session_id\":\"a37c5f81-7a23-47f7-8628-a8c00d676a4f\",\"timestamp_ms\":1784772074530}\n372:{\"type\":\"thinking\",\"subtype\":\"delta\",\"text\":\" errors such as `PACKAGE_NOT_FOUND`.\",\"session_id\":\"a37c5f81-7a23-47f7-8628-a8c00d676a4f\",\"timestamp_ms\":1784772082536}\n376:{\"type\":\"tool_call\",\"subtype\":\"started\",\"call_id\":\"call-b055ba1a-5fd0-4797-b220-5bf2d83b9747-55\\nfc_e5d29f54-94b2-9d88-b44f-3d8a847e5526_1\",\"tool_call\":{\"grepToolCall\":{\"args\":{\"pattern\":\"PACKAGE_NOT_FOUND|NOT_FOUND|packageId\",\"path\":\"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src\",\"glob\":\"**/errors*\",\"caseInsensitive\":false,\"multiline\":false,\"toolCallId\":\"call-b055ba1a-5fd0-4797-b220-5bf2d83b9747-55\\nfc_e5d29f54-94b2-9d88-b44f-3d8a847e5526_1\",\"offset\":0}},\"hookAdditionalContexts\":[],\"toolCallId\":\"call-b055ba1a-5fd0-4797-b220-5bf2d83b9747-55\\nfc_e5d29f54-94b2-9d88-b44f-3d8a847e5526_1\",\"startedAtMs\":\"1784772082538\"},\"model_call_id\":\"6b82946c-3426-4b1a-b96b-c24e3ae27360-11-p69p\",\"session_id\":\"a37c5f81-7a23-47f7-8628-a8c00d676a4f\",\"timestamp_ms\":1784772082540}\n380:{\"type\":\"tool_call\",\"subtype\":\"completed\",\"call_id\":\"call-b055ba1a-5fd0-4797-b220-5bf2d83b9747-54\\nfc_e5d29f54-94b2-9d88-b44f-3d8a847e5526_0\",\"tool_call\":{\"readToolCall\":{\"args\":{\"path\":\"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/http/apiResponse.server.ts\"},\"result\":{\"success\":{\"content\":\"/**\\n\\t* Studio V2 API JSON 响应助手（仅 route handler 使用）。\\n\\t*/\\nimport { NextResponse } from \\\"next/server\\\";\\n\\nexport function apiOk<T>(data: T, init?: ResponseInit): NextResponse {\\n\\treturn NextResponse.json({ ok: true, data }, init);\\n}\\n\\nexport function apiFail(\\n\\tcode: string,\\n\\tmessage: string,\\n\\tstatus = 400,\\n\\tdetails?: unknown,\\n): NextResponse {\\n\\treturn NextResponse.json(\\n\\t\\t{ ok: false, code, message, details },\\n\\t\\t{ status },\\n\\t);\\n}\\n\\n/** 将引擎 / 门面错误码映射到 HTTP 状态 */\\nexport function httpStatusForCode(code: string): number {\\n\\tswitch (code) {\\n\\t\\tcase \\\"OK\\\":\\n\\t\\t\\treturn 200;\\n\\t\\tcase \\\"VALIDATION_FAILED\\\":\\n\\t\\tcase \\\"INVALID_PACKAGE_ID\\\":\\n\\t\\t\\treturn 400;\\n\\t\\tcase \\\"PACKAGE_VALIDATION_FAILED\\\":\\n\\t\\t\\treturn 422;\\n\\t\\tcase \\\"UNAUTHORIZED\\\":\\n\\t\\t\\treturn 401;\\n\\t\\tca