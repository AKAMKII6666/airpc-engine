{"type":"tool_call","subtype":"started","call_id":"tool_65f3f314-3ba6-42ee-b29f-f74f58eb811","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/validation/collectReferencedAgentIds.test.ts","streamContent":"/**\n * S8-1：collectReferencedAgentIds + participants 可选 schema\n */\nimport { describe, expect, it } from \"vitest\";\nimport {\n  collectReferencedAgentIds,\n  StoryPackageConfSchema,\n  type CallCardDefinition,\n} from \"../../src/index.js\";\n\nfunction card(\n  partial: Partial<CallCardDefinition> & {\n    cardId: string;\n    ownerAgentId: string;\n  },\n): CallCardDefinition {\n  return {\n    cardKind: \"story\",\n    exits: [],\n    ...partial,\n  };\n}\n\ndescribe(\"collectReferencedAgentIds (S8-1)\", () => {\n  it(\"collects ownerAgentId from cards\", () => {\n    const ids = collectReferencedAgentIds({\n      conf: { schemaVersion: 1, packageId: \"pkg\", cards: [] },\n      cards: [\n        card({ cardId: \"c1\", ownerAgentId: \"lanxing\" }),\n        card({ cardId: \"c2\", ownerAgentId: \"xiaoyu\" }),\n      ],\n    });\n    expect([...ids].sort()).toEqual([\"lanxing\", \"xiaoyu\"]);\n  });\n\n  it(\"collects agentId from effects including end_story.next\", () => {\n    const ids = collectReferencedAgentIds({\n      conf: { schemaVersion: 1, packageId: \"pkg\", cards: [] },\n      cards: [\n        card({\n          cardId: \"c1\",\n          ownerAgentId: \"owner_a\",\n          exits: [\n            {\n              exitId: \"exit_ok\",\n              condition: { op: \"always\" },\n              effects: [\n                {\n                  id: \"e_attach\",\n                  effect: \"attach_call_card\",\n                  agentId: \"target_b\",\n                  cardId: \"free_b\",\n                },\n                {\n                  id: \"e_end\",\n                  effect: \"end_story\",\n                  next: {\n                    packageId: \"ch2\",\n                    agentId: \"entry_agent\",\n                    cardId: \"ch2_start\",\n                  },\n                },\n              ],\n            },\n          ],\n        }),\n      ],\n    });\n    expect([...ids].sort()).toEqual(\n      [\"entry_agent\", \"owner_a\", \"target_b\"].sort(),\n    );\n  });\n\n  it(\"deduplicates repeated agentId\", () => {\n    const ids = collectReferencedAgentIds({\n      conf: { schemaVersion: 1, packageId: \"pkg\", cards: [] },\n      cards: [\n        card({\n          cardId: \"c1\",\n          ownerAgentId: \"same\",\n          exits: [\n            {\n              exitId: \"e1\",\n              condition: { op: \"always\" },\n              effects: [\n                {\n                  id: \"unlock\",\n                  effect: \"set_character_unlocked\",\n                  agentId: \"same\",\n                },\n              ],\n            },\n          ],\n        }),\n      ],\n    });\n    expect(ids.size).toBe(1);\n    expect(ids.has(\"same\")).toBe(true);\n  });\n\n  it(\"StoryPackageConfSchema accepts missing participants\", () => {\n    const parsed = StoryPackageConfSchema.safeParse({\n      schemaVersion: 1,\n      packageId: \"new_pkg\",\n      cards: [],\n    });\n    expect(parsed.success).toBe(true);\n    if (!parsed.success) return;\n    expect(parsed.data.participants).toBeUndefined();\n  });\n});\n"}},"hookAdditionalContexts":[],"toolCallId":"tool_65f3f314-3ba6-42ee-b29f-f74f58eb811","startedAtMs":"1784715933411"},"model_call_id":"3a654a0f-ef17-4d6a-9b0a-d78b4ea717a4-13-kupy","session_id":"bb8d042c-eb78-47ba-b62e-6d01943955de","timestamp_ms":1784715933327}
