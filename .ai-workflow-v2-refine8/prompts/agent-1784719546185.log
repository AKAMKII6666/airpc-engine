{"type":"tool_call","subtype":"completed","call_id":"call-a4347ed6-a23f-46b4-bcee-0a29b7a425dd-15\nfc_8bb3c7fb-9bb4-9b9f-8f16-ce6cfd65886c_4","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/storyEditor/exitConditionForm.test.ts"},"result":{"success":{"content":"/**\n\t* ExitCondition v1 纯函数：摘要派生与 op 工厂（V2-S8-7）。\n\t*/\nimport { describe, expect, it } from \"vitest\";\nimport {\n\tbuildExitConditionForOp,\n\tdefaultExitCondition,\n\tisExitConditionV1Leaf,\n\tsummarizeExitCondition,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/exitConditionForm\";\n\ndescribe(\"exitConditionForm (V2-S8-7)\", () => {\n\tit(\"summarizes leaf ops\", () => {\n\t\texpect(summarizeExitCondition({ op: \"always\" })).toBe(\"始终\");\n\t\texpect(\n\t\t\tsummarizeExitCondition({ op: \"all_required_beats_completed\" }),\n\t\t).toBe(\"全部必做节拍完成\");\n\t\texpect(\n\t\t\tsummarizeExitCondition({\n\t\t\t\top: \"outcome_flag\",\n\t\t\t\tflag: \"answered_completed\",\n\t\t\t\tequals: true,\n\t\t\t}),\n\t\t).toContain(\"已接通并完成\");\n\t\texpect(\n\t\t\tsummarizeExitCondition({\n\t\t\t\top: \"beat_completed\",\n\t\t\t\tbeatId: \"b1\",\n\t\t\t}),\n\t\t).toBe(\"节拍已完成 · b1\");\n\t});\n\n\tit(\"marks nested as non-leaf and summarizes as read-only\", () => {\n\t\tconst nested = {\n\t\t\top: \"and\" as const,\n\t\t\titems: [{ op: \"always\" as const }],\n\t\t};\n\t\texpect(isExitConditionV1Leaf(nested)).toBe(false);\n\t\texpect(summarizeExitCondition(nested)).toContain(\"只读\");\n\t});\n\n\tit(\"buildExitConditionForOp switches leaf shapes\", () => {\n\t\texpect(buildExitConditionForOp(\"always\")).toEqual({ op: \"always\" });\n\t\texpect(buildExitConditionForOp(\"outcome_flag\")).toEqual({\n\t\t\top: \"outcome_flag\",\n\t\t\tflag: \"answered_completed\",\n\t\t\tequals: true,\n\t\t});\n\t\texpect(\n\t\t\tbuildExitConditionForOp(\"beat_missing\", {\n\t\t\t\top: \"beat_completed\",\n\t\t\t\tbeatId: \"x\",\n\t\t\t}),\n\t\t).toEqual({ op: \"beat_missing\", beatId: \"x\" });\n\t\texpect(defaultExitCondition().op).toBe(\"outcome_flag\");\n\t});\n});\n","isEmpty":false,"exceededLimit":false,"totalLines":58,"fileSize":1634,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/storyEditor/exitConditionForm.test.ts","readRange":{"startLine":1,"endLine":58},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-a4347ed6-a23f-46b4-bcee-0a29b7a425dd-15\nfc_8bb3c7fb-9bb4-9b9f-8f16-ce6cfd65886c_4","startedAtMs":"1784719577632","completedAtMs":"1784719577775"},"model_call_id":"a7bdf8ed-dc75-4c33-807c-6dd0309dcd95-3-n4sk","session_id":"1160cc54-f298-44a7-b320-a760f4687c62","timestamp_ms":1784719577753}
