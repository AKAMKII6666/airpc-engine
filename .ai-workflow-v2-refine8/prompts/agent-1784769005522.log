rPreviewUrl(valueStr.trim()) : null;\\n\\tconst previewSrc = session.localPreviewUrl ?? remotePreview;\\n\\tconst pickDisabled = Boolean(disabled || session.uploading || !uploadFile);\\n\\n\\treturn (\\n\\t\\t// 引用了FormFieldShell组件，用于统一 label/必填星/错误/watch 外壳\\n\\t\\t<FormFieldShell\\n\\t\\t\\tlabel={label}\\n\\t\\t\\tmode={mode}\\n\\t\\t\\trequired={required}\\n\\t\\t\\terror={errorMsg}\\n\\t\\t\\thelperText={helperText}\\n\\t\\t\\twatchText={valueStr || \\\"默认头像\\\"}\\n\\t\\t>\\n\\t\\t\\t{/* 引用了AvatarUploadBody组件，用于预览与上传控件 */}\\n\\t\\t\\t<AvatarUploadBody\\n\\t\\t\\t\\tassetId={valueStr}\\n\\t\\t\\t\\tpreviewSrc={previewSrc}\\n\\t\\t\\t\\tdisabled={pickDisabled}\\n\\t\\t\\t\\tuploading={session.uploading}\\n\\t\\t\\t\\tuploadError={session.uploadError}\\n\\t\\t\\t\\tonFilePick={session.handleFilePick}\\n\\t\\t\\t/>\\n\\t\\t</FormFieldShell>\\n\\t);\\n};\\n\",\"message\":\"Wrote contents to /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/commonUiComponents/form/blocks/AvatarUpload/index.tsx\"}}},\"hookAdditionalContexts\":[],\"toolCallId\":\"call-6ab9750e-2b78-4019-a2f2-8280f118d765-97\\nfc_5d3b7ca8-66a8-9169-90ce-3065e509ccfd_2\",\"startedAtMs\":\"1784768945352\",\"completedAtMs\":\"1784768945809\"},\"model_call_id\":\"17288759-001b-4838-a5a3-bc802f2e36cd-27-un15\",\"session_id\":\"b7917dae-9ff2-4027-991c-a16f09dab1b5\",\"timestamp_ms\":1784768945769}\n914:{\"type\":\"tool_call\",\"subtype\":\"completed\",\"call_id\":\"call-6ab9750e-2b78-4019-a2f2-8280f118d765-100\\nfc_5d3b7ca8-66a8-9169-90ce-3065e509ccfd_5\",\"tool_call\":{\"editToolCall\":{\"args\":{\"path\":\"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/characters/detail/form/characterDetailForm.ts\",\"streamContent\":\"export {\\n\\tCHARACTER_BASIC_ITEMS,\\n\\tCHARACTER_PROMPT_ITEMS,\\n} from \\\"./characterDetailFormItems\\\";\\nexport { validateCharacterDetailForm } from \\\"./characterDetailFormValidate\\\";\\nexport { withAvatarUploadItems } from \\\"@studio-v2/src/bis/pageBis