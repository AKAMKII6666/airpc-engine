{"type":"tool_call","subtype":"completed","call_id":"call-9dc9b1fb-a102-4474-a6d0-e8eaa2051c2a-36\nfc_898c9f2c-d98e-9963-9e82-d93572b8ba5f_2","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/assets/uploadAssetBinary.ts"},"result":{"success":{"content":"/**\n\t* 头像/图片直传：multipart → data/assets/files + meta；清除 pendingFile。\n\t* 供 /api/assets/upload 与 commitUploadAvatarImage 共用。\n\t*/\nimport type { AssetMeta } from \"@airpc/rpg-engine\";\n\n/** 头像直传允许的 MIME（与导向稿 05 §6.1 对齐） */\nconst AVATAR_MIME_EXT: Record<string, string> = {\n\t\"image/png\": \"png\",\n\t\"image/jpeg\": \"jpg\",\n\t\"image/webp\": \"webp\",\n};\n\n/** 单文件上限；防止误传过大原图拖垮本机 Studio */\nexport const AVATAR_UPLOAD_MAX_BYTES = 5 * 1024 * 1024;\n\n/**\n\t* 直传成功后组装 AssetMeta 的入参。\n\t* 调用方须先校验 MIME/大小；本结构不承担 HTTP 解析。\n\t*/\nexport type BuildUploadedImageMetaInput = {\n\t/** 系统生成的 assetId；须已通过 isValidAssetId */\n\tassetId: string;\n\t/** 人类可读名；空则回落 assetId */\n\tdisplayName: string;\n\t/** 规范化后的扩展名（无点） */\n\text: string;\n\t/** 原始 MIME，写入 meta.mimeType 便于预览 */\n\tmimeType: string;\n\t/** 文件字节数；写入 measureValue（size_bytes） */\n\tbyteLength: number;\n\t/**\n\t\t* 用途标记；avatar 时写入 meta.usage，便于资源库筛选。\n\t\t* 非头像直传可省略。\n\t\t*/\n\tusage?: \"avatar\";\n};\n\n/**\n\t* 由 MIME 解析图片扩展名；非允许类型返回 null（调用方转 VALIDATION_FAILED）。\n\t*/\nexport function imageExtFromMime(mimeType: string): string | null {\n\tconst key = mimeType.trim().toLowerCase();\n\treturn AVATAR_MIME_EXT[key] ?? null;\n}\n\n/**\n\t* 组装已落盘图片的 AssetMeta（kind=image，pendingFile 清除）。\n\t*/\nexport function buildUploadedImageAssetMeta(\n\tinput: BuildUploadedImageMetaInput,\n): AssetMeta {\n\tconst displayName = input.displayName.trim() || input.assetId;\n\tconst uri = `files/${input.assetId}.${input.ext}`;\n\tconst bag: Record<string, unknown> = {\n\t\tstudioKind: \"image\",\n\t\tformat: input.ext,\n\t\tmeasureValue: input.byteLength,\n\t\tmeasureUnit: \"size_bytes\",\n\t\tmimeType: input.mimeType,\n\t\tpendingFile: false,\n\t};\n\tif (input.usage === \"avatar\") {\n\t\tbag.usage = \"avatar\";\n\t}\n\treturn {\n\t\tassetId: input.assetId,\n\t\tkind: \"image\",\n\t\turi,\n\t\tdisplayName,\n\t\tmeta: bag,\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":74,"fileSize":2122,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/assets/uploadAssetBinary.ts","readRange":{"startLine":1,"endLine":74},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-9dc9b1fb-a102-4474-a6d0-e8eaa2051c2a-36\nfc_898c9f2c-d98e-9963-9e82-d93572b8ba5f_2","startedAtMs":"1784769049950","completedAtMs":"1784769050142"},"model_call_id":"7bdb2a01-873d-425f-86d3-e4d075552305-6-xebl","session_id":"660b8111-593e-4489-bfe7-94f14d49a22a","timestamp_ms":1784769050274}
