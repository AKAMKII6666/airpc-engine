undle, names);\n\treturn unique.map(function (agentId, index) {\n\t\tconst rawName = names[agentId]?.displayName?.trim();\n\t\tconst displayName =\n\t\t\trawName !== undefined && rawName !== \"\" ? rawName : agentId;\n\t\tconst pendingCardCount = pendingCountForAgent(agentId, bundle.cards);\n\t\tconst data: CharacterAnchorNodeData = {\n\t\t\tagentId,\n\t\t\tdisplayName,\n\t\t\tstatusLabel: characterAnchorStatusLabel(pendingCardCount),\n\t\t\tpendingCardCount,\n\t\t};\n\t\treturn {\n\t\t\tid: anchorNodeId(agentId),\n\t\t\ttype: \"characterAnchor\" as const,\n\t\t\tposition: { x: -40, y: 40 + index * 110 },\n\t\t\tdata,\n\t\t\tdraggable: false,\n\t\t\tselectable: true,\n\t\t};\n\t});\n}\n\nfunction ownerDisplayNameForCard(\n\tcard: CallCardDefinition,\n\tnames: CharacterDisplayLookup,\n): string {\n\tconst agentId = card.ownerAgentId ?? \"\";\n\tif (agentId && names[agentId]?.displayName) {\n\t\treturn names[agentId]!.displayName;\n\t}\n\treturn agentId;","isEmpty":false,"exceededLimit":false,"totalLines":484,"fileSize":13857,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/bis/pageBis/storyEditor/package/graph/diskBundleGraph.ts","readRange":{"startLine":77,"endLine":166},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-196e2a19-5707-4f79-969d-6fbc037135a2-48\nfc_cc74bd55-35e1-9005-9085-2cafb39d149f_2","startedAtMs":"1784721524985","completedAtMs":"1784721525122"},"model_call_id":"6f083b9c-715b-401c-bee6-8dedacfc25fa-11-j1l7","session_id":"9981a650-ae57-4a10-b6bb-90832abae14e","timestamp_ms":1784721525158}
