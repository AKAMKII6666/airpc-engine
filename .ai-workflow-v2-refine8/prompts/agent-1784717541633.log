{"type":"tool_call","subtype":"completed","call_id":"call-7a69ae96-3984-4e8e-af9a-e2501adb9b2e-69\nfc_7eac68e3-98b3-9f04-bf68-221fe746e685_0","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/storyEditor/callCardProjectionMapper.test.ts","streamContent":"/**\n\t* CallCard 投影 mapper：critical / effect 字段 roundtrip（V2-S8-6）。\n\t*/\nimport { describe, expect, it } from \"vitest\";\nimport type { CallCardDefinition, Effect } from \"@airpc/rpg-engine\";\nimport {\n\tcallCardDefToProjection,\n\tcallCardProjectionToDef,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/callCardProjectionMapper\";\n\nfunction sampleCard(effects: Effect[]): CallCardDefinition {\n\treturn {\n\t\tcardId: \"probe_card\",\n\t\tcardKind: \"story\",\n\t\ttitle: \"探针卡\",\n\t\townerAgentId: \"lanxing\",\n\t\tentryMode: \"inbound_user_dial\",\n\t\tinteractionMode: \"realtime_dialogue\",\n\t\tcontext: { objective: \"test\" },\n\t\texits: [\n\t\t\t{\n\t\t\t\texitId: \"exit_ok\",\n\t\t\t\texitKind: \"handoff\",\n\t\t\t\tpriority: 0,\n\t\t\t\tcondition: {\n\t\t\t\t\top: \"always\",\n\t\t\t\t},\n\t\t\t\teffects,\n\t\t\t},\n\t\t],\n\t};\n}\n\ndescribe(\"callCardProjectionMapper critical (V2-S8-6)\", () => {\n\tit(\"keeps critical:true through def → projection → def\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"keep_card_pending\",\n\t\t\t\tcritical: true,\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBe(true);\n\t\tconst back = callCardProjectionToDef(proj, def);\n\t\texpect(back.exits[0]?.effects[0]?.critical).toBe(true);\n\t});\n\n\tit(\"omits critical when absent on write-back\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"keep_card_pending\",\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBeUndefined();\n\t\tconst back = callCardProjectionToDef(proj, def);\n\t\texpect(back.exits[0]?.effects[0]?.critical).toBeUndefined();\n\t});\n\n\tit(\"does not put critical into params bag\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"set_character_unlocked\",\n\t\t\t\tcritical: true,\n\t\t\t\tagentId: \"lanxing\",\n\t\t\t\tunlocked: true,\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\tconst params = proj.exits[0]?.effects[0]?.params as Record<\n\t\t\tstring,\n\t\t\tunknown\n\t\t>;\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBe(true);\n\t\texpect(params.critical).toBeUndefined();\n\t\texpect(params.agentId).toBe(\"lanxing\");\n\t});\n});\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/storyEditor/callCardProjectionMapper.test.ts","linesAdded":2,"linesRemoved":20,"diffString":"--- a//Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/storyEditor/callCardProjectionMapper.test.ts\n+++ b//Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/storyEditor/callCardProjectionMapper.test.ts\n@@ -46,7 +46,7 @@\n \t\texpect(back.exits[0]?.effects[0]?.critical).toBe(true);\n \t});\n \n-\tit(\"omits critical when false/absent on write-back\", () => {\n+\tit(\"omits critical when absent on write-back\", () => {\n \t\tconst def = sampleCard([\n \t\t\t{\n \t\t\t\tid: \"fx_1\",\n@@ -55,25 +55,7 @@\n \t\t]);\n \t\tconst proj = callCardDefToProjection(def, \"澜星\");\n \t\texpect(proj.exits[0]?.effects[0]?.critical).toBeUndefined();\n-\t\tconst withOff = {\n-\t\t\t...proj,\n-\t\t\texits: proj.exits.map(function (ex, i) {\n-\t\t\t\tif (i !== 0) return ex;\n-\t\t\t\treturn {\n-\t\t\t\t\t...ex,\n-\t\t\t\t\teffects: ex.effects.map(function (fx) {\n-\t\t\t\t\t\treturn { ...fx, critical: false as boolean | undefined };\n-\t\t\t\t\t}),\n-\t\t\t\t};\n-\t\t\t}),\n-\t\t};\n-\t\t// 显式清掉 critical，模拟面板关开关\n-\t\twithOff.exits[0]!.effects[0] = {\n-\t\t\tid: \"fx_1\",\n-\t\t\teffect: \"keep_card_pending\",\n-\t\t\tparams: { effect: \"keep_card_pending\" },\n-\t\t};\n-\t\tconst back = callCardProjectionToDef(withOff, def);\n+\t\tconst back = callCardProjectionToDef(proj, def);\n \t\texpect(back.exits[0]?.effects[0]?.critical).toBeUndefined();\n \t});\n ","beforeFullFileContent":"/**\n\t* CallCard 投影 mapper：critical / effect 字段 roundtrip（V2-S8-6）。\n\t*/\nimport { describe, expect, it } from \"vitest\";\nimport type { CallCardDefinition, Effect } from \"@airpc/rpg-engine\";\nimport {\n\tcallCardDefToProjection,\n\tcallCardProjectionToDef,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/callCardProjectionMapper\";\n\nfunction sampleCard(effects: Effect[]): CallCardDefinition {\n\treturn {\n\t\tcardId: \"probe_card\",\n\t\tcardKind: \"story\",\n\t\ttitle: \"探针卡\",\n\t\townerAgentId: \"lanxing\",\n\t\tentryMode: \"inbound_user_dial\",\n\t\tinteractionMode: \"realtime_dialogue\",\n\t\tcontext: { objective: \"test\" },\n\t\texits: [\n\t\t\t{\n\t\t\t\texitId: \"exit_ok\",\n\t\t\t\texitKind: \"handoff\",\n\t\t\t\tpriority: 0,\n\t\t\t\tcondition: {\n\t\t\t\t\top: \"always\",\n\t\t\t\t},\n\t\t\t\teffects,\n\t\t\t},\n\t\t],\n\t};\n}\n\ndescribe(\"callCardProjectionMapper critical (V2-S8-6)\", () => {\n\tit(\"keeps critical:true through def → projection → def\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"keep_card_pending\",\n\t\t\t\tcritical: true,\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBe(true);\n\t\tconst back = callCardProjectionToDef(proj, def);\n\t\texpect(back.exits[0]?.effects[0]?.critical).toBe(true);\n\t});\n\n\tit(\"omits critical when false/absent on write-back\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"keep_card_pending\",\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBeUndefined();\n\t\tconst withOff = {\n\t\t\t...proj,\n\t\t\texits: proj.exits.map(function (ex, i) {\n\t\t\t\tif (i !== 0) return ex;\n\t\t\t\treturn {\n\t\t\t\t\t...ex,\n\t\t\t\t\teffects: ex.effects.map(function (fx) {\n\t\t\t\t\t\treturn { ...fx, critical: false as boolean | undefined };\n\t\t\t\t\t}),\n\t\t\t\t};\n\t\t\t}),\n\t\t};\n\t\t// 显式清掉 critical，模拟面板关开关\n\t\twithOff.exits[0]!.effects[0] = {\n\t\t\tid: \"fx_1\",\n\t\t\teffect: \"keep_card_pending\",\n\t\t\tparams: { effect: \"keep_card_pending\" },\n\t\t};\n\t\tconst back = callCardProjectionToDef(withOff, def);\n\t\texpect(back.exits[0]?.effects[0]?.critical).toBeUndefined();\n\t});\n\n\tit(\"does not put critical into params bag\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"set_character_unlocked\",\n\t\t\t\tcritical: true,\n\t\t\t\tagentId: \"lanxing\",\n\t\t\t\tunlocked: true,\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\tconst params = proj.exits[0]?.effects[0]?.params as Record<\n\t\t\tstring,\n\t\t\tunknown\n\t\t>;\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBe(true);\n\t\texpect(params.critical).toBeUndefined();\n\t\texpect(params.agentId).toBe(\"lanxing\");\n\t});\n});\n","afterFullFileContent":"/**\n\t* CallCard 投影 mapper：critical / effect 字段 roundtrip（V2-S8-6）。\n\t*/\nimport { describe, expect, it } from \"vitest\";\nimport type { CallCardDefinition, Effect } from \"@airpc/rpg-engine\";\nimport {\n\tcallCardDefToProjection,\n\tcallCardProjectionToDef,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/package/graph/callCardProjectionMapper\";\n\nfunction sampleCard(effects: Effect[]): CallCardDefinition {\n\treturn {\n\t\tcardId: \"probe_card\",\n\t\tcardKind: \"story\",\n\t\ttitle: \"探针卡\",\n\t\townerAgentId: \"lanxing\",\n\t\tentryMode: \"inbound_user_dial\",\n\t\tinteractionMode: \"realtime_dialogue\",\n\t\tcontext: { objective: \"test\" },\n\t\texits: [\n\t\t\t{\n\t\t\t\texitId: \"exit_ok\",\n\t\t\t\texitKind: \"handoff\",\n\t\t\t\tpriority: 0,\n\t\t\t\tcondition: {\n\t\t\t\t\top: \"always\",\n\t\t\t\t},\n\t\t\t\teffects,\n\t\t\t},\n\t\t],\n\t};\n}\n\ndescribe(\"callCardProjectionMapper critical (V2-S8-6)\", () => {\n\tit(\"keeps critical:true through def → projection → def\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"keep_card_pending\",\n\t\t\t\tcritical: true,\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBe(true);\n\t\tconst back = callCardProjectionToDef(proj, def);\n\t\texpect(back.exits[0]?.effects[0]?.critical).toBe(true);\n\t});\n\n\tit(\"omits critical when absent on write-back\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"keep_card_pending\",\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBeUndefined();\n\t\tconst back = callCardProjectionToDef(proj, def);\n\t\texpect(back.exits[0]?.effects[0]?.critical).toBeUndefined();\n\t});\n\n\tit(\"does not put critical into params bag\", () => {\n\t\tconst def = sampleCard([\n\t\t\t{\n\t\t\t\tid: \"fx_1\",\n\t\t\t\teffect: \"set_character_unlocked\",\n\t\t\t\tcritical: true,\n\t\t\t\tagentId: \"lanxing\",\n\t\t\t\tunlocked: true,\n\t\t\t},\n\t\t]);\n\t\tconst proj = callCardDefToProjection(def, \"澜星\");\n\t\tconst params = proj.exits[0]?.effects[0]?.params as Record<\n\t\t\tstring,\n\t\t\tunknown\n\t\t>;\n\t\texpect(proj.exits[0]?.effects[0]?.critical).toBe(true);\n\t\texpect(params.critical).toBeUndefined();\n\t\texpect(params.agentId).toBe(\"lanxing\");\n\t});\n});\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/storyEditor/callCardProjectionMapper.test.ts"}}},"hookAdditionalContexts":[],"toolCallId":"call-7a69ae96-3984-4e8e-af9a-e2501adb9b2e-69\nfc_7eac68e3-98b3-9f04-bf68-221fe746e685_0","startedAtMs":"1784717803795