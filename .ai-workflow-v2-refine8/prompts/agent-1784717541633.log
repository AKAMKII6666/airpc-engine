{"type":"tool_call","subtype":"started","call_id":"call-81e76750-862e-4d80-8e9b-c3dece48f208-48\nfc_d8bc0d2b-7ed6-9e6c-8646-63675cf0a167_1","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/typeFiles/story/editor/callCard/editorCallCardProjection.ts","streamContent":"export type EditorExitEffectProjection = {\n\t/** Effect 稳定键；对齐 EffectSchema.id */\n\tid: string;\n\t/**\n\t\t* Effect 名称；收紧为 KNOWN_EFFECT_NAMES 枚举联合。\n\t\t* 仅允许枚举下拉写入；与 params.effect 判别键保持一致。\n\t\t*/\n\teffect: KnownEffectName;\n\t/**\n\t\t* 失败是否中止后续 Effect；对齐 EffectSchema.critical。\n\t\t* 缺省等同 false；须 roundtrip 写盘，禁止投影 strip。\n\t\t*/\n\tcritical?: boolean;\n\t/** 人话摘要；缺省由 params 派生（S7-6），用户手改后不覆盖 */\n\tsummary?: string;\n\t/**\n\t\t* 按 effect 判别的参数；缺省等同未配置。\n\t\t* 不变量：存在时 params.effect 必须等于本行 effect。\n\t\t*/\n\tparams?: EditorEffectParams;\n};"}},"hookAdditionalContexts":[],"toolCallId":"call-81e76750-862e-4d80-8e9b-c3dece48f208-48\nfc_d8bc0d2b-7ed6-9e6c-8646-63675cf0a167_1","startedAtMs":"1784717642256"},"model_call_id":"92d839fd-07e8-44ae-b8e8-e85fd2fb8312-11-ti0z","session_id":"0baf0b73-236c-4e58-ac9d-ef9322fac058","timestamp_ms":1784717642854}
