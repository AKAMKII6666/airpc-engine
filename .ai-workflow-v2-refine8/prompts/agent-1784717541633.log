t\t}}\n \t\t\t\t\t\t\tonParamsChange={(next: EditorEffectParams) => {\n \t\t\t\t\t\t\t\tchangeParams(index, next);\n \t\t\t\t\t\t\t}}","beforeFullFileContent":"/**\n\t* 出口 Effect 列表：仅负责「增删行 + 列表编排」与「把每行分发到子组件」。\n\t* 每种 effect 的参数编辑与下拉都在 ExitEffectRow / com/effects/；整包保存时经 Formik 落盘。\n\t*/\n\"use client\";\n\nimport type { FC } from \"react\";\nimport { Button, Typography } from \"@mui/material\";\nimport type { EditorExitEffectProjection } from \"@studio-v2/typeFiles/story/editor/callCard/editorCallCardProjection\";\nimport type {\n\tEditorEffectParams,\n\tEffectPanelSources,\n} from \"@studio-v2/typeFiles/story/editor/callCard/editorEffectParams\";\nimport { EMPTY_EFFECT_PANEL_SOURCES } from \"@studio-v2/typeFiles/story/editor/callCard/editorEffectParams\";\nimport {\n\tcoerceKnownEffectName,\n\temptyEffectRow,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/exitListForm\";\nimport { defaultEffectParams } from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/effects/effectParams\";\nimport { summarizeEffect } from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/effects/summarizeEffect\";\n// 引用了ExitEffectRow组件，用于单个 Effect 行编辑\nimport { ExitEffectRow } from \"@studio-v2/src/pageComponents/storyEditor/com/panel/ExitListEditor/com/ExitEffectRow\";\nimport styles from \"../index.module.scss\";\n\nexport type ExitEffectsListProps = {\n\teffects: EditorExitEffectProjection[];\n\tonChange: (next: EditorExitEffectProjection[]) => void;\n\tsources?: EffectPanelSources;\n};\n\nexport const ExitEffectsList: FC<ExitEffectsListProps> =\n\tfunction ExitEffectsList({\n\t\t// effects 是当前出口的 Effect 行列表，用于增删与参数编辑\n\t\teffects,\n\t\t// onChange 是整表写回父行，用于同步 Formik\n\t\tonChange,\n\t\t// sources 是 id 下拉候选源，用于角色/卡/包/片段选择\n\t\tsources = EMPTY_EFFECT_PANEL_SOURCES,\n\t}) {\n\t\tconst list = Array.isArray(effects) ? effects : [];\n\n\t\tfunction patchRow(\n\t\t\tindex: number,\n\t\t\tpatch: Partial<EditorExitEffectProjection>,\n\t\t): void {\n\t\t\tonChange(\n\t\t\t\tlist.map((row, i) => (i === index ? { ...row, ...patch } : row)),\n\t\t\t);\n\t\t}\n\n\t\tfunction changeEffect(index: number, rawEffect: string): void {\n\t\t\tconst effect = coerceKnownEffectName(rawEffect);\n\t\t\t// 切换 effect 同时复位 params 并重派生摘要，保证判别键一致且摘要不残留旧 effect 文案\n\t\t\tconst params = defaultEffectParams(effect);\n\t\t\tpatchRow(index, {\n\t\t\t\teffect,\n\t\t\t\tparams,\n\t\t\t\tsummary: summarizeEffect(effect, params, sources),\n\t\t\t});\n\t\t}\n\n\t\t// 改 params 时：摘要仍为自动派生（空或等于旧 params 派生值）则刷新，用户手改后不覆盖\n\t\tfunction changeParams(index: number, next: EditorEffectParams): void {\n\t\t\tconst row = list[index];\n\t\t\tif (!row) return;\n\t\t\tconst prevAuto = summarizeEffect(row.effect, row.params, sources);\n\t\t\tconst isAutoSummary = !row.summary || row.summary === prevAuto;\n\t\t\tconst patch: Partial<EditorExitEffectProjection> = { params: next };\n\t\t\tif (isAutoSummary) {\n\t\t\t\tpatch.summary = summarizeEffect(row.effect, next, sources);\n\t\t\t}\n\t\t\tpatchRow(index, patch);\n\t\t}\n\n\t\treturn (\n\t\t\t<div className={styles.effects}>\n\t\t\t\t{/* 引用了Typography组件，用于 Effect 列表标题 */}\n\t\t\t\t<Typography variant=\"caption\" className={styles.effectsLabel}>\n\t\t\t\t\tEffects（每种 effect 专属参数面板）\n\t\t\t\t</Typography>\n\t\t\t\t<ul className={styles.effectsList}>\n\t\t\t\t\t{list.map((fx, index) => (\n\t\t\t\t\t\t// 引用了ExitEffectRow组件，用于单个 Effect 行编辑\n\t\t\t\t\t\t<ExitEffectRow\n\t\t\t\t\t\t\tkey={fx.id}\n\t\t\t\t\t\t\tfx={fx}\n\t\t\t\t\t\t\tsources={sources}\n\t\t\t\t\t\t\tonEffectChange={(raw) => {\n\t\t\t\t\t\t\t\tchangeEffect(index, raw);\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\tonParamsChange={(next: EditorEffectParams) => {\n\t\t\t\t\t\t\t\tchangeParams(index, next);\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\tonSummaryChange={(summary) => {\n\t\t\t\t\t\t\t\tpatchRow(index, { summary });\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\tonRemove={() => {\n\t\t\t\t\t\t\t\tonChange(list.filter((_, i) => i !== index));\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t/>\n\t\t\t\t\t))}\n\t\t\t\t</ul>\n\t\t\t\t{/* 引用了Button组件，用于新增 Effect 行 */}\n\t\t\t\t<Button\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tvariant=\"text\"\n\t\t\t\t\tonClick={() => {\n\t\t\t\t\t\tonChange([...list, emptyEffectRow(list)]);\n\t\t\t\t\t}}\n\t\t\t\t>\n\t\t\t\t\t添加 Effect\n\t\t\t\t</Button>\n\t\t\t</div>\n\t\t);\n\t};\n","afterFullFileContent":"/**\n\t* 出口 Effect 列表：仅负责「增删行 + 列表编排」与「把每行分发到子组件」。\n\t* 每种 effect 的参数编辑与下拉都在 ExitEffectRow / com/effects/；整包保存时经 Formik 落盘。\n\t*/\n\"use client\";\n\nimport type { FC } from \"react\";\nimport { Button, Typography } from \"@mui/material\";\nimport type { EditorExitEffectProjection } from \"@studio-v2/typeFiles/story/editor/callCard/editorCallCardProjection\";\nimport type {\n\tEditorEffectParams,\n\tEffectPanelSources,\n} from \"@studio-v2/typeFiles/story/editor/callCard/editorEffectParams\";\nimport { EMPTY_EFFECT_PANEL_SOURCES } from \"@studio-v2/typeFiles/story/editor/callCard/editorEffectParams\";\nimport {\n\tcoerceKnownEffectName,\n\temptyEffectRow,\n} from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/exitListForm\";\nimport { defaultEffectParams } from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/effects/effectParams\";\nimport { summarizeEffect } from \"@studio-v2/src/bis/pageBis/storyEditor/form/exitList/effects/summarizeEffect\";\n// 引用了ExitEffectRow组件，用于单个 Effect 行编辑\nimport { ExitEffectRow } from \"@studio-v2/src/pageComponents/storyEditor/com/panel/ExitListEditor/com/ExitEffectRow\";\nimport styles from \"../index.module.scss\";\n\nexport type ExitEffectsListProps = {\n\teffects: EditorExitEffectProjection[];\n\tonChange: (next: EditorExitEffectProjection[]) => void;\n\tsources?: EffectPanelSources;\n};\n\nexport const ExitEffectsList: FC<ExitEffectsListProps> =\n\tfunction ExitEffectsList({\n\t\t// effects 是当前出口的 Effect 行列表，用于增删与参数编辑\n\t\teffects,\n\t\t// onChange 是整表写回父行，用于同步 Formik\n\t\tonChange,\n\t\t// sources 是 id 下拉候选源，用于角色/卡/包/片段选择\n\t\tsources = EMPTY_EFFECT_PANEL_SOURCES,\n\t}) {\n\t\tconst list = Array.isArray(effects) ? effects : [];\n\n\t\tfunction patchRow(\n\t\t\tindex: number,\n\t\t\tpatch: Partial<EditorExitEffectProjection>,\n\t\t): void {\n\t\t\tonChange(\n\t\t\t\tlist.map((row, i) => (i === index ? { ...row, ...patch } : row)),\n\t\t\t);\n\t\t}\n\n\t\tfunction changeEffect(index: number, rawEffect: string): void {\n\t\t\tconst effect = coerceKnownEffectName(rawEffect);\n\t\t\t// 切换 effect 同时复位 params 并重派生摘要，保证判别键一致且摘要不残留旧 effect 文案\n\t\t\tconst params = defaultEffectParams(effect);\n\t\t\tpatchRow(index, {\n\t\t\t\teffect,\n\t\t\t\tparams,\n\t\t\t\tsummary: summarizeEffect(effect, params, sources),\n\t\t\t});\n\t\t}\n\n\t\t// 改 params 时：摘要仍为自动派生（空或等于旧 params 派生值）则刷新，用户手改后不覆盖\n\t\tfunction changeParams(index: number, next: EditorEffectParams): void {\n\t\t\tconst row = list[index];\n\t\t\tif (!row) return;\n\t\t\tconst prevAuto = summarizeEffect(row.effect, row.params, sources);\n\t\t\tconst isAutoSummary = !row.summary || row.summary === prevAuto;\n\t\t\tconst patch: Partial<EditorExitEffectProjection> = { params: next };\n\t\t\tif (isAutoSummary) {\n\t\t\t\tpatch.summary = summarizeEffect(row.effect, next, sources);\n\t\t\t}\n\t\t\tpatchRow(index, patch);\n\t\t}\n\n\t\treturn (\n\t\t\t<div className={styles.effects}>\n\t\t\t\t{/* 引用了Typography组件，用于 Effect 列表标题 */}\n\t\t\t\t<Typography variant=\"caption\" className={styles.effectsLabel}>\n\t\t\t\t\tEffects（每种 effect 专属参数面板）\n\t\t\t\t</Typography>\n\t\t\t\t<ul className={styles.effectsList}>\n\t\t\t\t\t{list.map((fx, index) => (\n\t\t\t\t\t\t// 引用了ExitEffectRow组件，用于单个 Effect 行编辑\n\t\t\t\t\t\t<ExitEffectRow\n\t\t\t\t\t\t\tkey={fx.id}\n\t\t\t\t\t\t\tfx={fx}\n\t\t\t\t\t\t\tsources={sources}\n\t\t\t\t\t\t\tonEffectChange={(raw) => {\n\t\t\t\t\t\t\t\tchangeEffect(index, raw);\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\tonCriticalChange={(critical) => {\n\t\t\t\t\t\t\t\t// false 清掉键，避免无意义 critical:false 写盘\n\t\t\t\t\t\t\t\tpatchRow(index, {\n\t\t\t\t\t\t\t\t\tcritical: critical ? true : undefined,\n\t\t\t\t\t\t\t\t});\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\tonParamsChange={(next: EditorEffectParams) => {\n\t\t\t\t\t\t\t\tchangeParams(index, next);\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\tonSummaryChange={(summary) => {\n\t\t\t\t\t\t\t\tpatchRow(index, { summary });\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t\tonRemove={() => {\n\t\t\t\t\t\t\t\tonChange(list.filter((_, i) => i !== index));\n\t\t\t\t\t\t\t}}\n\t\t\t\t\t\t/>\n\t\t\t\t\t))}\n\t\t\t\t</ul>\n\t\t\t\t{/* 引用了Button组件，用于新增 Effect 行 */}\n\t\t\t\t<Button\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tvariant=\"text\"\n\t\t\t\t\tonClick={() => {\n\t\t\t\t\t\tonChange([...list, emptyEffectRow(list)]);\n\t\t\t\t\t}}\n\t\t\t\t>\n\t\t\t\t\t添加 Effect\n\t\t\t\t</Button>\n\t\t\t</div>\n\t\t);\n\t};\n","message":"The file /Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/com/panel/ExitListEditor/com/ExitEffectsList.tsx has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"call-5bf24eed-e213-4f4f-a292-e27dd3a28858-54\nfc_92b44b20-478d-99c3-ba43-3393e9d915a0_1","startedAtMs":"1784717685868","completedAtMs":"1784717686338"},"model_call_id":"92d839fd-07e8-44ae-b8e8-e85fd2fb8312-12-gj2m","session_id":"0baf0b73-236c-4e58-ac9d-ef9322fac058","timestamp_ms":1784717686350}
{"type":"tool_call","subtype":"completed","call_id":"call-5bf24eed-e213-4f4f-a292-e27dd3a28858-55\nfc_92b44b20-478d-99c3-ba43-3393e9d915a0_2","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/library/PackageConfigFloat.tsx","streamContent":"/**\n\t* 故事包配置浮窗：StoryPackageConf 字段；entryCardId 可 Select，其余只读。\n\t* 入口写回会话 bundle；整包保存见顶栏。\n\t*/\n\"use client\";\n\nimport type { FC } from \"react\";\nimport { Button, MenuItem, TextField, Typography } from \"@mui/material\";\nimport { projectEditorPackageConfFromBundle } from \"@studio-v2/src/bis/pageBis/storyEditor/package/conf/packageConfProjection\";\nimport type { CallCardLabelOption } from \"@studio-v2/typeFiles/story/callCardLabels\";\nimport type { DiskStoryPackageBundle } from \"@studio-v2/typeFiles/story/package/diskStoryPackage\";\nimport styles from \"./EditorLibraryFloat.module.scss\";\n\nexport type PackageConfigFloatProps = {\n\t/** 当前打开的磁盘整包（含会话内已改 entryCardId） */\n\tbundle: DiskStoryPackageBundle;\n\t/** 入口卡 Select 候选；优先画布现有 CallCard，兜底 conf.cards */\n\tentryCardOptions: readonly CallCardLabelOption[];\n\topen: boolean;\n\tonClose: () => void;\n\t/** 入口卡变更；写会话 bundle.conf.entryCardId，顶栏保存落盘 */\n\tonEntryCardIdChange: (cardId: string) => void;\n};\n\nfunction labelOrDash(value: string): string {\n\treturn value.trim().length > 0 ? value : \"—\";\n}\n\nexport const PackageConfigFloat: FC<PackageConfigFloatProps> =\n\tfunction PackageConfigFloat({\n\t\t// bundle 是当前整包，用于投影与入口回显\n\t\tbundle,\n\t\t// entryCardOptions 是本包 cardId 候选，用于入口 Select\n\t\tentryCardOptions,\n\t\t// open 表示浮窗是否可见，用于条件渲染\n\t\topen,\n\t\t// onClose 是关闭回调，用于收起浮窗\n\t\tonClose,\n\t\t// onEntryCardIdChange 是入口卡写回，用于会话内改 conf.entryCardId\n\t\tonEntryCardIdChange,\n\t}) {\n\t\tif (!open) return null;\n\n\t\tconst conf = projectEditorPackageConfFromBundle(bundle);\n\t\tconst entryValue =\n\t\t\tentryCardOptions.some(function (opt) {\n\t\t\t\treturn opt.value === conf.entryCardId;\n\t\t\t})\n\t\t\t\t? conf.entryCardId\n\t\t\t\t: \"\";\n\n\t\treturn (\n\t\t\t<aside className={styles.floatRight} aria-label=\"包配置浮窗\">\n\t\t\t\t<div className={styles.head}>\n\t\t\t\t\t{/* 引用了Typography组件，用于浮窗标题 */}\n\t\t\t\t\t<Typography variant=\"subtitle2\" className={styles.title}>\n\t\t\t\t\t\t包配置\n\t\t\t\t\t</Typography>\n\t\t\t\t\t{/* 引用了Button组件，用于关闭包配置浮窗 */}\n\t\t\t\t\t<Button size=\"small\" onClick={onClose} aria-label=\"关闭包配置浮窗\">\n\t\t\t\t\t\t关闭\n\t\t\t\t\t</Button>\n\t\t\t\t</div>\n\t\t\t\t{/* 引用了Typography组件，用于可编说明 */}\n\t\t\t\t<Typography variant=\"caption\" className={styles.hint}>\n\t\t\t\t\t入口卡可改；其它包级元数据本刀次只读。编辑单卡请点画布\n\t\t\t\t\tCallCard；保存请用顶栏「保存」。\n\t\t\t\t</Typography>\n\n\t\t\t\t{/* 引用了TextField组件，用于入口卡 Select */}\n\t\t\t\t<TextField\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tselect\n\t\t\t\t\tfullWidth\n\t\t\t\t\tlabel=\"入口卡 entryCardId\"\n\t\t\t\t\tvalue={entryValue}\n\t\t\t\t\tdisabled={entryCardOptions.length === 0}\n\t\t\t\t\thelperText={\n\t\t\t\t\t\tentryCardOptions.length === 0\n\t\t\t\t\t\t\t? \"本包暂无 CallCard，请先放置卡片\"\n\t\t\t\t\t\t\t: \"章节起点；删入口卡时保存会改指向首张\"\n\t\t\t\t\t}\n\t\t\t\t\tonChange={(e) => {\n\t\t\t\t\t\tonEntryCardIdChange(e.target.value);\n\t\t\t\t\t}}\n\t\t\t\t>\n\t\t\t\t\t{entryCardOptions.map(function (opt) {\n\t\t\t\t\t\treturn (\n\t\t\t\t\t\t\t// 引用了MenuItem组件，用于入口卡选项\n\t\t\t\t\t\t\t<MenuItem key={opt.value} value={opt.value}>\n\t\t\t\t\t\t\t\t{opt.label}\n\t\t\t\t\t\t\t</MenuItem>\n\t\t\t\t\t\t);\n\t\t\t\t\t})}\n\t\t\t\t</TextField>\n\n\t\t\t\t<dl className={styles.readonlyList}>\n\t\t\t\t\t<div className={styles.readonlyRow}>\n\t\t\t\t\t\t<dt>schemaVersion</dt>\n\t\t\t\t\t\t<dd>{conf.schemaVersion}</dd>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div className={styles.readonlyRow}>\n\t\t\t\t\t\t<dt>packageId</dt>\n\t\t\t\t\t\t<dd>{conf.packageId}</dd>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div className={styles.readonlyRow}>\n\t\t\t\t\t\t<dt>title</dt>\n\t\t\t\t\t\t<dd>{labelOrDash(conf.title)}</dd>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class