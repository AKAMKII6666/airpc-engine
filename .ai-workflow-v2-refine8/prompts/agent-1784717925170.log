/}\n\t\t\t\t<Button\n\t\t\t\t\tsize=\"small\"\n\t\t\t\t\tvariant=\"text\"","isEmpty":false,"exceededLimit":false,"totalLines":129,"fileSize":4480,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/pageComponents/storyEditor/com/panel/ExitListEditor/com/ExitEffectsList.tsx","readRange":{"startLine":70,"endLine":119},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-79462297-9a17-43e9-bd90-e247722afd88-22\nfc_dd7a4d6d-e2ac-9be9-894d-021efd8e6f56_1","startedAtMs":"1784717979604","completedAtMs":"1784717979744"},"model_call_id":"9a365df1-46e7-462d-864c-dd0f00e661a7-5-rm49","session_id":"7b1899d1-4d23-4f88-b368-8bd6a8361c9b","timestamp_ms":1784717979733}
