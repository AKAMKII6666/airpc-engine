Studio 深引引擎内部路径「绕过门面」。\n","isEmpty":false,"exceededLimit":false,"totalLines":40,"fileSize":2554,"path":"/Users/bolbiao/workspace/airpc-engine/.cursor/rules/engine-boundaries.mdc","readRange":{"startLine":1,"endLine":40},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-969cfc14-4ffe-4f6c-a35c-a2469c0c9887-19\nfc_b5d6edd3-d965-94f8-86ea-b159bf8924eb_4","startedAtMs":"1784786274783","completedAtMs":"1784786274921"},"model_call_id":"e8d790a1-93fd-4d56-9a3d-1b6a957221fb-4-jbx6","session_id":"54731ed0-b797-4648-ab4c-b3b5d1ebe8bc","timestamp_ms":1784786274861}
