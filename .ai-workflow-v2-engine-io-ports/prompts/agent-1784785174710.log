located-test\");\n    assert.ok(errors.some((v) => v.ruleId === \"STUDIO-STRUCT-007\"));\n  });\n\n  it(\"深挖引擎内部路径失败\", async () => {\n    const { errors } = await gateFor(\"fail-deep-engine\");\n    assert.ok(errors.some((v) => v.ruleId === \"STUDIO-STRUCT-006\"));","isEmpty":false,"exceededLimit":false,"totalLines":222,"fileSize":7402,"path":"/Users/bolbiao/workspace/airpc-engine/scripts/studio-quality/tests/check-studio-structure.test.mjs","readRange":{"startLine":70,"endLine":129},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-41ef274b-f0f0-47fe-b63d-17074c3230fb-25\nfc_afb09b83-ec76-9c37-a2b0-36c5296248d7_1","startedAtMs":"1784785244595","completedAtMs":"1784785244993"},"model_call_id":"2fb3807b-8d6c-469c-9f63-98de79b224e7-5-19y7","session_id":"8af59e86-1d2d-4bfe-8a74-5ec4411676cc","timestamp_ms":1784785244955}
