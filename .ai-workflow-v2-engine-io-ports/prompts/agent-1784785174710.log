INTERNAL\",\n\t\t\t\t\tmessage: err instanceof Error ? err.message : String(err),\n\t\t\t\t};\n\t\t\t}\n\t\t\tthrow err;\n\t\t}\n\t}\n\tif (workspaceError && !workspaceLoaded) {\n\t\tthrow workspaceError;\n\t}\n\treturn host;\n}\n\nexport function getStudioV2WorkspaceLoadError(): {\n\tcode: string;\n\tmessage: string;\n} | null {\n\treturn workspaceError;\n}\n\n/**\n\t* Content 保存后刷新引擎工作区缓存。\n\t* 默认保留 sessions / profiles（与旧 Studio reload 口径一致）。\n\t*/\nexport async function reloadStudioV2Workspace(): Promise<void> {","isEmpty":false,"exceededLimit":false,"totalLines":128,"fileSize":3622,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/src/utils/server/host/engineHost.server.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f0c95d8b-10ca-4388-a578-a8b2419e6f57-23\nfc_271259ca-67ad-9341-89ca-2fb27d6183a7_5","startedAtMs":"1784785234280","completedAtMs":"1784785234914"},"model_call_id":"2fb3807b-8d6c-469c-9f63-98de79b224e7-4-tn7b","session_id":"8af59e86-1d2d-4bfe-8a74-5ec4411676cc","timestamp_ms":1784785235546}
