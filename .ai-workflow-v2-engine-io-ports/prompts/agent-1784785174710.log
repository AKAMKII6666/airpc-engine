n\t*\n\t* @param dataRoot 工作区根（本机即仓库 `data/` 或等价绝对路径）\n\t*/\nexport function createEngineIOPorts(dataRoot: string): EngineIOPorts {\n\treturn {\n\t\tmemory: createSqliteMemoryPort(\n\t\t\tpath.join(dataRoot, \"memory\", \"memory.sqlite\"),\n\t\t),\n\t\tprofile: createFsProfilePort(dataRoot),\n\t\tcontent: createFsContentPort(),\n\t\tengineLog: createFsEngineLogPort(dataRoot),\n\t};\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":57,"fileSize":2283,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/engineIOModule/createEngineIOPorts.ts","readRange":{"startLine":1,"endLine":57},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-2f2780be-98e6-4dea-b1cb-a6ac83663986-35\nfc_9faf045e-71c0-9111-8b13-4da2a74cd78b_4","startedAtMs":"1784785280143","completedAtMs":"1784785280607"},"model_call_id":"2fb3807b-8d6c-469c-9f63-98de79b224e7-6-tnkl","session_id":"8af59e86-1d2d-4bfe-8a74-5ec4411676cc","timestamp_ms":1784785280562}
