ator: \"fake://log\", lines: [...lines], truncated: false };\n\t\t},\n\t};\n}\n\ndescribe(\"createEngineHost Port injection (V2-IO-2)\", function () {\n\tit(\"未注入时 Port getter 为 null，缺省走遗留路径策略\", function () {\n\t\tconst host = createEngineHost({ persist: false, autoMemory: false });\n\t\texpect(host.getProfilePort()).toBeNull();\n\t\texpect(host.getContentPort()).toBeNull();\n\t\texpect(host.getEngineLogPort()).toBeNull();\n\t\texpect(host.getMemoryPort()).toBeNull();\n\t});\n\n\tit(\"注入后 Port getter 返回同一实例（持有策略）\", function () {\n\t\tconst profile = createFakeProfilePort();\n\t\tconst content = createFakeContentPort();\n\t\tconst engineLog = createFakeEngineLogPort();\n\t\tconst host = createEngineHost({\n\t\t\tpersist: false,\n\t\t\tautoMemory: false,\n\t\t\tprofile,\n\t\t\tcontent,\n\t\t\tengineLog,\n\t\t});\n\t\texpect(host.getProfilePort()).toBe(profile);\n\t\texpect(host.getContentPort()).toBe(content);\n\t\texpect(host.getEngineLogPort()).toBe(engineLog);\n\t});\n\n\tit(\"显式 null 与 undefined 均视为未注入\", function () {\n\t\tconst host = createEngineHost({\n\t\t\tpersist: false,\n\t\t\tautoMemory: false,\n\t\t\tprofile: null,\n\t\t\tcontent: null,\n\t\t\tengineLog: null,\n\t\t\tmemory: null,\n\t\t});\n\t\texpect(host.getProfilePort()).toBeNull();\n\t\texpect(host.getContentPort()).toBeNull();\n\t\texpect(host.getEngineLogPort()).toBeNull();\n\t\texpect(host.getMemoryPort()).toBeNull();\n\t});\n\n\tit(\"注入 engineLog 后 appendWet 经 Port.append 落旁路\", async function () {\n\t\tconst engineLog = createFakeEngineLogPort();\n\t\tconst host = createEngineHost({\n\t\t\tpersist: true,\n\t\t\tautoMemory: false,\n\t\t\tengineLog,\n\t\t});\n\t\t// loadWorkspace 仍走遗留 fs；此处仅验证 pushLog→engineLog 分支可调用\n\t\tconst record = host.appendWet({\n\t\t\ttype: \"wet.annotation\",\n\t\t\tpayload: { note: \"port-inject\" },\n\t\t});\n\t\tif (\"code\" in (record as object) && (record as { code?: string }).code) {\n\t\t\tthrow new Error(\"appendWet failed\");\n\t\t}\n\t\tconst slice = await engineLog.readSlice();\n\t\texpect(slice.lines.some(function (line) {\n\t\t\treturn line.type === \"wet.annotation\";\n\t\t})).toBe(true);\n\t\t// persist 且无 workspace 时 pushLog 不写盘；先挂假 workspace 不现实。\n\t\t// 有 Port 时 readLogFileSlice 不依赖 workspace：\n\t\tconst fileSlice = await host.readLogFileSlice({ limit: 10 });\n\t\tif (\"code\" in (fileSlice as object)) {\n\t\t\tthrow new Error(\"readLogFileSlice failed\");\n\t\t}\n\t\texpect(\n\t\t\t(fileSlice as { file: string }).file,\n\t\t).toBe(\"fake://log\");\n\t});\n\n\tit(\"ProfilePort / ContentPort 类型可被假实现满足（编译期合同）\", async function () {\n\t\tconst profile = createFakeProfilePort();\n\t\tconst content = createFakeContentPort();\n\t\tconst initial = {\n\t\t\tschemaVersion: 1 as const,\n\t\t\tuserId: \"u1\",\n\t\t\tuser: { displayName: \"t\" },\n\t\t\tcharacters: {},\n\t\t\tstories: {},\n\t\t\tcallCards: { board: { byAgent: {} } },\n\t\t\tworld: {},\n\t\t\tschedule: { clockMs: 0, intents: [] },\n\t\t\tresearch: {},\n\t\t} satisfies PlayerProfile;\n\t\tconst ensured = await profile.ensureProfile({\n\t\t\tuserId: \"u1\",\n\t\t\tinitial,\n\t\t});\n\t\texpect(ensured.userId).toBe(\"u1\");\n\t\tconst snap = await content.loadWorkspaceSnapshot({\n\t\t\tworkspaceKey: \"/tmp\",\n\t\t});\n\t\texpect(snap.packages).toEqual([]);\n\t});\n});\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/ports-injection.test.ts","linesAdded":171,"linesRemoved":0,"diffString":"--- /dev/null\n+++ b//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/ports-injection.test.ts\n@@ -1 +1,172 @@\n+/**\n+ * V2-IO-2：Content/Profile/EngineLog Port 注入面与缺省策略。\n+ */\n+import { describe, expect, it } from \"vitest\";\n+import {\n+\tcreateEngineHost,\n+\ttype ContentPort,\n+\ttype EngineLogPort,\n+\ttype PackageValidateBundle,\n+\ttype ProfilePort,\n+\ttype WorkspaceSnapshot,\n+} from \"../../src/index.js\";\n+import type { PlayerProfile } from \"../../src/schema/profile.js\";\n \n+function crea