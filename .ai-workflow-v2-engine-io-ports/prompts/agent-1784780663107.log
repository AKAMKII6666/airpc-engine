 媒介 EffectSink；缺省 Noop 桩 */\n\teffectSink?: EffectSink | null;\n\t/** Lore 生成端口；null／缺省 → 直接 fallback */\n\tloreBootstrap?: LoreBootstrapPort | null;\n}\n\n/**\n * 将 options 中的 Port 字段规范为 `T | null`（undefined 与 null 均视为未注入）。\n */\nexport function resolveOptionalPort<T>(value: T | null | undefined): T | null {\n\treturn value === undefined ? null : value;\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-397bf018-e0f3-4865-bd15-e2dd8c610c32-43\nfc_30ab0d84-0c96-9714-abb2-d3ea179bbe4c_0","startedAtMs":"1784780859057"},"model_call_id":"1a4ba06a-42b7-4c5a-bde0-e96315aab975-13-i1s6","session_id":"d7cfd367-04b7-4349-bda8-cb59179dc1e3","timestamp_ms":1784780859084}
