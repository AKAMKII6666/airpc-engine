{"type":"tool_call","subtype":"completed","call_id":"call-037dba52-4067-4c59-bcf1-702798faf2f1-68\nfc_b1ebba39-adbd-9086-a5df-091f32f0c0a5_0","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/ports/engineHostApi.ts","streamContent":"/** undefined 与 null 均视为未注入。 */\nexport function resolveOptionalPort<T>(value: T | null | undefined): T | null {\n\treturn value === undefined ? null : value;\n}\n\n/**\n * Port getter 面：从 createEngineHost 闭包拆出，避免 Host 组合函数 maxFnLines 净增。\n */\nexport function createInjectedPortAccessorsFromOptions(\n\toptions: CreateEngineHostOptions,\n\tgetMemory: () => MemoryPort | null,\n): Pick<\n\tEngineHost,\n\t\"getMemoryPort\" | \"getProfilePort\" | \"getContentPort\" | \"getEngineLogPort\"\n> {\n\treturn {\n\t\tgetMemoryPort: getMemory,\n\t\tgetProfilePort() {\n\t\t\treturn resolveOptionalPort(options.profile);\n\t\t},\n\t\tgetContentPort() {\n\t\t\treturn resolveOptionalPort(options.content);\n\t\t},\n\t\tgetEngineLogPort() {\n\t\t\treturn resolveOptionalPort(options.engineLog);\n\t\t},\n\t};\n}\n\n/**\n * Host 内存 ring +（过渡期）遗留 jsonl 旁路；从 createEngineHost 拆出以控 maxFnLines。\n */\nexport function createHostPushLog(input: {\n\tlogs: LogRecord[];\n\tisPersist: () => boolean;\n\tgetWorkspaceRootDir: () => string | null;\n\tappendJsonl: (rootDir: string, record: LogRecord) => Promise<void>;\n\tredact: (record: LogRecord) => LogRecord;\n}): (record: LogRecord) => void {\n\treturn function pushLog(record: LogRecord): void {\n\t\tconst safe = input.redact(record);\n\t\tinput.logs.push(safe);\n\t\tif (input.logs.length > 500) {\n\t\t\tinput.logs.shift();\n\t\t}\n\t\tif (!input.isPersist()) {\n\t\t\treturn;\n\t\t}\n\t\tconst rootDir = input.getWorkspaceRootDir();\n\t\tif (!rootDir) {\n\t\t\treturn;\n\t\t}\n\t\tvoid input.appendJsonl(rootDir, safe).catch(function () {\n\t\t\t// 旁路失败不打断主路径\n\t\t});\n\t};\n}\n"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/ports/engineHostApi.ts","linesAdded":37,"linesRemoved":10,"diffString":"--- a//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/ports/engineHostApi.ts\n+++ b//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/ports/engineHostApi.ts\n@@ -216,25 +216,52 @@\n /**\n  * Port getter 面：从 createEngineHost 闭包拆出，避免 Host 组合函数 maxFnLines 净增。\n  */\n-export function createInjectedPortAccessors(input: {\n-\tgetMemory: () => MemoryPort | null;\n-\tprofile: ProfilePort | null;\n-\tcontent: ContentPort | null;\n-\tengineLog: EngineLogPort | null;\n-}): Pick<\n+export function createInjectedPortAccessorsFromOptions(\n+\toptions: CreateEngineHostOptions,\n+\tgetMemory: () => MemoryPort | null,\n+): Pick<\n \tEngineHost,\n \t\"getMemoryPort\" | \"getProfilePort\" | \"getContentPort\" | \"getEngineLogPort\"\n > {\n \treturn {\n-\t\tgetMemoryPort: input.getMemory,\n+\t\tgetMemoryPort: getMemory,\n \t\tgetProfilePort() {\n-\t\t\treturn input.profile;\n+\t\t\treturn resolveOptionalPort(options.profile);\n \t\t},\n \t\tgetContentPort() {\n-\t\t\treturn input.content;\n+\t\t\treturn resolveOptionalPort(options.content);\n \t\t},\n \t\tgetEngineLogPort() {\n-\t\t\treturn input.engineLog;\n+\t\t\treturn resolveOptionalPort(options.engineLog);\n \t\t},\n \t};\n }\n+\n+/**\n+ * Host 内存 ring +（过渡期）遗留 jsonl 旁路；从 createEngineHost 拆出以控 maxFnLines。\n+ */\n+export function createHostPushLog(input: {\n+\tlogs: LogRecord[];\n+\tisPersist: () => boolean;\n+\tgetWorkspaceRootDir: () => string | null;\n+\tappendJsonl: (rootDir: string, record: LogRecord) => Promise<void>;\n+\tredact: (record: LogRecord) => LogRecord;\n+}): (record: LogRecord) => void {\n+\treturn function pushLog(record: LogRecord): void {\n+\t\tconst safe = input.redact(record);\n+\t\tinput.logs.push(safe);\n+\t\tif (input.logs.length > 500) {\n+\t\t\tinput.logs.shift();\n+\t\t}\n+\t\tif (!input.isPersist()) {\n+\t\t\treturn;\n+\t\t}\n+\t\tconst rootDir = input.getWorkspaceRootDir();\n+\t\tif (!rootDir) {\n+\t\t\treturn;\n+\t\t}\n+\t\tvoid input.appendJsonl(rootDir, safe).catch(function () {\n+\t\t\t// 旁路失败不打断主路径\n+\t\t});\n+\t};\n+}","beforeFullFileContent":"/**\n * 模块名称：EngineHost 公共 API 与存取 Port 注入选项（技术设计 19 / 23）\n * 模块说明：从 createEngineHost 实现文件拆出，避免遗留超限文件净增。\n */\nimport type { EngineError } from \"../host/errors.js\";\nimport type {\n\tBeginCallOpts,\n\tCallIntent,\n\tCallSession,\n\tEndCallResult,\n\tLogRecord,\n\tResolveResult,\n\tSaveReason,\n} from \"../host/types.js\";\nimport type {\n\tWetAppendInput,\n\tWetQueryOpts,\n\tWetReplayView,\n} from \"../host/wet.js\";\nimport type { LoreBootstrapPort } from \"../lore/types.js\";\nimport type { MemoryPort } from \"../memory/types.js\";\nimport type {\n\tAdvanceToNextResult,\n\tFiredScheduleItem,\n} from \"../runtime/scheduleTick.js\";\nimport type { EffectSink } from \"../runtime/effectSink.js\";\nimport type { CallFlowSimEventKind } from \"../runtime/selectCallFlowPrompt.js\";\nimport type { Outcome } from \"../schema/outcome.js\";\nimport type { PlayerProfile } from \"../schema/profile.js\";\nimport type { WorldLoreDoc } from \"../schema/worldLore.js\";\nimport type { ToolInvokeResult } from \"../tools/types.js\";\nimport type { ValidationReport } from \"../validation/types.js\";\nimport type { ContentPort } from \"./contentPort.js\";\nimport type { EngineLogPort } from \"./engineLogPort.js\";\nimport type { ProfilePort } from \"./profilePort.js\";\n\nexport interface LoadWorkspaceOptions {\n\t/**\n\t * 为 true 时清空 profiles / sessions / activeByUser。\n\t * 默认 false：仅刷 Content 缓存，保留本通调试 Session 与已载 Profile。\n\t * rootDir 变更时强制视为 true。\n\t */\n\tresetRuntime?: boolean;\n}\n\nexport interface EngineHost {\n\tloadWorkspace(\n\t\trootDir: string,\n\t\topts?: LoadWorkspaceOptions,\n\t): Promise<void>;\n\t/** 显式踢会话／清 Profile 缓存；不重读 Content。禁与普通 Content 保存绑定。 */\n\tresetRuntime(): void;\n\tpreloadCard(\n\t\tpackageId: string,\n\t\tcardId: string,\n\t): Promise<void | EngineError>;\n\tensureProfile(userId: string): Promise<PlayerProfile>;\n\tsaveProfile(userId: string, reason: SaveReason): Promise<void>;\n\tresolve(userId: string, intent: CallIntent): ResolveResult | EngineError;\n\tresolveAsync(\n\t\tuserId: string,\n\t\tintent: CallIntent,\n\t): Promise<ResolveResult | EngineError>;\n\tbeginCall(\n\t\tuserId: string,\n\t\tresult: ResolveResult,\n\t\topts: BeginCallOpts,\n\t): Promise<CallSession | EngineError>;\n\tendCall(\n\t\tsessionId: string,\n\t\toutcome: Outcome,\n\t): Promise<EndCallResult | EngineError>;\n\tinvokeTool(\n\t\tsessionId: string,\n\t\ttoolId: string,\n\t\targs?: Record<string, unknown>,\n\t): Promise<ToolInvokeResult | EngineError>;\n\t/**\n\t * 播放完成（桩）：置 playback_completed；\n\t * hybrid → dialogue；playback_only 仍可挂机收 Outcome。\n\t */\n\tcompletePlayback(sessionId: string): CallSession | EngineError;\n\t/**\n\t * 过程话术模拟：壳／Studio 上报事件，引擎选型注入 lastSimEvent（不计时、不写 Profile）。\n\t */\n\tsimEvent(\n\t\tsessionId: string,\n\t\tkind: CallFlowSimEventKind,\n\t): CallSession | EngineError;\n\t/**\n\t * 文本调试轮次登记（通话中）；不跑 Effect、不写 Profile。\n\t */\n\trecordChatTurn(\n\t\tsessionId: string,\n\t\tturn: { role: \"user\" | \"assistant\" | \"system\"; text: string },\n\t): CallSession | EngineError;\n\tgetActiveSession(userId: string): CallSession | null;\n\tgetSession(sessionId: string): CallSession | null;\n\tgetRecentLogs(opts?: { userId?: string; limit?: number }): LogRecord[];\n\t/** 读 data/logs/engine-YYYYMMDD.jsonl 切片（已脱敏写入） */\n\treadLogFileSlice(opts?: {\n\t\tday?: string;\n\t\tlimit?: number;\n\t}): Promise<{\n\t\tfile: string;\n\t\tlines: LogRecord[];\n\t\ttruncated: boolean;\n\t} | EngineError>;\n\t/**\n\t * WET 查询：合并 ring（+可选当日 jsonl），按 type／session／时间过滤。\n\t */\n\tqueryWet(opts?: WetQueryOpts & { includeFile?: boolean }): Promise<{\n\t\tevents: LogRecord[];\n\t\tstorageNote: string;\n\t\tfile?: string;\n\t\ttruncated?: boolean;\n\t} | EngineError>;\n\t/**\n\t * 受控追加：仅 wet.annotation／wet.compensation；禁止改写历史／冒充 effect 账本。\n\t */\n\tappendWet(input: WetAppendInput): LogRecord | EngineError;\n\t/** 重放视图：session 相关事件 + exit／effect plan 摘要（只读） */\n\tgetWetReplay(sessionId: string): Promise<WetReplayView | EngineError>;\n\tgetLoadedCardCount(packageId: string): number;\n\tgetMemoryPort(): MemoryPort | null;\n\t/** 已注入的 ProfilePort；未注入为 null（过渡期 Host 仍走遗留 fs） */\n\tgetProfilePort(): ProfilePort | null;\n\t/** 已注入的 ContentPort；未注入为 null（过渡期 Host 仍走遗留 fs） */\n\tgetContentPort(): ContentPort | null;\n\t/** 已注入的 EngineLogPort；未注入为 null（过渡期 Host 仍走遗留 jsonl） */\n\tgetEngineLogPort(): EngineLogPort | null;\n\tvalidatePackage(packageId: string): Promise<ValidationReport>;\n\t/**\n\t * 推进 Profile.schedule.clockMs：物化到期 recurring→once，再 tick once → outbound pending。\n\t * 返回本拍 fired 列表，供调试台再 resolve(agent_outbound)。\n\t */\n\tadvanceClock(\n\t\tuserId: string,\n\t\tdeltaMs: number,\n\t): FiredScheduleItem[] | EngineError;\n\t/** 跳到绝对逻辑时刻（仅前进）并 Tick */\n\tsetClockMs(\n\t\tuserId: string,\n\t\ttoClockMs: number,\n\t): FiredScheduleItem[] | EngineError;\n\t/** 推到下一意图（pending once 或 recurring 下次 occurrence） */\n\tadvanceClockToNextIntent(\n\t\tuserId: string,\n\t): AdvanceToNextResult | EngineError;\n\t/**\n\t * Lore bootstrap：有 location 或 force 时写入 Profile.world.lore；\n\t * port 失败降级 fallback；不阻塞调用方。\n\t */\n\tbootstrapLore(\n\t\tuserId: string,\n\t\topts?: { force?: boolean },\n\t): Promise<\n\t\t| {\n\t\t\t\tlore: WorldLoreDoc;\n\t\t\t\tusedFallback: boolean;\n\t\t\t\terrorMessage?: string;\n\t\t  }\n\t\t| EngineError\n\t>;\n}\n\n/**\n * Host 装配选项（存取 Port 合同见技术设计 23）。\n *\n * ## 注入缺省策略（已钉死）\n *\n * | Port | 选项 | 未注入时（过渡期） | 目标态（迁出完成后） |\n * |------|------|-------------------|----------------------|\n * | Memory | `memory` | `autoMemory!==false` 时仍 `createSqliteMemoryPort`（遗留，待 V2-IO-4 删） | 须由宿主注入；禁引擎内 sqlite 真源 |\n * | Profile | `profile` | 继续 `persistProfile` / `readProfile` fs 路径（待 V2-IO-5） | 必注入；Host 不拼磁盘路径 |\n * | Content | `content` | 继续 `loadWorkspaceState` fs 扫描（待 V2-IO-6/8） | 必注入 |\n * | EngineLog | `engineLog` | 继续 `engineLogFile` jsonl（待 V2-IO-7） | 可选；无则仅内存 ring |\n *\n * 本刀钉类型与注入面：已注入 Port 经 getter 可观测；调用改接在后续迁出刀完成。\n * 测试：注入内存假 Port。本机 Studio：`engineIOModule` 工厂一次创建全套并注入。\n */\nexport interface CreateEngineHostOptions {\n\tpersist?: boolean;\n\tmemory?: MemoryPort | null;\n\t/**\n\t * 未注入 memory 时是否自动建 sqlite。\n\t * 过渡期缺省 true（兼容既有测）；迁出完成后应视为废弃，宿主必须显式注入 memory。\n\t */\n\tautoMemory?: boolean;\n\t/**\n\t * 薄 Profile 读写。未注入 → 过渡期走引擎内 fs（将删除）。\n\t * 目标态：必注入。\n\t */\n\tprofile?: ProfilePort | null;\n\t/**\n\t * Content / Workspace 只读。未注入 → 过渡期走引擎内 fs（将删除）。\n\t * 目标态：必注入。\n\t */\n\tcontent?: ContentPort | null;\n\t/**\n\t * 旁路 jsonl。未注入 → 过渡期走引擎内 engineLogFile；\n\t * 目标态：可选（无则只保留 Host 内存 ring）。\n\t */\n\tengineLog?: EngineLogPort | null;\n\t/** 媒介 EffectSink；缺省 Noop 桩 */\n\teffectSink?: EffectSink | null;\n\t/** Lore 生成端口；null／缺省 → 直接 fallback */\n\tloreBootstrap?: LoreBootstrapPort | null;\n}\n\n/** undefined 与 null 均视为未注入。 */\nexport function resolveOptionalPort<T>(value: T | null | undefined): T | null {\n\treturn value === undefined ? null : value;\n}\n\n/**\n * Port getter 面：从 createEngineHost 闭包拆出，避免 Host 组合函数 maxFnLines 净增。\n */\nexport function createInjectedPortAccessors(input: {\n\tgetMemory: () => MemoryPort | null;\n\tprofile: ProfilePort | null;\n\tcontent: ContentPort | null;\n\tengineLog: EngineLogPort | null;\n}): Pick<\n\tEngineHost,\n\t\"getMemoryPort\" | \"getProfilePort\" | \"getContentPort\" | \"getEngineLogPort\"\n> {\n\treturn {\n\t\tgetMemoryPort: input.getMemory,\n\t\tgetProfilePort() {\n\t\t\treturn input.profile;\n\t\t},\n\t\tgetContentPort() {\n\t\t\treturn input.content;\n\t\t},\n\t\tgetEngineLogPort() {\n\t\t\treturn input.engineLog;\n\t\t},\n\t};\n}\n","afterFullFileContent":"/**\n * 模块名称：EngineHost 公共 API 与存取 Port 注入选项（技术设计 19 / 23）\n * 模块说明：从 createEngineHost 实现文件拆出，避免遗留超限文件净增。\n */\nimport type { EngineError } from \"../host/errors.js\";\nimport type {\n\tBeginCallOpts,\n\tCallIntent,\n\tCallSession,\n\tEndCallResult,\n\tLogRecord,\n\tResolveResult,\n\tSaveReason,\n} from \"../host/types.js\";\nimport type {\n\tWetAppendInput,\n\tWetQueryOpts,\n\tWetReplayView,\n} from \"../host/wet.js\";\nimport type { LoreBootstrapPort } from \"../lore/types.js\";\nimport type { MemoryPort } from \"../memory/types.js\";\nimport type {\n\tAdvanceToNextResult,\n\tFiredScheduleItem,\n} from \"../runtime/scheduleTick.js\";\nimport type { EffectSink } from \"../runtime/effectSink.js\";\nimport type { CallFlowSimEventKind } from \"../runtime/selectCallFlowPrompt.js\";\nimport type { Outcome } from \"../schema/outcome.js\";\nimport type { PlayerProfile } from \"../schema/profile.js\";\nimport type { WorldLoreDoc } from \"../schema/worldLore.js\";\nimport type { ToolInvokeResult } from \"../tools/types.js\";\nimport type { ValidationReport } from \"../validation/types.js\";\nimport type { ContentPort } from \"./contentPort.js\";\nimport type { EngineLogPort } from \"./engineLogPort.js\";\nimport type { ProfilePort } from \"./profilePort.js\";\n\nexport interface LoadWorkspaceOptions {\n\t/**\n\t * 为 true 时清空 profiles / sessions / activeByUser。\n\t * 默认 false：仅刷 Content 缓存，保留本通调试 Session 与已载 Profile。\n\t * rootDir 变更时强制视为 true。\n\t */\n\tresetRuntime?: boolean;\n}\n\nexport interface EngineHost {\n\tloadWorkspace(\n\t\trootDir: string,\n\t\topts?: LoadWorkspaceOptions,\n\t): Promise<void>;\n\t/** 显式踢会话／清 Profile 缓存；不重读 Content。禁与普通 Content 保存绑定。 */\n\tresetRuntime(): void;\n\tpreloadCard(\n\t\tpackageId: string,\n\t\tcardId: string,\n\t): Promise<void | EngineError>;\n\tensureProfile(userId: string): Promise<PlayerProfile>;\n\tsaveProfile(userId: string, reason: SaveReason): Promise<void>;\n\tresolve(userId: string, intent: CallIntent): ResolveResult | EngineError;\n\tresolveAsync(\n\t\tuserId: string,\n\t\tintent: CallIntent,\n\t): Promise<ResolveResult | EngineError>;\n\tbeginCall(\n\t\tuserId: string,\n\t\tresult: ResolveResult,\n\t\topts: BeginCallOpts,\n\t): Promise<CallSession | EngineError>;\n\tendCall(\n\t\tsessionId: string,\n\t\toutcome: Outcome,\n\t): Promise<EndCallResult | EngineError>;\n\tinvokeTool(\n\t\tsessionId: string,\n\t\ttoolId: string,\n\t\targs?: Record<string, unknown>,\n\t): Promise<ToolInvokeResult | EngineError>;\n\t/**\n\t * 播放完成（桩）：置 playback_completed；\n\t * hybrid → dialogue；playback_only 仍可挂机收 Outcome。\n\t */\n\tcompletePlayback(sessionId: string): CallSession | EngineError;\n\t/**\n\t * 过程话术模拟：壳／Studio 上报事件，引擎选型注入 lastSimEvent（不计时、不写 Profile）。\n\t */\n\tsimEvent(\n\t\tsessionId: string,\n\t\tkind: CallFlowSimEventKind,\n\t): CallSession | EngineError;\n\t/**\n\t * 文本调试轮次登记（通话中）；不跑 Effect、不写 Profile。\n\t */\n\trecordChatTurn(\n\t\tsessionId: string,\n\t\tturn: { role: \"user\" | \"assistant\" | \"system\"; text: string },\n\t): CallSession | EngineError;\n\tgetActiveSession(userId: string): CallSession | null;\n\tgetSession(sessionId: string): CallSession | null;\n\tgetRecentLogs(opts?: { userId?: string; limit?: number }): LogRecord[];\n\t/** 读 data/logs/engine-YYYYMMDD.jsonl 切片（已脱敏写入） */\n\treadLogFileSlice(opts?: {\n\t\tday?: string;\n\t\tlimit?: number;\n\t}): Promise<{\n\t\tfile: string;\n\t\tlines: LogRecord[];\n\t\ttruncated: boolean;\n\t} | EngineError>;\n\t/**\n\t * WET 查询：合并 ring（+可选当日 jsonl），按 type／session／时间过滤。\n\t */\n\tqueryWet(opts?: WetQueryOpts & { includeFile?: boolean }): Promise<{\n\t\tevents: LogRecord[];\n\t\tstorageNote: string;\n\t\tfile?: string;\n\t\ttruncated?: boolean;\n\t} | EngineError>;\n\t/**\n\t * 受控追加：仅 wet.annotation／wet.compensation；禁止改写历史／冒充 effect 账本。\n\t */\n\tappendWet(input: WetAppendInput): LogRecord | EngineError;\n\t/** 重放视图：session 相关事件 + exit／effect plan 摘要（只读） */\n\tgetWetReplay(sessionId: string): Promise<WetReplayView | EngineError>;\n\tgetLoadedCardCount(packageId: string): number;\n\tgetMemoryPort(): MemoryPort | null;\n\t/** 已注入的 ProfilePort；未注入为 null（过渡期 Host 仍走遗留 fs） */\n\tgetProfilePort(): ProfilePort | null;\n\t/** 已注入的 ContentPort；未注入为 null（过渡期 Host 仍走遗留 fs） */\n\tgetContentPort(): ContentPort | null;\n\t/** 已注入的 EngineLogPort；未注入为 null（过渡期 Host 仍走遗留 jsonl） */\n\tgetEngineLogPort(): EngineLogPort | null;\n\tvalidatePackage(packageId: string): Promise<ValidationReport>;\n\t/**\n\t * 推进 Profile.schedule.clockMs：物化到期 recurring→once，再 tick once → outbound pending。\n\t * 返回本拍 fired 列表，供调试台再 resolve(agent_outbound)。\n\t */\n\tadvanceClock(\n\t\tuserId: string,\n\t\tdeltaMs: number,\n\t): FiredScheduleItem[] | EngineError;\n\t/** 跳到绝对逻辑时刻（仅前进）并 Tick */\n\tsetClockMs(\n\t\tuserId: string,\n\t\ttoClockMs: number,\n\t): FiredScheduleItem[] | EngineError;\n\t/** 推到下一意图（pending once 或 recurring 下次 occurrence） */\n\tadvanceClockToNextIntent(\n\t\tuserId: string,\n\t): AdvanceToNextResult | EngineError;\n\t/**\n\t * Lore bootstrap：有 location 或 force 时写入 Profile.world.lore；\n\t * port 失败降级 fallback；不阻塞调用方。\n\t */\n\tbootstrapLore(\n\t\tuserId: string,\n\t\topts?: { force?: boolean },\n\t): Promise<\n\t\t| {\n\t\t\t\tlore: WorldLoreDoc;\n\t\t\t\tusedFallback: boolean;\n\t\t\t\terrorMessage?: string;\n\t\t  }\n\t\t| EngineError\n\t>;\n}\n\n/**\n * Host 装配选项（存取 Port 合同见技术设计 23）。\n *\n * ## 注入缺省策略（已钉死）\n *\n * | Port | 选项 | 未注入时（过渡期） | 目标态（迁出完成后） |\n * |------|------|-------------------|----------------------|\n * | Memory | `memory` | `autoMemory!==false` 时仍 `createSqliteMemoryPort`（遗留，待 V2-IO-4 删） | 须由宿主注入；禁引擎内 sqlite 真源 |\n * | Profile | `profile` | 继续 `persistProfile` / `readProfile` fs 路径（待 V2-IO-5） | 必注入；Host 不拼磁盘路径 |\n * | Content | `content` | 继续 `loadWorkspaceState` fs 扫描（待 V2-IO-6/8） | 必注入 |\n * | EngineLog | `engineLog` | 继续 `engineLogFile` jsonl（待 V2-IO-7） | 可选；无则仅内存 ring |\n *\n * 本刀钉类型与注入面：已注入 Port 经 getter 可观测；调用改接在后续迁出刀完成。\n * 测试：注入内存假 Port。本机 Studio：`engineIOModule` 工厂一次创建全套并注入。\n */\nexport interface CreateEngineHostOptions {\n\tpersist?: boolean;\n\tmemory?: MemoryPort | null;\n\t/**\n\t * 未注入 memory 时是否自动建 sqlite。\n\t * 过渡期缺省 true（兼容既有测）；迁出完成后应视为废弃，宿主必须显式注入 memory。\n\t */\n\tautoMemory?: boolean;\n\t/**\n\t * 薄 Profile 读写。未注入 → 过渡期走引擎内 fs（将删除）。\n\t * 目标态：必注入。\n\t */\n\tprofile?: ProfilePort | null;\n\t/**\n\t * Content / Workspace 只读。未注入 → 过渡期走引擎内 fs（将删除）。\n\t * 目标态：必注入。\n\t */\n\tcontent?: ContentPort | null;\n\t/**\n\t * 旁路 jsonl。未注入 → 过渡期走引擎内 engineLogFile；\n\t * 目标态：可选（无则只保留 Host 内存 ring）。\n\t */\n\tengineLog?: EngineLogPort | null;\n\t/** 媒介 EffectSink；缺省 Noop 桩 */\n\teffectSink?: EffectSink | null;\n\t/** Lore 生成端口；null／缺省 → 直接 fallback */\n\tloreBootstrap?: LoreBootstrapPort | null;\n}\n\n/** undefined 与 null 均视为未注入。 */\nexport function resolveOptionalPort<T>(value: T | null | undefined): T | null {\n\treturn value === undefined ? null : value;\n}\n\n/**\n * Port getter 面：从 createEngineHost 闭包拆出，避免 Host 组合函数 maxFnLines 净增。\n */\nexport function createInjectedPortAccessorsFromOptions(\n\toptions: CreateEngineHostOptions,\n\tgetMemory: () => MemoryPort | null,\n): Pick<\n\tEngineHost,\n\t\"getMemoryPort\" | \"getProfilePort\" | \"getContentPort\" | \"getEngineLogPort\"\n> {\n\treturn {\n\t\tgetMemoryPort: getMemory,\n\t\tgetProfilePort() {\n\t\t\treturn resolveOptionalPort(options.profile);\n\t\t},\n\t\tgetContentPort() {\n\t\t\treturn resolveOptionalPort(options.content);\n\t\t},\n\t\tgetEngineLogPort() {\n\t\t\treturn resolveOptionalPort(options.engineLog);\n\t\t},\n\t};\n}\n\n/**\n * Host 内存 ring +（过渡期）遗留 jsonl 旁路；从 createEngineHost 拆出以控 maxFnLines。\n */\nexport function createHostPushLog(input: {\n\tlogs: LogRecord[];\n\tisPersist: () => boolean;\n\tgetWorkspaceRootDir: () => string | null;\n\tappendJsonl: (rootDir: string, record: LogRecord) => Promise<void>;\n\tredact: (record: LogRecord) => LogRecord;\n}): (record: LogRecord) => void {\n\treturn function pushLog(record: LogRecord): void {\n\t\tconst safe = input.redact(record);\n\t\tinput.logs.push(safe);\n\t\tif (input.logs.length > 500) {\n\t\t\tinput.logs.shift();\n\t\t}\n\t\tif (!input.isPersist()) {\n\t\t\treturn;\n\t\t}\n\t\tconst rootDir = input.getWorkspaceRootDir();\n\t\tif (!rootDir) {\n\t\t\treturn;\n\t\t}\n\t\tvoid input.appendJsonl(rootDir, safe).catch(function () {\n\t\t\t// 旁路失败不打断主路径\n\t\t});\n\t};\n}\n","message":"The file /Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/ports/engineHostApi.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"call-037dba52-4067-4c59-bcf1-702798faf2f1-68\nfc_b1ebba39-adbd-9086-a5df-091f32f0c0a5_0","startedAtMs":"1784781007617","completedAtMs":"1784781007993"},"model_call_id":"1a4ba06a-42b7-4c5a-bde0-e96315aab975-26-izhz","session_id":"d7cfd367-04b7-4349-bda8-cb59179dc1e3","timestamp_ms":1784781007975}
