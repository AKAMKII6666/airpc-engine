t | 选项 | 未注入时（过渡期） | 目标态（迁出完成后） |\n * |------|------|-------------------|----------------------|\n * | Memory | `memory` | `autoMemory!==false` 时仍 `createSqliteMemoryPort`（遗留，待 V2-IO-4 删） | 须由宿主注入；禁引擎内 sqlite 真源 |\n * | Profile | `profile` | 继续 `persistProfile` / `readProfile` fs 路径（待 V2-IO-5） | 必注入；Host 不拼磁盘路径 |\n * | Content | `content` | 继续 `loadWorkspaceState` fs 扫描（待 V2-IO-6/8） | 必注入 |\n * | EngineLog | `engineLog` | 继续 `engineLogFile` jsonl（待 V2-IO-7） | 可选；无则仅内存 ring |\n *\n * 已注入的 Port 经 getter 可观测。EngineLog 在本刀已改接 append/readSlice；\n * Profile/Content 调用改接在后续迁出刀完成。\n * 测试：注入内存假 Port。本机 Studio：`engineIOModule` 工厂一次创建全套并注入。\n */\nexport interface CreateEngineHostOptions {\n  persist?: boolean;\n  memory?: MemoryPort | null;\n  /**\n   * 未注入 memory 时是否自动建 sqlite。\n   * 过渡期缺省 true（兼容既有测）；迁出完成后应视为废弃，宿主必须显式注入 memory。\n   */\n  autoMemory?: boolean;\n  /**\n   * 薄 Profile 读写。未注入 → 过渡期走引擎内 fs（将删除）。\n   * 目标态：必注入。\n   */\n  profile?: ProfilePort | null;\n  /**\n   * Content / Workspace 只读。未注入 → 过渡期走引擎内 fs（将删除）。\n   * 目标态：必注入。\n   */\n  content?: ContentPort | null;\n  /**\n   * 旁路 jsonl。未注入 → 过渡期走引擎内 engineLogFile；\n   * 目标态：可选（无则只保留 Host 内存 ring）。\n   */\n  engineLog?: EngineLogPort | null;\n  /** 媒介 EffectSink；缺省 Noop 桩 */\n  effectSink?: EffectSink | null;\n  /** Lore 生成端口；null／缺省 → 直接 fallback */\n  loreBootstrap?: LoreBootstrapPort | null;\n}\n\nexport function createEngineHost(\n  options: CreateEngineHostOptions = {},\n): EngineHost {\n  const persist = options.persist !== false;\n  const autoMemory = options.autoMemory !== false;\n  const effectSink: EffectSink =\n    options.effectSink === undefined\n      ? createNoopEffectSink()\n      : (options.effectSink ?? createNoopEffectSink());\n  const loreBootstrapPort =\n    options.loreBootstrap === undefined ? null : options.loreBootstrap;\n  /** 已注入则持有；Profile/Content 调用改接见后续迁出刀。undefined/null 均视为未注入。 */\n  const profilePort: ProfilePort | null =\n    options.profile === undefined ? null : options.profile;\n  const contentPort: ContentPort | null =\n    options.content === undefined ? null : options.content;\n  const engineLogPort: EngineLogPort | null =\n    options.engineLog === undefined ? null : options.engineLog;\n  let workspace: WorkspaceState | null = null;\n  let memory: MemoryPort | null =\n    options.memory === undefined ? null : options.memory;\n  const profiles = new Map<string, PlayerProfile>();\n  const sessions = new Map<string, CallSession>();\n  const activeByUser = new Map<string, string>();\n  const logs: LogRecord[] = [];\n","isEmpty":false,"exceededLimit":false,"totalLines":1474,"fileSize":44851,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/host/createEngineHost.ts","readRange":{"startLine":185,"endLine":304},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-8930b2df-1b53-483d-9f14-f9fb40e0d218-40\nfc_0ba9484a-5279-9ac1-8709-3967229112b6_0","startedAtMs":"1784780835663","completedAtMs":"1784780835825"},"model_call_id":"1a4ba06a-42b7-4c5a-bde0-e96315aab975-12-gsfl","session_id":"d7cfd367-04b7-4349-bda8-cb59179dc1e3","timestamp_ms":1784780835936}
