: (options.effectSink ?? createNoopEffectSink());\n  const loreBootstrapPort =\n    options.loreBootstrap === undefined ? null : options.loreBootstrap;\n  /** 已注入则持有；调用改接见后续迁出刀。undefined/null 均视为未注入。 */\n  const profilePort: ProfilePort | null =\n    options.profile === undefined ? null : options.profile;\n  const contentPort: ContentPort | null =\n    options.content === undefined ? null : options.content;\n  const engineLogPort: EngineLogPort | null =\n    options.engineLog === undefined ? null : options.engineLog;\n  let workspace: WorkspaceState | null = null;\n  let memory: MemoryPort | null =\n    options.memory === undefined ? null : options.memory;\n  const profiles = new Map<string, PlayerProfile>();\n  const sessions = new Map<string, CallSession>();\n  const activeByUser = new Map<string, string>();\n  const logs: LogRecord[] = [];\n\n  // 压制「仅持有、本刀未改接」的未使用告警；迁出刀将改用这些引用。\n  void profilePort;\n  void contentPort;\n  void engineLogPort;\n\n  function pushLog(record: LogRecord): void {\n    const safe = redactLogRecord(record);\n    logs.push(safe);\n    if (logs.length > 500) {\n      logs.shift();\n    }\n    if (persist && workspace) {\n      // 过渡期：有 engineLogPort 时优先经 Port；否则遗留 jsonl 直写。\n      if (engineLogPort) {\n        void engineLogPort.append({ record: safe }).catch(function () {\n          // 旁路失败不打断主路径\n        });\n      } else {\n        void appendEngineLogJsonl(workspace.rootDir, safe).catch(function () {\n          // 旁路失败不打断主路径\n        });\n      }\n    }\n  }"},"result":{"success":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/host/createEngineHost.ts","linesAdded":56,"linesRemoved":4,"diffString":"--- a//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/host/createEngineHost.ts\n+++ b//Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/host/createEngineHost.ts\n@@ -225,11 +225,44 @@\n   >;\n }\n \n+/**\n+ * Host 装配选项（存取 Port 合同见技术设计 23）。\n+ *\n+ * ## 注入缺省策略（已钉死）\n+ *\n+ * | Port | 选项 | 未注入时（