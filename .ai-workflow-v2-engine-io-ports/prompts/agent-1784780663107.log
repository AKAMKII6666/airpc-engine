iority 对齐（可选） */\n  priority: z.number().optional(),\n  createdAt: z.string(),\n  updatedAt: z.string().optional(),\n});\n\nexport type CallCardInstance = z.infer<typeof CallCardInstanceSchema>;\n\nexport const CharacterRuntimeSchema = z\n  .object({\n    agentId: z.string(),\n    unlocked: z.boolean().optional(),\n  })\n  .passthrough();\n\n/** ActiveStoryLock（需求 10 §3.2 / 技术设计 19 §8.4） */\nexport const ActiveStoryLockSchema = z.object({\n  activeStoryInstanceId: z.string(),\n  packageId: z.string(),\n  lockLevel: z.enum([\"soft\", \"hard\"]),\n  allowedAgentIds: z.array(z.string()),\n  blockedPolicy: z.enum([\n    \"reject_call\",\n    \"force_free_suppressed\",","isEmpty":false,"exceededLimit":false,"totalLines":160,"fileSize":4874,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/schema/profile.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f94f56bd-7c89-4946-bbe5-66c7dfa82eb2-32\nfc_73ea341a-353e-9464-833c-895fc0e1270d_0","startedAtMs":"1784780776091","completedAtMs":"1784780776257"},"model_call_id":"1a4ba06a-42b7-4c5a-bde0-e96315aab975-9-y07m","session_id":"d7cfd367-04b7-4349-bda8-cb59179dc1e3","timestamp_ms":1784780776283}
