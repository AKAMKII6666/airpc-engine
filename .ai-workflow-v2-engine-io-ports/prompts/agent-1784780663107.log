ound\";\n\tlocalTime: {\n\t\tisoWithOffset: string;\n\t\ttimeZone?: string;\n\t\t/** 用户本地小时 0–23；场景匹配仅用 localHourRange */\n\t\tlocalHour: number;\n\t};\n\ttimeMentionPolicy: \"allow_casual\" | \"correct_only\";\n}\n\nexport interface RenderedPrompt {\n\tsystemHard: string[];\n\topeningSpeakable?: string;\n\topeningPrivate?: string;\n\tspeakable: string;\n\tprivate: string;\n\tsoftContext: string[];\n\tmatchedLayerIds: string[];\n\tdebug?: { notes?: string[] };\n}","isEmpty":false,"exceededLimit":false,"totalLines":183,"fileSize":4651,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/host/types.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-db6d7c96-37a8-48b8-b6b2-e770dd7488ab-13\nfc_bbe0a8a5-a742-9402-9c32-4e01df0cc9e1_2","startedAtMs":"1784780698475","completedAtMs":"1784780698662"},"model_call_id":"1a4ba06a-42b7-4c5a-bde0-e96315aab975-3-4p5n","session_id":"d7cfd367-04b7-4349-bda8-cb59179dc1e3","timestamp_ms":1784780698687}
