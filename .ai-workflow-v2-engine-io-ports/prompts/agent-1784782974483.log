{"type":"tool_call","subtype":"started","call_id":"call-1de2e77d-06af-473b-b818-725da33ee6b5-85\nfc_1fdaf590-6e73-927e-b224-4090eb45c220_5","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/ports-injection.test.ts","streamContent":"\tit(\"未注入 ProfilePort 时 ensureProfile 抛 ENGINE_INTERNAL\", async function () {\n\t\tconst host = createEngineHost({ persist: false });\n\t\tawait expect(host.ensureProfile(\"u1\")).rejects.toSatisfy(function (\n\t\t\terr: unknown,\n\t\t) {\n\t\t\treturn (\n\t\t\t\ttypeof err === \"object\" &&\n\t\t\t\terr !== null &&\n\t\t\t\t(err as { code?: string }).code === \"ENGINE_INTERNAL\"\n\t\t\t);\n\t\t});\n\t});\n\n\tit(\"未注入 ContentPort 时 loadWorkspace 抛 ENGINE_INTERNAL\", async function () {\n\t\tconst host = createEngineHost({ persist: false });\n\t\tawait expect(host.loadWorkspace(\"/tmp\")).rejects.toSatisfy(function (\n\t\t\terr: unknown,\n\t\t) {\n\t\t\treturn (\n\t\t\t\ttypeof err === \"object\" &&\n\t\t\t\terr !== null &&\n\t\t\t\t(err as { code?: string }).code === \"ENGINE_INTERNAL\"\n\t\t\t);\n\t\t});\n\t});\n});\n"}},"hookAdditionalContexts":[],"toolCallId":"call-1de2e77d-06af-473b-b818-725da33ee6b5-85\nfc_1fdaf590-6e73-927e-b224-4090eb45c220_5","startedAtMs":"1784783367914"},"model_call_id":"767e144e-44a8-4ae4-864c-2c828f4666bf-24-jfb4","session_id":"51113bcf-a897-4d07-8900-c2eaa52bab10","timestamp_ms":1784783367891}
