{"type":"tool_call","subtype":"started","call_id":"call-5b612eda-c829-4c90-89ad-0870e82636fa-65\nfc_7c912cbe-8ec7-9ede-b333-3b08f44e50cd_2","tool_call":{"editToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/helpers/fsContentPort.ts","streamContent":"/**\n * 模块名称：测试用 Fs ContentPort\n * 模块说明：与 engineIOModule/content/fsContentPort 行为对齐的测试镜像；\n * 引擎测不得 import apps/studioV2（独立性优先于 DRY）。\n */\nimport { access, readdir, readFile } from \"node:fs/promises\";\nimport path from \"node:path\";\nimport { engineError } from \"../../src/host/errors.js\";\nimport {\n\tCallCardDefinitionSchema,\n\tStoryPackageConfSchema,\n\ttype CallCardDefinition,\n\ttype StoryPackageConf,\n} from \"../../src/schema/callCard.js\";\nimport {\n\tCharacterDefSchema,\n\ttype CharacterDef,\n} from \"../../src/schema/character.js\";\nimport {\n\tAssetMetaSchema,\n\ttype AssetMeta,\n} from \"../../src/schema/asset.js\";\nimport type {\n\tContentPort,\n\tPackageValidateBundle,\n\tWorkspaceSnapshot,\n} from \"../../src/ports/contentPort.js\";\nimport { FREE_PACKAGE_ID, SCHEDULE_PACKAGE_ID } from \"../../src/constants.js\";\n\nconst SUPPORTED_SCHEMA = 1;\n\nasync function readJsonFile(filePath: string): Promise<unknown> {\n\treturn JSON.parse(await readFile(filePath, \"utf8\")) as unknown;\n}\n\nfunction parseOrThrow<T>(label: string, parse: () => T): T {\n\ttry {\n\t\treturn parse();\n\t} catch (err) {\n\t\tthrow engineError(\"VALIDATION_FAILED\", `${label} parse failed`, err);\n\t}\n}\n\nasync function loadPackages(\n\trootDir: string,\n): Promise<WorkspaceSnapshot[\"packages\"]> {\n\tconst packagesRoot = path.join(rootDir, \"storis-packages\");\n\tlet entries: string[] = [];\n\ttry {\n\t\tentries = await readdir(packagesRoot);\n\t} catch {\n\t\tentries = [];\n\t}\n\tconst packages: WorkspaceSnapshot[\"packages\"] = [];\n\tfor (const name of entries) {\n\t\tconst dir = path.join(packagesRoot, name);\n\t\tlet confRaw: unknown;\n\t\ttry {\n\t\t\tconfRaw = await readJsonFile(path.join(dir, \"story.conf.json\"));\n\t\t} catch {\n\t\t\tcontinue;\n\t\t}\n\t\tconst conf = parseOrThrow(\"story.conf\", () =>\n\t\t\tStoryPackageConfSchema.parse(confRaw),\n\t\t);\n\t\tif (conf.schemaVersion !== SUPPORTED_SCHEMA) {\n\t\t\tthrow engineError(\n\t\t\t\t\"SCHEMA_UNSUPPORTED\",\n\t\t\t\t`package ${conf.packageId} schemaVersion unsupported`,\n\t\t\t);\n\t\t}\n\t\tpackages.push({\n\t\t\tpackageId: conf.packageId,\n\t\t\tconf,\n\t\t\tpackageLocator: dir,\n\t\t});\n\t}\n\treturn packages;\n}\n\nasync function findPackageDir(\n\tworkspaceKey: string,\n\tpackageId: string,\n): Promise<{ dir: string; conf: StoryPackageConf } | null> {\n\tconst packages = await loadPackages(workspaceKey);\n\tconst hit = packages.find((p) => p.packageId === packageId);\n\tif (!hit?.packageLocator) return null;\n\treturn { dir: hit.packageLocator, conf: hit.conf };\n}\n\nasync function loadSideCards(dir: string): Promise<CallCardDefinition[]> {\n\tlet files: string[] = [];\n\ttry {\n\t\tfiles = await readdir(dir);\n\t} catch {\n\t\tfiles = [];\n\t}\n\tconst cards: CallCardDefinition[] = [];\n\tfor (const name of files) {\n\t\tif (!name.endsWith(\".s-card.json\") && !name.endsWith(\".json\")) continue;\n\t\tconst raw = await readJsonFile(path.join(dir, name));\n\t\tcards.push(\n\t\t\tparseOrThrow(`card ${name}`, () =>\n\t\t\t\tCallCardDefinitionSchema.parse(raw),\n\t\t\t),\n\t\t);\n\t}\n\treturn cards;\n}\n\nasync function loadCharacters(rootDir: string): Promise<CharacterDef[]> {\n\tconst charactersRoot = path.join(rootDir, \"characters\");\n\tlet charFiles: string[] = [];\n\ttry {\n\t\tcharFiles = await readdir(charactersRoot);\n\t} catch {\n\t\tcharFiles = [];\n\t}\n\tconst characters: CharacterDef[] = [];\n\tfor (const name of charFiles) {\n\t\tif (!name.endsWith(\".json\")) continue;\n\t\tconst raw = await readJsonFile(path.join(charactersRoot, name));\n\t\tcharacters.push(\n\t\t\tparseOrThrow(`character ${name}`, () =>\n\t\t\t\tCharacterDefSchema.parse(raw),\n\t\t\t),\n\t\t);\n\t}\n\treturn characters;\n}\n\n/** 指向 workspaceKey=dataRoot 的 ContentPort；供 host 集成测注入。 */\nexport function createFsContentPort(): ContentPort {\n\treturn {\n\t\tasync loadWorkspaceSnapshot(input) {\n\t\t\tconst rootDir = input.workspaceKey;\n\t\t\tconst workspacePath = path.join(rootDir, \"workspace.json\");\n\t\t\tlet raw: { schemaVersion?: number };\n\t\t\ttry {\n\t\t\t\traw = (await readJsonFile(workspacePath)) as {\n\t\t\t\t\tschemaVersion?: number;\n\t\t\t\t};\n\t\t\t} catch (err) {\n\t\t\t\tthrow engineError(\n\t\t\t\t\t\"ENGINE_INTERNAL\",\n\t\t\t\t\t`workspace.json unreadable: ${workspacePath}`,\n\t\t\t\t\t{ reason: \"IO_FAILED\", cause: err },\n\t\t\t\t);\n\t\t\t}\n\t\t\tif (raw.schemaVersion !== SUPPORTED_SCHEMA) {\n\t\t\t\tthrow engineError(\n\t\t\t\t\t\"SCHEMA_UNSUPPORTED\",\n\t\t\t\t\t`workspace schemaVersion ${String(raw.schemaVersion)} unsupported`,\n\t\t\t\t);\n\t\t\t}\n\t\t\tconst charactersRoot = path.join(rootDir, \"characters\");\n\t\t\tconst [packages, characters, freeCards, scheduleCards] =\n\t\t\t\tawait Promise.all([\n\t\t\t\t\tloadPackages(rootDir),\n\t\t\t\t\tloadCharacters(rootDir),\n\t\t\t\t\tloadSideCards(path.join(charactersRoot, \"free-cards\")),\n\t\t\t\t\tloadSideCards(path.join(charactersRoot, \"schedule-cards\")),\n\t\t\t\t]);\n\t\t\treturn {\n\t\t\t\tworkspaceKey: rootDir,\n\t\t\t\tpackages,\n\t\t\t\tcharacters,\n\t\t\t\tfreeCards,\n\t\t\t\tscheduleCards,\n\t\t\t};\n\t\t},\n\n\t\tasync readCard(input) {\n\t\t\tconst { workspaceKey, packageId, cardId } = input;\n\t\t\tif (\n\t\t\t\tpackageId === FREE_PACKAGE_ID ||\n\t\t\t\tpackageId === SCHEDULE_PACKAGE_ID\n\t\t\t) {\n\t\t\t\tconst sub =\n\t\t\t\t\tpackageId === FREE_PACKAGE_ID\n\t\t\t\t\t\t? \"free-cards\"\n\t\t\t\t\t\t: \"schedule-cards\";\n\t\t\t\tconst dir = path.join(workspaceKey, \"characters\", sub);\n\t\t\t\tfor (const name of [\n\t\t\t\t\t`${cardId}.s-card.json`,\n\t\t\t\t\t`${cardId}.json`,\n\t\t\t\t]) {\n\t\t\t\t\ttry {\n\t\t\t\t\t\tconst raw = await readJsonFile(path.join(dir, name));\n\t\t\t\t\t\treturn parseOrThrow(`${sub}/${cardId}`, () =>\n\t\t\t\t\t\t\tCallCardDefinitionSchema.parse(raw),\n\t\t\t\t\t\t);\n\t\t\t\t\t} catch (err) {\n\t\t\t\t\t\tif (\n\t\t\t\t\t\t\ttypeof err === \"object\" &&\n\t\t\t\t\t\t\terr !== null &&\n\t\t\t\t\t\t\t(err as { code?: string }).code ===\n\t\t\t\t\t\t\t\t\"VALIDATION_FAILED\"\n\t\t\t\t\t\t) {\n\t\t\t\t\t\t\tthrow err;\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\treturn null;\n\t\t\t}\n\t\t\tconst found = await findPackageDir(workspaceKey, packageId);\n\t\t\tif (!found) return null;\n\t\t\ttry {\n\t\t\t\tconst raw = await readJsonFile(\n\t\t\t\t\tpath.join(found.dir, \"cards\", `${cardId}.s-card.json`),\n\t\t\t\t);\n\t\t\t\treturn parseOrThrow(`card ${packageId}/${cardId}`, () =>\n\t\t\t\t\tCallCardDefinitionSchema.parse(raw),\n\t\t\t\t);\n\t\t\t} catch (err) {\n\t\t\t\tif (\n\t\t\t\t\ttypeof err === \"object\" &&\n\t\t\t\t\terr !== null &&\n\t\t\t\t\t(err as { code?: string }).code === \"VALIDATION_FAILED\"\n\t\t\t\t) {\n\t\t\t\t\tthrow err;\n\t\t\t\t}\n\t\t\t\treturn null;\n\t\t\t}\n\t\t},\n\n\t\tasync readPackageConf(input) {\n\t\t\tconst found = await findPackageDir(\n\t\t\t\tinput.workspaceKey,\n\t\t\t\tinput.packageId,\n\t\t\t);\n\t\t\treturn found?.conf ?? null;\n\t\t},\n\n\t\tasync loadPackageForValidate(input) {\n\t\t\tconst found = await findPackageDir(\n\t\t\t\tinput.workspaceKey,\n\t\t\t\tinput.packageId,\n\t\t\t);\n\t\t\tconst characters = await loadCharacters(input.workspaceKey);\n\t\t\tif (!found) {\n\t\t\t\treturn {\n\t\t\t\t\tpackageId: input.packageId,\n\t\t\t\t\tconf: null,\n\t\t\t\t\tcards: [],\n\t\t\t\t\tcharacters,\n\t\t\t\t};\n\t\t\t}\n\t\t\tconst cards: PackageValidateBundle[\"cards\"] = [];\n\t\t\tfor (const entry of found.conf.cards) {\n\t\t\t\ttry {\n\t\t\t\t\tconst raw = await readJsonFile(\n\t\t\t\t\t\tpath.join(\n\t\t\t\t\t\t\tfound.dir,\n\t\t\t\t\t\t\t\"cards\",\n\t\t\t\t\t\t\t`${entry.cardId}.s-card.json`,\n\t\t\t\t\t\t),\n\t\t\t\t\t);\n\t\t\t\t\tcards.push({\n\t\t\t\t\t\tcardId: entry.cardId,\n\t\t\t\t\t\tcard: CallCardDefinitionSchema.parse(raw),\n\t\t\t\t\t});\n\t\t\t\t} catch {\n\t\t\t\t\tcards.push({ cardId: entry.cardId, card: null });\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tpackageId: input.packageId,\n\t\t\t\tconf: found.conf,\n\t\t\t\tcards,\n\t\t\t\tcharacters,\n\t\t\t};\n\t\t},\n\n\t\tasync assetMetaExists(input) {\n\t\t\ttry {\n\t\t\t\tawait access(\n\t\t\t\t\tpath.join(\n\t\t\t\t\t\tinput.workspaceKey,\n\t\t\t\t\t\t\"assets\",\n\t\t\t\t\t\t\"meta\",\n\t\t\t\t\t\t`${input.assetId}.json`,\n\t\t\t\t\t),\n\t\t\t\t);\n\t\t\t\treturn true;\n\t\t\t} catch {\n\t\t\t\treturn false;\n\t\t\t}\n\t\t},\n\n\t\tasync readAssetMeta(input) {\n\t\t\ttry {\n\t\t\t\tconst raw = await readJsonFile(\n\t\t\t\t\tpath.join(\n\t\t\t\t\t\tinput.workspaceKey,\n\t\t\t\t\t\t\"assets\",\n\t\t\t\t\t\t\"meta\",\n\t\t\t\t\t\t`${input.assetId}.json`,\n\t\t\t\t\t),\n\t\t\t\t);\n\t\t\t\tconst parsed = AssetMetaSchema.safeParse(raw);\n\t\t\t\treturn parsed.success ? parsed.data : null;\n\t\t\t} catch {\n\t\t\t\treturn null;\n\t\t\t}\n\t\t},\n\n\t\tasync assetUriExists(input) {\n\t\t\tconst uriRel = input.uri.replace(/^\\.?\\//, \"\");\n\t\t\tif (\n\t\t\t\turiRel.includes(\"..\") ||\n\t\t\t\tpath.isAbsolute(uriRel) ||\n\t\t\t\turiRel.startsWith(\"~\")\n\t\t\t) {\n\t\t\t\treturn false;\n\t\t\t}\n\t\t\ttry {\n\t\t\t\tawait access(\n\t\t\t\t\tpath.join(input.workspaceKey, \"assets\", uriRel),\n\t\t\t\t);\n\t\t\t\treturn true;\n\t\t\t} catch {\n\t\t\t\treturn false;\n\t\t\t}\n\t\t},\n\t};\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-5b612eda-c829-4c90-89ad-0870e82636fa-65\nfc_7c912cbe-8ec7-9ede-b333-3b08f44e50cd_2","startedAtMs":"1784783281682"},"model_call_id":"767e144e-44a8-4ae4-864c-2c828f4666bf-19-662h","session_id":"51113bcf-a897-4d07-8900-c2eaa52bab10","timestamp_ms":1784783281654}
