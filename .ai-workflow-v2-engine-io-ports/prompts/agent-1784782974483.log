ndingPort<T extends object>(\n\tportName: string,\n\ttaskId: string,\n): T {\n\treturn new Proxy({} as T, {\n\t\tget(_target, prop) {\n\t\t\t// 避免被当成 Thenable\n\t\t\tif (prop === \"then\") {\n\t\t\t\treturn undefined;\n\t\t\t}\n\t\t\tthrow new Error(\n\t\t\t\t`createEngineIOPorts：${portName}.${String(prop)} 尚未迁入（${taskId}）`,\n\t\t\t);\n\t\t},\n\t});\n}\n\n/**\n\t* 创建指向 `dataRoot` 的本机 Ports。\n\t* Memory：`<dataRoot>/memory/memory.sqlite`。\n\t* Profile：`<dataRoot>/users/<userId>/profile.save.json`。\n\t*\n\t* @param dataRoot 工作区根（本机即仓库 `data/` 或等价绝对路径）\n\t*/\nexport function createEngineIOPorts(dataRoot: string): EngineIOPorts {\n\treturn {\n\t\tmemory: createSqliteMemoryPort(\n\t\t\tpath.join(dataRoot, \"memory\", \"memory.sqlite\"),\n\t\t),\n\t\tprofile: createFsProfilePort(dataRoot),\n\t\tcontent: createPendingPort<ContentPort>(\"ContentPort\", \"V2-IO-6\"),\n\t\tengineLog: createPendingPort<EngineLogPort>(\"EngineLogPort\", \"V2-IO-7\"),\n\t};\n}\n","afterFullFileContent":"/**\n\t* 模块名称：本机引擎 IO 装配工厂\n\t* 模块说明：按 dataRoot 创建 Memory / Profile / Content / EngineLog Ports。\n\t* Server 边界：仅 app/api、Host 装配、*.server.ts、utils/server 可引用；\n\t* 禁止 Client（pageComponents / bis / stores / typeFiles / ajaxProxy 等）任何 import。\n\t* V2-IO-4/5/6：Memory + Profile + Content 已就绪；EngineLog 仍占位至 V2-IO-7。\n\t*/\nimport path from \"node:path\";\nimport type {\n\tContentPort,\n\tEngineLogPort,\n\tMemoryPort,\n\tProfilePort,\n} from \"@airpc/rpg-engine\";\n// 引用了 Sqlite Memory 工厂，用于本机 memory.sqlite 落盘\nimport { createSqliteMemoryPort } from \"./memory/sqliteMemoryPort\";\n// 引用了 Fs Profile 工厂，用于本机 profile.save.json 读写\nimport { createFsProfilePort } from \"./profile/fsProfilePort\";\n// 引用了 Fs Content 工厂，用于本机 Workspace / 包 / 角色读\nimport { createFsContentPort } from \"./content/fsContentPort\";\n\n/** 本机 Studio 注入 Host 的四 Port 套件（技术设计 23）。 */\nexport type EngineIOPorts = {\n\tmemory: MemoryPort;\n\tprofile: ProfilePort;\n\tcontent: ContentPort;\n\tengineLog: EngineLogPort;\n};\n\nexport { createSqliteMemoryPort } from \"./memory/sqliteMemoryPort\";\nexport { createFsProfilePort } from \"./profile/fsProfilePort\";\nexport { createFsContentPort } from \"./content/fsContentPort\";\n\n/**\n\t* 尚未迁入的 Port：任意方法访问即抛，避免误当成已实现。\n\t* 退出条件：V2-IO-7 EngineLog 迁完后删除本辅助函数。\n\t*/\nfunction createPendingPort<T extends object>(\n\tportName: string,\n\ttaskId: string,\n): T {\n\treturn new Proxy({} as T, {\n\t\tget(_target, prop) {\n\t\t\t// 避免被当成 Thenable\n\t\t\tif (prop === \"then\") {\n\t\t\t\treturn undefined;\n\t\t\t}\n\t\t\tthrow new Error(\n\t\t\t\t`createEngineIOPorts：${portName}.${String(prop)} 尚未迁入（${taskId}）`,\n\t\t\t);\n\t\t},\n\t});\n}\n\n/**\n\t* 创建指向 `dataRoot` 的本机 Ports。\n\t* Memory：`<dataRoot>/memory/memory.sqlite`。\n\t* Profile：`<dataRoot>/users/<userId>/profile.save.json`。\n\t* Content：以 Host `loadWorkspace(rootDir)` 的 rootDir 为 workspaceKey。\n\t*\n\t* @param dataRoot 工作区根（本机即仓库 `data/` 或等价绝对路径）\n\t*/\nexport function createEngineIOPorts(dataRoot: string): EngineIOPorts {\n\treturn {\n\t\tmemory: createSqliteMemoryPort(\n\t\t\tpath.join(dataRoot, \"memory\", \"memory.sqlite\"),\n\t\t),\n\t\tprofile: createFsProfilePort(dataRoot),\n\t\tcontent: createFsContentPort(),\n\t\tengineLog: createPendingPort<EngineLogPort>(\"EngineLogPort\", \"V2-IO-7\"),\n\t};\n}\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/apps/studioV2/engineIOModule/createEngineIOPorts.ts"}}},"hookAdditionalContexts":[],"toolCallId":"call-681bcf74-6bf7-44ae-a686-55970dd2e96b-68\nfc_51593589-5c40-9fd8-8c14-347ebdc6b432_2","startedAtMs":"1784783300489","completedAtMs":"1784783300852"},"model_call_id":"767e144e-44a8-4ae4-864c-2c828f4666bf-20-u6jj","session_id":"51113bcf-a897-4d07-8900-c2eaa52bab10","timestamp_ms":1784783300815}
