{"type":"tool_call","subtype":"started","call_id":"call-2eb21ce2-0299-413e-82d2-ac1348a1f696-8\nfc_1219b489-8953-9bd2-97f2-34aa8c221d3d_3","tool_call":{"grepToolCall":{"args":{"pattern":"createEngineHost|profilePort|ProfilePort|ports\\.profile","path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src","caseInsensitive":false,"multiline":false,"toolCallId":"call-2eb21ce2-0299-413e-82d2-ac1348a1f696-8\nfc_1219b489-8953-9bd2-97f2-34aa8c221d3d_3","offset":0}},"hookAdditionalContexts":[],"toolCallId":"call-2eb21ce2-0299-413e-82d2-ac1348a1f696-8\nfc_1219b489-8953-9bd2-97f2-34aa8c221d3d_3","startedAtMs":"1784782372529"},"model_call_id":"c6486826-ed4f-4672-a7a9-7db3492b820e-2-rmjt","session_id":"5df7473c-b605-4b3a-9f07-31e036300ac3","timestamp_ms":1784782372506}
