ards,\n\t\tscheduleCards,\n\t};\n}\n\n/** 供 readPackageConf / validate 复用：按 packageId 找包目录。 */\nexport async function findPackageDir(\n\tworkspaceKey: string,\n\tpackageId: string,\n): Promise<{ dir: string; conf: StoryPackageConf } | null> {\n\tconst packages = await loadPackages(workspaceKey);\n\tconst hit = packages.find((p) => p.packageId === packageId);\n\tif (!hit?.packageLocator) {\n\t\treturn null;\n\t}\n\treturn { dir: hit.packageLocator, conf: hit.conf };\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":174,"fileSize":4512,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/engineIOModule/content/workspaceSnapshot.ts","readRange":{"startLine":100,"endLine":174},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-e9fbcaf0-bd23-4c77-93e0-b3fc04452352-37\nfc_3b0efc75-cd79-9145-8d6e-59e6cc1937a5_0","startedAtMs":"1784784186358","completedAtMs":"1784784186519"},"model_call_id":"7d5a523f-ae64-455e-b049-3e18d53be39c-9-l3vt","session_id":"dd5da7ec-5aa4-4eeb-a3ad-17dbb2f5d133","timestamp_ms":1784784186419}
