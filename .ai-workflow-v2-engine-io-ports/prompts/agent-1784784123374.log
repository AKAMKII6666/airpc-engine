tudio 深引引擎内部路径「绕过门面」。\n","isEmpty":false,"exceededLimit":false,"totalLines":40,"fileSize":2554,"path":"/Users/bolbiao/workspace/airpc-engine/.cursor/rules/engine-boundaries.mdc","readRange":{"startLine":1,"endLine":40},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-11bc799b-90ad-446c-8b52-db2b15230cc4-4\nfc_e7b47b14-1d56-92a9-9788-b949b3a9cbad_3","startedAtMs":"1784784137834","completedAtMs":"1784784138137"},"model_call_id":"7d5a523f-ae64-455e-b049-3e18d53be39c-1-pdfl","session_id":"dd5da7ec-5aa4-4eeb-a3ad-17dbb2f5d133","timestamp_ms":1784784138037}
