(iso: string): RollupPeriod {\n\tconst d = new Date(iso);\n\tconst prev = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth() - 3, 15));\n\treturn quarterPeriodFromIso(prev.toISOString());\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"call-8647d102-1cdf-42be-80b0-7ed7a496815f-128\nfc_6a2cd26a-965f-9fe9-b23c-948ffa57ed14_2","startedAtMs":"1784781982214"},"model_call_id":"13c061d1-bf77-4f24-9332-8c1ca31f861a-41-gqg8","session_id":"01baa976-9ca0-4238-822f-22f39680caba","timestamp_ms":1784781982188}
