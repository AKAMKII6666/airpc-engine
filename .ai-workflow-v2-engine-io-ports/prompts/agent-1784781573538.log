lupIfNeeded(): Promise<void> {\n-      // 假 Port：不实现 rollup；引擎测不依赖本路径\n-    },\n+    async rollupIfNeeded(): Promise<void> {},\n   };\n-\n-  return port;\n }","beforeFullFileContent":"/**\n * 模块名称：测试用内存 MemoryPort\n * 模块说明：引擎测注入假 Port，不依赖 sqlite / engineIOModule。\n * 覆盖 commit / search / project / applyPatch / getById 的最小行为；rollup 为空操作。\n */\nimport { randomUUID } from \"node:crypto\";\nimport { engineError } from \"../../src/host/errors.js\";\nimport type {\n  MemoryCommitInput,\n  MemoryCommitResult,\n  MemoryPort,\n  MemoryProjection,\n  MemorySearchHit,\n  MemorySearchQuery,\n} from \"../../src/memory/types.js\";\nimport {\n  MEMORY_PROJECT_DEFAULTS,\n  MEMORY_SEARCH_DEFAULTS,\n} from \"../../src/constants.js\";\n\ninterface MemEntry {\n  id: string;\n  userId: string;\n  agentId: string;\n  layer: string;\n  kind: string;\n  text: string;\n  at: string;\n  createdAt: string;\n}\n\nfunction truncate(text: string, max: number): string {\n  if (text.length <= max) return text;\n  return text.slice(0, max - 1) + \"…\";\n}\n\n/** 进程内 MemoryPort：供 host / pipeline 测注入。 */\nexport function createInMemoryMemoryPort(): MemoryPort {\n  const entries: MemEntry[] = [];\n\n  function insert(input: {\n    userId: string;\n    agentId: string;\n    layer: string;\n    kind: string;\n    text: string;\n    at: string;\n  }): string {\n    const id = randomUUID();\n    entries.push({\n      id,\n      userId: input.userId,\n      agentId: input.agentId,\n      layer: input.layer,\n      kind: input.kind,\n      text: input.text,\n      at: input.at,\n      createdAt: input.at,\n    });\n    return id;\n  }\n\n  const port: MemoryPort = {\n    async projectForCall(input): Promise<MemoryProjection> {\n      const {\n        maxCallSummaries,\n        maxVignettes,\n        maxSoftChars,\n      } = MEMORY_PROJECT_DEFAULTS;\n      const summaries = entries\n        .filter(function (e) {\n          return (\n            e.userId === input.userId &&\n            e.agentId === input.agentId &&\n            e.kind === \"call_summary\"\n          );\n        })\n        .sort(function (a, b) {\n          return b.at.localeCompare(a.at);\n        })\n        .slice(0, maxCallSummaries);\n      const vignettes = entries\n        .filter(function (e) {\n          return (\n            e.userId === input.userId &&\n            e.agentId === input.agentId &&\n            e.kind === \"vignette\"\n          );\n        })\n        .sort(function (a, b) {\n          return b.at.localeCompare(a.at);\n        })\n        .slice(0, maxVignettes);\n\n      const chunks: string[] = [];\n      const includedEntryIds: string[] = [];\n      let chars = 0;\n      function push(label: string, id: string, text: string): void {\n        const line = `[${label}] (${id.slice(0, 8)}) ${text}`;\n        if (chars + line.length > maxSoftChars) return;\n        chunks.push(line);\n        chars += line.length + 1;\n        includedEntryIds.push(id);\n      }\n      for (const row of summaries) {\n        push(\"call_summary\", row.id, row.text);\n      }\n      for (const row of vignettes) {\n        push(\"vignette\", row.id, row.text);\n      }\n      return {\n        softText: chunks.join(\"\\n\"),\n        includedEntryIds,\n        rollupIds: [],\n        debug: { hotCount: includedEntryIds.length, chars },\n      };\n    },\n\n    async search(input: MemorySearchQuery): Promise<MemorySearchHit[]> {\n      const textQ = input.textQuery?.trim() ?? \"\";\n      const hasText = textQ.length > 0;\n      const hasWindow = Boolean(input.fromIso || input.toIso);\n      if (!hasText && !hasWindow) {\n        throw engineError(\n          \"VALIDATION_FAILED\",\n          \"search requires textQuery or time window\",\n          { rule: \"MEMORY_SEARCH_REJECT\" },\n        );\n      }\n      const maxResults = Math.min(\n        Math.max(1, Math.floor(input.maxResults) || MEMORY_SEARCH_DEFAULTS.defaultMaxResults),\n        MEMORY_SEARCH_DEFAULTS.hardMaxResults,\n      );\n      let rows = entries.filter(function (e) {\n        if (e.userId !== input.userId || e.agentId !== input.agentId) {\n          return false;\n        }\n        if (input.fromIso && e.at < input.fromIso) return false;\n        if (input.toIso && e.at > input.toIso) return false;\n        if (input.kinds && input.kinds.length > 0 && !input.kinds.includes(e.kind as never)) {\n          return false;\n        }\n        if (hasText && !e.text.includes(textQ)) return false;\n        return true;\n      });\n      rows = rows\n        .sort(function (a, b) {\n          return b.at.localeCompare(a.at);\n        })\n        .slice(0, maxResults);\n      return rows.map(function (r) {\n        return {\n          id: r.id,\n          layer: r.layer,\n          kind: r.kind,\n          text: truncate(r.text, MEMORY_SEARCH_DEFAULTS.searchSnippetChars),\n          at: r.at,\n          createdAt: r.createdAt,\n        };\n      });\n    },\n\n    async getById(input): Promise<MemorySearchHit | null> {\n      const row = entries.find(function (e) {\n        return (\n          e.id === input.entryId &&\n          e.userId === input.userId &&\n          e.agentId === input.agentId\n        );\n      });\n      if (!row) return null;\n      return {\n        id: row.id,\n        layer: row.layer,\n        kind: row.kind,\n        text: truncate(row.text, MEMORY_SEARCH_DEFAULTS.getByIdChars),\n        at: row.at,\n        createdAt: row.createdAt,\n      };\n    },\n\n    async applyPatch(input): Promise<void> {\n      const payload = input.payload as { text?: string; kind?: string };\n      const text =\n        typeof payload?.text === \"string\"\n          ? payload.text\n          : JSON.stringify(input.payload);\n      const kind =\n        typeof payload?.kind === \"string\"\n          ? payload.kind\n          : input.layer === \"semantic\"\n            ? \"semantic\"\n            : \"beat\";\n      insert({\n        userId: input.userId,\n        agentId: input.agentId,\n        layer: input.layer,\n        kind,\n        text,\n        at: new Date().toISOString(),\n      });\n    },\n\n    async commitAfterCall(input: MemoryCommitInput): Promise<MemoryCommitResult> {\n      try {\n        const summary =\n          input.summaryText?.trim() ||\n          `call_summary session=${input.sessionId} ended=${input.endedAt}`;\n        const ids: string[] = [];\n        ids.push(\n          insert({\n            userId: input.userId,\n            agentId: input.agentId,\n            layer: \"episodic\",\n            kind: \"call_summary\",\n            text: summary,\n            at: input.endedAt,\n          }),\n        );\n        for (const raw of input.vignettes ?? []) {\n          const text = typeof raw === \"string\" ? raw.trim() : \"\";\n          if (!text) continue;\n          ids.push(\n            insert({\n              userId: input.userId,\n              agentId: input.agentId,\n              layer: \"episodic\",\n              kind: \"vignette\",\n              text,\n              at: input.endedAt,\n            }),\n          );\n        }\n        return {\n          ok: true,\n          writtenLayers: [\"episodic\"],\n          writtenEpisodicIds: ids,\n        };\n      } catch (err) {\n        return {\n          ok: false,\n          writtenLayers: [],\n          error: err instanceof Error ? err.message : String(err),\n        };\n      }\n    },\n\n    async rollupIfNeeded(): Promise<void> {\n      // 假 Port：不实现 rollup；引擎测不依赖本路径\n    },\n  };\n\n  return port;\n}\n","afterFullFileContent":"/**\n * 模块名称：测试用内存 MemoryPort\n * 模块说明：引擎测注入假 Port，不依赖 sqlite / engineIOModule。\n */\nimport { randomUUID } from \"node:crypto\";\nimport { engineError } from \"../../src/host/errors.js\";\nimport type {\n  MemoryCommitInput,\n  MemoryCommitResult,\n  MemoryPort,\n  MemoryProjection,\n  MemorySearchHit,\n  MemorySearchQuery,\n} from \"../../src/memory/types.js\";\nimport { MEMORY_SEARCH_DEFAULTS } from \"../../src/constants.js\";\n\ninterface MemEntry {\n  id: string;\n  userId: string;\n  agentId: string;\n  layer: string;\n  kind: string;\n  text: string;\n  at: string;\n  createdAt: string;\n}\n\nfunction truncate(text: string, max: number): string {\n  return text.length <= max ? text : text.slice(0, max - 1) + \"…\";\n}\n\nfunction toHit(row: MemEntry, max: number): MemorySearchHit {\n  return {\n    id: row.id,\n    layer: row.layer,\n    kind: row.kind,\n    text: truncate(row.text, max),\n    at: row.at,\n    createdAt: row.createdAt,\n  };\n}\n\nfunction matchEntry(e: MemEntry, input: MemorySearchQuery, textQ: string): boolean {\n  if (e.userId !== input.userId || e.agentId !== input.agentId) return false;\n  if (input.fromIso && e.at < input.fromIso) return false;\n  if (input.toIso && e.at > input.toIso) return false;\n  if (input.kinds?.length && !input.kinds.includes(e.kind as never)) return false;\n  if (textQ && !e.text.includes(textQ)) return false;\n  return true;\n}\n\nfunction insertEntry(\n  entries: MemEntry[],\n  input: {\n    userId: string;\n    agentId: string;\n    layer: string;\n    kind: string;\n    text: string;\n    at: string;\n  },\n): string {\n  const id = randomUUID();\n  entries.push({\n    id,\n    userId: input.userId,\n    agentId: input.agentId,\n    layer: input.layer,\n    kind: input.kind,\n    text: input.text,\n    at: input.at,\n    createdAt: input.at,\n  });\n  return id;\n}\n\n/** 进程内 MemoryPort：供 host / pipeline 测注入。 */\nexport function createInMemoryMemoryPort(): MemoryPort {\n  const entries: MemEntry[] = [];\n\n  return {\n    async projectForCall(input): Promise<MemoryProjection> {\n      const mine = entries.filter(function (e) {\n        return e.userId === input.userId && e.agentId === input.agentId;\n      });\n      const ids = mine.map(function (e) {\n        return e.id;\n      });\n      const softText = mine\n        .map(function (e) {\n          return `[${e.kind}] ${e.text}`;\n        })\n        .join(\"\\n\");\n      return {\n        softText,\n        includedEntryIds: ids,\n        rollupIds: [],\n        debug: { hotCount: ids.length, chars: softText.length },\n      };\n    },\n\n    async search(input: MemorySearchQuery): Promise<MemorySearchHit[]> {\n      const textQ = input.textQuery?.trim() ?? \"\";\n      if (!textQ && !input.fromIso && !input.toIso) {\n        throw engineError(\n          \"VALIDATION_FAILED\",\n          \"search requires textQuery or time window\",\n          { rule: \"MEMORY_SEARCH_REJECT\" },\n        );\n      }\n      const maxResults = Math.min(\n        Math.max(1, Math.floor(input.maxResults) || MEMORY_SEARCH_DEFAULTS.defaultMaxResults),\n        MEMORY_SEARCH_DEFAULTS.hardMaxResults,\n      );\n      return entries\n        .filter(function (e) {\n          return matchEntry(e, input, textQ);\n        })\n        .sort(function (a, b) {\n          return b.at.localeCompare(a.at);\n        })\n        .slice(0, maxResults)\n        .map(function (r) {\n          return toHit(r, MEMORY_SEARCH_DEFAULTS.searchSnippetChars);\n        });\n    },\n\n    async getById(input): Promise<MemorySearchHit | null> {\n      const row = entries.find(function (e) {\n        return (\n          e.id === input.entryId &&\n          e.userId === input.userId &&\n          e.agentId === input.agentId\n        );\n      });\n      return row ? toHit(row, MEMORY_SEARCH_DEFAULTS.getByIdChars) : null;\n    },\n\n    async applyPatch(input): Promise<void> {\n      const payload = input.payload as { text?: string; kind?: string };\n      const text =\n        typeof payload?.text === \"string\"\n          ? payload.text\n          : JSON.stringify(input.payload);\n      const kind =\n        typeof payload?.kind === \"string\"\n          ? payload.kind\n          : input.layer === \"semantic\"\n            ? \"semantic\"\n            : \"beat\";\n      insertEntry(entries, {\n        userId: input.userId,\n        agentId: input.agentId,\n        layer: input.layer,\n        kind,\n        text,\n        at: new Date().toISOString(),\n      });\n    },\n\n    async commitAfterCall(input: MemoryCommitInput): Promise<MemoryCommitResult> {\n      const summary =\n        input.summaryText?.trim() ||\n        `call_summary session=${input.sessionId} ended=${input.endedAt}`;\n      const ids = [\n        insertEntry(entries, {\n          userId: input.userId,\n          agentId: input.agentId,\n          layer: \"episodic\",\n          kind: \"call_summary\",\n          text: summary,\n          at: input.endedAt,\n        }),\n      ];\n      for (const raw of input.vignettes ?? []) {\n        const text = typeof raw === \"string\" ? raw.trim() : \"\";\n        if (!text) continue;\n        ids.push(\n          insertEntry(entries, {\n            userId: input.userId,\n            agentId: input.agentId,\n            layer: \"episodic\",\n            kind: \"vignette\",\n            text,\n            at: input.endedAt,\n          }),\n        );\n      }\n      return { ok: true, writtenLayers: [\"episodic\"], writtenEpisodicIds: ids };\n    },\n\n    async rollupIfNeeded(): Promise<void> {},\n  };\n}\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/helpers/inMemoryMemoryPort.ts"}}},"hookAdditionalContexts":[],"toolCallId":"call-e233a607-43f4-4640-9720-fd41edd6098a-97\nfc_768dce33-4c0b-9bb1-8a98-0b53b41a9396_1","startedAtMs":"1784781843363","completedAtMs":"1784781843880"},"model_call_id":"13c061d1-bf77-4f24-9332-8c1ca31f861a-26-e63h","session_id":"01baa976-9ca0-4238-822f-22f39680caba","timestamp_ms":1784781843876}
