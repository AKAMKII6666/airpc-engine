IO-4+ 完成后再装配生产 Host。\n+\t* Memory 路径与迁前 Host 默认一致：`<dataRoot>/memory/memory.sqlite`。\n \t*\n-\t* @param _dataRoot 工作区根（本机即仓库 `data/` 或等价绝对路径）\n+\t* @param dataRoot 工作区根（本机即仓库 `data/` 或等价绝对路径）\n \t*/\n-export function createEngineIOPorts(_dataRoot: string): EngineIOPorts {\n-\tthrow new Error(\n-\t\t\"createEngineIOPorts：IO 实现尚未迁入 engineIOModule（见里程碑 V2-IO-4+）\",\n-\t);\n+export function createEngineIOPorts(dataRoot: string): EngineIOPorts {\n+\treturn {\n+\t\tmemory: createSqliteMemoryPort(\n+\t\t\tpath.join(dataRoot, \"memory\", \"memory.sqlite\"),\n+\t\t),\n+\t\tprofile: createPendingPort<ProfilePort>(\"ProfilePort\", \"V2-IO-5\"),\n+\t\tcontent: createPendingPort<ContentPort>(\"ContentPort\", \"V2-IO-6\"),\n+\t\tengineLog: createPendingPort<EngineLogPort>(\"EngineLogPort\", \"V2-IO-7\"),\n+\t};\n }","beforeFullFileContent":"/**\n\t* 模块名称：本机引擎 IO 装配工厂（骨架）\n\t* 模块说明：按 dataRoot 创建 Memory / Profile / Content / EngineLog Ports。\n\t* Server 边界：仅 app/api、Host 装配、*.server.ts、utils/server 可引用；\n\t* 禁止 Client（pageComponents / bis / stores / typeFiles / ajaxProxy 等）任何 import。\n\t* 实现迁入节奏见里程碑 V2-IO-4～V2-IO-7；本文件在 V2-IO-3 仅占位，避免误用未迁完的装配。\n\t*/\nimport type {\n\tContentPort,\n\tEngineLogPort,\n\tMemoryPort,\n\tProfilePort,\n} from \"@airpc/rpg-engine\";\n\n/** 本机 Studio 注入 Host 的四 Port 套件（技术设计 23）。 */\nexport type EngineIOPorts = {\n\tmemory: MemoryPort;\n\tprofile: ProfilePort;\n\tcontent: ContentPort;\n\tengineLog: EngineLogPort;\n};\n\n/**\n\t* 创建指向 `dataRoot` 的本机 Ports。\n\t* V2-IO-3 骨架阶段尚未迁入实现；调用方须等 V2-IO-4+ 完成后再装配生产 Host。\n\t*\n\t* @param _dataRoot 工作区根（本机即仓库 `data/` 或等价绝对路径）\n\t*/\nexport function createEngineIOPorts(_dataRoot: string): EngineIOPorts {\n\tthrow new Error(\n\t\t\"createEngineIOPorts：IO 实现尚未迁入 engineIOModule（见里程碑 V2-IO-4+）\",\n\t);\n}\n","afterFullFileContent":"/**\n\t* 模块名称：本机引擎 IO 装配工厂\n\t* 模块说明：按 dataRoot 创建 Memory / Profile / Content / EngineLog Ports。\n\t* Server 边界：仅 app/api、Host 装配、*.server.ts、utils/server 可引用；\n\t* 禁止 Client（pageComponents / bis / stores / typeFiles / ajaxProxy 等）任何 import。\n\t* V2-IO-4：Memory 已就绪；Profile/Content/Log 仍占位至 V2-IO-5～7。\n\t*/\nimport path from \"node:path\";\nimport type {\n\tContentPort,\n\tEngineLogPort,\n\tMemoryPort,\n\tProfilePort,\n} from \"@airpc/rpg-engine\";\n// 引用了 Sqlite Memory 工厂，用于本机 memory.sqlite 落盘\nimport { createSqliteMemoryPort } from \"./memory/sqliteMemoryPort\";\n\n/** 本机 Studio 注入 Host 的四 Port 套件（技术设计 23）。 */\nexport type EngineIOPorts = {\n\tmemory: MemoryPort;\n\tprofile: ProfilePort;\n\tcontent: ContentPort;\n\tengineLog: EngineLogPort;\n};\n\nexport { createSqliteMemoryPort } from \"./memory/sqliteMemoryPort\";\n\n/**\n\t* 尚未迁入的 Port：任意方法访问即抛，避免误当成已实现。\n\t* 退出条件：对应 V2-IO-5～7 迁完后删除本辅助函数。\n\t*/\nfunction createPendingPort<T extends object>(\n\tportName: string,\n\ttaskId: string,\n): T {\n\treturn new Proxy({} as T, {\n\t\tget(_target, prop) {\n\t\t\t// 避免被当成 Thenable\n\t\t\tif (prop === \"then\") {\n\t\t\t\treturn undefined;\n\t\t\t}\n\t\t\tthrow new Error(\n\t\t\t\t`createEngineIOPorts：${portName}.${String(prop)} 尚未迁入（${taskId}）`,\n\t\t\t);\n\t\t},\n\t});\n}\n\n/**\n\t* 创建指向 `dataRoot` 的本机 Ports。\n\t* Memory 路径与迁前 Host 默认一致：`<dataRoot>/memory/memory.sqlite`。\n\t*\n\t* @param dataRoot 工作区根（本机即仓库 `data/` 或等价绝对路径）\n\t*/\nexport function createEngineIOPorts(dataRoot: string): EngineIOPorts {\n\treturn {\n\t\tmemory: createSqliteMemoryPort(\n\t\t\tpath.join(dataRoot, \"memory\", \"memory.sqlite\"),\n\t\t),\n\t\tprofile: createPendingPort<ProfilePort>(\"ProfilePort\", \"V2-IO-5\"),\n\t\tcontent: createPendingPort<ContentPort>(\"ContentPort\", \"V2-IO-6\"),\n\t\tengineLog: createPendingPort<EngineLogPort>(\"EngineLogPort\", \"V2-IO-7\"),\n\t};\n}\n","message":"Wrote contents to /Users/bolbiao/workspace/airpc-engine/apps/studioV2/engineIOModule/createEngineIOPorts.ts"}}},"hookAdditionalContexts":[],"toolCallId":"call-c295bc13-1417-4f3a-92c8-2a173a360913-56\nfc_c5ed8ab4-30a3-9e5d-bcd2-68db2aef895f_1","startedAtMs":"1784781728491","completedAtMs":"1784781728854"},