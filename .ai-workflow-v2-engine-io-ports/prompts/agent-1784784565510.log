rdKind === \"story\") {\n\t\tpush(errors, {\n\t\t\truleId: \"SCHEDULE_RECURRING_IN_STORY\",\n\t\t\tlevel: \"error\",\n\t\t\tpath: issuePath,\n\t\t\tmessage:\n\t\t\t\t\"schedule_recurring_call is not allowed on StoryCard（周期性外呼归 ScheduleCard）\",\n\t\t});\n\t}\n\n\tconst scheduleCardId =\n\t\ttypeof effect.scheduleCardId === \"string\" ? effect.scheduleCardId : \"\";\n\tconst cardId = typeof effect.cardId === \"string\" ? effect.cardId : \"\";\n\tconst packageId =\n\t\ttypeof effect.packageId === \"string\" ? effect.packageId : \"\";\n\n\tif (!scheduleCardId && !(cardId && packageId)) {\n\t\tpush(errors, {\n\t\t\truleId: \"SCHEDULE_RECURRING_CARD_REQUIRED\",\n\t\t\tlevel: \"error\",\n\t\t\tpath: issuePath,\n\t\t\tmessage:\n\t\t\t\t\"schedule_recurring_call requires scheduleCardId or cardId+packageId\",\n\t\t});\n\t\treturn;\n\t}\n\n\tif (scheduleCardId) {\n\t\tawait assertScheduleCardViaPort(\n\t\t\tcontent,\n\t\t\tworkspaceKey,\n\t\t\tscheduleCardId,\n\t\t\tissuePath,\n\t\t\terrors,","isEmpty":false,"exceededLimit":false,"totalLines":215,"fileSize":5532,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/validation/package/schedule.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-64ca6fd8-d9f4-4ba2-9755-747af2826415-43\nfc_20a5fef5-0dad-9797-a594-a477c3a94d5e_3","startedAtMs":"1784784632627","completedAtMs":"1784784633010"},"model_call_id":"c0d34820-39af-4d80-9abb-2160cf02e177-8-0kba","session_id":"f7435cbd-4c2d-4a98-b05d-9ec7531ce3c6","timestamp_ms":1784784632965}
