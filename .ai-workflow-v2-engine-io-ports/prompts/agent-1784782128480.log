{"type":"tool_call","subtype":"completed","call_id":"call-d2673d96-0cc1-4a19-a6ab-53bbb2e84b4b-38\nfc_43b21a16-9833-9890-95bc-322fab9106e5_5","tool_call":{"readToolCall":{"args":{"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/engineIOModule/sqliteMemoryPort.test.ts","limit":80},"result":{"success":{"content":"/**\n * 模块名称：engineIOModule SqliteMemoryPort 验收测（自引擎迁出后）\n */\nimport { mkdtemp, rm } from \"node:fs/promises\";\nimport os from \"node:os\";\nimport path from \"node:path\";\nimport { afterEach, describe, expect, it } from \"vitest\";\nimport {\n\tCallCardDefinitionSchema,\n\tisEngineError,\n\tMEMORY_PROJECT_DEFAULTS,\n\tMEMORY_SEARCH_DEFAULTS,\n} from \"@airpc/rpg-engine\";\n// 引用了本机 Sqlite Memory 工厂，用于验收迁出后的 IO 行为等价\nimport { createSqliteMemoryPort } from \"../../engineIOModule/memory/sqliteMemoryPort\";\n\ndescribe(\"SqliteMemoryPort\", () => {\n\tlet tmp: string | undefined;\n\tlet port: ReturnType<typeof createSqliteMemoryPort> | undefined;\n\n\tafterEach(async () => {\n\t\tport?.close?.();\n\t\tport = undefined;\n\t\tif (tmp) {\n\t\t\tawait rm(tmp, { recursive: true, force: true });\n\t\t\ttmp = undefined;\n\t\t}\n\t});\n\n\tasync function setup() {\n\t\ttmp = await mkdtemp(path.join(os.tmpdir(), \"airpc-mem-\"));\n\t\tport = createSqliteMemoryPort(path.join(tmp, \"memory.sqlite\"));\n\t\treturn port;\n\t}\n\n\tit(\"projectForCall respects count/char budget; no full-table dump\", async () => {\n\t\tconst mem = await setup();\n\t\tconst card = CallCardDefinitionSchema.parse({\n\t\t\tcardId: \"c\",\n\t\t\townerAgentId: \"a\",\n\t\t\texits: [],\n\t\t});\n\t\tfor (let i = 0; i < 20; i++) {\n\t\t\tawait mem.commitAfterCall({\n\t\t\t\tuserId: \"u1\",\n\t\t\t\tagentId: \"a1\",\n\t\t\t\tsessionId: `s${i}`,\n\t\t\t\ttranscript: null,\n\t\t\t\tendedAt: `2026-07-${String(10 + (i % 20)).padStart(2, \"0\")}T12:00:00.000Z`,\n\t\t\t\tsummaryText: `summary-${i} ` + \"x\".repeat(300),\n\t\t\t});\n\t\t}\n\t\tconst proj = await mem.projectForCall({\n\t\t\tuserId: \"u1\",\n\t\t\tagentId: \"a1\",\n\t\t\tcard,\n\t\t});\n\t\texpect(proj.debug?.hotCount).toBeLessThanOrEqual(\n\t\t\tMEMORY_PROJECT_DEFAULTS.maxCallSummaries +\n\t\t\t\tMEMORY_PROJECT_DEFAULTS.maxVignettes +\n\t\t\t\tMEMORY_PROJECT_DEFAULTS.maxRollups,\n\t\t);\n\t\texpect(proj.debug?.chars ?? 0).toBeLessThanOrEqual(\n\t\t\tMEMORY_PROJECT_DEFAULTS.maxSoftChars,\n\t\t);\n\t\texpect(proj.includedEntryIds.length).toBeLessThanOrEqual(\n\t\t\tMEMORY_PROJECT_DEFAULTS.maxCallSummaries,\n\t\t);\n\t});\n\n\tit(\"search rejects without text or time window\", async () => {\n\t\tconst mem = await setup();\n\t\tawait expect(\n\t\t\tmem.search({\n\t\t\t\tuserId: \"u1\",\n\t\t\t\tagentId: \"a1\",\n\t\t\t\tmaxResults: 5,\n\t\t\t}),\n\t\t).rejects.toSatisfy(function (err: unknown) {\n\t\t\treturn isEngineError(err);","isEmpty":false,"exceededLimit":false,"totalLines":330,"fileSize":8688,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studioV2/tests/engineIOModule/sqliteMemoryPort.test.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-d2673d96-0cc1-4a19-a6ab-53bbb2e84b4b-38\nfc_43b21a16-9833-9890-95bc-322fab9106e5_5","startedAtMs":"1784782199604","completedAtMs":"1784782199764"},"model_call_id":"49f972fa-1d48-4fc3-8cb7-08f965d2cc16-6-pdhv","session_id":"70d21e95-4cce-45b9-a422-f0323e0e22d7","timestamp_ms":1784782199730}
