oIso) return false;\n  return true;\n}\n\nfunction searchEntries(\n  entries: MemEntry[],\n  input: MemorySearchQuery,\n): MemorySearchHit[] {\n  const textQ = input.textQuery?.trim() ?? \"\";\n  if (!textQ && !input.fromIso && !input.toIso) {\n    throw engineError(\n      \"VALIDATION_FAILED\",\n      \"search requires textQuery or time window\",\n      { rule: \"MEMORY_SEARCH_REJECT\" },","isEmpty":false,"exceededLimit":false,"totalLines":225,"fileSize":5673,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/helpers/inMemoryMemoryPort.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-d191aa6f-b809-4248-b0e0-fba22ea01db6-26\nfc_1292dde5-5635-9ec8-a97c-b47eeaa24610_1","startedAtMs":"1784782176109","completedAtMs":"1784782176393"},"model_call_id":"49f972fa-1d48-4fc3-8cb7-08f965d2cc16-5-quoz","session_id":"70d21e95-4cce-45b9-a422-f0323e0e22d7","timestamp_ms":1784782176393}
