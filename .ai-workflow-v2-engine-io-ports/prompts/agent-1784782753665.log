tent.loadPackageForValidate({\n\t\t\tworkspaceKey: \"/tmp\",\n\t\t\tpackageId: \"demo\",\n\t\t});\n\t\texpect(bundle.packageId).toBe(\"demo\");\n\t\texpect(bundle.conf).toBeNull();\n\t\tconst profile = createFakeProfilePort();\n\t\texpect(await profile.readProfile({ userId: \"u1\" })).toBeNull();\n\t});\n\n\tit(\"未注入 ProfilePort 时 ensureProfile 抛 ENGINE_INTERNAL\", async function () {\n\t\tconst host = createEngineHost({ persist: false });\n\t\tawait expect(host.ensureProfile(\"u1\")).rejects.toSatisfy(function (\n\t\t\terr: unknown,\n\t\t) {\n\t\t\treturn (\n\t\t\t\ttypeof err === \"object\" &&\n\t\t\t\terr !== null &&\n\t\t\t\t(err as { code?: string }).code === \"ENGINE_INTERNAL\"\n\t\t\t);\n\t\t});\n\t});\n});\n","isEmpty":false,"exceededLimit":false,"totalLines":164,"fileSize":4003,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/tests/host/ports-injection.test.ts","readRange":{"startLine":1,"endLine":164},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-f7756996-fb8f-4a47-b07d-7fe123563e0e-31\nfc_c340b33c-6ed5-9570-8193-26d8e3990bdb_1","startedAtMs":"1784782879270","completedAtMs":"1784782879439"},"model_call_id":"64ed3551-d7b9-4668-b2f9-5e28e05e4b02-6-44x9","session_id":"5fe2590b-d41a-4c9d-bd28-d429f96b8f06","timestamp_ms":1784782879415}
