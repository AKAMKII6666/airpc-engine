);\n  }\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":55,"fileSize":1677,"path":"/Users/bolbiao/workspace/airpc-engine/apps/studio/app/api/logs/route.ts","readRange":{"startLine":1,"endLine":55},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-7636fdcb-27ec-4580-978e-2985bd81f0d7-52\nfc_09beac6c-7892-9edf-a516-0c460a3b2c5a_1","startedAtMs":"1784783695960","completedAtMs":"1784783696257"},"model_call_id":"52008335-d82f-44bf-8dea-dc4a51ff92d7-10-0uw6","session_id":"2383dc52-dc16-4409-b801-44671704850f","timestamp_ms":1784783696171}
