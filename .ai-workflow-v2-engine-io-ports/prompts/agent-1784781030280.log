\tworkspaceKey: string;\n\t}): Promise<WorkspaceSnapshot>;\n\n\t/**\n\t * 按需读单卡。\n\t * packageId 为故事包 id，或哨兵 __free__ / __schedule__。\n\t * 不存在：null；损坏：throw VALIDATION_FAILED。\n\t */\n\treadCard(input: {\n\t\tworkspaceKey: string;\n\t\tpackageId: string;\n\t\tcardId: string;\n\t}): Promise<CallCardDefinition | null>;\n\n\t/**\n\t * 读故事包 conf（不强制带齐所有卡）。不存在：null。\n\t */\n\treadPackageConf(input: {\n\t\tworkspaceKey: string;\n\t\tpackageId: string;\n\t}): Promise<StoryPackageConf | null>;\n\n\t/**\n\t * 校验装包：一次取出 validate 规则所需内容。\n\t * 缺 conf：仍返回结构，由引擎规则报错（或 Port 在 conf 位给 null）。\n\t */\n\tloadPackageForValidate(input: {\n\t\tworkspaceKey: string;\n\t\tpackageId: string;\n\t}): Promise<PackageValidateBundle>;\n\n\t/** 资产 meta 是否存在（校验 ASSET_*） */\n\tassetMetaExists(input: {\n\t\tworkspaceKey: string;\n\t\tassetId: string;\n\t}): Promise<boolean>;\n\n\t/** 读资产 meta；不存在 null */\n\treadAssetMeta(input: {\n\t\tworkspaceKey: string;\n\t\tassetId: string;\n\t}): Promise<AssetMeta | null>;\n\n\t/**\n\t * 可选：探测二进制/uri 是否在位（对应 ASSET_URI_MISSING）。\n\t * 不做则引擎只能跳过或降级该规则（实现须声明）。\n\t */\n\tassetUriExists?(input: {\n\t\tworkspaceKey: string;\n\t\t/** 相对 data/assets 或实现约定的 uri */\n\t\turi: string;\n\t}): Promise<boolean>;\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":113,"fileSize":3521,"path":"/Users/bolbiao/workspace/airpc-engine/packages/rpg-engine/src/ports/contentPort.ts","readRange":{"startLine":1,"endLine":113},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"call-a844ebc3-4244-435c-821d-aedfa7338d97-16\nfc_e31d8d88-9685-936b-9c95-2fbdcffd6f15_1","startedAtMs":"1784781059511","completedAtMs":"1784781059814"},"model_call_id":"9f263e57-b2c1-47ed-9905-82bf9f5aaae0-4-xm3w","session_id":"def2b1d3-2d58-4359-98bd-4c7ac30faf77","timestamp_ms":1784781059860}
